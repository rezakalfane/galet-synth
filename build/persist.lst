   6:src/persist.cpp **** using namespace daisy;
   7:src/persist.cpp **** 
   8:src/persist.cpp **** // The live bank + RAM backing for the editable names.
   9:src/persist.cpp **** Voice       g_bank[NUM_VOICES];
  10:src/persist.cpp **** int         g_boot_voice = 2;            // persisted power-on voice (mirrors flash)
  11:src/persist.cpp **** static char g_names[NUM_VOICES][VOICE_NAME_MAX];
  12:src/persist.cpp **** 
  13:src/persist.cpp **** // â”€â”€ Flash format â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â
  14:src/persist.cpp **** // Bump BANK_MAGIC whenever the Voice struct layout changes â€” a mismatch makes the
  15:src/persist.cpp **** // stored blob be ignored (falls back to factory), so old data can't be misread.
  16:src/persist.cpp **** static constexpr uint32_t BANK_MAGIC = 0x47564232;  // 'GVB2' (bumped: Voice gained the lfo_* field
  17:src/persist.cpp **** 
  18:src/persist.cpp **** struct StoredVoice {
  19:src/persist.cpp ****     Voice   v;                       // raw; v.name / v.scale are fixed up on load
  20:src/persist.cpp ****     char    name[VOICE_NAME_MAX];    // the real (portable) name
  21:src/persist.cpp ****     uint8_t scale_id;                // 0 none, 1 chromatic, 2 major, 3 minor
  22:src/persist.cpp **** };
  23:src/persist.cpp **** struct StoredBank {
  24:src/persist.cpp ****     uint32_t    magic;
  25:src/persist.cpp ****     int32_t     voice_idx;
  26:src/persist.cpp ****     StoredVoice voices[NUM_VOICES];
  27:src/persist.cpp ****     bool operator!=(const StoredBank &o) const { return memcmp(this, &o, sizeof(*this)) != 0; }
  28:src/persist.cpp **** };
  29:src/persist.cpp **** 
