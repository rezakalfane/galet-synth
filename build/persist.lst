  33:src/persist.cpp **** static uint8_t scale_id(const int8_t *s) {
  34:src/persist.cpp ****     if(s == SCALE_CHROMATIC) return 1;
  35:src/persist.cpp ****     if(s == SCALE_MAJOR)     return 2;
  36:src/persist.cpp ****     if(s == SCALE_MINOR)     return 3;
  37:src/persist.cpp ****     return 0;
  38:src/persist.cpp **** }
  39:src/persist.cpp **** static const int8_t *id_scale(uint8_t id) {
  40:src/persist.cpp ****     switch(id) {
  41:src/persist.cpp ****         case 1: return SCALE_CHROMATIC;
  42:src/persist.cpp ****         case 2: return SCALE_MAJOR;
  43:src/persist.cpp ****         case 3: return SCALE_MINOR;
  44:src/persist.cpp ****         default: return nullptr;
  45:src/persist.cpp ****     }
  46:src/persist.cpp **** }
  47:src/persist.cpp **** static int id_scale_len(uint8_t id) {
  48:src/persist.cpp ****     switch(id) {
  49:src/persist.cpp ****         case 1: return (int)(sizeof(SCALE_CHROMATIC) / sizeof(SCALE_CHROMATIC[0]));
  50:src/persist.cpp ****         case 2: return (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0]));
  51:src/persist.cpp ****         case 3: return (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0]));
  52:src/persist.cpp ****         default: return 0;
  53:src/persist.cpp ****     }
  54:src/persist.cpp **** }
  55:src/persist.cpp **** 
  56:src/persist.cpp **** static void set_name(int i, const char *src) {
