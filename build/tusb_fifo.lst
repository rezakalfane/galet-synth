 374:lib/tinyusb/src/common/tusb_fifo.c **** {
 375:lib/tinyusb/src/common/tusb_fifo.c ****   // We limit the index space of p such that a correct wrap around happens
 376:lib/tinyusb/src/common/tusb_fifo.c ****   // Check for a wrap around or if we are in unused index space - This has to be checked first!!
 377:lib/tinyusb/src/common/tusb_fifo.c ****   // We are exploiting the wrap around to the correct index
 378:lib/tinyusb/src/common/tusb_fifo.c ****   uint16_t new_idx = (uint16_t) (idx - offset);
 379:lib/tinyusb/src/common/tusb_fifo.c ****   if ( (idx < new_idx) || (new_idx >= 2*depth) )
 380:lib/tinyusb/src/common/tusb_fifo.c ****   {
 381:lib/tinyusb/src/common/tusb_fifo.c ****     uint16_t const non_used_index_space = (uint16_t) (UINT16_MAX - (2*depth-1));
