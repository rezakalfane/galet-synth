 650:lib/tinyusb/src/common/tusb_fifo.c **** /*!
 651:lib/tinyusb/src/common/tusb_fifo.c ****     @brief Check if overflow happened.
 652:lib/tinyusb/src/common/tusb_fifo.c **** 
 653:lib/tinyusb/src/common/tusb_fifo.c ****      BE AWARE - THIS FUNCTION MIGHT NOT GIVE A CORRECT ANSWERE IN CASE WRITE POINTER "OVERFLOWS"
 654:lib/tinyusb/src/common/tusb_fifo.c ****      Only one overflow is allowed for this function to work e.g. if depth = 100, you must not
 655:lib/tinyusb/src/common/tusb_fifo.c ****      write more than 2*depth-1 items in one rush without updating write pointer. Otherwise
 656:lib/tinyusb/src/common/tusb_fifo.c ****      write pointer wraps and your pointer states are messed up. This can only happen if you
 657:lib/tinyusb/src/common/tusb_fifo.c ****      use DMAs, write functions do not allow such an error. Avoid such nasty things!
 658:lib/tinyusb/src/common/tusb_fifo.c **** 
 659:lib/tinyusb/src/common/tusb_fifo.c ****      All reading functions (read, peek) check for overflows and correct read pointer on their own s
 660:lib/tinyusb/src/common/tusb_fifo.c ****      that latest items are read.
 661:lib/tinyusb/src/common/tusb_fifo.c ****      If required (e.g. for DMA use) you can also correct the read pointer by
 662:lib/tinyusb/src/common/tusb_fifo.c ****      tu_fifo_correct_read_pointer().
 663:lib/tinyusb/src/common/tusb_fifo.c **** 
 664:lib/tinyusb/src/common/tusb_fifo.c ****     @param[in]  f
 665:lib/tinyusb/src/common/tusb_fifo.c ****                 Pointer to the FIFO buffer to manipulate
 666:lib/tinyusb/src/common/tusb_fifo.c **** 
 667:lib/tinyusb/src/common/tusb_fifo.c ****     @returns True if overflow happened
 668:lib/tinyusb/src/common/tusb_fifo.c ****  */
 669:lib/tinyusb/src/common/tusb_fifo.c **** /******************************************************************************/
 670:lib/tinyusb/src/common/tusb_fifo.c **** bool tu_fifo_overflowed(tu_fifo_t* f)
