1042:lib/tinyusb/src/common/tusb_fifo.c **** /******************************************************************************/
1043:lib/tinyusb/src/common/tusb_fifo.c **** /*!
1044:lib/tinyusb/src/common/tusb_fifo.c ****    @brief Get linear write info
1045:lib/tinyusb/src/common/tusb_fifo.c **** 
1046:lib/tinyusb/src/common/tusb_fifo.c ****    Returns the length and pointer to which bytes can be written into FIFO in a linear manner.
1047:lib/tinyusb/src/common/tusb_fifo.c ****    This is of major interest for DMA transmissions not using circular mode. If a returned length is
1048:lib/tinyusb/src/common/tusb_fifo.c ****    corresponding pointer is invalid. The returned lengths summed up are the currently free space in
1049:lib/tinyusb/src/common/tusb_fifo.c ****    The write pointer does NOT get advanced, use tu_fifo_advance_write_pointer() to do so!
1050:lib/tinyusb/src/common/tusb_fifo.c ****    TAKE CARE TO NOT OVERFLOW THE BUFFER MORE THAN TWO TIMES THE FIFO DEPTH - IT CAN NOT RECOVERE OT
1051:lib/tinyusb/src/common/tusb_fifo.c ****    @param[in]       f
