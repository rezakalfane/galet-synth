  98:lib/tinyusb/src/common/tusb_fifo.c **** // Intended to be used to read from hardware USB FIFO in e.g. STM32 where all data is read from a c
  99:lib/tinyusb/src/common/tusb_fifo.c **** // Code adapted from dcd_synopsys.c
 100:lib/tinyusb/src/common/tusb_fifo.c **** // TODO generalize with configurable 1 byte or 4 byte each read
 101:lib/tinyusb/src/common/tusb_fifo.c **** static void _ff_push_const_addr(uint8_t * ff_buf, const void * app_buf, uint16_t len)
 102:lib/tinyusb/src/common/tusb_fifo.c **** {
 103:lib/tinyusb/src/common/tusb_fifo.c ****   volatile const uint32_t * reg_rx = (volatile const uint32_t *) app_buf;
 104:lib/tinyusb/src/common/tusb_fifo.c **** 
 105:lib/tinyusb/src/common/tusb_fifo.c ****   // Reading full available 32 bit words from const app address
 106:lib/tinyusb/src/common/tusb_fifo.c ****   uint16_t full_words = len >> 2;
 107:lib/tinyusb/src/common/tusb_fifo.c ****   while(full_words--)
 108:lib/tinyusb/src/common/tusb_fifo.c ****   {
 109:lib/tinyusb/src/common/tusb_fifo.c ****     tu_unaligned_write32(ff_buf, *reg_rx);
 110:lib/tinyusb/src/common/tusb_fifo.c ****     ff_buf += 4;
 111:lib/tinyusb/src/common/tusb_fifo.c ****   }
 112:lib/tinyusb/src/common/tusb_fifo.c **** 
 113:lib/tinyusb/src/common/tusb_fifo.c ****   // Read the remaining 1-3 bytes from const app address
 114:lib/tinyusb/src/common/tusb_fifo.c ****   uint8_t const bytes_rem = len & 0x03;
 115:lib/tinyusb/src/common/tusb_fifo.c ****   if ( bytes_rem )
 116:lib/tinyusb/src/common/tusb_fifo.c ****   {
 117:lib/tinyusb/src/common/tusb_fifo.c ****     uint32_t tmp32 = *reg_rx;
 118:lib/tinyusb/src/common/tusb_fifo.c ****     memcpy(ff_buf, &tmp32, bytes_rem);
 119:lib/tinyusb/src/common/tusb_fifo.c ****   }
 120:lib/tinyusb/src/common/tusb_fifo.c **** }
