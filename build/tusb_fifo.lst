 122:lib/tinyusb/src/common/tusb_fifo.c **** // Intended to be used to write to hardware USB FIFO in e.g. STM32
 123:lib/tinyusb/src/common/tusb_fifo.c **** // where all data is written to a constant address in full word copies
 124:lib/tinyusb/src/common/tusb_fifo.c **** static void _ff_pull_const_addr(void * app_buf, const uint8_t * ff_buf, uint16_t len)
 125:lib/tinyusb/src/common/tusb_fifo.c **** {
 126:lib/tinyusb/src/common/tusb_fifo.c ****   volatile uint32_t * reg_tx = (volatile uint32_t *) app_buf;
 127:lib/tinyusb/src/common/tusb_fifo.c **** 
 128:lib/tinyusb/src/common/tusb_fifo.c ****   // Write full available 32 bit words to const address
 129:lib/tinyusb/src/common/tusb_fifo.c ****   uint16_t full_words = len >> 2;
 130:lib/tinyusb/src/common/tusb_fifo.c ****   while(full_words--)
 131:lib/tinyusb/src/common/tusb_fifo.c ****   {
 132:lib/tinyusb/src/common/tusb_fifo.c ****     *reg_tx = tu_unaligned_read32(ff_buf);
 133:lib/tinyusb/src/common/tusb_fifo.c ****     ff_buf += 4;
 134:lib/tinyusb/src/common/tusb_fifo.c ****   }
 135:lib/tinyusb/src/common/tusb_fifo.c **** 
 136:lib/tinyusb/src/common/tusb_fifo.c ****   // Write the remaining 1-3 bytes into const address
 137:lib/tinyusb/src/common/tusb_fifo.c ****   uint8_t const bytes_rem = len & 0x03;
 138:lib/tinyusb/src/common/tusb_fifo.c ****   if ( bytes_rem )
 139:lib/tinyusb/src/common/tusb_fifo.c ****   {
 140:lib/tinyusb/src/common/tusb_fifo.c ****     uint32_t tmp32 = 0;
 141:lib/tinyusb/src/common/tusb_fifo.c ****     memcpy(&tmp32, ff_buf, bytes_rem);
 142:lib/tinyusb/src/common/tusb_fifo.c **** 
 143:lib/tinyusb/src/common/tusb_fifo.c ****     *reg_tx = tmp32;
 144:lib/tinyusb/src/common/tusb_fifo.c ****   }
