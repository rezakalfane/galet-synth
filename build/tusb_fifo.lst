 389:lib/tinyusb/src/common/tusb_fifo.c **** // index to pointer, simply an modulo with minus.
 390:lib/tinyusb/src/common/tusb_fifo.c **** TU_ATTR_ALWAYS_INLINE static inline
 391:lib/tinyusb/src/common/tusb_fifo.c **** uint16_t idx2ptr(uint16_t depth, uint16_t idx)
 392:lib/tinyusb/src/common/tusb_fifo.c **** {
