 354:lib/tinyusb/src/common/tusb_fifo.c **** // Advance an absolute index
 355:lib/tinyusb/src/common/tusb_fifo.c **** // "absolute" index is only in the range of [0..2*depth)
 356:lib/tinyusb/src/common/tusb_fifo.c **** static uint16_t advance_index(uint16_t depth, uint16_t idx, uint16_t offset)
 357:lib/tinyusb/src/common/tusb_fifo.c **** {
 358:lib/tinyusb/src/common/tusb_fifo.c ****   // We limit the index space of p such that a correct wrap around happens
 359:lib/tinyusb/src/common/tusb_fifo.c ****   // Check for a wrap around or if we are in unused index space - This has to be checked first!!
 360:lib/tinyusb/src/common/tusb_fifo.c ****   // We are exploiting the wrap around to the correct index
 361:lib/tinyusb/src/common/tusb_fifo.c ****   uint16_t new_idx = (uint16_t) (idx + offset);
 362:lib/tinyusb/src/common/tusb_fifo.c ****   if ( (idx > new_idx) || (new_idx >= 2*depth) )
 363:lib/tinyusb/src/common/tusb_fifo.c ****   {
 364:lib/tinyusb/src/common/tusb_fifo.c ****     uint16_t const non_used_index_space = (uint16_t) (UINT16_MAX - (2*depth-1));
 365:lib/tinyusb/src/common/tusb_fifo.c ****     new_idx = (uint16_t) (new_idx + non_used_index_space);
 366:lib/tinyusb/src/common/tusb_fifo.c ****   }
 367:lib/tinyusb/src/common/tusb_fifo.c **** 
 368:lib/tinyusb/src/common/tusb_fifo.c ****   return new_idx;
 369:lib/tinyusb/src/common/tusb_fifo.c **** }
