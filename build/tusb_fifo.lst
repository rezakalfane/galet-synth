 411:lib/tinyusb/src/common/tusb_fifo.c ****   }
 412:lib/tinyusb/src/common/tusb_fifo.c **** 
 413:lib/tinyusb/src/common/tusb_fifo.c ****   f->rd_idx = rd_idx;
 414:lib/tinyusb/src/common/tusb_fifo.c **** 
 415:lib/tinyusb/src/common/tusb_fifo.c ****   return rd_idx;
