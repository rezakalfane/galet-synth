 401:lib/tinyusb/src/common/tusb_fifo.c **** TU_ATTR_ALWAYS_INLINE static inline
 402:lib/tinyusb/src/common/tusb_fifo.c **** uint16_t _ff_correct_read_index(tu_fifo_t* f, uint16_t wr_idx)
 403:lib/tinyusb/src/common/tusb_fifo.c **** {
