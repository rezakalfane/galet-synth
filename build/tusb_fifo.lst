 328:lib/tinyusb/src/common/tusb_fifo.c **** // return only the index difference and as such can be used to determine an overflow i.e overflowab
 329:lib/tinyusb/src/common/tusb_fifo.c **** TU_ATTR_ALWAYS_INLINE static inline
 330:lib/tinyusb/src/common/tusb_fifo.c **** uint16_t _ff_count(uint16_t depth, uint16_t wr_idx, uint16_t rd_idx)
 331:lib/tinyusb/src/common/tusb_fifo.c **** {
 332:lib/tinyusb/src/common/tusb_fifo.c ****   // In case we have non-power of two depth we need a further modification
 333:lib/tinyusb/src/common/tusb_fifo.c ****   if (wr_idx >= rd_idx)
 334:lib/tinyusb/src/common/tusb_fifo.c ****   {
 335:lib/tinyusb/src/common/tusb_fifo.c ****     return (uint16_t) (wr_idx - rd_idx);
 336:lib/tinyusb/src/common/tusb_fifo.c ****   } else
 337:lib/tinyusb/src/common/tusb_fifo.c ****   {
 338:lib/tinyusb/src/common/tusb_fifo.c ****     return (uint16_t) (2*depth - (rd_idx - wr_idx));
 339:lib/tinyusb/src/common/tusb_fifo.c ****   }
 340:lib/tinyusb/src/common/tusb_fifo.c **** }
 341:lib/tinyusb/src/common/tusb_fifo.c **** 
 342:lib/tinyusb/src/common/tusb_fifo.c **** // return remaining slot in fifo
 343:lib/tinyusb/src/common/tusb_fifo.c **** TU_ATTR_ALWAYS_INLINE static inline
 344:lib/tinyusb/src/common/tusb_fifo.c **** uint16_t _ff_remaining(uint16_t depth, uint16_t wr_idx, uint16_t rd_idx)
 345:lib/tinyusb/src/common/tusb_fifo.c **** {
 346:lib/tinyusb/src/common/tusb_fifo.c ****   uint16_t const count = _ff_count(depth, wr_idx, rd_idx);
 347:lib/tinyusb/src/common/tusb_fifo.c ****   return (depth > count) ? (depth - count) : 0;
 348:lib/tinyusb/src/common/tusb_fifo.c **** }
