 277:src/engine.cpp ****         // Slew all parameters
 278:src/engine.cpp ****         s_freq    = s_freq   *s_glide_c + tfreq*(1.0f-s_glide_c);
 279:src/engine.cpp ****         // Cutoff: fast when opening (smoothed), slow when closing (with release)
 280:src/engine.cpp ****         { float sc = (tcut > s_cutoff) ? SLEW_CUT : s_rel_c;
 281:src/engine.cpp ****           s_cutoff = s_cutoff * sc + tcut * (1.0f - sc); }
 282:src/engine.cpp ****         s_drive   = s_drive   * SLEW_MISC + tdrv * (1.0f - SLEW_MISC);
 283:src/engine.cpp ****         s_vibdepth= s_vibdepth* SLEW_MISC + tvib * (1.0f - SLEW_MISC);
 284:src/engine.cpp ****         // Finger 2 params: fast attack, slow release
 285:src/engine.cpp ****         { float sa = tdet     > s_detune   ? SLEW_F2_A : SLEW_F2_R;
 286:src/engine.cpp ****           s_detune   = s_detune   * sa + tdet * (1.0f - sa); }
 287:src/engine.cpp ****         { float sa = tbc      > s_bitcrush ? SLEW_F2_A : SLEW_F2_R;
 288:src/engine.cpp ****           s_bitcrush = s_bitcrush * sa + tbc  * (1.0f - sa); }
 289:src/engine.cpp ****         { float sa = trm      > s_ringmod  ? SLEW_F2_A : SLEW_F2_R;
 290:src/engine.cpp ****           s_ringmod  = s_ringmod  * sa + trm  * (1.0f - sa); }
 291:src/engine.cpp ****         // Amp decay-to-sustain: s_decay rides 1 â†’ sustain over decay_ms while the
 292:src/engine.cpp ****         // note is gated (stays pinned at 1 when decay_ms == 0, i.e. every other
 293:src/engine.cpp ****         // voice). It scales the gated target so the note plucks down to `sustain`.
 294:src/engine.cpp ****         s_decay = s_decay * s_decay_c + s_sustain * (1.0f - s_decay_c);
 295:src/engine.cpp ****         float eff_tamp = tamp * s_decay;
 296:src/engine.cpp ****         // Asymmetric envelope: attack while rising OR decaying-while-held (track the
 297:src/engine.cpp ****         // decay shape quickly â€” its rate comes from s_decay); release only once the
