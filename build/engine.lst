 329:src/engine.cpp ****         // Vibrato: modulate frequency by Â±~1 semitone * depth. Depth = the
 330:src/engine.cpp ****         // finger-pressure amount (s_vibdepth) + the voice's always-on lfo_pitch.
 331:src/engine.cpp ****         float vib_amt = lfo * (s_vibdepth + VOICE.lfo_pitch) * 0.05f;
 332:src/engine.cpp ****         float freq_vib = s_freq * (1.0f + vib_amt) * s_pmult;  // s_pmult: pitch-env sweep
 333:src/engine.cpp **** 
 334:src/engine.cpp ****         // Osc 2 frequency. Lead: finger-2 detune around the base ratio.
 335:src/engine.cpp ****         // Bass (and any fixed-interval voice): hold osc2_ratio (e.g. a 5th).
 336:src/engine.cpp ****         // VOICE is constexpr, so only the taken branch is compiled in.
 337:src/engine.cpp ****         float freq2;
 338:src/engine.cpp ****         if(VOICE.osc2_detune) {
 339:src/engine.cpp ****             float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for Â±1 oct
 340:src/engine.cpp ****             freq2 = freq_vib * VOICE.osc2_ratio * det_ratio;
 341:src/engine.cpp ****         } else {
 342:src/engine.cpp ****             freq2 = freq_vib * VOICE.osc2_ratio;
 343:src/engine.cpp ****         }
 344:src/engine.cpp **** 
 345:src/engine.cpp ****         // Sub and octave oscillators (ratios are voice-defined).
 346:src/engine.cpp ****         float freq_sub = freq_vib * VOICE.sub_ratio;
 347:src/engine.cpp ****         float freq_oct = freq_vib * VOICE.oct_ratio;
