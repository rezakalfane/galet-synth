 357:src/engine.cpp ****         float osc_oct = osc(s_phase_oct,VOICE.oct_wave)  * VOICE.oct_level;
 358:src/engine.cpp **** 
 359:src/engine.cpp ****         // Noise (xorshift32 â†’ -1..1), voice-defined level. Adds breath / chiff /
 360:src/engine.cpp ****         // hiss. noise_hp blends from full white ("shhh") to high-passed ("tsss",
 361:src/engine.cpp ****         // for hi-hats). The `if` folds away when a voice sets noise_level = 0.
 362:src/engine.cpp ****         float noise = 0.0f;
 363:src/engine.cpp ****         if(VOICE.noise_level > 0.0f){
 364:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 13;
 365:src/engine.cpp ****             s_noise_rng ^= s_noise_rng >> 17;
 366:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 5;
 367:src/engine.cpp ****             float white = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 368:src/engine.cpp ****             // One-pole high-pass = white minus its low-frequency content.
 369:src/engine.cpp ****             s_noise_lp += NOISE_HP_COEF * (white - s_noise_lp);
 370:src/engine.cpp ****             float bright = white - s_noise_lp;
 371:src/engine.cpp ****             // Blend white â†’ high-passed by noise_hp (Ã—2 to make up lost level).
 372:src/engine.cpp ****             float n = white + (bright * 2.0f - white) * VOICE.noise_hp;
 373:src/engine.cpp ****             noise = n * VOICE.noise_level;
 374:src/engine.cpp ****         }
 375:src/engine.cpp **** 
 376:src/engine.cpp ****         // Mix oscillator stack + noise
 377:src/engine.cpp ****         float mix = osc1 + osc2 + sub + osc_oct + noise;
 378:src/engine.cpp **** 
 379:src/engine.cpp ****         // Diatonic chord (Voice::chords): add the snapped triad's 3rd and 5th as
 380:src/engine.cpp ****         // extra saw+pulse voices above the root. They ride freq_vib (so they
 381:src/engine.cpp ****         // glide/vibrato with the root) scaled by the per-note ratios. Sub and
 382:src/engine.cpp ****         // noise stay on the root only â€” keeps the low end tight and the chord
 383:src/engine.cpp ****         // clear â€” and the upper notes are scaled by VOICE.chord_level for headroom.
 384:src/engine.cpp ****         // VOICE is a runtime ref (selection is live), so this is a cheap
 385:src/engine.cpp ****         // well-predicted branch â€” skipped each sample for single-note voices.
 386:src/engine.cpp ****         if(VOICE.chords){
 387:src/engine.cpp ****             float f3 = freq_vib * tcr2;   // 3rd
 388:src/engine.cpp ****             float f5 = freq_vib * tcr3;   // 5th
