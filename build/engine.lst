  76:src/engine.cpp **** // White-noise generator state (xorshift32) for the per-voice noise oscillator.
  77:src/engine.cpp **** static uint32_t s_noise_rng = 0x1234567u;
  78:src/engine.cpp **** // One-pole low-pass state used to derive high-passed ("tsss") noise from white.
