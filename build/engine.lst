 371:src/engine.cpp **** 
 372:src/engine.cpp ****         // Noise (xorshift32 â†’ -1..1), voice-defined level. Adds breath / chiff /
 373:src/engine.cpp ****         // hiss. noise_hp blends from full white ("shhh") to high-passed ("tsss",
 374:src/engine.cpp ****         // for hi-hats). The `if` folds away when a voice sets noise_level = 0.
 375:src/engine.cpp ****         float noise = 0.0f;
