   1:src/dsp.h     **** #pragma once
   2:src/dsp.h     **** // Pure DSP/math primitives â€” no hardware, no global state (except moog()
   3:src/dsp.h     **** // which lives in the engine). Header-only & inline for the audio hot path.
   4:src/dsp.h     **** #include <math.h>
   5:src/dsp.h     **** 
   6:src/dsp.h     **** // Oscillator shape â€” set per oscillator, so one voice can mix (e.g. saw root +
   7:src/dsp.h     **** // square fifth + sine sub). SQUARE and SAW are naive (not band-limited) â€” they
   8:src/dsp.h     **** // alias at high pitch, but on a low bass voice that just reads as rich harmonics
   9:src/dsp.h     **** // for the filter to chew.
  10:src/dsp.h     **** enum Waveform { WAVE_TRI, WAVE_SINE, WAVE_SQUARE, WAVE_SAW };
  11:src/dsp.h     **** 
  12:src/dsp.h     **** static inline float clampf(float v,float lo,float hi){
  13:src/dsp.h     ****     return v<lo?lo:v>hi?hi:v;
  14:src/dsp.h     **** }
  15:src/dsp.h     **** static inline float smoothstep_f(float x){
  16:src/dsp.h     ****     x = x<0?0:x>1?1:x; return x*x*(3.0f - 2.0f*x);
  17:src/dsp.h     **** }
  18:src/dsp.h     **** static inline float smootherstep_f(float x){
  19:src/dsp.h     ****     x = x<0?0:x>1?1:x; return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
  20:src/dsp.h     **** }
  21:src/dsp.h     **** 
  22:src/dsp.h     **** // Fast tanh approximation (PadÃ©)
  23:src/dsp.h     **** static inline float fast_tanh(float x)
  24:src/dsp.h     **** {
  25:src/dsp.h     ****     if(x> 3.0f)return  1.0f;
  26:src/dsp.h     ****     if(x<-3.0f)return -1.0f;
  27:src/dsp.h     ****     float x2=x*x;
  28:src/dsp.h     ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
  29:src/dsp.h     **** }
  30:src/dsp.h     **** 
ARM GAS  /tmp/claude-502/ccGcxGZf.s 			page 2


  31:src/dsp.h     **** // Convert a one-pole time constant in milliseconds to a per-sample slew
  32:src/dsp.h     **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
  33:src/dsp.h     **** static inline float ms_to_coeff(float ms, float sr){
  34:src/dsp.h     ****     if(ms <= 0.0f) return 0.0f;            // instant
  35:src/dsp.h     ****     return expf(-1.0f / (ms * 0.001f * sr));
  36:src/dsp.h     **** }
  37:src/dsp.h     **** 
  38:src/dsp.h     **** // â”€â”€ Oscillator waveforms (phase ph in [0,1) â†’ sample in [-1,1]) â”€â”€â”€â”€â”€â”€â”€â”€â”€
  39:src/dsp.h     **** // Triangle wave
  40:src/dsp.h     **** static inline float tri(float ph){
  41:src/dsp.h     ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
  42:src/dsp.h     **** }
  43:src/dsp.h     **** // Sine via parabolic approximation (no libm call) â€” matches sin(2Ï€Â·ph).
  44:src/dsp.h     **** static inline float osc_sine(float ph){
  45:src/dsp.h     ****     constexpr float PI = 3.14159265f;
  46:src/dsp.h     ****     float x = ph*2.0f*PI - PI;                 // -Ï€..Ï€ (angle shifted by Ï€)
  47:src/dsp.h     ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
  48:src/dsp.h     ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
  49:src/dsp.h     ****     return -y;                                 // undo the Ï€ shift: sin(x+Ï€) = -sin(x)
  50:src/dsp.h     **** }
  51:src/dsp.h     **** // Naive square / saw â€” alias at high pitch but sound rich on a bass voice.
  52:src/dsp.h     **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
  53:src/dsp.h     **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
  54:src/dsp.h     **** 
  55:src/dsp.h     **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
  56:src/dsp.h     **** // switched live). A small jump table â€” cheap at audio rate on the H750.
  57:src/dsp.h     **** static inline float osc(float ph, Waveform w){
  58:src/dsp.h     ****     switch(w){
  59:src/dsp.h     ****         case WAVE_SINE:   return osc_sine(ph);
  60:src/dsp.h     ****         case WAVE_SQUARE: return osc_square(ph);
  61:src/dsp.h     ****         case WAVE_SAW:    return osc_saw(ph);
  62:src/dsp.h     ****         case WAVE_TRI:
  63:src/dsp.h     ****         default:          return tri(ph);
  64:src/dsp.h     ****     }
  65:src/dsp.h     **** }
  66:src/dsp.h     **** 
