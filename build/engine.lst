 398:src/engine.cpp ****             s_phase1c += f5*VOICE.osc1_ratio/sr; if(s_phase1c>=1.0f)s_phase1c-=1.0f;
 399:src/engine.cpp ****             s_phase2c += f5*VOICE.osc2_ratio/sr; if(s_phase2c>=1.0f)s_phase2c-=1.0f;
 400:src/engine.cpp ****         }
