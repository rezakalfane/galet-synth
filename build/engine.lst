 296:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 13;
ARM GAS  /tmp/claude-502/ccU8FNgW.s 			page 28


 297:src/engine.cpp ****             s_noise_rng ^= s_noise_rng >> 17;
 298:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 5;
 299:src/engine.cpp ****             float white = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 300:src/engine.cpp ****             // One-pole high-pass = white minus its low-frequency content.
 301:src/engine.cpp ****             s_noise_lp += NOISE_HP_COEF * (white - s_noise_lp);
 302:src/engine.cpp ****             float bright = white - s_noise_lp;
 303:src/engine.cpp ****             // Blend white → high-passed by noise_hp (×2 to make up lost level).
 304:src/engine.cpp ****             float n = white + (bright * 2.0f - white) * VOICE.noise_hp;
 305:src/engine.cpp ****             noise = n * VOICE.noise_level;
 306:src/engine.cpp ****         }
 307:src/engine.cpp **** 
 308:src/engine.cpp ****         // Mix oscillator stack + noise
 309:src/engine.cpp ****         float mix = osc1 + osc2 + sub + osc_oct + noise;
 310:src/engine.cpp **** 
 311:src/engine.cpp ****         // Ring modulation (finger 2 pressure → metallic/bell edge)
 312:src/engine.cpp ****         float rm_carrier = tri(s_phase_rm);
 313:src/engine.cpp ****         mix = mix*(1.0f-s_ringmod) + (mix*rm_carrier)*s_ringmod;
 314:src/engine.cpp **** 
 315:src/engine.cpp ****         // Waveshaper drive before filter (adds harmonics, warms tone)
 316:src/engine.cpp ****         mix = fast_tanh(mix * s_drive);
 317:src/engine.cpp **** 
 318:src/engine.cpp ****         // Moog ladder filter — no attack boost (was causing onset clicks)
 319:src/engine.cpp ****         float eff_cutoff = clampf(s_cutoff, 20.0f, 20000.0f);
 320:src/engine.cpp ****         float filtered = moog(mix, eff_cutoff, VOICE.resonance, sr);
 321:src/engine.cpp **** 
 322:src/engine.cpp ****         // Wavefold distortion (finger 2 pressure)
 323:src/engine.cpp ****         float crushed = wavefold(filtered, s_bitcrush);
 324:src/engine.cpp **** 
 325:src/engine.cpp ****         // Soft clip output
 326:src/engine.cpp ****         float sample = fast_tanh(crushed * 1.3f) * s_amp * s_master_vol;
 327:src/engine.cpp **** 
 328:src/engine.cpp ****         // Drums MultiVoice: replace the (silent) mono output with the summed
 329:src/engine.cpp ****         // polyphonic drum voices, soft-clipped, at master volume.
 330:src/engine.cpp ****         if(poly_drums){
 331:src/engine.cpp ****             float m = 0.0f;
 332:src/engine.cpp ****             for(int k = 0; k < POLY; k++) m += drum_render(g_hits[k], sr);
 333:src/engine.cpp ****             sample = fast_tanh(m) * s_master_vol;
 334:src/engine.cpp ****         }
 335:src/engine.cpp **** 
 336:src/engine.cpp ****         out[0][i] = sample;
 337:src/engine.cpp ****         out[1][i] = sample;
