 315:src/engine.cpp ****         if(s_lfo_phase>=1.0f)s_lfo_phase-=1.0f;
 316:src/engine.cpp ****         float lfo = tri(s_lfo_phase); // -1..1
 317:src/engine.cpp **** 
 318:src/engine.cpp ****         // Vibrato: modulate frequency by Â±~1 semitone * depth. Depth = the
 319:src/engine.cpp ****         // finger-pressure amount (s_vibdepth) + the voice's always-on lfo_pitch.
 320:src/engine.cpp ****         float vib_amt = lfo * (s_vibdepth + VOICE.lfo_pitch) * 0.05f;
 321:src/engine.cpp ****         float freq_vib = s_freq * (1.0f + vib_amt) * s_pmult;  // s_pmult: pitch-env sweep
 322:src/engine.cpp **** 
 323:src/engine.cpp ****         // Osc 2 frequency. Lead: finger-2 detune around the base ratio.
 324:src/engine.cpp ****         // Bass (and any fixed-interval voice): hold osc2_ratio (e.g. a 5th).
 325:src/engine.cpp ****         // VOICE is constexpr, so only the taken branch is compiled in.
 326:src/engine.cpp ****         float freq2;
 327:src/engine.cpp ****         if(VOICE.osc2_detune) {
 328:src/engine.cpp ****             float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for Â±1 oct
 329:src/engine.cpp ****             freq2 = freq_vib * VOICE.osc2_ratio * det_ratio;
 330:src/engine.cpp ****         } else {
 331:src/engine.cpp ****             freq2 = freq_vib * VOICE.osc2_ratio;
 332:src/engine.cpp ****         }
 333:src/engine.cpp **** 
 334:src/engine.cpp ****         // Sub and octave oscillators (ratios are voice-defined).
 335:src/engine.cpp ****         float freq_sub = freq_vib * VOICE.sub_ratio;
 336:src/engine.cpp ****         float freq_oct = freq_vib * VOICE.oct_ratio;
 337:src/engine.cpp **** 
 338:src/engine.cpp ****         // Ring mod carrier. ringmod_ratio=1.0 is unison; non-integer ratios give
 339:src/engine.cpp ****         // inharmonic bell/metallic tones.
 340:src/engine.cpp ****         float freq_rm = freq_vib * VOICE.ringmod_ratio;
