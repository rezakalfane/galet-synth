  78:src/engine.cpp **** // White-noise generator state (xorshift32) for the per-voice noise oscillator.
  79:src/engine.cpp **** static uint32_t s_noise_rng = 0x1234567u;
  80:src/engine.cpp **** // One-pole low-pass state used to derive high-passed ("tsss") noise from white.
  81:src/engine.cpp **** static float    s_noise_lp  = 0.0f;
  82:src/engine.cpp **** // High-pass corner coefficient: higher = brighter/higher "tsss" for hi-hats.
  83:src/engine.cpp **** static constexpr float NOISE_HP_COEF = 0.8f;
  84:src/engine.cpp **** 
  85:src/engine.cpp **** // Slew rates (per sample at 48 kHz)
  86:src/engine.cpp **** // Lower value = faster response.
  87:src/engine.cpp **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
  88:src/engine.cpp **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
  89:src/engine.cpp **** // callback. The constants below are the ones still shared by all voices.
  90:src/engine.cpp **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
  91:src/engine.cpp **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
  92:src/engine.cpp **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
  93:src/engine.cpp **** // those steps for a smooth filter sweep while still feeling responsive.
  94:src/engine.cpp **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff â€” ~35 ms smooth
