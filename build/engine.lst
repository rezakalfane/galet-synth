 305:src/engine.cpp ****         float eff_cutoff = clampf(s_cutoff, 20.0f, 20000.0f);
 306:src/engine.cpp ****         float filtered = moog(mix, eff_cutoff, VOICE.resonance, sr);
 307:src/engine.cpp **** 
 308:src/engine.cpp ****         // Wavefold distortion (finger 2 pressure)
 309:src/engine.cpp ****         float crushed = wavefold(filtered, s_bitcrush);
 310:src/engine.cpp **** 
 311:src/engine.cpp ****         // Soft clip output
 312:src/engine.cpp ****         float sample = fast_tanh(crushed * 1.3f) * s_amp * s_master_vol;
 313:src/engine.cpp **** 
 314:src/engine.cpp ****         // Drums MultiVoice: replace the (silent) mono output with the summed
 315:src/engine.cpp ****         // polyphonic drum voices, soft-clipped, at master volume.
 316:src/engine.cpp ****         if(poly_drums){
 317:src/engine.cpp ****             float m = 0.0f;
 318:src/engine.cpp ****             for(int k = 0; k < POLY; k++) m += drum_render(g_hits[k], sr);
 319:src/engine.cpp ****             sample = fast_tanh(m) * s_master_vol;
 320:src/engine.cpp ****         }
 321:src/engine.cpp **** 
 322:src/engine.cpp ****         out[0][i] = sample;
 323:src/engine.cpp ****         out[1][i] = sample;
 324:src/engine.cpp **** 
 325:src/engine.cpp ****         // Advance phases
 326:src/engine.cpp ****         s_phase1   += freq_vib*VOICE.osc1_ratio/sr;  if(s_phase1  >=1.0f)s_phase1  -=1.0f;
