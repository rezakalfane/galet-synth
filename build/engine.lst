  98:src/engine.cpp **** 
  99:src/engine.cpp **** static float drum_render(DrumHit& h, float sr)
 100:src/engine.cpp **** {
 101:src/engine.cpp ****     if(!h.active) return 0.0f;
 102:src/engine.cpp ****     const Voice& V = VOICES[h.vidx];
 103:src/engine.cpp ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 104:src/engine.cpp ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
 105:src/engine.cpp ****     float c   = (tgt > h.amp) ? h.atk_c : h.rel_c;
 106:src/engine.cpp ****     h.amp = h.amp*c + tgt*(1.0f-c);
 107:src/engine.cpp ****     if(!h.gate && h.amp < 0.0004f){ h.active=false; return 0.0f; }
 108:src/engine.cpp ****     // Pitch envelope decays to 1.0.
 109:src/engine.cpp ****     h.pmult = 1.0f + (h.pmult - 1.0f) * h.penv_c;
 110:src/engine.cpp ****     float f = h.freq * h.pmult;
 111:src/engine.cpp ****     // Oscillators + noise
 112:src/engine.cpp ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 113:src/engine.cpp ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 114:src/engine.cpp ****               + osc(h.phs,V.sub_wave )*V.sub_level
 115:src/engine.cpp ****               + osc(h.pho,V.oct_wave )*V.oct_level;
 116:src/engine.cpp ****     if(V.noise_level > 0.0f){
 117:src/engine.cpp ****         s_noise_rng ^= s_noise_rng<<13; s_noise_rng ^= s_noise_rng>>17; s_noise_rng ^= s_noise_rng<
 118:src/engine.cpp ****         float white  = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 119:src/engine.cpp ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 120:src/engine.cpp ****         float bright = white - h.noise_lp;
 121:src/engine.cpp ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
 122:src/engine.cpp ****     }
 123:src/engine.cpp ****     mix = fast_tanh(mix * h.drive);
 124:src/engine.cpp ****     // Per-drum 1-pole lowpass (cheap — one multiply-add — instead of the 4-pole
 125:src/engine.cpp ****     // Moog) at the drum's own cutoff: keeps Kick/Tom dark, Snare/Hat bright.
 126:src/engine.cpp ****     h.lp_state += h.lp_coeff * (mix - h.lp_state);
 127:src/engine.cpp ****     h.ph1 += f*V.osc1_ratio/sr; if(h.ph1>=1.0f)h.ph1-=1.0f;
 128:src/engine.cpp ****     h.ph2 += f*V.osc2_ratio/sr; if(h.ph2>=1.0f)h.ph2-=1.0f;
 129:src/engine.cpp ****     h.phs += f*V.sub_ratio /sr; if(h.phs>=1.0f)h.phs-=1.0f;
 130:src/engine.cpp ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
 131:src/engine.cpp ****     return fast_tanh(h.lp_state*1.3f) * h.amp;
 132:src/engine.cpp **** }
