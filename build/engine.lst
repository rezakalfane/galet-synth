 291:src/engine.cpp ****         // Noise (xorshift32 → -1..1), voice-defined level. Adds breath / chiff /
 292:src/engine.cpp ****         // hiss. noise_hp blends from full white ("shhh") to high-passed ("tsss",
 293:src/engine.cpp ****         // for hi-hats). The `if` folds away when a voice sets noise_level = 0.
 294:src/engine.cpp ****         float noise = 0.0f;
 295:src/engine.cpp ****         if(VOICE.noise_level > 0.0f){
 1026              		.loc 1 295 18 view .LVU338
