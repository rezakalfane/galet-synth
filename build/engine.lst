  82:src/engine.cpp **** 
  83:src/engine.cpp **** // Slew rates (per sample at 48 kHz)
  84:src/engine.cpp **** // Lower value = faster response.
  85:src/engine.cpp **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
  86:src/engine.cpp **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
  87:src/engine.cpp **** // callback. The constants below are the ones still shared by all voices.
  88:src/engine.cpp **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
  89:src/engine.cpp **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
  90:src/engine.cpp **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
  91:src/engine.cpp **** // those steps for a smooth filter sweep while still feeling responsive.
  92:src/engine.cpp **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff â€” ~35 ms smooth
  93:src/engine.cpp **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
  94:src/engine.cpp **** // Finger 2 â€” asymmetric attack/release
ARM GAS  /tmp/claude-502/ccqMMOxD.s 			page 19


  95:src/engine.cpp **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
  96:src/engine.cpp **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
