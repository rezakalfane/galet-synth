 342:src/engine.cpp ****         // Oscillators (mix levels are voice-defined).
 343:src/engine.cpp ****         float osc1    = osc(s_phase1,   VOICE.osc1_wave) * VOICE.osc1_level;
 344:src/engine.cpp ****         float osc2    = osc(s_phase2,   VOICE.osc2_wave) * VOICE.osc2_level;
 345:src/engine.cpp ****         float sub     = osc(s_phase_sub,VOICE.sub_wave)  * VOICE.sub_level;
 346:src/engine.cpp ****         float osc_oct = osc(s_phase_oct,VOICE.oct_wave)  * VOICE.oct_level;
 347:src/engine.cpp **** 
 348:src/engine.cpp ****         // Noise (xorshift32 â†’ -1..1), voice-defined level. Adds breath / chiff /
 349:src/engine.cpp ****         // hiss. noise_hp blends from full white ("shhh") to high-passed ("tsss",
 350:src/engine.cpp ****         // for hi-hats). The `if` folds away when a voice sets noise_level = 0.
 351:src/engine.cpp ****         float noise = 0.0f;
 352:src/engine.cpp ****         if(VOICE.noise_level > 0.0f){
 353:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 13;
 354:src/engine.cpp ****             s_noise_rng ^= s_noise_rng >> 17;
 355:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 5;
 356:src/engine.cpp ****             float white = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 357:src/engine.cpp ****             // One-pole high-pass = white minus its low-frequency content.
 358:src/engine.cpp ****             s_noise_lp += NOISE_HP_COEF * (white - s_noise_lp);
 359:src/engine.cpp ****             float bright = white - s_noise_lp;
 360:src/engine.cpp ****             // Blend white â†’ high-passed by noise_hp (Ã—2 to make up lost level).
 361:src/engine.cpp ****             float n = white + (bright * 2.0f - white) * VOICE.noise_hp;
 362:src/engine.cpp ****             noise = n * VOICE.noise_level;
 363:src/engine.cpp ****         }
 364:src/engine.cpp **** 
 365:src/engine.cpp ****         // Mix oscillator stack + noise
 366:src/engine.cpp ****         float mix = osc1 + osc2 + sub + osc_oct + noise;
 367:src/engine.cpp **** 
 368:src/engine.cpp ****         // Diatonic chord (Voice::chords): add the snapped triad's 3rd and 5th as
 369:src/engine.cpp ****         // extra saw+pulse voices above the root. They ride freq_vib (so they
 370:src/engine.cpp ****         // glide/vibrato with the root) scaled by the per-note ratios. Sub and
 371:src/engine.cpp ****         // noise stay on the root only â€” keeps the low end tight and the chord
 372:src/engine.cpp ****         // clear â€” and the upper notes are scaled by VOICE.chord_level for headroom.
 373:src/engine.cpp ****         // VOICE is a runtime ref (selection is live), so this is a cheap
 374:src/engine.cpp ****         // well-predicted branch â€” skipped each sample for single-note voices.
 375:src/engine.cpp ****         if(VOICE.chords){
 376:src/engine.cpp ****             float f3 = freq_vib * tcr2;   // 3rd
 377:src/engine.cpp ****             float f5 = freq_vib * tcr3;   // 5th
 378:src/engine.cpp ****             float cl = VOICE.chord_level;
 379:src/engine.cpp ****             mix += (osc(s_phase1b, VOICE.osc1_wave) * VOICE.osc1_level
 380:src/engine.cpp ****                   + osc(s_phase2b, VOICE.osc2_wave) * VOICE.osc2_level) * cl;
 381:src/engine.cpp ****             mix += (osc(s_phase1c, VOICE.osc1_wave) * VOICE.osc1_level
 382:src/engine.cpp ****                   + osc(s_phase2c, VOICE.osc2_wave) * VOICE.osc2_level) * cl;
 383:src/engine.cpp ****             s_phase1b += f3*VOICE.osc1_ratio/sr; if(s_phase1b>=1.0f)s_phase1b-=1.0f;
 384:src/engine.cpp ****             s_phase2b += f3*VOICE.osc2_ratio/sr; if(s_phase2b>=1.0f)s_phase2b-=1.0f;
 385:src/engine.cpp ****             s_phase1c += f5*VOICE.osc1_ratio/sr; if(s_phase1c>=1.0f)s_phase1c-=1.0f;
 386:src/engine.cpp ****             s_phase2c += f5*VOICE.osc2_ratio/sr; if(s_phase2c>=1.0f)s_phase2c-=1.0f;
 387:src/engine.cpp ****         }
 388:src/engine.cpp **** 
 389:src/engine.cpp ****         // Ring modulation (finger 2 pressure â†’ metallic/bell edge)
 390:src/engine.cpp ****         float rm_carrier = tri(s_phase_rm);
 391:src/engine.cpp ****         mix = mix*(1.0f-s_ringmod) + (mix*rm_carrier)*s_ringmod;
