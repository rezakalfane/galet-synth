  72:src/engine.cpp **** // Slew rates (per sample at 48 kHz)
  73:src/engine.cpp **** // Lower value = faster response.
  74:src/engine.cpp **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
  75:src/engine.cpp **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
  76:src/engine.cpp **** // callback. The constants below are the ones still shared by all voices.
  77:src/engine.cpp **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
  78:src/engine.cpp **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
  79:src/engine.cpp **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
  80:src/engine.cpp **** // those steps for a smooth filter sweep while still feeling responsive.
  81:src/engine.cpp **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff â€” ~35 ms smooth
  82:src/engine.cpp **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
  83:src/engine.cpp **** // Finger 2 â€” asymmetric attack/release
  84:src/engine.cpp **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
  85:src/engine.cpp **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
