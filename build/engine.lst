 373:src/engine.cpp ****             // Blend white â†’ high-passed by noise_hp (Ã—2 to make up lost level).
 374:src/engine.cpp ****             float n = white + (bright * 2.0f - white) * VOICE.noise_hp;
 375:src/engine.cpp ****             noise = n * VOICE.noise_level;
 376:src/engine.cpp ****         }
 377:src/engine.cpp **** 
 378:src/engine.cpp ****         // Mix oscillator stack + noise
 379:src/engine.cpp ****         float mix = osc1 + osc2 + sub + osc_oct + noise;
 380:src/engine.cpp **** 
 381:src/engine.cpp ****         // Diatonic chord (Voice::chords): add the snapped triad's 3rd and 5th as
 382:src/engine.cpp ****         // extra saw+pulse voices above the root. They ride freq_vib (so they
 383:src/engine.cpp ****         // glide/vibrato with the root) scaled by the per-note ratios. Sub and
 384:src/engine.cpp ****         // noise stay on the root only â€” keeps the low end tight and the chord
 385:src/engine.cpp ****         // clear â€” and the upper notes are scaled by VOICE.chord_level for headroom.
 386:src/engine.cpp ****         // VOICE is a runtime ref (selection is live), so this is a cheap
 387:src/engine.cpp ****         // well-predicted branch â€” skipped each sample for single-note voices.
 388:src/engine.cpp ****         if(VOICE.chords){
 389:src/engine.cpp ****             float f3 = freq_vib * tcr2;   // 3rd
 390:src/engine.cpp ****             float f5 = freq_vib * tcr3;   // 5th
 391:src/engine.cpp ****             float cl = VOICE.chord_level;
 392:src/engine.cpp ****             mix += (osc(s_phase1b, VOICE.osc1_wave) * VOICE.osc1_level
 393:src/engine.cpp ****                   + osc(s_phase2b, VOICE.osc2_wave) * VOICE.osc2_level) * cl;
