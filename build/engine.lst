 295:src/engine.cpp ****         // Bleed filter state toward zero when silent
 296:src/engine.cpp ****         // Prevents stale filter energy from clicking on next note onset
 297:src/engine.cpp ****         if(s_amp < 0.001f) {
 298:src/engine.cpp ****             s_flt[0] *= 0.999f;
 299:src/engine.cpp ****             s_flt[1] *= 0.999f;
