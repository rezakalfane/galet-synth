 135:src/engine.cpp **** 
 136:src/engine.cpp **** static float drum_render(DrumHit& h, float sr)
 137:src/engine.cpp **** {
 138:src/engine.cpp ****     if(!h.active) return 0.0f;
 139:src/engine.cpp ****     const Voice& V = g_bank[h.vidx];
 140:src/engine.cpp ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 141:src/engine.cpp ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
 142:src/engine.cpp ****     float c   = (tgt > h.amp) ? h.atk_c : h.rel_c;
 143:src/engine.cpp ****     h.amp = h.amp*c + tgt*(1.0f-c);
 144:src/engine.cpp ****     if(!h.gate && h.amp < 0.0004f){ h.active=false; return 0.0f; }
 145:src/engine.cpp ****     // Pitch envelope decays to 1.0.
 146:src/engine.cpp ****     h.pmult = 1.0f + (h.pmult - 1.0f) * h.penv_c;
 147:src/engine.cpp ****     float f = h.freq * h.pmult;
 148:src/engine.cpp ****     // Oscillators + noise
 149:src/engine.cpp ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 150:src/engine.cpp ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 151:src/engine.cpp ****               + osc(h.phs,V.sub_wave )*V.sub_level
 152:src/engine.cpp ****               + osc(h.pho,V.oct_wave )*V.oct_level;
 153:src/engine.cpp ****     if(V.noise_level > 0.0f){
 154:src/engine.cpp ****         s_noise_rng ^= s_noise_rng<<13; s_noise_rng ^= s_noise_rng>>17; s_noise_rng ^= s_noise_rng<
 155:src/engine.cpp ****         float white  = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 156:src/engine.cpp ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 157:src/engine.cpp ****         float bright = white - h.noise_lp;
 158:src/engine.cpp ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
 159:src/engine.cpp ****     }
 160:src/engine.cpp ****     mix = fast_tanh(mix * h.drive);
 161:src/engine.cpp ****     // Per-drum 4-pole Moog ladder at the latched cutoff with the drum voice's own
 162:src/engine.cpp ****     // resonance â€” the same filter the mono engine runs, so a kit hit sounds like
 163:src/engine.cpp ****     // selecting that drum and tapping it (not a dulled 1-pole approximation).
 164:src/engine.cpp ****     float filtered = moog_st(mix, clampf(h.cutoff, 20.0f, 20000.0f), V.resonance, sr, h.flt);
 165:src/engine.cpp ****     h.ph1 += f*V.osc1_ratio/sr; if(h.ph1>=1.0f)h.ph1-=1.0f;
 166:src/engine.cpp ****     h.ph2 += f*V.osc2_ratio/sr; if(h.ph2>=1.0f)h.ph2-=1.0f;
 167:src/engine.cpp ****     h.phs += f*V.sub_ratio /sr; if(h.phs>=1.0f)h.phs-=1.0f;
 168:src/engine.cpp ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
 169:src/engine.cpp ****     return fast_tanh(filtered*1.3f) * h.amp;
 170:src/engine.cpp **** }
