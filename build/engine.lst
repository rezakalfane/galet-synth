  88:src/engine.cpp **** // White-noise generator state (xorshift32) for the per-voice noise oscillator.
  89:src/engine.cpp **** static uint32_t s_noise_rng = 0x1234567u;
  90:src/engine.cpp **** // One-pole low-pass state used to derive high-passed ("tsss") noise from white.
  91:src/engine.cpp **** static float    s_noise_lp  = 0.0f;
  92:src/engine.cpp **** // High-pass corner coefficient: higher = brighter/higher "tsss" for hi-hats.
  93:src/engine.cpp **** static constexpr float NOISE_HP_COEF = 0.8f;
  94:src/engine.cpp **** 
  95:src/engine.cpp **** // Slew rates (per sample at 48 kHz)
  96:src/engine.cpp **** // Lower value = faster response.
  97:src/engine.cpp **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
  98:src/engine.cpp **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
  99:src/engine.cpp **** // callback. The constants below are the ones still shared by all voices.
 100:src/engine.cpp **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 101:src/engine.cpp **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 102:src/engine.cpp **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 103:src/engine.cpp **** // those steps for a smooth filter sweep while still feeling responsive.
 104:src/engine.cpp **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff â€” ~35 ms smooth
 105:src/engine.cpp **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 106:src/engine.cpp **** // Finger 2 â€” asymmetric attack/release
 107:src/engine.cpp **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 108:src/engine.cpp **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 109:src/engine.cpp **** 
 110:src/engine.cpp **** 
 111:src/engine.cpp **** // Mono ladder using the shared global state (the monophonic melodic engine).
 112:src/engine.cpp **** static inline float moog(float in, float cutoff, float res, float sr)
 113:src/engine.cpp **** {
 114:src/engine.cpp ****     return moog_st(in, cutoff, res, sr, s_flt);
 115:src/engine.cpp **** }
