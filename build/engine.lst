 103:src/dsp.h     **** 
 104:src/dsp.h     **** // â”€â”€ Reverb (compact mono Freeverb: 8 damped combs + 4 allpass) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
 105:src/dsp.h     **** // Schroederâ€“Moorer: 8 parallel comb filters (each with a one-pole lowpass in its
 106:src/dsp.h     **** // feedback for HF damping) summed, then 4 series allpass diffusers. Mono (the
 107:src/dsp.h     **** // synth output is mono). Delay lengths are the classic Freeverb 44.1k tunings
 108:src/dsp.h     **** // scaled to 48k. One shared instance lives in the engine; voices feed it via
 109:src/dsp.h     **** // Voice::reverb_send and the global g_reverb_* params drive `feedback` (tail
 110:src/dsp.h     **** // length) and `damp` (HF rolloff) per call, so the room is global + tweakable.
 111:src/dsp.h     **** // All state is zero (silent) at startup â€” it has static storage in the engine.
 112:src/dsp.h     **** struct Reverb {
 113:src/dsp.h     ****     static constexpr int NCOMB = 8;
 114:src/dsp.h     ****     static constexpr int NAP   = 4;
 115:src/dsp.h     ****     static constexpr int COMB_MAX = 1760;   // largest comb delay
 116:src/dsp.h     ****     static constexpr int AP_MAX   = 605;    // largest allpass delay
 117:src/dsp.h     ****     float comb_buf[NCOMB][COMB_MAX] = {};
 118:src/dsp.h     ****     float ap_buf[NAP][AP_MAX]       = {};
 119:src/dsp.h     ****     int   ci[NCOMB] = {};                   // comb write indices
 120:src/dsp.h     ****     int   ai[NAP]   = {};                   // allpass indices
 121:src/dsp.h     ****     float clp[NCOMB] = {};                  // comb damping-lowpass state
 122:src/dsp.h     **** 
 123:src/dsp.h     ****     // feedback â‰ˆ room size / tail length (0..~0.96); damp = HF damping (0..1).
 124:src/dsp.h     ****     inline float process(float in, float feedback, float damp){
 125:src/dsp.h     ****         static constexpr int CL[NCOMB] = {1215,1293,1390,1476,1548,1623,1695,1760};
 126:src/dsp.h     ****         static constexpr int AL[NAP]   = {605,480,371,245};
 127:src/dsp.h     ****         float inp = in * 0.015f;            // fixed input gain (keeps the combs tame)
 128:src/dsp.h     ****         float out = 0.0f;
 129:src/dsp.h     ****         for(int c = 0; c < NCOMB; c++){
 130:src/dsp.h     ****             float y = comb_buf[c][ci[c]];
 131:src/dsp.h     ****             clp[c] = y*(1.0f - damp) + clp[c]*damp;       // lowpass in the feedback path
 132:src/dsp.h     ****             comb_buf[c][ci[c]] = inp + clp[c]*feedback;
 133:src/dsp.h     ****             if(++ci[c] >= CL[c]) ci[c] = 0;
 134:src/dsp.h     ****             out += y;
 135:src/dsp.h     ****         }
 136:src/dsp.h     ****         for(int a = 0; a < NAP; a++){
 137:src/dsp.h     ****             float bufout = ap_buf[a][ai[a]];
 138:src/dsp.h     ****             float y = -out + bufout;
 139:src/dsp.h     ****             ap_buf[a][ai[a]] = out + bufout*0.5f;
 140:src/dsp.h     ****             if(++ai[a] >= AL[a]) ai[a] = 0;
 141:src/dsp.h     ****             out = y;
 142:src/dsp.h     ****         }
 143:src/dsp.h     ****         return out;
 144:src/dsp.h     ****     }
 145:src/dsp.h     **** };
 146:src/dsp.h     **** 
 147:src/dsp.h     **** // â”€â”€ Delay (mono, feedback + HF damping) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
 148:src/dsp.h     **** // A single delay line with a feedback path that runs through a one-pole lowpass,
 149:src/dsp.h     **** // so each repeat is a little darker than the last â€” the warm, analog-ish echo
 150:src/dsp.h     **** // instead of a sterile digital copy. One shared instance lives in the engine;
 151:src/dsp.h     **** // voices feed it via Voice::delay_send, and the global g_delay_* params set the
 152:src/dsp.h     **** // time / feedback / level. State is zero (silent) at startup (static storage).
 153:src/dsp.h     **** struct Delay {
 154:src/dsp.h     ****     static constexpr int MAX = 36000;       // 750 ms at 48 kHz
 155:src/dsp.h     ****     float buf[MAX] = {};
 156:src/dsp.h     ****     int   w = 0;                            // write index
 157:src/dsp.h     ****     float damp_state = 0.0f;                // feedback lowpass state
