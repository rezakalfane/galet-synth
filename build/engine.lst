 113:src/engine.cpp **** 
 114:src/engine.cpp **** static float drum_render(DrumHit& h, float sr)
 115:src/engine.cpp **** {
 116:src/engine.cpp ****     if(!h.active) return 0.0f;
 117:src/engine.cpp ****     const Voice& V = g_bank[h.vidx];
 118:src/engine.cpp ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 119:src/engine.cpp ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
 120:src/engine.cpp ****     float c   = (tgt > h.amp) ? h.atk_c : h.rel_c;
 121:src/engine.cpp ****     h.amp = h.amp*c + tgt*(1.0f-c);
 122:src/engine.cpp ****     if(!h.gate && h.amp < 0.0004f){ h.active=false; return 0.0f; }
 123:src/engine.cpp ****     // Pitch envelope decays to 1.0.
 124:src/engine.cpp ****     h.pmult = 1.0f + (h.pmult - 1.0f) * h.penv_c;
 125:src/engine.cpp ****     float f = h.freq * h.pmult;
 126:src/engine.cpp ****     // Oscillators + noise
 127:src/engine.cpp ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 128:src/engine.cpp ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 129:src/engine.cpp ****               + osc(h.phs,V.sub_wave )*V.sub_level
 130:src/engine.cpp ****               + osc(h.pho,V.oct_wave )*V.oct_level;
 131:src/engine.cpp ****     if(V.noise_level > 0.0f){
 132:src/engine.cpp ****         s_noise_rng ^= s_noise_rng<<13; s_noise_rng ^= s_noise_rng>>17; s_noise_rng ^= s_noise_rng<
 133:src/engine.cpp ****         float white  = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 134:src/engine.cpp ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 135:src/engine.cpp ****         float bright = white - h.noise_lp;
 136:src/engine.cpp ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
 137:src/engine.cpp ****     }
 138:src/engine.cpp ****     mix = fast_tanh(mix * h.drive);
 139:src/engine.cpp ****     // Per-drum 1-pole lowpass (cheap â€” one multiply-add â€” instead of the 4-pole
 140:src/engine.cpp ****     // Moog) at the drum's own cutoff: keeps Kick/Tom dark, Snare/Hat bright.
 141:src/engine.cpp ****     h.lp_state += h.lp_coeff * (mix - h.lp_state);
 142:src/engine.cpp ****     h.ph1 += f*V.osc1_ratio/sr; if(h.ph1>=1.0f)h.ph1-=1.0f;
 143:src/engine.cpp ****     h.ph2 += f*V.osc2_ratio/sr; if(h.ph2>=1.0f)h.ph2-=1.0f;
 144:src/engine.cpp ****     h.phs += f*V.sub_ratio /sr; if(h.phs>=1.0f)h.phs-=1.0f;
 145:src/engine.cpp ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
ARM GAS  /tmp/claude-502/cc4mXj64.s 			page 11


 146:src/engine.cpp ****     return fast_tanh(h.lp_state*1.3f) * h.amp;
 147:src/engine.cpp **** }
