  39:src/engine.cpp **** 
  40:src/engine.cpp **** // White-noise generator state (xorshift32) for the per-voice noise oscillator.
  41:src/engine.cpp **** static uint32_t s_noise_rng = 0x1234567u;
  42:src/engine.cpp **** // One-pole low-pass state used to derive high-passed ("tsss") noise from white.
  43:src/engine.cpp **** static float    s_noise_lp  = 0.0f;
  44:src/engine.cpp **** // High-pass corner coefficient: higher = brighter/higher "tsss" for hi-hats.
  45:src/engine.cpp **** static constexpr float NOISE_HP_COEF = 0.8f;
  46:src/engine.cpp **** 
  47:src/engine.cpp **** // Slew rates (per sample at 48 kHz)
  48:src/engine.cpp **** // Lower value = faster response.
  49:src/engine.cpp **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
  50:src/engine.cpp **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
  51:src/engine.cpp **** // callback. The constants below are the ones still shared by all voices.
  52:src/engine.cpp **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
  53:src/engine.cpp **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
  54:src/engine.cpp **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
  55:src/engine.cpp **** // those steps for a smooth filter sweep while still feeling responsive.
  56:src/engine.cpp **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff — ~35 ms smooth
  57:src/engine.cpp **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
  58:src/engine.cpp **** // Finger 2 — asymmetric attack/release
  59:src/engine.cpp **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
  60:src/engine.cpp **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
  61:src/engine.cpp **** 
  62:src/engine.cpp **** 
  63:src/engine.cpp **** // Mono ladder using the shared global state (the monophonic melodic engine).
  64:src/engine.cpp **** static inline float moog(float in, float cutoff, float res, float sr)
  65:src/engine.cpp **** {
  66:src/engine.cpp ****     return moog_st(in, cutoff, res, sr, s_flt);
  67:src/engine.cpp **** }
