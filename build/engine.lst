  66:src/engine.cpp **** static uint32_t s_noise_rng = 0x1234567u;
  67:src/engine.cpp **** // One-pole low-pass state used to derive high-passed ("tsss") noise from white.
  68:src/engine.cpp **** static float    s_noise_lp  = 0.0f;
  69:src/engine.cpp **** // High-pass corner coefficient: higher = brighter/higher "tsss" for hi-hats.
