 159:src/engine.cpp ****     // Snapshot the active voice once per block, so a mid-block switch from the
 160:src/engine.cpp ****     // touch loop can't tear fields across the block. All VOICE.* reads below
 161:src/engine.cpp ****     // resolve against this reference. g_active_voice tracks g_voice_idx except in
 162:src/engine.cpp ****     // MultiVoice mode, where the touch loop routes it per tap to a drum.
 163:src/engine.cpp ****     int vi = g_active_voice;
ARM GAS  /tmp/claude-502/ccaZRenT.s 			page 14


 164:src/engine.cpp ****     if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 165:src/engine.cpp ****     const Voice& VOICE = VOICES[vi];
 166:src/engine.cpp **** 
 167:src/engine.cpp ****     // In the Drums MultiVoice the polyphonic drum engine plays instead of the
 168:src/engine.cpp ****     // mono path (which the touch loop holds silent). Decided once per block.
 169:src/engine.cpp ****     bool poly_drums = (g_voice_idx == MULTI_IDX);
