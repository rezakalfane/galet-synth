 267:src/engine.cpp ****         s_freq    = s_freq   *s_glide_c + tfreq*(1.0f-s_glide_c);
 268:src/engine.cpp ****         // Cutoff: fast when opening (smoothed), slow when closing (with release)
 269:src/engine.cpp ****         { float sc = (tcut > s_cutoff) ? SLEW_CUT : s_rel_c;
 270:src/engine.cpp ****           s_cutoff = s_cutoff * sc + tcut * (1.0f - sc); }
 271:src/engine.cpp ****         s_drive   = s_drive   * SLEW_MISC + tdrv * (1.0f - SLEW_MISC);
 272:src/engine.cpp ****         s_vibdepth= s_vibdepth* SLEW_MISC + tvib * (1.0f - SLEW_MISC);
 273:src/engine.cpp ****         // Finger 2 params: fast attack, slow release
 274:src/engine.cpp ****         { float sa = tdet     > s_detune   ? SLEW_F2_A : SLEW_F2_R;
 275:src/engine.cpp ****           s_detune   = s_detune   * sa + tdet * (1.0f - sa); }
 276:src/engine.cpp ****         { float sa = tbc      > s_bitcrush ? SLEW_F2_A : SLEW_F2_R;
 277:src/engine.cpp ****           s_bitcrush = s_bitcrush * sa + tbc  * (1.0f - sa); }
 278:src/engine.cpp ****         { float sa = trm      > s_ringmod  ? SLEW_F2_A : SLEW_F2_R;
 279:src/engine.cpp ****           s_ringmod  = s_ringmod  * sa + trm  * (1.0f - sa); }
 280:src/engine.cpp ****         // Amp decay-to-sustain: s_decay rides 1 â†’ sustain over decay_ms while the
 281:src/engine.cpp ****         // note is gated (stays pinned at 1 when decay_ms == 0, i.e. every other
 282:src/engine.cpp ****         // voice). It scales the gated target so the note plucks down to `sustain`.
 283:src/engine.cpp ****         s_decay = s_decay * s_decay_c + s_sustain * (1.0f - s_decay_c);
 284:src/engine.cpp ****         float eff_tamp = tamp * s_decay;
 285:src/engine.cpp ****         // Asymmetric envelope: attack while rising OR decaying-while-held (track the
 286:src/engine.cpp ****         // decay shape quickly â€” its rate comes from s_decay); release only once the
 287:src/engine.cpp ****         // note is actually let go (tamp â†’ 0).
 288:src/engine.cpp ****         float slew_amp = (eff_tamp > s_amp || tamp > 0.001f) ? s_atk_c : s_rel_c;
 289:src/engine.cpp ****         s_amp = s_amp * slew_amp + eff_tamp * (1.0f - slew_amp);
