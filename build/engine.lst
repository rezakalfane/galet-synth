 330:src/engine.cpp **** 
 331:src/engine.cpp ****         // Vibrato: modulate frequency by Â±~1 semitone * depth. Depth = the
 332:src/engine.cpp ****         // finger-pressure amount (s_vibdepth) + the voice's always-on lfo_pitch.
 333:src/engine.cpp ****         float vib_amt = lfo * (s_vibdepth + VOICE.lfo_pitch) * 0.05f;
 334:src/engine.cpp ****         float freq_vib = s_freq * (1.0f + vib_amt) * s_pmult;  // s_pmult: pitch-env sweep
 335:src/engine.cpp **** 
 336:src/engine.cpp ****         // Osc 2 frequency. Lead: finger-2 detune around the base ratio.
 337:src/engine.cpp ****         // Bass (and any fixed-interval voice): hold osc2_ratio (e.g. a 5th).
 338:src/engine.cpp ****         // VOICE is constexpr, so only the taken branch is compiled in.
 339:src/engine.cpp ****         float freq2;
 340:src/engine.cpp ****         if(VOICE.osc2_detune) {
 341:src/engine.cpp ****             float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for Â±1 oct
 342:src/engine.cpp ****             freq2 = freq_vib * VOICE.osc2_ratio * det_ratio;
 343:src/engine.cpp ****         } else {
 344:src/engine.cpp ****             freq2 = freq_vib * VOICE.osc2_ratio;
 345:src/engine.cpp ****         }
 346:src/engine.cpp **** 
 347:src/engine.cpp ****         // Sub and octave oscillators (ratios are voice-defined).
 348:src/engine.cpp ****         float freq_sub = freq_vib * VOICE.sub_ratio;
 349:src/engine.cpp ****         float freq_oct = freq_vib * VOICE.oct_ratio;
 350:src/engine.cpp **** 
 351:src/engine.cpp ****         // Ring mod carrier. ringmod_ratio=1.0 is unison; non-integer ratios give
 352:src/engine.cpp ****         // inharmonic bell/metallic tones.
 353:src/engine.cpp ****         float freq_rm = freq_vib * VOICE.ringmod_ratio;
 354:src/engine.cpp **** 
 355:src/engine.cpp ****         // Oscillators (mix levels are voice-defined).
 356:src/engine.cpp ****         float osc1    = osc(s_phase1,   VOICE.osc1_wave) * VOICE.osc1_level;
 357:src/engine.cpp ****         float osc2    = osc(s_phase2,   VOICE.osc2_wave) * VOICE.osc2_level;
 358:src/engine.cpp ****         float sub     = osc(s_phase_sub,VOICE.sub_wave)  * VOICE.sub_level;
 359:src/engine.cpp ****         float osc_oct = osc(s_phase_oct,VOICE.oct_wave)  * VOICE.oct_level;
 360:src/engine.cpp **** 
 361:src/engine.cpp ****         // Noise (xorshift32 â†’ -1..1), voice-defined level. Adds breath / chiff /
 362:src/engine.cpp ****         // hiss. noise_hp blends from full white ("shhh") to high-passed ("tsss",
 363:src/engine.cpp ****         // for hi-hats). The `if` folds away when a voice sets noise_level = 0.
 364:src/engine.cpp ****         float noise = 0.0f;
 365:src/engine.cpp ****         if(VOICE.noise_level > 0.0f){
 366:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 13;
 367:src/engine.cpp ****             s_noise_rng ^= s_noise_rng >> 17;
 368:src/engine.cpp ****             s_noise_rng ^= s_noise_rng << 5;
 369:src/engine.cpp ****             float white = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 370:src/engine.cpp ****             // One-pole high-pass = white minus its low-frequency content.
