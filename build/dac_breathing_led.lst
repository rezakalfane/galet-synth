  30:tools/dac_breathing_led.cpp **** // â”€â”€ Tweak these â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
  31:tools/dac_breathing_led.cpp **** static constexpr float PERIOD_S      = 2.0f;   // full cycle length, seconds
  32:tools/dac_breathing_led.cpp **** // Per-LED shape: rise (RISE_FRAC), hold at peak (HOLD_FRAC), fall (RISE_FRAC).
  33:tools/dac_breathing_led.cpp **** // Three chained LEDs â†’ constraint: 4*RISE_FRAC + HOLD_FRAC = 1.0.
  34:tools/dac_breathing_led.cpp **** // Lower RISE_FRAC = longer bright overlap.
  35:tools/dac_breathing_led.cpp **** static constexpr float RISE_FRAC     = 0.2f;
  36:tools/dac_breathing_led.cpp **** static constexpr float HOLD_FRAC     = 1.0f - 4.0f * RISE_FRAC;
  37:tools/dac_breathing_led.cpp **** 
  38:tools/dac_breathing_led.cpp **** // â”€â”€ Probably leave these alone â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
  39:tools/dac_breathing_led.cpp **** static constexpr float UPDATE_HZ     = 200.0f; // DAC refresh rate
  40:tools/dac_breathing_led.cpp **** static constexpr float GAMMA         = 0.6f;   // <1 boosts brightness, 1.0 = linear, 2.2 = percept
  41:tools/dac_breathing_led.cpp **** static constexpr uint16_t DAC_MAX    = 4095;   // 12-bit
  42:tools/dac_breathing_led.cpp **** static constexpr uint32_t PWM_PERIOD_US = 500; // 2 kHz software PWM on LED3
  43:tools/dac_breathing_led.cpp **** static constexpr float LED3_INTENSITY = 0.15f; // scales LED3 max brightness (1.0 = full)
