  28:lib/tinyusb/src/common/tusb_fifo.h **** #ifndef _TUSB_FIFO_H_
  29:lib/tinyusb/src/common/tusb_fifo.h **** #define _TUSB_FIFO_H_
  30:lib/tinyusb/src/common/tusb_fifo.h **** 
  31:lib/tinyusb/src/common/tusb_fifo.h **** #ifdef __cplusplus
  32:lib/tinyusb/src/common/tusb_fifo.h **** extern "C" {
  33:lib/tinyusb/src/common/tusb_fifo.h **** #endif
  34:lib/tinyusb/src/common/tusb_fifo.h **** 
  35:lib/tinyusb/src/common/tusb_fifo.h **** // Due to the use of unmasked pointers, this FIFO does not suffer from losing
  36:lib/tinyusb/src/common/tusb_fifo.h **** // one item slice. Furthermore, write and read operations are completely
  37:lib/tinyusb/src/common/tusb_fifo.h **** // decoupled as write and read functions do not modify a common state. Henceforth,
  38:lib/tinyusb/src/common/tusb_fifo.h **** // writing or reading from the FIFO within an ISR is safe as long as no other
  39:lib/tinyusb/src/common/tusb_fifo.h **** // process (thread or ISR) interferes.
  40:lib/tinyusb/src/common/tusb_fifo.h **** // Also, this FIFO is ready to be used in combination with a DMA as the write and
  41:lib/tinyusb/src/common/tusb_fifo.h **** // read pointers can be updated from within a DMA ISR. Overflows are detectable
  42:lib/tinyusb/src/common/tusb_fifo.h **** // within a certain number (see tu_fifo_overflow()).
  43:lib/tinyusb/src/common/tusb_fifo.h **** 
  44:lib/tinyusb/src/common/tusb_fifo.h **** #include "common/tusb_common.h"
  45:lib/tinyusb/src/common/tusb_fifo.h **** #include "osal/osal.h"
ARM GAS  /tmp/claude-502/ccY3ow5l.s 			page 44


  46:lib/tinyusb/src/common/tusb_fifo.h **** 
  47:lib/tinyusb/src/common/tusb_fifo.h **** // mutex is only needed for RTOS
  48:lib/tinyusb/src/common/tusb_fifo.h **** // for OS None, we don't get preempted
  49:lib/tinyusb/src/common/tusb_fifo.h **** #define CFG_FIFO_MUTEX      OSAL_MUTEX_REQUIRED
  50:lib/tinyusb/src/common/tusb_fifo.h **** 
  51:lib/tinyusb/src/common/tusb_fifo.h **** /* Write/Read index is always in the range of:
  52:lib/tinyusb/src/common/tusb_fifo.h ****  *      0 .. 2*depth-1
  53:lib/tinyusb/src/common/tusb_fifo.h ****  * The extra window allow us to determine the fifo state of empty or full with only 2 indices
  54:lib/tinyusb/src/common/tusb_fifo.h ****  * Following are examples with depth = 3
  55:lib/tinyusb/src/common/tusb_fifo.h ****  *
  56:lib/tinyusb/src/common/tusb_fifo.h ****  * - empty: W = R
  57:lib/tinyusb/src/common/tusb_fifo.h ****  *                |
  58:lib/tinyusb/src/common/tusb_fifo.h ****  *    -------------------------
  59:lib/tinyusb/src/common/tusb_fifo.h ****  *    | 0 | RW| 2 | 3 | 4 | 5 |
  60:lib/tinyusb/src/common/tusb_fifo.h ****  *
  61:lib/tinyusb/src/common/tusb_fifo.h ****  * - full 1: W > R
  62:lib/tinyusb/src/common/tusb_fifo.h ****  *                |
  63:lib/tinyusb/src/common/tusb_fifo.h ****  *    -------------------------
  64:lib/tinyusb/src/common/tusb_fifo.h ****  *    | 0 | R | 2 | 3 | W | 5 |
  65:lib/tinyusb/src/common/tusb_fifo.h ****  *
  66:lib/tinyusb/src/common/tusb_fifo.h ****  * - full 2: W < R
  67:lib/tinyusb/src/common/tusb_fifo.h ****  *                |
  68:lib/tinyusb/src/common/tusb_fifo.h ****  *    -------------------------
  69:lib/tinyusb/src/common/tusb_fifo.h ****  *    | 0 | 1 | W | 3 | 4 | R |
  70:lib/tinyusb/src/common/tusb_fifo.h ****  *
  71:lib/tinyusb/src/common/tusb_fifo.h ****  * - Number of items in the fifo can be determined in either cases:
  72:lib/tinyusb/src/common/tusb_fifo.h ****  *    - case W >= R: Count = W - R
  73:lib/tinyusb/src/common/tusb_fifo.h ****  *    - case W <  R: Count = 2*depth - (R - W)
  74:lib/tinyusb/src/common/tusb_fifo.h ****  *
  75:lib/tinyusb/src/common/tusb_fifo.h ****  * In non-overwritable mode, computed Count (in above 2 cases) is at most equal to depth.
  76:lib/tinyusb/src/common/tusb_fifo.h ****  * However, in over-writable mode, write index can be repeatedly increased and count can be
  77:lib/tinyusb/src/common/tusb_fifo.h ****  * temporarily larger than depth (overflowed condition) e.g
  78:lib/tinyusb/src/common/tusb_fifo.h ****  *
  79:lib/tinyusb/src/common/tusb_fifo.h ****  *  - Overflowed 1: write(3), write(1)
  80:lib/tinyusb/src/common/tusb_fifo.h ****  *    In this case we will adjust Read index when read()/peek() is called so that count = depth.
  81:lib/tinyusb/src/common/tusb_fifo.h ****  *                  |
  82:lib/tinyusb/src/common/tusb_fifo.h ****  *      -------------------------
  83:lib/tinyusb/src/common/tusb_fifo.h ****  *      | R | 1 | 2 | 3 | W | 5 |
  84:lib/tinyusb/src/common/tusb_fifo.h ****  *
  85:lib/tinyusb/src/common/tusb_fifo.h ****  *  - Double Overflowed i.e index is out of allowed range [0,2*depth)
  86:lib/tinyusb/src/common/tusb_fifo.h ****  *    This occurs when we continue to write after 1st overflowed to 2nd overflowed. e.g:
  87:lib/tinyusb/src/common/tusb_fifo.h ****  *      write(3), write(1), write(2)
  88:lib/tinyusb/src/common/tusb_fifo.h ****  *    This must be prevented since it will cause unrecoverable state, in above example
  89:lib/tinyusb/src/common/tusb_fifo.h ****  *    if not handled the fifo will be empty instead of continue-to-be full. Since we must not modif
  90:lib/tinyusb/src/common/tusb_fifo.h ****  *    read index in write() function, which cause race condition. We will re-position write index s
  91:lib/tinyusb/src/common/tusb_fifo.h ****  *    after data is written it is a full fifo i.e W = depth - R
  92:lib/tinyusb/src/common/tusb_fifo.h ****  *
  93:lib/tinyusb/src/common/tusb_fifo.h ****  *      re-position W = 1 before write(2)
  94:lib/tinyusb/src/common/tusb_fifo.h ****  *      Note: we should also move data from mem[3] to read index as well, but deliberately skipped 
  95:lib/tinyusb/src/common/tusb_fifo.h ****  *      since it is an expensive operation !!!
  96:lib/tinyusb/src/common/tusb_fifo.h ****  *                  |
  97:lib/tinyusb/src/common/tusb_fifo.h ****  *      -------------------------
  98:lib/tinyusb/src/common/tusb_fifo.h ****  *      | R | W | 2 | 3 | 4 | 5 |
