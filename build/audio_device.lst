 775:lib/tinyusb/src/class/audio/audio_device.c **** // Decoding according to 2.3.1.5 Audio Streams
 776:lib/tinyusb/src/class/audio/audio_device.c **** 
 777:lib/tinyusb/src/class/audio/audio_device.c **** // Helper function
 778:lib/tinyusb/src/class/audio/audio_device.c **** static inline void * audiod_interleaved_copy_bytes_fast_decode(uint16_t const nBytesPerSample, void
 779:lib/tinyusb/src/class/audio/audio_device.c **** {
 780:lib/tinyusb/src/class/audio/audio_device.c ****   // Due to one FIFO contains 2 channels, data always aligned to (nBytesPerSample * 2)
 781:lib/tinyusb/src/class/audio/audio_device.c ****   uint16_t * dst16 = dst;
 782:lib/tinyusb/src/class/audio/audio_device.c ****   uint16_t * src16 = src;
 783:lib/tinyusb/src/class/audio/audio_device.c ****   const uint16_t * dst_end16 = dst_end;
 784:lib/tinyusb/src/class/audio/audio_device.c ****   uint32_t * dst32 = dst;
 785:lib/tinyusb/src/class/audio/audio_device.c ****   uint32_t * src32 = src;
 786:lib/tinyusb/src/class/audio/audio_device.c ****   const uint32_t * dst_end32 = dst_end;
 787:lib/tinyusb/src/class/audio/audio_device.c **** 
 788:lib/tinyusb/src/class/audio/audio_device.c ****   if (nBytesPerSample == 1)
 789:lib/tinyusb/src/class/audio/audio_device.c ****   {
 790:lib/tinyusb/src/class/audio/audio_device.c ****     while(dst16 < dst_end16)
 791:lib/tinyusb/src/class/audio/audio_device.c ****     {
 792:lib/tinyusb/src/class/audio/audio_device.c ****       *dst16++ = *src16++;
 793:lib/tinyusb/src/class/audio/audio_device.c ****       src16 += n_ff_used - 1;
 794:lib/tinyusb/src/class/audio/audio_device.c ****     }
 795:lib/tinyusb/src/class/audio/audio_device.c ****     return src16;
 796:lib/tinyusb/src/class/audio/audio_device.c ****   }
 797:lib/tinyusb/src/class/audio/audio_device.c ****   else if (nBytesPerSample == 2)
 798:lib/tinyusb/src/class/audio/audio_device.c ****   {
 799:lib/tinyusb/src/class/audio/audio_device.c ****     while(dst32 < dst_end32)
 800:lib/tinyusb/src/class/audio/audio_device.c ****     {
 801:lib/tinyusb/src/class/audio/audio_device.c ****       *dst32++ = *src32++;
 802:lib/tinyusb/src/class/audio/audio_device.c ****       src32 += n_ff_used - 1;
 803:lib/tinyusb/src/class/audio/audio_device.c ****     }
 804:lib/tinyusb/src/class/audio/audio_device.c ****     return src32;
 805:lib/tinyusb/src/class/audio/audio_device.c ****   }
 806:lib/tinyusb/src/class/audio/audio_device.c ****   else if (nBytesPerSample == 3)
 807:lib/tinyusb/src/class/audio/audio_device.c ****   {
 808:lib/tinyusb/src/class/audio/audio_device.c ****     while(dst16 < dst_end16)
 809:lib/tinyusb/src/class/audio/audio_device.c ****     {
 810:lib/tinyusb/src/class/audio/audio_device.c ****       *dst16++ = *src16++;
 811:lib/tinyusb/src/class/audio/audio_device.c ****       *dst16++ = *src16++;
 812:lib/tinyusb/src/class/audio/audio_device.c ****       *dst16++ = *src16++;
 813:lib/tinyusb/src/class/audio/audio_device.c ****       src16 += 3 * (n_ff_used - 1);
 814:lib/tinyusb/src/class/audio/audio_device.c ****     }
 815:lib/tinyusb/src/class/audio/audio_device.c ****     return src16;
 816:lib/tinyusb/src/class/audio/audio_device.c ****   }
 817:lib/tinyusb/src/class/audio/audio_device.c ****   else // nBytesPerSample == 4
 818:lib/tinyusb/src/class/audio/audio_device.c ****   {
 819:lib/tinyusb/src/class/audio/audio_device.c ****     while(dst32 < dst_end32)
 820:lib/tinyusb/src/class/audio/audio_device.c ****     {
 821:lib/tinyusb/src/class/audio/audio_device.c ****       *dst32++ = *src32++;
 822:lib/tinyusb/src/class/audio/audio_device.c ****       *dst32++ = *src32++;
 823:lib/tinyusb/src/class/audio/audio_device.c ****       src32 += 2 * (n_ff_used - 1);
 824:lib/tinyusb/src/class/audio/audio_device.c ****     }
 825:lib/tinyusb/src/class/audio/audio_device.c ****     return src32;
 826:lib/tinyusb/src/class/audio/audio_device.c ****   }
 827:lib/tinyusb/src/class/audio/audio_device.c **** }
