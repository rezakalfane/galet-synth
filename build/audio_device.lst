2867:lib/tinyusb/src/class/audio/audio_device.c ****         ctrl_blackout = 0;
2868:lib/tinyusb/src/class/audio/audio_device.c ****       } else
2869:lib/tinyusb/src/class/audio/audio_device.c ****       {
