2859:lib/tinyusb/src/class/audio/audio_device.c ****       ctrl_blackout = 10;
2860:lib/tinyusb/src/class/audio/audio_device.c ****     } else
2861:lib/tinyusb/src/class/audio/audio_device.c ****     if (data_count > fifo_depth / 2 + slot_size && !ctrl_blackout)
2862:lib/tinyusb/src/class/audio/audio_device.c ****     {
