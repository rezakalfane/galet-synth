  38:src/serialtune.cpp **** // â”€â”€ Tuning state (the seam declared in engine.h) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
  39:src/serialtune.cpp **** Voice             g_live_voice = VOICE_LEAD;   // snapshotted from the active voice on `tune 1`
  40:src/serialtune.cpp **** volatile bool     g_live_tune  = false;
  41:src/serialtune.cpp **** volatile uint32_t g_live_rev   = 0;
  42:src/serialtune.cpp **** volatile bool     g_mon        = false;
  43:src/serialtune.cpp **** volatile bool     g_serial_quiet = false;
  44:src/serialtune.cpp **** 
  45:src/serialtune.cpp **** // Suppress autonomous serial when a host has gone away (g_serial_quiet) or while
  46:src/serialtune.cpp **** // tuning with the dashboard off. See g_serial_quiet in serialtune.h for why
  47:src/serialtune.cpp **** // printing to a dead port hangs the synth.
  48:src/serialtune.cpp **** bool serial_display_muted() { return g_serial_quiet || (g_live_tune && !g_mon); }
  49:src/serialtune.cpp **** 
