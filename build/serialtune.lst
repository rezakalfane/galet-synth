 205:src/serialtune.cpp **** static void handle_command(char *line) {
 206:src/serialtune.cpp ****     char *cmd = strtok(line, " \t");
 207:src/serialtune.cpp ****     if(!cmd) return;
 208:src/serialtune.cpp **** 
 209:src/serialtune.cpp ****     if(!strcmp(cmd, "tune")) {
 210:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 211:src/serialtune.cpp ****         if(a && to_i(a)) { snapshot_active(); g_live_tune = true;
 212:src/serialtune.cpp ****                            hw.PrintLine("ok tune=1 voice=%s", g_live_voice.name); }
 213:src/serialtune.cpp ****         else             { g_live_tune = false; hw.PrintLine("ok tune=0"); }
 214:src/serialtune.cpp ****         return;
 215:src/serialtune.cpp ****     }
 216:src/serialtune.cpp ****     if(!strcmp(cmd, "set")) {
 217:src/serialtune.cpp ****         char *f = strtok(NULL, " \t");
 218:src/serialtune.cpp ****         if(!f) { hw.PrintLine("err set <field> <value>"); return; }
 219:src/serialtune.cpp ****         if(!strcmp(f, "name")) {
 220:src/serialtune.cpp ****             // Name is the rest of the line (may contain spaces, e.g. "SH-101 min").
 221:src/serialtune.cpp ****             char *rest = strtok(NULL, "");
 222:src/serialtune.cpp ****             while(rest && (*rest == ' ' || *rest == '\t')) rest++;
 223:src/serialtune.cpp ****             strncpy(g_live_name, rest ? rest : "", VOICE_NAME_MAX - 1);
 224:src/serialtune.cpp ****             g_live_name[VOICE_NAME_MAX - 1] = 0;
 225:src/serialtune.cpp ****             g_live_voice.name = g_live_name;
 226:src/serialtune.cpp ****             hw.PrintLine("ok name=%s", g_live_name);
 227:src/serialtune.cpp ****             return;
 228:src/serialtune.cpp ****         }
 229:src/serialtune.cpp ****         char *v = strtok(NULL, " \t");
 230:src/serialtune.cpp ****         if(!v) { hw.PrintLine("err set <field> <value>"); return; }
 231:src/serialtune.cpp ****         if(set_param(f, v)) { g_live_rev++; hw.PrintLine("ok %s=%s", f, v); }
 232:src/serialtune.cpp ****         else hw.PrintLine("err unknown field '%s'", f);
 233:src/serialtune.cpp ****         return;
 234:src/serialtune.cpp ****     }
 235:src/serialtune.cpp ****     if(!strcmp(cmd, "select")) {
ARM GAS  /tmp/claude-502/ccqR7WfB.s 			page 21


 236:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 237:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 238:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 239:src/serialtune.cpp ****             g_voice_idx   = n;
 240:src/serialtune.cpp ****             g_active_voice = (n == MULTI_IDX) ? MULTI_ZONES[0] : n;
 241:src/serialtune.cpp ****             if(g_live_tune) snapshot_active();   // tune the newly selected voice
 242:src/serialtune.cpp ****             hw.PrintLine("ok select=%d %s", n, g_bank[n].name);
 243:src/serialtune.cpp ****         } else hw.PrintLine("err select 0..%d", NUM_VOICES - 1);
 244:src/serialtune.cpp ****         return;
 245:src/serialtune.cpp ****     }
 246:src/serialtune.cpp ****     if(!strcmp(cmd, "dump"))  { dump_voice(); return; }
 247:src/serialtune.cpp ****     if(!strcmp(cmd, "names")) {
 248:src/serialtune.cpp ****         // List every bank slot's (possibly edited) name so the host can label its
 249:src/serialtune.cpp ****         // voice picker from flash, not just the factory defaults.
 250:src/serialtune.cpp ****         for(int i = 0; i < NUM_VOICES; i++) hw.PrintLine("name %d %s", i, g_bank[i].name);
 251:src/serialtune.cpp ****         hw.PrintLine("end");
 252:src/serialtune.cpp ****         return;
 253:src/serialtune.cpp ****     }
 254:src/serialtune.cpp ****     if(!strcmp(cmd, "mon"))   { char *a = strtok(NULL, " \t"); g_mon = (a && to_i(a));
 255:src/serialtune.cpp ****                                 hw.PrintLine("ok mon=%d", g_mon ? 1 : 0); return; }
 256:src/serialtune.cpp ****     if(!strcmp(cmd, "save")) {
 257:src/serialtune.cpp ****         // Commit the live voice (incl. name) into its bank slot, then persist the
 258:src/serialtune.cpp ****         // whole bank to flash â€” survives power-off.
 259:src/serialtune.cpp ****         int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 260:src/serialtune.cpp ****         bank_set(vi, g_live_voice, g_live_name);
 261:src/serialtune.cpp ****         persist_save_bank();
 262:src/serialtune.cpp ****         hw.PrintLine("ok saved %d %s", vi, g_bank[vi].name);
 263:src/serialtune.cpp ****         return;
 264:src/serialtune.cpp ****     }
 265:src/serialtune.cpp ****     if(!strcmp(cmd, "factory")) {
 266:src/serialtune.cpp ****         // `factory`     â†’ revert the active voice to its source default
 267:src/serialtune.cpp ****         // `factory all` â†’ revert the whole bank
 268:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 269:src/serialtune.cpp ****         if(a && !strcmp(a, "all")) {
 270:src/serialtune.cpp ****             bank_revert_all();
 271:src/serialtune.cpp ****         } else {
 272:src/serialtune.cpp ****             int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 273:src/serialtune.cpp ****             bank_revert_voice(vi);
 274:src/serialtune.cpp ****         }
 275:src/serialtune.cpp ****         persist_save_bank();
 276:src/serialtune.cpp ****         if(g_live_tune) snapshot_active();   // reload the live copy from the reverted bank
 277:src/serialtune.cpp ****         hw.PrintLine("ok factory %s", (a && !strcmp(a, "all")) ? "all" : g_bank[g_active_voice].nam
 278:src/serialtune.cpp ****         return;
 279:src/serialtune.cpp ****     }
 280:src/serialtune.cpp ****     if(!strcmp(cmd, "help")) {
 281:src/serialtune.cpp ****         hw.PrintLine("cmds: tune 0|1 | set <field> <val> | set name <text> | select <n>");
 282:src/serialtune.cpp ****         hw.PrintLine("      dump | save | factory [all] | mon 0|1");
 283:src/serialtune.cpp ****         for(int i = 0; i < NFIELDS; i++) hw.PrintLine("  %s", FIELDS[i].name);
 284:src/serialtune.cpp ****         hw.PrintLine("  name scale(chromatic|major|minor) reverb_decay reverb_level delay_time_ms d
 285:src/serialtune.cpp ****         return;
 286:src/serialtune.cpp ****     }
 287:src/serialtune.cpp ****     hw.PrintLine("err unknown cmd '%s'", cmd);
 288:src/serialtune.cpp **** }
