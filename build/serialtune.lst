  67:src/serialtune.cpp **** // â”€â”€ Float key=value print (no stdio: the logger has no %f, and pulling in
  68:src/serialtune.cpp **** // snprintf adds ~16 KB to internal flash). Decompose to integer parts and use
  69:src/serialtune.cpp **** // only the logger-supported %c/%d/%04d specifiers. 4 decimals, rounded. â”€â”€â”€â”€â”€â”€â”€
  70:src/serialtune.cpp **** static void print_kv_f(const char *key, float v) {
  71:src/serialtune.cpp ****     char sign = v < 0.0f ? '-' : ' ';
  72:src/serialtune.cpp ****     if(v < 0.0f) v = -v;
  73:src/serialtune.cpp ****     int ip = (int)v;
  74:src/serialtune.cpp ****     int fp = (int)((v - (float)ip) * 10000.0f + 0.5f);
  75:src/serialtune.cpp ****     if(fp >= 10000) { ip++; fp -= 10000; }
  76:src/serialtune.cpp ****     hw.PrintLine("%s=%c%d.%04d", key, sign, ip, fp);
  77:src/serialtune.cpp **** }
  78:src/serialtune.cpp **** 
  79:src/serialtune.cpp **** // â”€â”€ Field table (name â†’ offset in Voice) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
