  46:src/serialtune.cpp **** // â”€â”€ USB CDC receive ring buffer â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â
  47:src/serialtune.cpp **** // The receive callback runs in USB interrupt context, so it only copies bytes
  48:src/serialtune.cpp **** // into this ring; serial_tune_poll() (control-loop thread) parses whole lines.
  49:src/serialtune.cpp **** static constexpr int     RX_SZ = 512;
