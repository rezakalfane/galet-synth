  95:src/serialtune.cpp **** static const char *wave_name(Waveform w) {
  96:src/serialtune.cpp ****     switch(w) {
  97:src/serialtune.cpp ****         case WAVE_SINE:   return "sine";
  98:src/serialtune.cpp ****         case WAVE_SQUARE: return "square";
  99:src/serialtune.cpp ****         case WAVE_SAW:    return "saw";
 100:src/serialtune.cpp ****         default:          return "tri";
 101:src/serialtune.cpp ****     }
 102:src/serialtune.cpp **** }
 103:src/serialtune.cpp **** static bool parse_wave(const char *s, Waveform &w) {
 104:src/serialtune.cpp ****     if(!strcmp(s, "tri"))         w = WAVE_TRI;
 105:src/serialtune.cpp ****     else if(!strcmp(s, "sine"))   w = WAVE_SINE;
 106:src/serialtune.cpp ****     else if(!strcmp(s, "square")) w = WAVE_SQUARE;
 107:src/serialtune.cpp ****     else if(!strcmp(s, "saw"))    w = WAVE_SAW;
 108:src/serialtune.cpp ****     else return false;
 109:src/serialtune.cpp ****     return true;
 110:src/serialtune.cpp **** }
 111:src/serialtune.cpp **** static const char *scale_name(const int8_t *s) {
 112:src/serialtune.cpp ****     if(s == SCALE_CHROMATIC) return "chromatic";
 113:src/serialtune.cpp ****     if(s == SCALE_MAJOR)     return "major";
 114:src/serialtune.cpp ****     if(s == SCALE_MINOR)     return "minor";
 115:src/serialtune.cpp ****     return s ? "custom" : "none";
 116:src/serialtune.cpp **** }
