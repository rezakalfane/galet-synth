 133:src/serialtune.cpp **** // Apply `set <field> <value>` to the live voice (or a global). Returns false for
 134:src/serialtune.cpp **** // an unknown field or a bad value.
 135:src/serialtune.cpp **** static bool set_param(const char *f, const char *v) {
 136:src/serialtune.cpp ****     if(!strcmp(f, "scale")) {
 137:src/serialtune.cpp ****         if(!strcmp(v, "chromatic")) {
 138:src/serialtune.cpp ****             g_live_voice.scale = SCALE_CHROMATIC;
 139:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_CHROMATIC) / sizeof(SCALE_CHROMATIC[0]));
 140:src/serialtune.cpp ****         } else if(!strcmp(v, "major")) {
 141:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MAJOR;
 142:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0]));
ARM GAS  /tmp/claude-502/ccqR7WfB.s 			page 12


 143:src/serialtune.cpp ****         } else if(!strcmp(v, "minor")) {
 144:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MINOR;
 145:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0]));
 146:src/serialtune.cpp ****         } else return false;
 147:src/serialtune.cpp ****         return true;
 148:src/serialtune.cpp ****     }
 149:src/serialtune.cpp ****     if(set_global(f, to_f(v))) return true;
 150:src/serialtune.cpp **** 
 151:src/serialtune.cpp ****     char *base = (char *)&g_live_voice;
 152:src/serialtune.cpp ****     for(int i = 0; i < NFIELDS; i++) {
 153:src/serialtune.cpp ****         if(strcmp(FIELDS[i].name, f)) continue;
 154:src/serialtune.cpp ****         void *p = base + FIELDS[i].off;
 155:src/serialtune.cpp ****         switch(FIELDS[i].type) {
 156:src/serialtune.cpp ****             case FT_F: *(float *)p = to_f(v); break;
 157:src/serialtune.cpp ****             case FT_I: *(int *)p   = to_i(v);        break;
