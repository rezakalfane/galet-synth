 211:src/serialtune.cpp **** static void handle_command(char *line) {
 212:src/serialtune.cpp ****     char *cmd = strtok(line, " \t");
 213:src/serialtune.cpp ****     if(!cmd) return;
 214:src/serialtune.cpp **** 
 215:src/serialtune.cpp ****     if(!strcmp(cmd, "tune")) {
 216:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 217:src/serialtune.cpp ****         if(a && to_i(a)) { g_serial_quiet = false;   // a host is here
 218:src/serialtune.cpp ****                            snapshot_active(); g_live_tune = true;
 219:src/serialtune.cpp ****                            hw.PrintLine("ok tune=1 voice=%s", g_live_voice.name); }
 220:src/serialtune.cpp ****         else             { g_live_tune = false; hw.PrintLine("ok tune=0"); }
 221:src/serialtune.cpp ****         return;
 222:src/serialtune.cpp ****     }
 223:src/serialtune.cpp ****     if(!strcmp(cmd, "bye")) {
 224:src/serialtune.cpp ****         // Host disconnecting: leave tune mode (so the synth plays the bank + the
 225:src/serialtune.cpp ****         // idle chase resumes) and go silent so no autonomous print blocks on the
ARM GAS  /tmp/claude-502/ccavRpV6.s 			page 21


 226:src/serialtune.cpp ****         // now-dead USB port. Cleared again by the next `tune 1`.
 227:src/serialtune.cpp ****         g_live_tune = false;
 228:src/serialtune.cpp ****         hw.PrintLine("ok bye");      // last line out while the host is still here
 229:src/serialtune.cpp ****         g_serial_quiet = true;
 230:src/serialtune.cpp ****         return;
 231:src/serialtune.cpp ****     }
 232:src/serialtune.cpp ****     if(!strcmp(cmd, "set")) {
 233:src/serialtune.cpp ****         char *f = strtok(NULL, " \t");
 234:src/serialtune.cpp ****         if(!f) { hw.PrintLine("err set <field> <value>"); return; }
 235:src/serialtune.cpp ****         if(!strcmp(f, "name")) {
 236:src/serialtune.cpp ****             // Name is the rest of the line (may contain spaces, e.g. "SH-101 min").
 237:src/serialtune.cpp ****             char *rest = strtok(NULL, "");
 238:src/serialtune.cpp ****             while(rest && (*rest == ' ' || *rest == '\t')) rest++;
 239:src/serialtune.cpp ****             strncpy(g_live_name, rest ? rest : "", VOICE_NAME_MAX - 1);
 240:src/serialtune.cpp ****             g_live_name[VOICE_NAME_MAX - 1] = 0;
 241:src/serialtune.cpp ****             g_live_voice.name = g_live_name;
 242:src/serialtune.cpp ****             hw.PrintLine("ok name=%s", g_live_name);
 243:src/serialtune.cpp ****             return;
 244:src/serialtune.cpp ****         }
 245:src/serialtune.cpp ****         char *v = strtok(NULL, " \t");
 246:src/serialtune.cpp ****         if(!v) { hw.PrintLine("err set <field> <value>"); return; }
 247:src/serialtune.cpp ****         if(set_param(f, v)) { g_live_rev++; hw.PrintLine("ok %s=%s", f, v); }
 248:src/serialtune.cpp ****         else hw.PrintLine("err unknown field '%s'", f);
 249:src/serialtune.cpp ****         return;
 250:src/serialtune.cpp ****     }
 251:src/serialtune.cpp ****     if(!strcmp(cmd, "select")) {
 252:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 253:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 254:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 255:src/serialtune.cpp ****             g_voice_idx   = n;
 256:src/serialtune.cpp ****             g_active_voice = (n == MULTI_IDX) ? MULTI_ZONES[0] : n;
 257:src/serialtune.cpp ****             if(g_live_tune) snapshot_active();   // tune the newly selected voice
 258:src/serialtune.cpp ****             hw.PrintLine("ok select=%d %s", n, g_bank[n].name);
 259:src/serialtune.cpp ****         } else hw.PrintLine("err select 0..%d", NUM_VOICES - 1);
 260:src/serialtune.cpp ****         return;
 261:src/serialtune.cpp ****     }
 262:src/serialtune.cpp ****     if(!strcmp(cmd, "dump"))  { dump_voice(); return; }
 263:src/serialtune.cpp ****     if(!strcmp(cmd, "names")) {
 264:src/serialtune.cpp ****         // List every bank slot's (possibly edited) name so the host can label its
 265:src/serialtune.cpp ****         // voice picker from flash, not just the factory defaults.
 266:src/serialtune.cpp ****         for(int i = 0; i < NUM_VOICES; i++) hw.PrintLine("name %d %s", i, g_bank[i].name);
 267:src/serialtune.cpp ****         hw.PrintLine("end");
 268:src/serialtune.cpp ****         return;
 269:src/serialtune.cpp ****     }
 270:src/serialtune.cpp ****     if(!strcmp(cmd, "mon"))   { char *a = strtok(NULL, " \t"); g_mon = (a && to_i(a));
 271:src/serialtune.cpp ****                                 hw.PrintLine("ok mon=%d", g_mon ? 1 : 0); return; }
 272:src/serialtune.cpp ****     if(!strcmp(cmd, "save")) {
 273:src/serialtune.cpp ****         // Commit the live voice (incl. name) into its bank slot, then persist the
 274:src/serialtune.cpp ****         // whole bank to flash â€” survives power-off.
 275:src/serialtune.cpp ****         int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 276:src/serialtune.cpp ****         bank_set(vi, g_live_voice, g_live_name);
 277:src/serialtune.cpp ****         persist_save_bank();
 278:src/serialtune.cpp ****         hw.PrintLine("ok saved %d %s", vi, g_bank[vi].name);
 279:src/serialtune.cpp ****         return;
 280:src/serialtune.cpp ****     }
 281:src/serialtune.cpp ****     if(!strcmp(cmd, "copy")) {
 282:src/serialtune.cpp ****         // `copy <n> [name]` â€” duplicate the current live voice into another slot
ARM GAS  /tmp/claude-502/ccavRpV6.s 			page 22


 283:src/serialtune.cpp ****         // and persist, without changing the active voice / interrupting audio.
 284:src/serialtune.cpp ****         // An optional name (rest of the line, spaces ok) names the copy; omitted
 285:src/serialtune.cpp ****         // â†’ keep the live voice's name.
 286:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 287:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 288:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 289:src/serialtune.cpp ****             char *nm = strtok(NULL, "");                 // rest of line = optional name
 290:src/serialtune.cpp ****             while(nm && (*nm == ' ' || *nm == '\t')) nm++;
 291:src/serialtune.cpp ****             bank_set(n, g_live_voice, (nm && *nm) ? nm : g_live_name);
 292:src/serialtune.cpp ****             persist_save_bank();
 293:src/serialtune.cpp ****             hw.PrintLine("ok copy=%d %s", n, g_bank[n].name);
 294:src/serialtune.cpp ****         } else hw.PrintLine("err copy 0..%d", NUM_VOICES - 1);
 295:src/serialtune.cpp ****         return;
 296:src/serialtune.cpp ****     }
 297:src/serialtune.cpp ****     if(!strcmp(cmd, "factory")) {
 298:src/serialtune.cpp ****         // `factory`     â†’ revert the active voice to its source default
 299:src/serialtune.cpp ****         // `factory all` â†’ revert the whole bank
 300:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 301:src/serialtune.cpp ****         if(a && !strcmp(a, "all")) {
 302:src/serialtune.cpp ****             bank_revert_all();
 303:src/serialtune.cpp ****         } else {
 304:src/serialtune.cpp ****             int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 305:src/serialtune.cpp ****             bank_revert_voice(vi);
 306:src/serialtune.cpp ****         }
 307:src/serialtune.cpp ****         persist_save_bank();
 308:src/serialtune.cpp ****         if(g_live_tune) snapshot_active();   // reload the live copy from the reverted bank
 309:src/serialtune.cpp ****         hw.PrintLine("ok factory %s", (a && !strcmp(a, "all")) ? "all" : g_bank[g_active_voice].nam
 310:src/serialtune.cpp ****         return;
 311:src/serialtune.cpp ****     }
 312:src/serialtune.cpp ****     if(!strcmp(cmd, "help")) {
 313:src/serialtune.cpp ****         hw.PrintLine("cmds: tune 0|1 | set <field> <val> | set name <text> | select <n>");
 314:src/serialtune.cpp ****         hw.PrintLine("      dump | save | copy <n> [name] | factory [all] | mon 0|1 | bye");
 315:src/serialtune.cpp ****         for(int i = 0; i < NFIELDS; i++) hw.PrintLine("  %s", FIELDS[i].name);
 316:src/serialtune.cpp ****         hw.PrintLine("  name scale(chromatic|major|minor) reverb_decay reverb_level delay_time_ms d
 317:src/serialtune.cpp ****         return;
 318:src/serialtune.cpp ****     }
 319:src/serialtune.cpp ****     hw.PrintLine("err unknown cmd '%s'", cmd);
 320:src/serialtune.cpp **** }
