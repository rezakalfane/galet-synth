 123:src/serialtune.cpp **** // Global (non-Voice) effect params, settable by name.
 124:src/serialtune.cpp **** static bool set_global(const char *f, float val) {
 125:src/serialtune.cpp ****     if(!strcmp(f, "reverb_decay"))   { g_reverb_decay   = val; return true; }
 126:src/serialtune.cpp ****     if(!strcmp(f, "reverb_level"))   { g_reverb_level   = val; return true; }
 127:src/serialtune.cpp ****     if(!strcmp(f, "delay_time_ms"))  { g_delay_time_ms  = val; return true; }
 128:src/serialtune.cpp ****     if(!strcmp(f, "delay_feedback")) { g_delay_feedback = val; return true; }
 129:src/serialtune.cpp ****     if(!strcmp(f, "delay_level"))    { g_delay_level    = val; return true; }
 130:src/serialtune.cpp ****     return false;
 131:src/serialtune.cpp **** }
