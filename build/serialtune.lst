 164:src/serialtune.cpp **** static void dump_voice() {
 165:src/serialtune.cpp ****     usb_log("dump name=%s", g_live_voice.name);
 166:src/serialtune.cpp ****     usb_log("idx=%d", g_voice_idx);   // bank slot, so the host syncs by index (rename-proof)
 167:src/serialtune.cpp ****     usb_log("boot=%d", g_boot_voice); // persisted power-on voice â†’ GUI marks the default
 168:src/serialtune.cpp ****     const char *base = (const char *)&g_live_voice;
 169:src/serialtune.cpp ****     for(int i = 0; i < NFIELDS; i++) {
 170:src/serialtune.cpp ****         const void *p = base + FIELDS[i].off;
 171:src/serialtune.cpp ****         switch(FIELDS[i].type) {
 172:src/serialtune.cpp ****             case FT_F: print_kv_f(FIELDS[i].name, *(const float *)p); break;
 173:src/serialtune.cpp ****             case FT_I: usb_log("%s=%d", FIELDS[i].name, *(const int *)p); break;
 174:src/serialtune.cpp ****             case FT_B: usb_log("%s=%d", FIELDS[i].name, *(const bool *)p ? 1 : 0); break;
 175:src/serialtune.cpp ****             case FT_W: usb_log("%s=%s", FIELDS[i].name, wave_name(*(const Waveform *)p)); break;
 176:src/serialtune.cpp ****         }
 177:src/serialtune.cpp ****     }
 178:src/serialtune.cpp ****     usb_log("scale=%s", scale_name(g_live_voice.scale));
 179:src/serialtune.cpp ****     print_kv_f("reverb_decay",   g_reverb_decay);
 180:src/serialtune.cpp ****     print_kv_f("reverb_level",   g_reverb_level);
 181:src/serialtune.cpp ****     print_kv_f("delay_time_ms",  g_delay_time_ms);
 182:src/serialtune.cpp ****     print_kv_f("delay_feedback", g_delay_feedback);
 183:src/serialtune.cpp ****     print_kv_f("delay_level",    g_delay_level);
 184:src/serialtune.cpp ****     usb_log("end");
 185:src/serialtune.cpp **** }
