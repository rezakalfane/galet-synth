 177:src/serialtune.cpp ****             case FT_F: print_kv_f(FIELDS[i].name, *(const float *)p); break;
 178:src/serialtune.cpp ****             case FT_I: hw.PrintLine("%s=%d", FIELDS[i].name, *(const int *)p); break;
 179:src/serialtune.cpp ****             case FT_B: hw.PrintLine("%s=%d", FIELDS[i].name, *(const bool *)p ? 1 : 0); break;
 180:src/serialtune.cpp ****             case FT_W: hw.PrintLine("%s=%s", FIELDS[i].name, wave_name(*(const Waveform *)p)); brea
 181:src/serialtune.cpp ****         }
