 145:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MAJOR;
 146:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0]));
 147:src/serialtune.cpp ****         } else if(!strcmp(v, "minor")) {
 148:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MINOR;
 149:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0]));
 150:src/serialtune.cpp ****         } else return false;
