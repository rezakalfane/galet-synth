 129:src/serialtune.cpp **** // Apply `set <field> <value>` to the live voice (or a global). Returns false for
 130:src/serialtune.cpp **** // an unknown field or a bad value.
 131:src/serialtune.cpp **** static bool set_param(const char *f, const char *v) {
 132:src/serialtune.cpp ****     if(!strcmp(f, "scale")) {
 133:src/serialtune.cpp ****         if(!strcmp(v, "chromatic")) {
ARM GAS  /tmp/claude-502/cciP8p2t.s 			page 17


 134:src/serialtune.cpp ****             g_live_voice.scale = SCALE_CHROMATIC;
 135:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_CHROMATIC) / sizeof(SCALE_CHROMATIC[0]));
 136:src/serialtune.cpp ****         } else if(!strcmp(v, "major")) {
 137:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MAJOR;
 138:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0]));
 139:src/serialtune.cpp ****         } else if(!strcmp(v, "minor")) {
 140:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MINOR;
 141:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0]));
 142:src/serialtune.cpp ****         } else return false;
 143:src/serialtune.cpp ****         return true;
 144:src/serialtune.cpp ****     }
 145:src/serialtune.cpp ****     if(set_global(f, to_f(v))) return true;
 146:src/serialtune.cpp **** 
 147:src/serialtune.cpp ****     char *base = (char *)&g_live_voice;
 148:src/serialtune.cpp ****     for(int i = 0; i < NFIELDS; i++) {
 149:src/serialtune.cpp ****         if(strcmp(FIELDS[i].name, f)) continue;
 150:src/serialtune.cpp ****         void *p = base + FIELDS[i].off;
 151:src/serialtune.cpp ****         switch(FIELDS[i].type) {
 152:src/serialtune.cpp ****             case FT_F: *(float *)p = to_f(v); break;
 153:src/serialtune.cpp ****             case FT_I: *(int *)p   = to_i(v);        break;
 154:src/serialtune.cpp ****             case FT_B: *(bool *)p  = (to_i(v) != 0); break;
 155:src/serialtune.cpp ****             case FT_W: { Waveform w; if(!parse_wave(v, w)) return false; *(Waveform *)p = w; } brea
 156:src/serialtune.cpp ****         }
 157:src/serialtune.cpp ****         // freq_low / freq_high drive the exponential pitch map â†’ keep its
 158:src/serialtune.cpp ****         // precomputed log ratio in sync.
 159:src/serialtune.cpp ****         if(!strcmp(f, "freq_low") || !strcmp(f, "freq_high"))
 160:src/serialtune.cpp ****             g_live_voice.log_freq_ratio = logf(g_live_voice.freq_high / g_live_voice.freq_low);
 161:src/serialtune.cpp ****         return true;
 162:src/serialtune.cpp ****     }
 163:src/serialtune.cpp ****     return false;
 164:src/serialtune.cpp **** }
