  39:src/serialtune.cpp **** // â”€â”€ Tuning state (the seam declared in engine.h) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
  40:src/serialtune.cpp **** Voice             g_live_voice = VOICE_LEAD;   // snapshotted from the active voice on `tune 1`
  41:src/serialtune.cpp **** volatile bool     g_live_tune  = false;
  42:src/serialtune.cpp **** volatile uint32_t g_live_rev   = 0;
