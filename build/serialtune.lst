 201:src/serialtune.cpp **** static void handle_command(char *line) {
 202:src/serialtune.cpp ****     char *cmd = strtok(line, " \t");
 203:src/serialtune.cpp ****     if(!cmd) return;
 204:src/serialtune.cpp **** 
 205:src/serialtune.cpp ****     if(!strcmp(cmd, "tune")) {
 206:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 207:src/serialtune.cpp ****         if(a && to_i(a)) { g_serial_quiet = false;   // a host is here
 208:src/serialtune.cpp ****                            snapshot_active(); g_live_tune = true;
 209:src/serialtune.cpp ****                            usb_log("ok tune=1 voice=%s", g_live_voice.name); }
 210:src/serialtune.cpp ****         else             { g_live_tune = false; usb_log("ok tune=0"); }
 211:src/serialtune.cpp ****         return;
 212:src/serialtune.cpp ****     }
 213:src/serialtune.cpp ****     if(!strcmp(cmd, "bye")) {
 214:src/serialtune.cpp ****         // Host disconnecting: leave tune mode (so the synth plays the bank + the
 215:src/serialtune.cpp ****         // idle chase resumes) and go silent so no autonomous print blocks on the
 216:src/serialtune.cpp ****         // now-dead USB port. Cleared again by the next `tune 1`.
ARM GAS  /tmp/claude-502/ccQdItoo.s 			page 16


 217:src/serialtune.cpp ****         g_live_tune = false;
 218:src/serialtune.cpp ****         usb_log("ok bye");      // last line out while the host is still here
 219:src/serialtune.cpp ****         g_serial_quiet = true;
 220:src/serialtune.cpp ****         return;
 221:src/serialtune.cpp ****     }
 222:src/serialtune.cpp ****     if(!strcmp(cmd, "set")) {
 223:src/serialtune.cpp ****         char *f = strtok(NULL, " \t");
 224:src/serialtune.cpp ****         if(!f) { usb_log("err set <field> <value>"); return; }
 225:src/serialtune.cpp ****         if(!strcmp(f, "name")) {
 226:src/serialtune.cpp ****             // Name is the rest of the line (may contain spaces, e.g. "SH-101 min").
 227:src/serialtune.cpp ****             char *rest = strtok(NULL, "");
 228:src/serialtune.cpp ****             while(rest && (*rest == ' ' || *rest == '\t')) rest++;
 229:src/serialtune.cpp ****             strncpy(g_live_name, rest ? rest : "", VOICE_NAME_MAX - 1);
 230:src/serialtune.cpp ****             g_live_name[VOICE_NAME_MAX - 1] = 0;
 231:src/serialtune.cpp ****             g_live_voice.name = g_live_name;
 232:src/serialtune.cpp ****             usb_log("ok name=%s", g_live_name);
 233:src/serialtune.cpp ****             return;
 234:src/serialtune.cpp ****         }
 235:src/serialtune.cpp ****         char *v = strtok(NULL, " \t");
 236:src/serialtune.cpp ****         if(!v) { usb_log("err set <field> <value>"); return; }
 237:src/serialtune.cpp ****         if(set_param(f, v)) { g_live_rev++; usb_log("ok %s=%s", f, v); }
 238:src/serialtune.cpp ****         else usb_log("err unknown field '%s'", f);
 239:src/serialtune.cpp ****         return;
 240:src/serialtune.cpp ****     }
 241:src/serialtune.cpp ****     if(!strcmp(cmd, "select")) {
 242:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 243:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 244:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 245:src/serialtune.cpp ****             g_voice_idx   = n;
 246:src/serialtune.cpp ****             g_active_voice = (n == MULTI_IDX) ? MULTI_ZONES[0] : n;
 247:src/serialtune.cpp ****             if(g_live_tune) snapshot_active();   // tune the newly selected voice
 248:src/serialtune.cpp ****             usb_log("ok select=%d %s", n, g_bank[n].name);
 249:src/serialtune.cpp ****         } else usb_log("err select 0..%d", NUM_VOICES - 1);
 250:src/serialtune.cpp ****         return;
 251:src/serialtune.cpp ****     }
 252:src/serialtune.cpp ****     if(!strcmp(cmd, "dump"))  { dump_voice(); return; }
 253:src/serialtune.cpp ****     if(!strcmp(cmd, "names")) {
 254:src/serialtune.cpp ****         // List every bank slot's (possibly edited) name so the host can label its
 255:src/serialtune.cpp ****         // voice picker from flash, not just the factory defaults.
 256:src/serialtune.cpp ****         for(int i = 0; i < NUM_VOICES; i++) usb_log("name %d %s", i, g_bank[i].name);
 257:src/serialtune.cpp ****         usb_log("end");
 258:src/serialtune.cpp ****         return;
 259:src/serialtune.cpp ****     }
 260:src/serialtune.cpp ****     if(!strcmp(cmd, "mon"))   { char *a = strtok(NULL, " \t"); g_mon = (a && to_i(a));
 261:src/serialtune.cpp ****                                 usb_log("ok mon=%d", g_mon ? 1 : 0); return; }
 262:src/serialtune.cpp ****     if(!strcmp(cmd, "save")) {
 263:src/serialtune.cpp ****         // Commit the live voice (incl. name) into its bank slot, then persist the
 264:src/serialtune.cpp ****         // whole bank to flash â€” survives power-off.
 265:src/serialtune.cpp ****         int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 266:src/serialtune.cpp ****         bank_set(vi, g_live_voice, g_live_name);
 267:src/serialtune.cpp ****         persist_save_bank();
 268:src/serialtune.cpp ****         usb_log("ok saved %d %s", vi, g_bank[vi].name);
 269:src/serialtune.cpp ****         return;
 270:src/serialtune.cpp ****     }
 271:src/serialtune.cpp ****     if(!strcmp(cmd, "copy")) {
 272:src/serialtune.cpp ****         // `copy <n> [name]` â€” duplicate the current live voice into another slot
 273:src/serialtune.cpp ****         // and persist, without changing the active voice / interrupting audio.
ARM GAS  /tmp/claude-502/ccQdItoo.s 			page 17


 274:src/serialtune.cpp ****         // An optional name (rest of the line, spaces ok) names the copy; omitted
 275:src/serialtune.cpp ****         // â†’ keep the live voice's name.
 276:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 277:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 278:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 279:src/serialtune.cpp ****             char *nm = strtok(NULL, "");                 // rest of line = optional name
 280:src/serialtune.cpp ****             while(nm && (*nm == ' ' || *nm == '\t')) nm++;
 281:src/serialtune.cpp ****             bank_set(n, g_live_voice, (nm && *nm) ? nm : g_live_name);
 282:src/serialtune.cpp ****             persist_save_bank();
 283:src/serialtune.cpp ****             usb_log("ok copy=%d %s", n, g_bank[n].name);
 284:src/serialtune.cpp ****         } else usb_log("err copy 0..%d", NUM_VOICES - 1);
 285:src/serialtune.cpp ****         return;
 286:src/serialtune.cpp ****     }
 287:src/serialtune.cpp ****     if(!strcmp(cmd, "astat")) {
 288:src/serialtune.cpp ****         // USB-audio capture diagnostics: ring fill (frames), starved/overrun counts,
 289:src/serialtune.cpp ****         // pre-load calls, streaming flag.
 290:src/serialtune.cpp ****         extern volatile uint32_t g_aud_over, g_aud_under, g_aud_calls, g_aud_fill;
 291:src/serialtune.cpp ****         extern volatile float    g_cpu_avg, g_cpu_max;
 292:src/serialtune.cpp ****         usb_log("astat streaming=%d fill=%lu calls=%lu under=%lu over=%lu cpu=%d%% max=%d%%",
 293:src/serialtune.cpp ****                 usb_audio_is_streaming(), (unsigned long)g_aud_fill,
 294:src/serialtune.cpp ****                 (unsigned long)g_aud_calls, (unsigned long)g_aud_under, (unsigned long)g_aud_over,
 295:src/serialtune.cpp ****                 (int)(g_cpu_avg + 0.5f), (int)(g_cpu_max + 0.5f));
 296:src/serialtune.cpp ****         return;
 297:src/serialtune.cpp ****     }
 298:src/serialtune.cpp ****     if(!strcmp(cmd, "bootvoice")) {
 299:src/serialtune.cpp ****         // Persist the CURRENT selection as the power-on voice, without committing
 300:src/serialtune.cpp ****         // any live edits to the bank (unlike `save`). Just writes g_voice_idx (+ the
 301:src/serialtune.cpp ****         // already-committed bank) to flash. The GUI's "Set as default" button.
 302:src/serialtune.cpp ****         persist_save_bank();
 303:src/serialtune.cpp ****         int vi = (g_voice_idx < 0 || g_voice_idx >= NUM_VOICES) ? 0 : g_voice_idx;
 304:src/serialtune.cpp ****         usb_log("ok bootvoice=%d %s", g_voice_idx, g_bank[vi].name);
 305:src/serialtune.cpp ****         return;
 306:src/serialtune.cpp ****     }
 307:src/serialtune.cpp ****     if(!strcmp(cmd, "factory")) {
 308:src/serialtune.cpp ****         // `factory`     â†’ revert the active voice to its source default
 309:src/serialtune.cpp ****         // `factory all` â†’ revert the whole bank
 310:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 311:src/serialtune.cpp ****         if(a && !strcmp(a, "all")) {
 312:src/serialtune.cpp ****             bank_revert_all();
 313:src/serialtune.cpp ****         } else {
 314:src/serialtune.cpp ****             int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 315:src/serialtune.cpp ****             bank_revert_voice(vi);
 316:src/serialtune.cpp ****         }
 317:src/serialtune.cpp ****         persist_save_bank();
 318:src/serialtune.cpp ****         if(g_live_tune) snapshot_active();   // reload the live copy from the reverted bank
 319:src/serialtune.cpp ****         usb_log("ok factory %s", (a && !strcmp(a, "all")) ? "all" : g_bank[g_active_voice].name);
 320:src/serialtune.cpp ****         return;
 321:src/serialtune.cpp ****     }
 322:src/serialtune.cpp ****     if(!strcmp(cmd, "help")) {
 323:src/serialtune.cpp ****         usb_log("cmds: tune 0|1 | set <field> <val> | set name <text> | select <n>");
 324:src/serialtune.cpp ****         usb_log("      dump | save | copy <n> [name] | bootvoice | factory [all] | mon 0|1 | bye");
 325:src/serialtune.cpp ****         for(int i = 0; i < NFIELDS; i++) usb_log("  %s", FIELDS[i].name);
 326:src/serialtune.cpp ****         usb_log("  name scale(chromatic|major|minor) reverb_decay reverb_level delay_time_ms delay_
 327:src/serialtune.cpp ****         return;
 328:src/serialtune.cpp ****     }
 329:src/serialtune.cpp ****     usb_log("err unknown cmd '%s'", cmd);
 330:src/serialtune.cpp **** }
