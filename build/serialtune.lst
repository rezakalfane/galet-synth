 212:src/serialtune.cpp **** static void handle_command(char *line) {
 213:src/serialtune.cpp ****     char *cmd = strtok(line, " \t");
 214:src/serialtune.cpp ****     if(!cmd) return;
 215:src/serialtune.cpp **** 
 216:src/serialtune.cpp ****     if(!strcmp(cmd, "tune")) {
 217:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 218:src/serialtune.cpp ****         if(a && to_i(a)) { g_serial_quiet = false;   // a host is here
 219:src/serialtune.cpp ****                            snapshot_active(); g_live_tune = true;
 220:src/serialtune.cpp ****                            hw.PrintLine("ok tune=1 voice=%s", g_live_voice.name); }
 221:src/serialtune.cpp ****         else             { g_live_tune = false; hw.PrintLine("ok tune=0"); }
 222:src/serialtune.cpp ****         return;
 223:src/serialtune.cpp ****     }
 224:src/serialtune.cpp ****     if(!strcmp(cmd, "bye")) {
 225:src/serialtune.cpp ****         // Host disconnecting: leave tune mode (so the synth plays the bank + the
ARM GAS  /tmp/claude-502/cc0wImgF.s 			page 21


 226:src/serialtune.cpp ****         // idle chase resumes) and go silent so no autonomous print blocks on the
 227:src/serialtune.cpp ****         // now-dead USB port. Cleared again by the next `tune 1`.
 228:src/serialtune.cpp ****         g_live_tune = false;
 229:src/serialtune.cpp ****         hw.PrintLine("ok bye");      // last line out while the host is still here
 230:src/serialtune.cpp ****         g_serial_quiet = true;
 231:src/serialtune.cpp ****         return;
 232:src/serialtune.cpp ****     }
 233:src/serialtune.cpp ****     if(!strcmp(cmd, "set")) {
 234:src/serialtune.cpp ****         char *f = strtok(NULL, " \t");
 235:src/serialtune.cpp ****         if(!f) { hw.PrintLine("err set <field> <value>"); return; }
 236:src/serialtune.cpp ****         if(!strcmp(f, "name")) {
 237:src/serialtune.cpp ****             // Name is the rest of the line (may contain spaces, e.g. "SH-101 min").
 238:src/serialtune.cpp ****             char *rest = strtok(NULL, "");
 239:src/serialtune.cpp ****             while(rest && (*rest == ' ' || *rest == '\t')) rest++;
 240:src/serialtune.cpp ****             strncpy(g_live_name, rest ? rest : "", VOICE_NAME_MAX - 1);
 241:src/serialtune.cpp ****             g_live_name[VOICE_NAME_MAX - 1] = 0;
 242:src/serialtune.cpp ****             g_live_voice.name = g_live_name;
 243:src/serialtune.cpp ****             hw.PrintLine("ok name=%s", g_live_name);
 244:src/serialtune.cpp ****             return;
 245:src/serialtune.cpp ****         }
 246:src/serialtune.cpp ****         char *v = strtok(NULL, " \t");
 247:src/serialtune.cpp ****         if(!v) { hw.PrintLine("err set <field> <value>"); return; }
 248:src/serialtune.cpp ****         if(set_param(f, v)) { g_live_rev++; hw.PrintLine("ok %s=%s", f, v); }
 249:src/serialtune.cpp ****         else hw.PrintLine("err unknown field '%s'", f);
 250:src/serialtune.cpp ****         return;
 251:src/serialtune.cpp ****     }
 252:src/serialtune.cpp ****     if(!strcmp(cmd, "select")) {
 253:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 254:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 255:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 256:src/serialtune.cpp ****             g_voice_idx   = n;
 257:src/serialtune.cpp ****             g_active_voice = (n == MULTI_IDX) ? MULTI_ZONES[0] : n;
 258:src/serialtune.cpp ****             if(g_live_tune) snapshot_active();   // tune the newly selected voice
 259:src/serialtune.cpp ****             hw.PrintLine("ok select=%d %s", n, g_bank[n].name);
 260:src/serialtune.cpp ****         } else hw.PrintLine("err select 0..%d", NUM_VOICES - 1);
 261:src/serialtune.cpp ****         return;
 262:src/serialtune.cpp ****     }
 263:src/serialtune.cpp ****     if(!strcmp(cmd, "dump"))  { dump_voice(); return; }
 264:src/serialtune.cpp ****     if(!strcmp(cmd, "names")) {
 265:src/serialtune.cpp ****         // List every bank slot's (possibly edited) name so the host can label its
 266:src/serialtune.cpp ****         // voice picker from flash, not just the factory defaults.
 267:src/serialtune.cpp ****         for(int i = 0; i < NUM_VOICES; i++) hw.PrintLine("name %d %s", i, g_bank[i].name);
 268:src/serialtune.cpp ****         hw.PrintLine("end");
 269:src/serialtune.cpp ****         return;
 270:src/serialtune.cpp ****     }
 271:src/serialtune.cpp ****     if(!strcmp(cmd, "mon"))   { char *a = strtok(NULL, " \t"); g_mon = (a && to_i(a));
 272:src/serialtune.cpp ****                                 hw.PrintLine("ok mon=%d", g_mon ? 1 : 0); return; }
 273:src/serialtune.cpp ****     if(!strcmp(cmd, "save")) {
 274:src/serialtune.cpp ****         // Commit the live voice (incl. name) into its bank slot, then persist the
 275:src/serialtune.cpp ****         // whole bank to flash â€” survives power-off.
 276:src/serialtune.cpp ****         int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 277:src/serialtune.cpp ****         bank_set(vi, g_live_voice, g_live_name);
 278:src/serialtune.cpp ****         persist_save_bank();
 279:src/serialtune.cpp ****         hw.PrintLine("ok saved %d %s", vi, g_bank[vi].name);
 280:src/serialtune.cpp ****         return;
 281:src/serialtune.cpp ****     }
 282:src/serialtune.cpp ****     if(!strcmp(cmd, "copy")) {
ARM GAS  /tmp/claude-502/cc0wImgF.s 			page 22


 283:src/serialtune.cpp ****         // `copy <n> [name]` â€” duplicate the current live voice into another slot
 284:src/serialtune.cpp ****         // and persist, without changing the active voice / interrupting audio.
 285:src/serialtune.cpp ****         // An optional name (rest of the line, spaces ok) names the copy; omitted
 286:src/serialtune.cpp ****         // â†’ keep the live voice's name.
 287:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 288:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 289:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 290:src/serialtune.cpp ****             char *nm = strtok(NULL, "");                 // rest of line = optional name
 291:src/serialtune.cpp ****             while(nm && (*nm == ' ' || *nm == '\t')) nm++;
 292:src/serialtune.cpp ****             bank_set(n, g_live_voice, (nm && *nm) ? nm : g_live_name);
 293:src/serialtune.cpp ****             persist_save_bank();
 294:src/serialtune.cpp ****             hw.PrintLine("ok copy=%d %s", n, g_bank[n].name);
 295:src/serialtune.cpp ****         } else hw.PrintLine("err copy 0..%d", NUM_VOICES - 1);
 296:src/serialtune.cpp ****         return;
 297:src/serialtune.cpp ****     }
 298:src/serialtune.cpp ****     if(!strcmp(cmd, "bootvoice")) {
 299:src/serialtune.cpp ****         // Persist the CURRENT selection as the power-on voice, without committing
 300:src/serialtune.cpp ****         // any live edits to the bank (unlike `save`). Just writes g_voice_idx (+ the
 301:src/serialtune.cpp ****         // already-committed bank) to flash. The GUI's "Set as default" button.
 302:src/serialtune.cpp ****         persist_save_bank();
 303:src/serialtune.cpp ****         int vi = (g_voice_idx < 0 || g_voice_idx >= NUM_VOICES) ? 0 : g_voice_idx;
 304:src/serialtune.cpp ****         hw.PrintLine("ok bootvoice=%d %s", g_voice_idx, g_bank[vi].name);
 305:src/serialtune.cpp ****         return;
 306:src/serialtune.cpp ****     }
 307:src/serialtune.cpp ****     if(!strcmp(cmd, "factory")) {
 308:src/serialtune.cpp ****         // `factory`     â†’ revert the active voice to its source default
 309:src/serialtune.cpp ****         // `factory all` â†’ revert the whole bank
 310:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 311:src/serialtune.cpp ****         if(a && !strcmp(a, "all")) {
 312:src/serialtune.cpp ****             bank_revert_all();
 313:src/serialtune.cpp ****         } else {
 314:src/serialtune.cpp ****             int vi = g_active_voice; if(vi < 0 || vi >= NUM_VOICES) vi = 0;
 315:src/serialtune.cpp ****             bank_revert_voice(vi);
 316:src/serialtune.cpp ****         }
 317:src/serialtune.cpp ****         persist_save_bank();
 318:src/serialtune.cpp ****         if(g_live_tune) snapshot_active();   // reload the live copy from the reverted bank
 319:src/serialtune.cpp ****         hw.PrintLine("ok factory %s", (a && !strcmp(a, "all")) ? "all" : g_bank[g_active_voice].nam
 320:src/serialtune.cpp ****         return;
 321:src/serialtune.cpp ****     }
 322:src/serialtune.cpp ****     if(!strcmp(cmd, "help")) {
 323:src/serialtune.cpp ****         hw.PrintLine("cmds: tune 0|1 | set <field> <val> | set name <text> | select <n>");
 324:src/serialtune.cpp ****         hw.PrintLine("      dump | save | copy <n> [name] | bootvoice | factory [all] | mon 0|1 | b
 325:src/serialtune.cpp ****         for(int i = 0; i < NFIELDS; i++) hw.PrintLine("  %s", FIELDS[i].name);
 326:src/serialtune.cpp ****         hw.PrintLine("  name scale(chromatic|major|minor) reverb_decay reverb_level delay_time_ms d
 327:src/serialtune.cpp ****         return;
 328:src/serialtune.cpp ****     }
 329:src/serialtune.cpp ****     hw.PrintLine("err unknown cmd '%s'", cmd);
 330:src/serialtune.cpp **** }
