 104:src/serialtune.cpp **** static const char *wave_name(Waveform w) {
 105:src/serialtune.cpp ****     switch(w) {
 106:src/serialtune.cpp ****         case WAVE_SINE:   return "sine";
 107:src/serialtune.cpp ****         case WAVE_SQUARE: return "square";
 108:src/serialtune.cpp ****         case WAVE_SAW:    return "saw";
 109:src/serialtune.cpp ****         default:          return "tri";
 110:src/serialtune.cpp ****     }
 111:src/serialtune.cpp **** }
 112:src/serialtune.cpp **** static bool parse_wave(const char *s, Waveform &w) {
 113:src/serialtune.cpp ****     if(!strcmp(s, "tri"))         w = WAVE_TRI;
 114:src/serialtune.cpp ****     else if(!strcmp(s, "sine"))   w = WAVE_SINE;
 115:src/serialtune.cpp ****     else if(!strcmp(s, "square")) w = WAVE_SQUARE;
 116:src/serialtune.cpp ****     else if(!strcmp(s, "saw"))    w = WAVE_SAW;
 117:src/serialtune.cpp ****     else return false;
 118:src/serialtune.cpp ****     return true;
 119:src/serialtune.cpp **** }
 120:src/serialtune.cpp **** static const char *scale_name(const int8_t *s) {
 121:src/serialtune.cpp ****     if(s == SCALE_CHROMATIC) return "chromatic";
 122:src/serialtune.cpp ****     if(s == SCALE_MAJOR)     return "major";
 123:src/serialtune.cpp ****     if(s == SCALE_MINOR)     return "minor";
 124:src/serialtune.cpp ****     return s ? "custom" : "none";
 125:src/serialtune.cpp **** }
