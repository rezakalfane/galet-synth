  94:src/serialtune.cpp **** static const char *wave_name(Waveform w) {
  95:src/serialtune.cpp ****     switch(w) {
  96:src/serialtune.cpp ****         case WAVE_SINE:   return "sine";
  97:src/serialtune.cpp ****         case WAVE_SQUARE: return "square";
  98:src/serialtune.cpp ****         case WAVE_SAW:    return "saw";
  99:src/serialtune.cpp ****         default:          return "tri";
 100:src/serialtune.cpp ****     }
 101:src/serialtune.cpp **** }
 102:src/serialtune.cpp **** static bool parse_wave(const char *s, Waveform &w) {
 103:src/serialtune.cpp ****     if(!strcmp(s, "tri"))         w = WAVE_TRI;
 104:src/serialtune.cpp ****     else if(!strcmp(s, "sine"))   w = WAVE_SINE;
 105:src/serialtune.cpp ****     else if(!strcmp(s, "square")) w = WAVE_SQUARE;
 106:src/serialtune.cpp ****     else if(!strcmp(s, "saw"))    w = WAVE_SAW;
 107:src/serialtune.cpp ****     else return false;
 108:src/serialtune.cpp ****     return true;
 109:src/serialtune.cpp **** }
 110:src/serialtune.cpp **** static const char *scale_name(const int8_t *s) {
 111:src/serialtune.cpp ****     if(s == SCALE_CHROMATIC) return "chromatic";
 112:src/serialtune.cpp ****     if(s == SCALE_MAJOR)     return "major";
 113:src/serialtune.cpp ****     if(s == SCALE_MINOR)     return "minor";
 114:src/serialtune.cpp ****     return s ? "custom" : "none";
 115:src/serialtune.cpp **** }
 116:src/serialtune.cpp **** 
 117:src/serialtune.cpp **** // Global (non-Voice) effect params, settable by name.
 118:src/serialtune.cpp **** static bool set_global(const char *f, float val) {
 119:src/serialtune.cpp ****     if(!strcmp(f, "reverb_decay"))   { g_reverb_decay   = val; return true; }
 120:src/serialtune.cpp ****     if(!strcmp(f, "reverb_level"))   { g_reverb_level   = val; return true; }
 121:src/serialtune.cpp ****     if(!strcmp(f, "delay_time_ms"))  { g_delay_time_ms  = val; return true; }
 122:src/serialtune.cpp ****     if(!strcmp(f, "delay_feedback")) { g_delay_feedback = val; return true; }
 123:src/serialtune.cpp ****     if(!strcmp(f, "delay_level"))    { g_delay_level    = val; return true; }
 124:src/serialtune.cpp ****     return false;
 125:src/serialtune.cpp **** }
 126:src/serialtune.cpp **** 
 127:src/serialtune.cpp **** // Apply `set <field> <value>` to the live voice (or a global). Returns false for
 128:src/serialtune.cpp **** // an unknown field or a bad value.
 129:src/serialtune.cpp **** static bool set_param(const char *f, const char *v) {
 130:src/serialtune.cpp ****     if(!strcmp(f, "scale")) {
 131:src/serialtune.cpp ****         if(!strcmp(v, "chromatic")) {
 132:src/serialtune.cpp ****             g_live_voice.scale = SCALE_CHROMATIC;
 133:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_CHROMATIC) / sizeof(SCALE_CHROMATIC[0]));
 134:src/serialtune.cpp ****         } else if(!strcmp(v, "major")) {
 135:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MAJOR;
 136:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0]));
 137:src/serialtune.cpp ****         } else if(!strcmp(v, "minor")) {
 138:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MINOR;
 139:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0]));
 140:src/serialtune.cpp ****         } else return false;
 141:src/serialtune.cpp ****         return true;
 142:src/serialtune.cpp ****     }
 143:src/serialtune.cpp ****     if(set_global(f, to_f(v))) return true;
 144:src/serialtune.cpp **** 
