 106:src/serialtune.cpp **** static const char *wave_name(Waveform w) {
 107:src/serialtune.cpp ****     switch(w) {
 108:src/serialtune.cpp ****         case WAVE_SINE:   return "sine";
 109:src/serialtune.cpp ****         case WAVE_SQUARE: return "square";
 110:src/serialtune.cpp ****         case WAVE_SAW:    return "saw";
 111:src/serialtune.cpp ****         default:          return "tri";
 112:src/serialtune.cpp ****     }
 113:src/serialtune.cpp **** }
 114:src/serialtune.cpp **** static bool parse_wave(const char *s, Waveform &w) {
 115:src/serialtune.cpp ****     if(!strcmp(s, "tri"))         w = WAVE_TRI;
 116:src/serialtune.cpp ****     else if(!strcmp(s, "sine"))   w = WAVE_SINE;
 117:src/serialtune.cpp ****     else if(!strcmp(s, "square")) w = WAVE_SQUARE;
 118:src/serialtune.cpp ****     else if(!strcmp(s, "saw"))    w = WAVE_SAW;
 119:src/serialtune.cpp ****     else return false;
 120:src/serialtune.cpp ****     return true;
 121:src/serialtune.cpp **** }
 122:src/serialtune.cpp **** static const char *scale_name(const int8_t *s) {
 123:src/serialtune.cpp ****     if(s == SCALE_CHROMATIC) return "chromatic";
 124:src/serialtune.cpp ****     if(s == SCALE_MAJOR)     return "major";
 125:src/serialtune.cpp ****     if(s == SCALE_MINOR)     return "minor";
 126:src/serialtune.cpp ****     return s ? "custom" : "none";
 127:src/serialtune.cpp **** }
