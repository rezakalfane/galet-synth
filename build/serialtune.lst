 195:src/serialtune.cpp **** static void handle_command(char *line) {
 196:src/serialtune.cpp ****     char *cmd = strtok(line, " \t");
 197:src/serialtune.cpp ****     if(!cmd) return;
 198:src/serialtune.cpp **** 
 199:src/serialtune.cpp ****     if(!strcmp(cmd, "tune")) {
 200:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 201:src/serialtune.cpp ****         if(a && to_i(a)) { snapshot_active(); g_live_tune = true;
 202:src/serialtune.cpp ****                            hw.PrintLine("ok tune=1 voice=%s", g_live_voice.name); }
 203:src/serialtune.cpp ****         else             { g_live_tune = false; hw.PrintLine("ok tune=0"); }
 204:src/serialtune.cpp ****         return;
 205:src/serialtune.cpp ****     }
 206:src/serialtune.cpp ****     if(!strcmp(cmd, "set")) {
 207:src/serialtune.cpp ****         char *f = strtok(NULL, " \t"), *v = strtok(NULL, " \t");
 208:src/serialtune.cpp ****         if(!f || !v) { hw.PrintLine("err set <field> <value>"); return; }
 209:src/serialtune.cpp ****         if(set_param(f, v)) { g_live_rev++; hw.PrintLine("ok %s=%s", f, v); }
 210:src/serialtune.cpp ****         else hw.PrintLine("err unknown field '%s'", f);
 211:src/serialtune.cpp ****         return;
 212:src/serialtune.cpp ****     }
 213:src/serialtune.cpp ****     if(!strcmp(cmd, "select")) {
 214:src/serialtune.cpp ****         char *a = strtok(NULL, " \t");
 215:src/serialtune.cpp ****         int n = a ? to_i(a) : -1;
 216:src/serialtune.cpp ****         if(n >= 0 && n < NUM_VOICES) {
 217:src/serialtune.cpp ****             g_voice_idx   = n;
 218:src/serialtune.cpp ****             g_active_voice = (n == MULTI_IDX) ? MULTI_ZONES[0] : n;
 219:src/serialtune.cpp ****             if(g_live_tune) snapshot_active();   // tune the newly selected voice
 220:src/serialtune.cpp ****             hw.PrintLine("ok select=%d %s", n, VOICES[n].name);
 221:src/serialtune.cpp ****         } else hw.PrintLine("err select 0..%d", NUM_VOICES - 1);
 222:src/serialtune.cpp ****         return;
 223:src/serialtune.cpp ****     }
 224:src/serialtune.cpp ****     if(!strcmp(cmd, "dump"))  { dump_voice(); return; }
 225:src/serialtune.cpp ****     if(!strcmp(cmd, "mon"))   { char *a = strtok(NULL, " \t"); g_mon = (a && to_i(a));
 226:src/serialtune.cpp ****                                 hw.PrintLine("ok mon=%d", g_mon ? 1 : 0); return; }
 227:src/serialtune.cpp ****     if(!strcmp(cmd, "help")) {
 228:src/serialtune.cpp ****         hw.PrintLine("cmds: tune 0|1 | set <field> <val> | select <n> | dump | mon 0|1");
 229:src/serialtune.cpp ****         for(int i = 0; i < NFIELDS; i++) hw.PrintLine("  %s", FIELDS[i].name);
 230:src/serialtune.cpp ****         hw.PrintLine("  scale(chromatic|major|minor) reverb_decay reverb_level delay_time_ms delay_
