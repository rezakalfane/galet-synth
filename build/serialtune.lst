 159:src/serialtune.cpp ****             case FT_W: { Waveform w; if(!parse_wave(v, w)) return false; *(Waveform *)p = w; } brea
 160:src/serialtune.cpp ****         }
 161:src/serialtune.cpp ****         // freq_low / freq_high drive the exponential pitch map â†’ keep its
 162:src/serialtune.cpp ****         // precomputed log ratio in sync.
 163:src/serialtune.cpp ****         if(!strcmp(f, "freq_low") || !strcmp(f, "freq_high"))
 164:src/serialtune.cpp ****             g_live_voice.log_freq_ratio = logf(g_live_voice.freq_high / g_live_voice.freq_low);
 165:src/serialtune.cpp ****         return true;
 166:src/serialtune.cpp ****     }
 167:src/serialtune.cpp ****     return false;
 168:src/serialtune.cpp **** }
