 135:src/serialtune.cpp ****         } else if(!strcmp(v, "major")) {
 136:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MAJOR;
 137:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0]));
 138:src/serialtune.cpp ****         } else if(!strcmp(v, "minor")) {
 139:src/serialtune.cpp ****             g_live_voice.scale = SCALE_MINOR;
 140:src/serialtune.cpp ****             g_live_voice.scale_len = (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0]));
 141:src/serialtune.cpp ****         } else return false;
