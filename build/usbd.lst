 573:lib/tinyusb/src/device/usbd.c **** 
 574:lib/tinyusb/src/device/usbd.c ****   // Loop until there is no more events in the queue
 575:lib/tinyusb/src/device/usbd.c ****   while (1) {
 576:lib/tinyusb/src/device/usbd.c ****     dcd_event_t event;
 577:lib/tinyusb/src/device/usbd.c ****     if (!osal_queue_receive(_usbd_q, &event, timeout_ms)) return;
