1168:lib/tinyusb/src/device/usbd.c ****       }
1169:lib/tinyusb/src/device/usbd.c ****       break;
1170:lib/tinyusb/src/device/usbd.c **** 
1171:lib/tinyusb/src/device/usbd.c ****     case DCD_EVENT_RESUME:
1172:lib/tinyusb/src/device/usbd.c ****       // skip event if not connected (especially required for SAMD)
1173:lib/tinyusb/src/device/usbd.c ****       if (_usbd_dev.connected) {
