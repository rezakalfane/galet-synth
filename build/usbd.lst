 554:lib/tinyusb/src/device/usbd.c **** /* USB Device Driver task
 555:lib/tinyusb/src/device/usbd.c ****  * This top level thread manages all device controller event and delegates events to class-specific
 556:lib/tinyusb/src/device/usbd.c ****  * This should be called periodically within the mainloop or rtos thread.
 557:lib/tinyusb/src/device/usbd.c ****  *
 558:lib/tinyusb/src/device/usbd.c ****     int main(void) {
 559:lib/tinyusb/src/device/usbd.c ****       application_init();
 560:lib/tinyusb/src/device/usbd.c ****       tusb_init();
 561:lib/tinyusb/src/device/usbd.c **** 
 562:lib/tinyusb/src/device/usbd.c ****       while(1) { // the mainloop
 563:lib/tinyusb/src/device/usbd.c ****         application_code();
 564:lib/tinyusb/src/device/usbd.c ****         tud_task(); // tinyusb device task
 565:lib/tinyusb/src/device/usbd.c ****       }
