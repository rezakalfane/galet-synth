1257:lib/tinyusb/src/device/usbd.c **** // Helper to defer an isr function
1258:lib/tinyusb/src/device/usbd.c **** void usbd_defer_func(osal_task_func_t func, void* param, bool in_isr) {
1259:lib/tinyusb/src/device/usbd.c ****   dcd_event_t event = {
1260:lib/tinyusb/src/device/usbd.c ****       .rhport   = 0,
1261:lib/tinyusb/src/device/usbd.c ****       .event_id = USBD_EVENT_FUNC_CALL,
1262:lib/tinyusb/src/device/usbd.c ****   };
1263:lib/tinyusb/src/device/usbd.c ****   event.func_call.func  = func;
1264:lib/tinyusb/src/device/usbd.c ****   event.func_call.param = param;
1265:lib/tinyusb/src/device/usbd.c **** 
1266:lib/tinyusb/src/device/usbd.c ****   queue_event(&event, in_isr);
1267:lib/tinyusb/src/device/usbd.c **** }
