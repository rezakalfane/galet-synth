 585:lib/tinyusb/src/device/usbd.c ****       case DCD_EVENT_BUS_RESET:
 586:lib/tinyusb/src/device/usbd.c ****         TU_LOG_USBD(": %s Speed\r\n", tu_str_speed[event.bus_reset.speed]);
 587:lib/tinyusb/src/device/usbd.c ****         usbd_reset(event.rhport);
 588:lib/tinyusb/src/device/usbd.c ****         _usbd_dev.speed = event.bus_reset.speed;
 589:lib/tinyusb/src/device/usbd.c ****         break;
 590:lib/tinyusb/src/device/usbd.c **** 
