 604:lib/tinyusb/src/device/usbd.c ****         }
 605:lib/tinyusb/src/device/usbd.c **** 
 606:lib/tinyusb/src/device/usbd.c ****         // Mark as connected after receiving 1st setup packet.
 607:lib/tinyusb/src/device/usbd.c ****         // But it is easier to set it every time instead of wasting time to check then set
 608:lib/tinyusb/src/device/usbd.c ****         _usbd_dev.connected = 1;
 609:lib/tinyusb/src/device/usbd.c **** 
