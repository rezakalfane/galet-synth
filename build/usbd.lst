1305:lib/tinyusb/src/device/usbd.c **** bool usbd_edpt_xfer(uint8_t rhport, uint8_t ep_addr, uint8_t* buffer, uint16_t total_bytes) {
1306:lib/tinyusb/src/device/usbd.c ****   rhport = _usbd_rhport;
1307:lib/tinyusb/src/device/usbd.c **** 
1308:lib/tinyusb/src/device/usbd.c ****   uint8_t const epnum = tu_edpt_number(ep_addr);
1309:lib/tinyusb/src/device/usbd.c ****   uint8_t const dir = tu_edpt_dir(ep_addr);
1310:lib/tinyusb/src/device/usbd.c **** 
1311:lib/tinyusb/src/device/usbd.c ****   // TODO skip ready() check for now since enumeration also use this API
1312:lib/tinyusb/src/device/usbd.c ****   // TU_VERIFY(tud_ready());
1313:lib/tinyusb/src/device/usbd.c **** 
1314:lib/tinyusb/src/device/usbd.c ****   TU_LOG_USBD("  Queue EP %02X with %u bytes ...\r\n", ep_addr, total_bytes);
1315:lib/tinyusb/src/device/usbd.c **** #if CFG_TUD_LOG_LEVEL >= 3
1316:lib/tinyusb/src/device/usbd.c ****   if(dir == TUSB_DIR_IN) {
1317:lib/tinyusb/src/device/usbd.c ****     TU_LOG_MEM(CFG_TUD_LOG_LEVEL, buffer, total_bytes, 2);
1318:lib/tinyusb/src/device/usbd.c ****   }
1319:lib/tinyusb/src/device/usbd.c **** #endif
1320:lib/tinyusb/src/device/usbd.c **** 
1321:lib/tinyusb/src/device/usbd.c ****   // Attempt to transfer on a busy endpoint, sound like an race condition !
1322:lib/tinyusb/src/device/usbd.c ****   TU_ASSERT(_usbd_dev.ep_status[epnum][dir].busy == 0);
1323:lib/tinyusb/src/device/usbd.c **** 
1324:lib/tinyusb/src/device/usbd.c ****   // Set busy first since the actual transfer can be complete before dcd_edpt_xfer()
1325:lib/tinyusb/src/device/usbd.c ****   // could return and USBD task can preempt and clear the busy
1326:lib/tinyusb/src/device/usbd.c ****   _usbd_dev.ep_status[epnum][dir].busy = 1;
1327:lib/tinyusb/src/device/usbd.c **** 
1328:lib/tinyusb/src/device/usbd.c ****   if (dcd_edpt_xfer(rhport, ep_addr, buffer, total_bytes)) {
1329:lib/tinyusb/src/device/usbd.c ****     return true;
1330:lib/tinyusb/src/device/usbd.c ****   } else {
1331:lib/tinyusb/src/device/usbd.c ****     // DCD error, mark endpoint as ready to allow next transfer
1332:lib/tinyusb/src/device/usbd.c ****     _usbd_dev.ep_status[epnum][dir].busy = 0;
1333:lib/tinyusb/src/device/usbd.c ****     _usbd_dev.ep_status[epnum][dir].claimed = 0;
1334:lib/tinyusb/src/device/usbd.c ****     TU_LOG_USBD("FAILED\r\n");
1335:lib/tinyusb/src/device/usbd.c ****     TU_BREAKPOINT();
1336:lib/tinyusb/src/device/usbd.c ****     return false;
