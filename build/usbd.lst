1233:lib/tinyusb/src/device/usbd.c **** // Parse consecutive endpoint descriptors (IN & OUT)
1234:lib/tinyusb/src/device/usbd.c **** bool usbd_open_edpt_pair(uint8_t rhport, uint8_t const* p_desc, uint8_t ep_count, uint8_t xfer_type
1235:lib/tinyusb/src/device/usbd.c **** {
1236:lib/tinyusb/src/device/usbd.c ****   for(int i=0; i<ep_count; i++)
1237:lib/tinyusb/src/device/usbd.c ****   {
1238:lib/tinyusb/src/device/usbd.c ****     tusb_desc_endpoint_t const * desc_ep = (tusb_desc_endpoint_t const *) p_desc;
1239:lib/tinyusb/src/device/usbd.c **** 
1240:lib/tinyusb/src/device/usbd.c ****     TU_ASSERT(TUSB_DESC_ENDPOINT == desc_ep->bDescriptorType && xfer_type == desc_ep->bmAttributes.
1241:lib/tinyusb/src/device/usbd.c ****     TU_ASSERT(usbd_edpt_open(rhport, desc_ep));
1242:lib/tinyusb/src/device/usbd.c **** 
1243:lib/tinyusb/src/device/usbd.c ****     if ( tu_edpt_dir(desc_ep->bEndpointAddress) == TUSB_DIR_IN )
1244:lib/tinyusb/src/device/usbd.c ****     {
1245:lib/tinyusb/src/device/usbd.c ****       (*ep_in) = desc_ep->bEndpointAddress;
1246:lib/tinyusb/src/device/usbd.c ****     }else
1247:lib/tinyusb/src/device/usbd.c ****     {
1248:lib/tinyusb/src/device/usbd.c ****       (*ep_out) = desc_ep->bEndpointAddress;
1249:lib/tinyusb/src/device/usbd.c ****     }
1250:lib/tinyusb/src/device/usbd.c **** 
1251:lib/tinyusb/src/device/usbd.c ****     p_desc = tu_desc_next(p_desc);
1252:lib/tinyusb/src/device/usbd.c ****   }
1253:lib/tinyusb/src/device/usbd.c **** 
1254:lib/tinyusb/src/device/usbd.c ****   return true;
1255:lib/tinyusb/src/device/usbd.c **** }
