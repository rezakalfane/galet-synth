1340:lib/tinyusb/src/device/usbd.c **** // The number of bytes has to be given explicitly to allow more flexible control of how many
1341:lib/tinyusb/src/device/usbd.c **** // bytes should be written and second to keep the return value free to give back a boolean
1342:lib/tinyusb/src/device/usbd.c **** // success message. If total_bytes is too big, the FIFO will copy only what is available
1343:lib/tinyusb/src/device/usbd.c **** // into the USB buffer!
1344:lib/tinyusb/src/device/usbd.c **** bool usbd_edpt_xfer_fifo(uint8_t rhport, uint8_t ep_addr, tu_fifo_t* ff, uint16_t total_bytes) {
1345:lib/tinyusb/src/device/usbd.c ****   rhport = _usbd_rhport;
1346:lib/tinyusb/src/device/usbd.c **** 
1347:lib/tinyusb/src/device/usbd.c ****   uint8_t const epnum = tu_edpt_number(ep_addr);
1348:lib/tinyusb/src/device/usbd.c ****   uint8_t const dir = tu_edpt_dir(ep_addr);
1349:lib/tinyusb/src/device/usbd.c **** 
1350:lib/tinyusb/src/device/usbd.c ****   TU_LOG_USBD("  Queue ISO EP %02X with %u bytes ... ", ep_addr, total_bytes);
1351:lib/tinyusb/src/device/usbd.c **** 
1352:lib/tinyusb/src/device/usbd.c ****   // Attempt to transfer on a busy endpoint, sound like an race condition !
1353:lib/tinyusb/src/device/usbd.c ****   TU_ASSERT(_usbd_dev.ep_status[epnum][dir].busy == 0);
1354:lib/tinyusb/src/device/usbd.c **** 
1355:lib/tinyusb/src/device/usbd.c ****   // Set busy first since the actual transfer can be complete before dcd_edpt_xfer() could return
1356:lib/tinyusb/src/device/usbd.c ****   // and usbd task can preempt and clear the busy
1357:lib/tinyusb/src/device/usbd.c ****   _usbd_dev.ep_status[epnum][dir].busy = 1;
1358:lib/tinyusb/src/device/usbd.c **** 
1359:lib/tinyusb/src/device/usbd.c ****   if (dcd_edpt_xfer_fifo(rhport, ep_addr, ff, total_bytes)) {
1360:lib/tinyusb/src/device/usbd.c ****     TU_LOG_USBD("OK\r\n");
1361:lib/tinyusb/src/device/usbd.c ****     return true;
1362:lib/tinyusb/src/device/usbd.c ****   } else {
1363:lib/tinyusb/src/device/usbd.c ****     // DCD error, mark endpoint as ready to allow next transfer
1364:lib/tinyusb/src/device/usbd.c ****     _usbd_dev.ep_status[epnum][dir].busy = 0;
1365:lib/tinyusb/src/device/usbd.c ****     _usbd_dev.ep_status[epnum][dir].claimed = 0;
1366:lib/tinyusb/src/device/usbd.c ****     TU_LOG_USBD("failed\r\n");
1367:lib/tinyusb/src/device/usbd.c ****     TU_BREAKPOINT();
1368:lib/tinyusb/src/device/usbd.c ****     return false;
1369:lib/tinyusb/src/device/usbd.c ****   }
1370:lib/tinyusb/src/device/usbd.c **** }
