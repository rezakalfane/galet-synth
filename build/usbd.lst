 304:lib/tinyusb/src/device/usbd.c **** 
 305:lib/tinyusb/src/device/usbd.c **** // Additional class drivers implemented by application
 306:lib/tinyusb/src/device/usbd.c **** tu_static usbd_class_driver_t const * _app_driver = NULL;
 307:lib/tinyusb/src/device/usbd.c **** tu_static uint8_t _app_driver_count = 0;
 308:lib/tinyusb/src/device/usbd.c **** 
 309:lib/tinyusb/src/device/usbd.c **** #define TOTAL_DRIVER_COUNT    (_app_driver_count + BUILTIN_DRIVER_COUNT)
 310:lib/tinyusb/src/device/usbd.c **** 
 311:lib/tinyusb/src/device/usbd.c **** // virtually joins built-in and application drivers together.
 312:lib/tinyusb/src/device/usbd.c **** // Application is positioned first to allow overwriting built-in ones.
 313:lib/tinyusb/src/device/usbd.c **** TU_ATTR_ALWAYS_INLINE static inline usbd_class_driver_t const * get_driver(uint8_t drvid) {
 314:lib/tinyusb/src/device/usbd.c ****   usbd_class_driver_t const * driver = NULL;
 315:lib/tinyusb/src/device/usbd.c ****   if ( drvid < _app_driver_count ) {
 316:lib/tinyusb/src/device/usbd.c ****     // Application drivers
 317:lib/tinyusb/src/device/usbd.c ****     driver = &_app_driver[drvid];
 318:lib/tinyusb/src/device/usbd.c ****   } else if ( drvid < TOTAL_DRIVER_COUNT && BUILTIN_DRIVER_COUNT > 0 ){
 319:lib/tinyusb/src/device/usbd.c ****     driver = &_usbd_driver[drvid - _app_driver_count];
 320:lib/tinyusb/src/device/usbd.c ****   }
 321:lib/tinyusb/src/device/usbd.c ****   return driver;
 322:lib/tinyusb/src/device/usbd.c **** }
