1162:lib/tinyusb/src/device/usbd.c ****       // can accidentally meet the SUSPEND condition ( Bus Idle for 3ms ).
1163:lib/tinyusb/src/device/usbd.c ****       // In addition, some MCUs such as SAMD or boards that haven no VBUS detection cannot distingu
1164:lib/tinyusb/src/device/usbd.c ****       // suspended vs disconnected. We will skip handling SUSPEND/RESUME event if not currently con
1165:lib/tinyusb/src/device/usbd.c ****       if (_usbd_dev.connected) {
