 580:lib/tinyusb/src/device/usbd.c ****     if (event.event_id == DCD_EVENT_SETUP_RECEIVED) TU_LOG_USBD("\r\n"); // extra line for setup
 581:lib/tinyusb/src/device/usbd.c ****     TU_LOG_USBD("USBD %s ", event.event_id < DCD_EVENT_COUNT ? _usbd_event_str[event.event_id] : "C
 582:lib/tinyusb/src/device/usbd.c **** #endif
 583:lib/tinyusb/src/device/usbd.c **** 
 584:lib/tinyusb/src/device/usbd.c ****     switch (event.event_id) {
 585:lib/tinyusb/src/device/usbd.c ****       case DCD_EVENT_BUS_RESET:
 586:lib/tinyusb/src/device/usbd.c ****         TU_LOG_USBD(": %s Speed\r\n", tu_str_speed[event.bus_reset.speed]);
 587:lib/tinyusb/src/device/usbd.c ****         usbd_reset(event.rhport);
 588:lib/tinyusb/src/device/usbd.c ****         _usbd_dev.speed = event.bus_reset.speed;
 589:lib/tinyusb/src/device/usbd.c ****         break;
 590:lib/tinyusb/src/device/usbd.c **** 
 591:lib/tinyusb/src/device/usbd.c ****       case DCD_EVENT_UNPLUGGED:
 592:lib/tinyusb/src/device/usbd.c ****         TU_LOG_USBD("\r\n");
 593:lib/tinyusb/src/device/usbd.c ****         usbd_reset(event.rhport);
 594:lib/tinyusb/src/device/usbd.c ****         tud_umount_cb();
 595:lib/tinyusb/src/device/usbd.c ****         break;
 596:lib/tinyusb/src/device/usbd.c **** 
 597:lib/tinyusb/src/device/usbd.c ****       case DCD_EVENT_SETUP_RECEIVED:
 598:lib/tinyusb/src/device/usbd.c ****         TU_ASSERT(_usbd_queued_setup > 0,);
 599:lib/tinyusb/src/device/usbd.c ****         _usbd_queued_setup--;
