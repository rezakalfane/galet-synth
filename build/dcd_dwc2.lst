  95:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // EP0 transfers are limited to 1 packet - larger sizes has to be split
  96:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static uint16_t ep0_pending[2];               // Index determines direction as tusb_dir_t type
  97:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
  98:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // TX FIFO RAM allocation so far in words - RX FIFO size is readily available from dwc2->grxfsiz
  99:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static uint16_t _allocated_fifo_words_tx;     // TX FIFO size in words (IN EPs)
 100:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 101:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // SOF enabling flag - required for SOF to not get disabled in ISR when SOF was enabled by
 102:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static bool _sof_en;
 103:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 104:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // Calculate the RX FIFO size according to minimum recommendations from reference manual
 105:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // RxFIFO = (5 * number of control endpoints + 8) +
 106:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** //          ((largest USB packet used / 4) + 1 for status information) +
 107:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** //          (2 * number of OUT endpoints) + 1 for Global NAK
 108:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // with number of control endpoints = 1 we have
 109:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // RxFIFO = 15 + (largest USB packet used / 4) + 2 * number of OUT endpoints
 110:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // we double the largest USB packet size to be able to hold up to 2 packets
 111:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static inline uint16_t calc_grxfsiz(uint16_t max_ep_size, uint8_t ep_count) {
 112:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   return 15 + 2 * (max_ep_size / 4) + 2 * ep_count;
 113:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
 114:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 115:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** TU_ATTR_ALWAYS_INLINE static inline void fifo_flush_tx(dwc2_regs_t* dwc2, uint8_t epnum) {
 116:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // flush TX fifo and wait for it cleared
 117:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->grstctl = GRSTCTL_TXFFLSH | (epnum << GRSTCTL_TXFNUM_Pos);
 118:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   while (dwc2->grstctl & GRSTCTL_TXFFLSH_Msk) {}
 119:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
 120:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** TU_ATTR_ALWAYS_INLINE static inline void fifo_flush_rx(dwc2_regs_t* dwc2) {
 121:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // flush RX fifo and wait for it cleared
 122:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->grstctl = GRSTCTL_RXFFLSH;
 123:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   while (dwc2->grstctl & GRSTCTL_RXFFLSH_Msk) {}
 124:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
 125:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 126:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static bool fifo_alloc(uint8_t rhport, uint8_t ep_addr, uint16_t packet_size) {
