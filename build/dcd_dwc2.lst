 547:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static bool check_dwc2(dwc2_regs_t* dwc2) {
 548:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** #if CFG_TUSB_DEBUG >= DWC2_DEBUG
 549:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   print_dwc2_info(dwc2);
