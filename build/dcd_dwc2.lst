 449:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static bool phy_hs_supported(dwc2_regs_t* dwc2) {
 450:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   (void) dwc2;
 451:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 452:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** #if TU_CHECK_MCU(OPT_MCU_ESP32S2, OPT_MCU_ESP32S3)
 453:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // note: esp32 incorrect report its hs_phy_type as utmi
 454:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   return false;
 455:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** #elif !TUD_OPT_HIGH_SPEED
 456:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   return false;
 457:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** #else
 458:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   return dwc2->ghwcfg2_bm.hs_phy_type != HS_PHY_TYPE_NONE;
 459:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** #endif
 460:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
