 555:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint32_t const gsnpsid = dwc2->gsnpsid & GSNPSID_ID_MASK;
 556:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   TU_ASSERT(gsnpsid == DWC2_OTG_ID || gsnpsid == DWC2_FS_IOT_ID || gsnpsid == DWC2_HS_IOT_ID);
 557:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** #endif
 558:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 559:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   return true;
 560:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
