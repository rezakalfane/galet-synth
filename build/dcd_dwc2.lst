 424:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // print guid, gsnpsid, ghwcfg1, ghwcfg2, ghwcfg3, ghwcfg4
 425:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // use dwc2_info.py/md for bit-field value and comparison with other ports
