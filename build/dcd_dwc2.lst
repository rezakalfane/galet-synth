 552:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // For some reasons: GD32VF103 snpsid and all hwcfg register are always zero (skip it)
 553:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   (void) dwc2;
