 924:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** //  TU_LOG(DWC2_DEBUG, "  EP %02X, Byte Count %u, %s\r\n", epnum, bcnt, pktsts_str[pktsts]);
 925:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** //  TU_LOG(DWC2_DEBUG, "  daint = %08lX, doepint = %04X\r\n", (unsigned long) dwc2->daint, (unsigne
 926:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** //#endif
 927:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 928:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   switch (pktsts) {
 929:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // Global OUT NAK: do nothing
 930:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     case GRXSTS_PKTSTS_GLOBALOUTNAK:
 931:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****       break;
