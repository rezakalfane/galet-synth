 462:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void phy_fs_init(dwc2_regs_t* dwc2) {
 463:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   TU_LOG(DWC2_DEBUG, "Fullspeed PHY init\r\n");
 464:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 465:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Select FS PHY
 466:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->gusbcfg |= GUSBCFG_PHYSEL;
 467:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 468:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // MCU specific PHY init before reset
 469:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_phy_init(dwc2, HS_PHY_TYPE_NONE);
 470:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 471:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Reset core after selecting PHY
 472:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   reset_core(dwc2);
 473:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 474:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // USB turnaround time is critical for certification where long cables and 5-Hubs are used.
 475:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // So if you need the AHB to run at less than 30 MHz, and if USB turnaround time is not critical,
 476:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // these bits can be programmed to a larger value. Default is 5
 477:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->gusbcfg = (dwc2->gusbcfg & ~GUSBCFG_TRDT_Msk) | (5u << GUSBCFG_TRDT_Pos);
 478:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 479:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // MCU specific PHY update post reset
 480:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_phy_update(dwc2, HS_PHY_TYPE_NONE);
 481:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 482:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // set max speed
 483:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->dcfg = (dwc2->dcfg & ~DCFG_DSPD_Msk) | (DCFG_DSPD_FS << DCFG_DSPD_Pos);
 484:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
 485:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 486:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void phy_hs_init(dwc2_regs_t* dwc2) {
 487:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint32_t gusbcfg = dwc2->gusbcfg;
 488:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 489:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // De-select FS PHY
 490:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   gusbcfg &= ~GUSBCFG_PHYSEL;
 491:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 492:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   if (dwc2->ghwcfg2_bm.hs_phy_type == HS_PHY_TYPE_ULPI) {
 493:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     TU_LOG(DWC2_DEBUG, "Highspeed ULPI PHY init\r\n");
ARM GAS  /tmp/claude-502/ccFotbfS.s 			page 41


 494:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 495:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // Select ULPI
 496:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     gusbcfg |= GUSBCFG_ULPI_UTMI_SEL;
 497:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 498:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // ULPI 8-bit interface, single data rate
 499:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     gusbcfg &= ~(GUSBCFG_PHYIF16 | GUSBCFG_DDRSEL);
 500:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 501:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // default internal VBUS Indicator and Drive
 502:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     gusbcfg &= ~(GUSBCFG_ULPIEVBUSD | GUSBCFG_ULPIEVBUSI);
 503:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 504:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // Disable FS/LS ULPI
 505:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     gusbcfg &= ~(GUSBCFG_ULPIFSLS | GUSBCFG_ULPICSM);
 506:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   } else {
 507:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     TU_LOG(DWC2_DEBUG, "Highspeed UTMI+ PHY init\r\n");
 508:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 509:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // Select UTMI+ with 8-bit interface
 510:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     gusbcfg &= ~(GUSBCFG_ULPI_UTMI_SEL | GUSBCFG_PHYIF16);
 511:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 512:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     // Set 16-bit interface if supported
 513:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     if (dwc2->ghwcfg4_bm.utmi_phy_data_width) gusbcfg |= GUSBCFG_PHYIF16;
 514:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 515:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 516:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Apply config
 517:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->gusbcfg = gusbcfg;
 518:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 519:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // mcu specific phy init
 520:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_phy_init(dwc2, dwc2->ghwcfg2_bm.hs_phy_type);
 521:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 522:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Reset core after selecting PHY
 523:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   reset_core(dwc2);
 524:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 525:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Set turn-around, must after core reset otherwise it will be clear
 526:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // - 9 if using 8-bit PHY interface
 527:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // - 5 if using 16-bit PHY interface
 528:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   gusbcfg &= ~GUSBCFG_TRDT_Msk;
 529:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   gusbcfg |= (dwc2->ghwcfg4_bm.utmi_phy_data_width ? 5u : 9u) << GUSBCFG_TRDT_Pos;
 530:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->gusbcfg = gusbcfg;
 531:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 532:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // MCU specific PHY update post reset
 533:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_phy_update(dwc2, dwc2->ghwcfg2_bm.hs_phy_type);
 534:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 535:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Set max speed
 536:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint32_t dcfg = dwc2->dcfg;
 537:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dcfg &= ~DCFG_DSPD_Msk;
 538:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dcfg |= DCFG_DSPD_HS << DCFG_DSPD_Pos;
 539:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 540:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // XCVRDLY: transceiver delay between xcvr_sel and txvalid during device chirp is required
 541:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // when using with some PHYs such as USB334x (USB3341, USB3343, USB3346, USB3347)
 542:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   if (dwc2->ghwcfg2_bm.hs_phy_type == HS_PHY_TYPE_ULPI) dcfg |= DCFG_XCVRDLY;
 543:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 544:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->dcfg = dcfg;
 545:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
