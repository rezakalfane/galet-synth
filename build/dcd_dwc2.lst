 437:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->grstctl |= GRSTCTL_CSRST;
 438:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 439:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // wait for reset bit is cleared
 440:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // TODO version 4.20a should wait for RESET DONE mask
 441:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   while (dwc2->grstctl & GRSTCTL_CSRST) {}
 442:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 443:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // wait for AHB master IDLE
 444:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   while (!(dwc2->grstctl & GRSTCTL_AHBIDL)) {}
