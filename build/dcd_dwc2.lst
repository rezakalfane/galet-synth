 855:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 856:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // Read a single data packet from receive FIFO
 857:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void read_fifo_packet(uint8_t rhport, uint8_t* dst, uint16_t len) {
 858:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   (void) rhport;
 859:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 860:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_regs_t* dwc2 = DWC2_REG(rhport);
 861:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   volatile const uint32_t* rx_fifo = dwc2->fifo[0];
 862:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 863:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Reading full available 32 bit words from fifo
 864:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint16_t full_words = len >> 2;
 865:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   while (full_words--) {
 866:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     tu_unaligned_write32(dst, *rx_fifo);
 867:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     dst += 4;
 868:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 869:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 870:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Read the remaining 1-3 bytes from fifo
 871:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint8_t const bytes_rem = len & 0x03;
 872:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   if (bytes_rem != 0) {
 873:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     uint32_t const tmp = *rx_fifo;
 874:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     dst[0] = tu_u32_byte0(tmp);
 875:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     if (bytes_rem > 1) dst[1] = tu_u32_byte1(tmp);
 876:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     if (bytes_rem > 2) dst[2] = tu_u32_byte2(tmp);
 877:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 878:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
