 435:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void reset_core(dwc2_regs_t* dwc2) {
 436:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // reset core
