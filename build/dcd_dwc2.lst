 880:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // Write a single data packet to EPIN FIFO
 881:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void write_fifo_packet(uint8_t rhport, uint8_t fifo_num, uint8_t const* src, uint16_t len) {
 882:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   (void) rhport;
 883:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 884:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_regs_t* dwc2 = DWC2_REG(rhport);
 885:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   volatile uint32_t* tx_fifo = dwc2->fifo[fifo_num];
 886:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 887:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Pushing full available 32 bit words to fifo
 888:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint16_t full_words = len >> 2;
 889:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   while (full_words--) {
 890:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     *tx_fifo = tu_unaligned_read32(src);
 891:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     src += 4;
 892:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 893:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 894:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Write the remaining 1-3 bytes into fifo
 895:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint8_t const bytes_rem = len & 0x03;
 896:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   if (bytes_rem) {
 897:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     uint32_t tmp_word = src[0];
 898:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     if (bytes_rem > 1) tmp_word |= (src[1] << 8);
 899:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     if (bytes_rem > 2) tmp_word |= (src[2] << 16);
 900:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 901:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     *tx_fifo = tmp_word;
 902:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 903:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
