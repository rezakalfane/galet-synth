 905:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void handle_rxflvl_irq(uint8_t rhport) {
 906:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_regs_t* dwc2 = DWC2_REG(rhport);
 907:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   volatile uint32_t const* rx_fifo = dwc2->fifo[0];
 908:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 909:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Pop control word off FIFO
 910:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint32_t const ctl_word = dwc2->grxstsp;
 911:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint8_t const pktsts = (ctl_word & GRXSTSP_PKTSTS_Msk) >> GRXSTSP_PKTSTS_Pos;
 912:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint8_t const epnum = (ctl_word & GRXSTSP_EPNUM_Msk) >> GRXSTSP_EPNUM_Pos;
 913:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint16_t const bcnt = (ctl_word & GRXSTSP_BCNT_Msk) >> GRXSTSP_BCNT_Pos;
 914:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 915:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_epout_t* epout = &dwc2->epout[epnum];
 916:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 917:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** //#if CFG_TUSB_DEBUG >= DWC2_DEBUG
