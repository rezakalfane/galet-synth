 266:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** // Start of Bus Reset
 267:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** static void bus_reset(uint8_t rhport) {
 268:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2_regs_t* dwc2 = DWC2_REG(rhport);
 269:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   uint8_t const ep_count = _dwc2_controller[rhport].ep_count;
 270:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 271:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   tu_memclr(xfer_status, sizeof(xfer_status));
 272:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 273:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   _sof_en = false;
 274:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 275:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // clear device address
 276:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->dcfg &= ~DCFG_DAD_Msk;
 277:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 278:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // 1. NAK for all OUT endpoints
ARM GAS  /tmp/claude-502/ccFotbfS.s 			page 32


 279:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   for (uint8_t n = 0; n < ep_count; n++) {
 280:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     dwc2->epout[n].doepctl |= DOEPCTL_SNAK;
 281:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 282:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 283:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // 2. Disable all IN endpoints
 284:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   for (uint8_t n = 0; n < ep_count; n++) {
 285:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     if (dwc2->epin[n].diepctl & DIEPCTL_EPENA) {
 286:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****       dwc2->epin[n].diepctl |= DIEPCTL_SNAK | DIEPCTL_EPDIS;
 287:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****     }
 288:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   }
 289:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 290:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   fifo_flush_tx(dwc2, 0x10); // all tx fifo
 291:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   fifo_flush_rx(dwc2);
 292:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 293:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // 3. Set up interrupt mask
 294:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->daintmsk = TU_BIT(DAINTMSK_OEPM_Pos) | TU_BIT(DAINTMSK_IEPM_Pos);
 295:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->doepmsk = DOEPMSK_STUPM | DOEPMSK_XFRCM;
 296:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->diepmsk = DIEPMSK_TOM | DIEPMSK_XFRCM;
 297:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 298:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // "USB Data FIFOs" section in reference manual
 299:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Peripheral FIFO architecture
 300:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 301:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // The FIFO is split up in a lower part where the RX FIFO is located and an upper part where the 
 302:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // We do this to allow the RX FIFO to grow dynamically which is possible since the free space is 
 303:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // between the RX and TX FIFOs. This is required by ISO OUT EPs which need a bigger FIFO than the
 304:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // configuration done below.
 305:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 306:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Dynamically FIFO sizes are of interest only for ISO EPs since all others are usually not opene
 307:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // All EPs other than ISO are opened as soon as the driver starts up i.e. when the host sends a
 308:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // configure interface command. Hence, all IN EPs other the ISO will be located at the top. IN IS
 309:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // opened when the host sends an additional command: setInterface. At this point in time
 310:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // the ISO EP will be located next to the free space and can change its size. In case more IN EPs
 311:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // an additional memory
 312:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 313:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // --------------- 320 or 1024 ( 1280 or 4096 bytes )
 314:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // | IN FIFO 0   |
 315:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // --------------- (320 or 1024) - 16
 316:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // | IN FIFO 1   |
 317:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // --------------- (320 or 1024) - 16 - x
 318:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // |   . . . .   |
 319:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // --------------- (320 or 1024) - 16 - x - y - ... - z
 320:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // | IN FIFO MAX |
 321:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // ---------------
 322:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // |    FREE     |
 323:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // --------------- GRXFSIZ
 324:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // | OUT FIFO    |
 325:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // | ( Shared )  |
 326:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // --------------- 0
 327:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 328:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // According to "FIFO RAM allocation" section in RM, FIFO RAM are allocated as follows (each word
 329:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // - Each EP IN needs at least max packet size, 16 words is sufficient for EP0 IN
 330:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 331:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // - All EP OUT shared a unique OUT FIFO which uses
 332:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   - 13 for setup packets + control words (up to 3 setup packets).
 333:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   - 1 for global NAK (not required/used here).
 334:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   - Largest-EPsize / 4 + 1. ( FS: 64 bytes, HS: 512 bytes). Recommended is  "2 x (Largest-EPsi
 335:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   - 2 for each used OUT endpoint
ARM GAS  /tmp/claude-502/ccFotbfS.s 			page 33


 336:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 337:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   Therefore GRXFSIZ = 13 + 1 + 1 + 2 x (Largest-EPsize/4) + 2 x EPOUTnum
 338:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   - FullSpeed (64 Bytes ): GRXFSIZ = 15 + 2 x  16 + 2 x ep_count = 47  + 2 x ep_count
 339:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   - Highspeed (512 bytes): GRXFSIZ = 15 + 2 x 128 + 2 x ep_count = 271 + 2 x ep_count
 340:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 341:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   NOTE: Largest-EPsize & EPOUTnum is actual used endpoints in configuration. Since DCD has no 
 342:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   of the overall picture yet. We will use the worst scenario: largest possible + ep_count
 343:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //
 344:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   For Isochronous, largest EP size can be 1023/1024 for FS/HS respectively. In addition if mul
 345:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   are enabled at least "2 x (Largest-EPsize/4) + 1" are recommended.  Maybe provide a macro fo
 346:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   //   overwrite this.
 347:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 348:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // EP0 out max is 64
 349:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->grxfsiz = calc_grxfsiz(64, ep_count);
 350:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 351:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Setup the control endpoint 0
 352:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   _allocated_fifo_words_tx = 16;
 353:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 354:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Control IN uses FIFO 0 with 64 bytes ( 16 32-bit word )
 355:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->dieptxf0 = (16 << DIEPTXF0_TX0FD_Pos) | (_dwc2_controller[rhport].ep_fifo_size / 4 - _alloc
 356:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 357:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   // Fixed control EP0 size to 64 bytes
 358:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->epin[0].diepctl &= ~(0x03 << DIEPCTL_MPSIZ_Pos);
 359:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   xfer_status[0][TUSB_DIR_OUT].max_size = 64;
 360:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   xfer_status[0][TUSB_DIR_IN].max_size = 64;
 361:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 362:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->epout[0].doeptsiz |= (3 << DOEPTSIZ_STUPCNT_Pos);
 363:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
 364:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   dwc2->gintmsk |= GINTMSK_OEPINT | GINTMSK_IEPINT;
 365:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** }
 366:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c **** 
