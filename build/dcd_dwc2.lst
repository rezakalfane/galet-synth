 583:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****   /* Set HS/FS Timeout Calibration to 7 (max available value).
 584:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****    * The number of PHY clocks that the application programs in
 585:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****    * this field is added to the high/full speed interpacket timeout
 586:lib/tinyusb/src/portable/synopsys/dwc2/dcd_dwc2.c ****    * duration in the core to account for any additional delays
