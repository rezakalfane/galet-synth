1001:src/voice.h   ****     VOICE_SH101,     // SH-101 mono synth, minor-scale chords (cyclable; kept after
1002:src/voice.h   ****                      // the raw drums so their bank indices ŌĆö and MULTI_ZONES ŌĆö stay put)
1003:src/voice.h   ****     VOICE_SH101_MAJ, // same synth, major-scale chords ŌĆö cycle here to flip the flavor
1004:src/voice.h   ****     VOICE_DRUMS,     // MultiVoice ŌĆö must stay last (MULTI_IDX = NUM_VOICES-1)
1005:src/voice.h   **** };
1006:src/voice.h   **** static constexpr int NUM_VOICES = (int)(sizeof(VOICES) / sizeof(VOICES[0]));
