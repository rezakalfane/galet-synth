   1:src/main.cpp  **** /**
   2:src/main.cpp  ****  * mpr121_synth.cpp ŌĆö Glass Touch Moog Synth
   3:src/main.cpp  ****  * Daisy Seed ŌĆö Bit-Bang I2C  SDA=D12  SCL=D11
   4:src/main.cpp  ****  *
   5:src/main.cpp  ****  * FINGER 1:
   6:src/main.cpp  ****  *   Position  ŌåÆ Pitch (quantized on touch-down, continuous slide after)
   7:src/main.cpp  ****  *   Pressure  ŌåÆ Filter cutoff (light=dark/closed, hard=bright/open)
   8:src/main.cpp  ****  *               + Vibrato depth (press harder for more wobble)
   9:src/main.cpp  ****  *
  10:src/main.cpp  ****  * FINGER 2:
  11:src/main.cpp  ****  *   Position  ŌåÆ Oscillator detune (spread between osc1 and osc2)
  12:src/main.cpp  ****  *   Pressure  ŌåÆ Wavefold distortion (gentle saturation to complex fold)
  13:src/main.cpp  ****  *               + Ring mod amount (extreme pressure adds metallic edge)
  14:src/main.cpp  ****  *
  15:src/main.cpp  ****  * EXPRESSION:
ARM GAS  /tmp/claude-502/ccGIYDbf.s 			page 9


  16:src/main.cpp  ****  *   - Note quantize on initial touch, then free pitch bend on slide
  17:src/main.cpp  ****  *   - Pressure-controlled vibrato (LFO depth from finger 1 pressure)
  18:src/main.cpp  ****  *   - Portamento / glide between quantized notes
  19:src/main.cpp  ****  *   - Sub oscillator one octave below (adds weight)
  20:src/main.cpp  ****  *   - Soft-clip waveshaper before output
  21:src/main.cpp  ****  *   - Amplitude envelope: fast attack, pressure-controlled release
  22:src/main.cpp  ****  */
  23:src/main.cpp  **** 
  24:src/main.cpp  **** #include "daisy_seed.h"
  25:src/main.cpp  **** #include <math.h>
  26:src/main.cpp  **** #include <string.h>
  27:src/main.cpp  **** 
  28:src/main.cpp  **** using namespace daisy;
  29:src/main.cpp  **** using namespace daisy::seed;
  30:src/main.cpp  **** 
  31:src/main.cpp  **** // ŌöĆŌöĆ Pin / I2C config ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  32:src/main.cpp  **** static constexpr Pin      SDA_PIN  = D12;
  33:src/main.cpp  **** static constexpr Pin      SCL_PIN  = D11;
  34:src/main.cpp  **** static constexpr uint8_t  MPR_ADDR = 0x5A;
  35:src/main.cpp  **** static constexpr uint32_t HP       = 5;
  36:src/main.cpp  **** static constexpr int      N_CH     = 12;
  37:src/main.cpp  **** 
  38:src/main.cpp  **** // ŌöĆŌöĆ Touch tuning ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  39:src/main.cpp  **** static constexpr int32_t  TOUCH_THRESHOLD    = 10;
  40:src/main.cpp  **** static constexpr int32_t  PRESSURE_MAX_REF[12] = {
  41:src/main.cpp  ****     42,35,34,34,34,34,
  42:src/main.cpp  ****     34,34,33,32,29,30
  43:src/main.cpp  **** };
  44:src/main.cpp  **** static constexpr int32_t  MIN_FINGER_SEP     = 4;
  45:src/main.cpp  **** static constexpr uint32_t REBASELINE_IDLE_MS = 2000;
  46:src/main.cpp  **** static constexpr int      REBASELINE_SAMPLES = 32;
  47:src/main.cpp  **** static constexpr int32_t  MAX_POS_JUMP       = 200;
  48:src/main.cpp  **** 
  49:src/main.cpp  **** // LED slew at ~60Hz touch loop. Closer to 1.0 = smoother/slower fade.
  50:src/main.cpp  **** // 0.0 = no smoothing (snap), 0.7 = ~80ms fade, 0.9 = ~250ms fade.
  51:src/main.cpp  **** static constexpr float    LED_SMOOTH         = 0.45f;
  52:src/main.cpp  **** // LED3 (software sigma-delta PWM on A0 / ADC0 / pin 22) max-brightness scale.
  53:src/main.cpp  **** static constexpr float    LED3_INTENSITY     = 0.1f;
  54:src/main.cpp  **** // Smoothing coefficient used for LED3 only when no finger is touching. Smaller
  55:src/main.cpp  **** // than LED_SMOOTH = faster fade-out on lift. 0.0 = instant snap to 0.
  56:src/main.cpp  **** static constexpr float    LED3_RELEASE_SMOOTH = 0.10f;
  57:src/main.cpp  **** 
  58:src/main.cpp  **** // ŌöĆŌöĆ Voices ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  59:src/main.cpp  **** // A "Voice" bundles everything that defines a sound: the oscillator stack
  60:src/main.cpp  **** // (which pitches sound and at what level), the filter/drive character, and the
  61:src/main.cpp  **** // pitch range finger-1 sweeps across. Presets live in the VOICES[] bank below;
  62:src/main.cpp  **** // the active one is `g_voice_idx`, which the FSR-hold gesture cycles live. The
  63:src/main.cpp  **** // audio callback snapshots it once per block.
  64:src/main.cpp  **** 
  65:src/main.cpp  **** // Oscillator shape ŌĆö set per oscillator, so one voice can mix (e.g. saw root +
  66:src/main.cpp  **** // square fifth + sine sub). SQUARE and SAW are naive (not band-limited) ŌĆö they
  67:src/main.cpp  **** // alias at high pitch, but on a low bass voice that just reads as rich harmonics
  68:src/main.cpp  **** // for the filter to chew.
  69:src/main.cpp  **** enum Waveform { WAVE_TRI, WAVE_SINE, WAVE_SQUARE, WAVE_SAW };
  70:src/main.cpp  **** 
  71:src/main.cpp  **** struct Voice {
  72:src/main.cpp  ****     const char* name;
ARM GAS  /tmp/claude-502/ccGIYDbf.s 			page 10


  73:src/main.cpp  **** 
  74:src/main.cpp  ****     // Pitch range. Finger-1 position 0ŌĆō1000 maps exponentially across this.
  75:src/main.cpp  ****     float freq_low;
  76:src/main.cpp  ****     float freq_high;
  77:src/main.cpp  ****     float log_freq_ratio;   // = ln(freq_high / freq_low), precomputed (logf isn't constexpr)
  78:src/main.cpp  **** 
  79:src/main.cpp  ****     // Oscillator stack. Each oscillator's pitch = fundamental * ratio, and each
  80:src/main.cpp  ****     // has its own waveform. Set a level to 0 to silence an oscillator.
  81:src/main.cpp  ****     float osc1_ratio, osc1_level;  Waveform osc1_wave;   // primary
  82:src/main.cpp  ****     float osc2_ratio, osc2_level;  Waveform osc2_wave;   // second osc (see osc2_detune)
  83:src/main.cpp  ****     float sub_ratio,  sub_level;   Waveform sub_wave;    // weight below
  84:src/main.cpp  ****     float oct_ratio,  oct_level;   Waveform oct_wave;    // shimmer / chord top
  85:src/main.cpp  ****     bool  osc2_detune;              // true  ŌåÆ finger-2 detune controls osc2 pitch (lead)
  86:src/main.cpp  ****                                     // false ŌåÆ osc2 stays at osc2_ratio (e.g. a fixed 5th)
  87:src/main.cpp  **** 
  88:src/main.cpp  ****     // Filter character. Base cutoff = freq * cutoff_mult; pressure opens it
  89:src/main.cpp  ****     // by up to cutoff_oct_max octaves on top.
  90:src/main.cpp  ****     float cutoff_mult;
  91:src/main.cpp  ****     float cutoff_oct_max;
  92:src/main.cpp  ****     float resonance;
  93:src/main.cpp  **** 
  94:src/main.cpp  ****     // Drive ŌĆö pressure-controlled waveshaper gain added on top of 1.0.
  95:src/main.cpp  ****     float drive_max;
  96:src/main.cpp  **** 
  97:src/main.cpp  ****     // ŌöĆŌöĆ Extras (appended so existing field order stays stable) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  98:src/main.cpp  ****     float noise_level;     // white noise mixed into the oscillator stack (0 = none)
  99:src/main.cpp  ****     float keytrack;        // 0..1 ŌĆö how much the cutoff follows pitch (1 = full)
 100:src/main.cpp  ****     float ringmod_ratio;   // ring-mod carrier pitch ratio (1.0 = unison; non-int = bell/metallic)
 101:src/main.cpp  ****     float ringmod_max;     // max ring-mod wet from finger-2 pressure
 102:src/main.cpp  ****     float fold_max;        // max wavefold amount from finger-2 pressure
 103:src/main.cpp  ****     float attack_ms;       // amp envelope attack time
 104:src/main.cpp  ****     float release_ms;      // amp envelope + filter-close release time
 105:src/main.cpp  ****     float glide_ms;        // portamento (pitch glide) time
 106:src/main.cpp  **** 
 107:src/main.cpp  ****     // Pitch envelope ŌĆö a fast downward pitch sweep at note onset (kick "boom",
 108:src/main.cpp  ****     // zap, tom thump). Left at 0 (the default for voices that omit them) = off.
 109:src/main.cpp  ****     float pitch_env_oct;   // octaves the pitch starts ABOVE the note at onset (0 = none)
 110:src/main.cpp  ****     float pitch_env_ms;    // time the pitch sweep takes to settle to the note
 111:src/main.cpp  **** 
 112:src/main.cpp  ****     // Noise tone: 0 = full white noise ("shhh"), 1 = high-passed/bright ("tsss",
 113:src/main.cpp  ****     // for hi-hats/cymbals). Default 0 leaves the noise white. See NOISE_HP_COEF.
 114:src/main.cpp  ****     float noise_hp;
 115:src/main.cpp  **** };
 116:src/main.cpp  **** 
 117:src/main.cpp  **** // Perfect-fifth frequency ratio = 2^(7/12).
 118:src/main.cpp  **** static constexpr float RATIO_FIFTH = 1.49831f;
 119:src/main.cpp  **** 
 120:src/main.cpp  **** // ŌöĆŌöĆ Voice 0: the original glass-Moog lead ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 121:src/main.cpp  **** //   F1 posŌåÆpitch, F1 prsŌåÆcutoff+vibrato; F2 posŌåÆdetune, F2 prsŌåÆwavefold+ringmod.
 122:src/main.cpp  **** static constexpr Voice VOICE_LEAD = {
 123:src/main.cpp  ****     "Lead",
 124:src/main.cpp  ****     50.0f, 300.0f, 1.79176f,   // 50ŌĆō300 Hz, ln(6)
 125:src/main.cpp  ****     1.0f, 0.50f, WAVE_TRI,   // osc1  ŌĆö root
 126:src/main.cpp  ****     1.0f, 0.22f, WAVE_TRI,   // osc2  ŌĆö detune-controlled, ratio is just the base
 127:src/main.cpp  ****     0.5f, 0.18f, WAVE_TRI,   // sub   ŌĆö one octave below
 128:src/main.cpp  ****     2.0f, 0.15f, WAVE_TRI,   // oct   ŌĆö one octave above
 129:src/main.cpp  ****     true,          // osc2 follows finger-2 detune
ARM GAS  /tmp/claude-502/ccGIYDbf.s 			page 11


 130:src/main.cpp  ****     0.3f, 12.0f, 0.75f,
 131:src/main.cpp  ****     2.5f,
 132:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 133:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.15f, 0.18f, 4.0f, 400.0f, 40.0f
 134:src/main.cpp  **** };
 135:src/main.cpp  **** 
 136:src/main.cpp  **** // ŌöĆŌöĆ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 137:src/main.cpp  **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
 138:src/main.cpp  **** //   so every note sounds as a power chord. Lower range, gentler filter, less
 139:src/main.cpp  **** //   drive ŌåÆ deep and round rather than bright and screaming.
 140:src/main.cpp  **** static constexpr Voice VOICE_BASS = {
 141:src/main.cpp  ****     "Bass",
 142:src/main.cpp  ****     40.0f, 160.0f, 1.38629f,   // 40ŌĆō160 Hz, ln(4) ŌĆö sits under the lead
 143:src/main.cpp  ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ŌĆö root
 144:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ŌĆö fixed perfect fifth (the power chord)
 145:src/main.cpp  ****     0.5f,        0.34f, WAVE_TRI,   // sub   ŌĆö extra weight for a round bottom
 146:src/main.cpp  ****     2.0f,        0.20f, WAVE_TRI,   // oct   ŌĆö top of the power chord
 147:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 148:src/main.cpp  ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 149:src/main.cpp  ****     1.0f,                 // less drive ŌĆö keep it clean and round
 150:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 151:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.12f, 0.12f, 6.0f, 300.0f, 25.0f
 152:src/main.cpp  **** };
 153:src/main.cpp  **** 
 154:src/main.cpp  **** // ŌöĆŌöĆ Voice 2: open power-chord bass ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 155:src/main.cpp  **** //   Same chord stack as VOICE_BASS, but the filter starts brighter and sweeps
 156:src/main.cpp  **** //   much further with pressure ŌĆö light touch is still warm, hard press opens it
 157:src/main.cpp  **** //   wide. A touch more resonance and drive for presence as it opens.
 158:src/main.cpp  **** static constexpr Voice VOICE_BASS_OPEN = {
 159:src/main.cpp  ****     "OpenBass",
