 147:src/main.cpp  **** void read_electrodes(uint16_t* out)
 148:src/main.cpp  **** {
 149:src/main.cpp  ****     uint8_t buf[24];
 150:src/main.cpp  ****     mpr_read(REG_ELE0_LSB,buf,24);
 151:src/main.cpp  ****     for(int i=0;i<N_CH;i++)
 152:src/main.cpp  ****         out[i]=(uint16_t)(buf[i*2]|((buf[i*2+1]&0x03)<<8));
 153:src/main.cpp  **** }
