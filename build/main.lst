 296:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 297:src/main.cpp  **** {
 298:src/main.cpp  ****     for(int i=7;i>=0;i--){
 299:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 300:src/main.cpp  ****         d();scl_high();d();scl_low();d();
ARM GAS  /tmp/claude-502/ccL8jzgy.s 			page 14


 301:src/main.cpp  ****     }
 302:src/main.cpp  ****     sda_high();d();scl_high();d();
 303:src/main.cpp  ****     bool ack=!sda.Read();
 304:src/main.cpp  ****     scl_low();d();
 305:src/main.cpp  ****     return ack;
 306:src/main.cpp  **** }
 307:src/main.cpp  **** 
 308:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 309:src/main.cpp  **** {
 310:src/main.cpp  ****     uint8_t b=0;sda_high();
 311:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 312:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 313:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 314:src/main.cpp  ****     return b;
 315:src/main.cpp  **** }
