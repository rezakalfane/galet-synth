 941:src/main.cpp  ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
 942:src/main.cpp  ****     return fast_tanh(h.lp_state*1.3f) * h.amp;
 943:src/main.cpp  **** }
