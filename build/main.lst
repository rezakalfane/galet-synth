 337:src/main.cpp  ****     // advances them between loops so glass taps still register (the old blocking
 338:src/main.cpp  ****     // flash stalled the loop up to ~2 s). Voice-select blinks the position on
 339:src/main.cpp  ****     // enter and on save (which voice), and a single blink per tap-advance (the
 340:src/main.cpp  ****     // audio preview IDs it). Startup uses the blocking flasher for the boot voice.
 341:src/main.cpp  ****     int      blink_left    = 0;
 342:src/main.cpp  ****     bool     blink_on      = false;
 343:src/main.cpp  ****     uint32_t blink_t       = 0;
 344:src/main.cpp  ****     auto leds_write = [&](bool on){
 345:src/main.cpp  ****         hw.dac.WriteValue(DacHandle::Channel::ONE, on ? (uint16_t)LED1_MAX : 0);
 346:src/main.cpp  ****         hw.dac.WriteValue(DacHandle::Channel::TWO, on ? (uint16_t)LED2_MAX : 0);
 347:src/main.cpp  ****         g_led3_duty = on ? LED3_INTENSITY : 0.0f;
 348:src/main.cpp  ****     };
 349:src/main.cpp  ****     auto blink_start = [&](int n, uint32_t now){
 350:src/main.cpp  ****         blink_left = n;
 351:src/main.cpp  ****         if(n > 0){ leds_write(true); blink_on = true; blink_t = now + 110; }
 352:src/main.cpp  ****         else     { leds_write(false); blink_on = false; }
 353:src/main.cpp  ****     };
 354:src/main.cpp  ****     auto blink_tick = [&](uint32_t now){
 355:src/main.cpp  ****         if(blink_left == 0 && !blink_on) return;
 356:src/main.cpp  ****         if((int32_t)(now - blink_t) < 0)  return;
 357:src/main.cpp  ****         if(blink_on){ leds_write(false); blink_on = false; blink_left--; blink_t = now + 140; }
 358:src/main.cpp  ****         else if(blink_left > 0){ leds_write(true); blink_on = true; blink_t = now + 110; }
 359:src/main.cpp  ****     };
