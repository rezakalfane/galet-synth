 336:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 337:src/main.cpp  **** {
 338:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 339:src/main.cpp  ****     for(int i=s;i<=e;i++){
 340:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 341:src/main.cpp  ****         sw+=w;swx+=w*i;
 342:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 343:src/main.cpp  ****     }
 344:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 345:src/main.cpp  ****     if(sw==0)return -1;
 346:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 347:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 348:src/main.cpp  ****     return p;
 349:src/main.cpp  **** }
