1253:src/main.cpp  ****         // Fourth-root curve (gamma=0.25) keeps each LED above its forward-voltage
1254:src/main.cpp  ****         // floor at the handoff points (50% raw ‚Üí ~84% drive). Pressure adds a
1255:src/main.cpp  ****         // subtle ~75%‚Üí100% intensity scale.
1256:src/main.cpp  ****         float led1_target = 0.0f, led2_target = 0.0f, led3_target = 0.0f;
1257:src/main.cpp  ****         if(f1_on) {
