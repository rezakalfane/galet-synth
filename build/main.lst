 826:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 827:src/main.cpp  **** // switched live). A small jump table ŌĆö cheap at audio rate on the H750.
 828:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 829:src/main.cpp  ****     switch(w){
 830:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 831:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 832:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 833:src/main.cpp  ****         case WAVE_TRI:
 834:src/main.cpp  ****         default:          return tri(ph);
 835:src/main.cpp  ****     }
 836:src/main.cpp  **** }
