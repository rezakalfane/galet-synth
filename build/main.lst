 955:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
 956:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 957:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
 958:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
 959:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
 960:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
 961:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
 962:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 963:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
 964:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
 965:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
 966:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 967:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
 968:src/main.cpp  ****             };
 969:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
 970:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 971:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
 972:src/main.cpp  ****             };
 973:src/main.cpp  **** 
 974:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top.
