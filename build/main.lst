 910:src/main.cpp  **** static float drum_render(DrumHit& h, float sr)
 911:src/main.cpp  **** {
 912:src/main.cpp  ****     if(!h.active) return 0.0f;
 913:src/main.cpp  ****     const Voice& V = VOICES[h.vidx];
 914:src/main.cpp  ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 915:src/main.cpp  ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
