1133:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
1134:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
