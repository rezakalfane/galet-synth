 376:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 377:src/main.cpp  **** static inline float fast_tanh(float x)
 378:src/main.cpp  **** {
 379:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 380:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 381:src/main.cpp  ****     float x2=x*x;
 382:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 383:src/main.cpp  **** }
