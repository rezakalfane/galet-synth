 172:src/main.cpp  ****     auto commit_fsr_avg = [&](uint32_t acc, int n) {
 173:src/main.cpp  ****         if(n == 0) return;
 174:src/main.cpp  ****         uint16_t avg = (uint16_t)(acc / n);
 175:src/main.cpp  ****         // Sanity floor ‚Äî without enough headroom over FSR_MIN the volume curve
