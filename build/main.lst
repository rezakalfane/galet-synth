 317:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 318:src/main.cpp  **** {
 319:src/main.cpp  ****     i2c_start();
 320:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 321:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 322:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 323:src/main.cpp  ****     i2c_stop();return true;
 324:src/main.cpp  **** }
 325:src/main.cpp  **** 
 326:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 327:src/main.cpp  **** {
 328:src/main.cpp  ****     i2c_start();
 329:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 330:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 331:src/main.cpp  ****     i2c_start();
 332:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 333:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 334:src/main.cpp  ****     i2c_stop();return true;
 335:src/main.cpp  **** }
