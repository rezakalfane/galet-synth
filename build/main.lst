 423:src/voice.h   ****     1.0f,
 424:src/voice.h   ****     0.42f,
 425:src/voice.h   ****     WAVE_SAW,            // osc1  ‚Äî saw root
 426:src/voice.h   ****     // SECONDARY OSCILLATOR
 427:src/voice.h   ****     1.008f,
 428:src/voice.h   ****     0.38f,
 429:src/voice.h   ****     WAVE_SAW,            // osc2  ‚Äî slightly sharp twin ‚Üí thick beating buzz
 430:src/voice.h   ****     // SUB OSCILLATOR
 431:src/voice.h   ****     0.5f,
 432:src/voice.h   ****     0.20f,
 433:src/voice.h   ****     WAVE_SAW,            // sub   ‚Äî a little weight underneath
 434:src/voice.h   ****     // OCTAVE OSCILLATOR
 435:src/voice.h   ****     2.0f,
 436:src/voice.h   ****     0.30f,
 437:src/voice.h   ****     WAVE_SAW,            // oct   ‚Äî octave up for bright, cutting scream
 438:src/voice.h   ****     // FILTER
 439:src/voice.h   ****     false,               // osc2 is a fixed detune, not finger-2 controlled
 440:src/voice.h   ****     3.0f,
 441:src/voice.h   ****     11.0f,
 442:src/voice.h   ****     0.90f,               // bright base + wide sweep + near-self-osc resonance
 443:src/voice.h   ****     // DRIVE
 444:src/voice.h   ****     4.0f,                // heavy drive ‚Äî saturated and aggressive
 445:src/voice.h   ****     // NOISE
 446:src/voice.h   ****     0.05f,               // noise level ‚Äî hiss
 447:src/voice.h   ****     1.0f,                // keytrack
 448:src/voice.h   ****     2.5f,                // ringmod ratio ‚Äî inharmonic metallic
 449:src/voice.h   ****     0.40f,               // ringmod max
