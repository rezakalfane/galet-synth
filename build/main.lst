 361:src/main.cpp  ****         if(ra[r])continue;
 362:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 363:src/main.cpp  ****             if(!tracked[slot].alive){
 364:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 365:src/main.cpp  ****                 ra[r]=true;break;
 366:src/main.cpp  ****             }
 367:src/main.cpp  ****         }
