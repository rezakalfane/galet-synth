  78:src/main.cpp  **** inline void sda_high(){sda.Init(SDA_PIN,GPIO::Mode::INPUT, GPIO::Pull::PULLUP);}
  79:src/main.cpp  **** inline void sda_low() {sda.Init(SDA_PIN,GPIO::Mode::OUTPUT,GPIO::Pull::NOPULL);sda.Write(false);}
  80:src/main.cpp  **** inline void scl_high(){scl.Init(SCL_PIN,GPIO::Mode::INPUT, GPIO::Pull::PULLUP);}
  81:src/main.cpp  **** inline void scl_low() {scl.Init(SCL_PIN,GPIO::Mode::OUTPUT,GPIO::Pull::NOPULL);scl.Write(false);}
  82:src/main.cpp  **** inline void d(){System::DelayUs(HP);}
  83:src/main.cpp  **** 
  84:src/main.cpp  **** void i2c_start(){sda_high();d();scl_high();d();sda_low();d();scl_low();d();}
  85:src/main.cpp  **** void i2c_stop() {sda_low();d();scl_high();d();sda_high();d();}
  86:src/main.cpp  **** 
  87:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
  88:src/main.cpp  **** {
  89:src/main.cpp  ****     for(int i=7;i>=0;i--){
  90:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
  91:src/main.cpp  ****         d();scl_high();d();scl_low();d();
  92:src/main.cpp  ****     }
  93:src/main.cpp  ****     sda_high();d();scl_high();d();
  94:src/main.cpp  ****     bool ack=!sda.Read();
  95:src/main.cpp  ****     scl_low();d();
  96:src/main.cpp  ****     return ack;
  97:src/main.cpp  **** }
  98:src/main.cpp  **** 
  99:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 100:src/main.cpp  **** {
 101:src/main.cpp  ****     uint8_t b=0;sda_high();
 102:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 103:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 104:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 105:src/main.cpp  ****     return b;
 106:src/main.cpp  **** }
