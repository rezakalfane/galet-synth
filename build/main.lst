 238:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 239:src/main.cpp  **** {
 240:src/main.cpp  ****     bool ra[MAX_FINGERS]={};
 241:src/main.cpp  ****     for(int slot=0;slot<MAX_FINGERS;slot++){
 242:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 243:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
ARM GAS  /tmp/claude-502/cc3JAR3K.s 			page 13


 244:src/main.cpp  ****         for(int r=0;r<n;r++){
 245:src/main.cpp  ****             if(ra[r])continue;
