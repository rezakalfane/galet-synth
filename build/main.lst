 429:src/voice.h   **** //   sweeps it wide open. Finger-2 pressure piles on ring-mod + wavefold for
 430:src/voice.h   **** //   extra snarl. Loud and nasty ŌĆö the output soft-clip keeps it from blowing up.
 431:src/voice.h   **** static constexpr Voice VOICE_SCREAM = {
