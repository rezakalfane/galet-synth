 189:src/main.cpp  **** // ŌöĆŌöĆ Touch structs ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 190:src/main.cpp  **** struct Finger { bool active; int32_t pos,pressure,peak_ch,peak_delta; };
 191:src/main.cpp  **** struct TrackedFinger { bool alive; int32_t pos,pressure; int peak_ch; int32_t peak_delta; };
 192:src/main.cpp  **** static TrackedFinger tracked[2]={};
 193:src/main.cpp  **** 
 194:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 195:src/main.cpp  **** {
 196:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 197:src/main.cpp  ****     for(int i=s;i<=e;i++){
 198:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 199:src/main.cpp  ****         sw+=w;swx+=w*i;
 200:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 201:src/main.cpp  ****     }
 202:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 203:src/main.cpp  ****     if(sw==0)return -1;
 204:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 205:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 206:src/main.cpp  ****     return p;
 207:src/main.cpp  **** }
