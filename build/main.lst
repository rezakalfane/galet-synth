 439:src/main.cpp  ****         if(s_lfo_phase>=1.0f)s_lfo_phase-=1.0f;
 440:src/main.cpp  ****         float lfo = tri(s_lfo_phase); // -1..1
 441:src/main.cpp  **** 
 442:src/main.cpp  ****         // Vibrato: modulate frequency by ┬▒1 semitone * depth
 443:src/main.cpp  ****         // powf(2, semitones/12) ŌĆö approx for small values: exp(x*0.0578)
 444:src/main.cpp  ****         float vib_amt = lfo * s_vibdepth * 0.05f; // max ┬▒~0.05 semitones*depth
 445:src/main.cpp  ****         float freq_vib = s_freq * (1.0f + vib_amt);
 446:src/main.cpp  **** 
 447:src/main.cpp  ****         // Osc 2 frequency: detuned by s_detune semitones
 448:src/main.cpp  ****         // pow2(s_detune/12) approximated
 449:src/main.cpp  ****         float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for ┬▒1 oct
 450:src/main.cpp  ****         float freq2 = freq_vib * det_ratio;
 451:src/main.cpp  **** 
 452:src/main.cpp  ****         // Sub osc: one octave down
 453:src/main.cpp  ****         float freq_sub = freq_vib * 0.5f;
 454:src/main.cpp  ****         // Octave-up osc: one octave above fundamental ŌĆö adds air and sparkle
 455:src/main.cpp  ****         float freq_oct = freq_vib * 2.0f;
 456:src/main.cpp  **** 
 457:src/main.cpp  ****         // Ring mod carrier: slightly above fundamental for metallic beating
 458:src/main.cpp  ****         float freq_rm = freq_vib * 1.0f; // unison ring mod (can offset for effect)
 459:src/main.cpp  **** 
 460:src/main.cpp  ****         // Oscillators
 461:src/main.cpp  ****         float osc1    = tri(s_phase1)   * 0.50f;
 462:src/main.cpp  ****         float osc2    = tri(s_phase2)   * 0.22f; // detuned copy
 463:src/main.cpp  ****         float sub     = tri(s_phase_sub)* 0.18f; // one octave below
 464:src/main.cpp  ****         float osc_oct = tri(s_phase_oct)* 0.15f; // one octave above ŌĆö bright shimmer
 465:src/main.cpp  **** 
 466:src/main.cpp  ****         // Mix ŌĆö reduce osc1 slightly to make room for the new octave osc
 467:src/main.cpp  ****         float mix = osc1 + osc2 + sub + osc_oct;
 468:src/main.cpp  **** 
 469:src/main.cpp  ****         // Ring modulation (finger 2 pressure ŌåÆ metallic/bell edge)
 470:src/main.cpp  ****         float rm_carrier = tri(s_phase_rm);
 471:src/main.cpp  ****         mix = mix*(1.0f-s_ringmod) + (mix*rm_carrier)*s_ringmod;
 472:src/main.cpp  **** 
 473:src/main.cpp  ****         // Waveshaper drive before filter (adds harmonics, warms tone)
 474:src/main.cpp  ****         mix = fast_tanh(mix * s_drive);
 475:src/main.cpp  **** 
 476:src/main.cpp  ****         // Moog ladder filter ŌĆö no attack boost (was causing onset clicks)
 477:src/main.cpp  ****         float eff_cutoff = clampf(s_cutoff, 20.0f, 20000.0f);
 478:src/main.cpp  ****         float filtered = moog(mix, eff_cutoff, 0.75f, sr);
