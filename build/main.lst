 951:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 952:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 953:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 954:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 955:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 956:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 957:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 958:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 959:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 960:src/main.cpp  ****             g_led3_duty = led3;
 961:src/main.cpp  **** 
 962:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 963:src/main.cpp  ****             if(!calibrated) {
 964:src/main.cpp  ****                 acc += hw.adc.Get(0);
 965:src/main.cpp  ****                 n++;
 966:src/main.cpp  ****                 if(elapsed >= 2000) {
 967:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 968:src/main.cpp  ****                     calibrated = true;
