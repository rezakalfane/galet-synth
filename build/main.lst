 819:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 820:src/main.cpp  **** // switched live). A small jump table ŌĆö cheap at audio rate on the H750.
 821:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 822:src/main.cpp  ****     switch(w){
 823:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 824:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 825:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 826:src/main.cpp  ****         case WAVE_TRI:
 827:src/main.cpp  ****         default:          return tri(ph);
 828:src/main.cpp  ****     }
 829:src/main.cpp  **** }
