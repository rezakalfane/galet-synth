 736:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 737:src/main.cpp  **** // Lower value = faster response.
 738:src/main.cpp  **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
 739:src/main.cpp  **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
 740:src/main.cpp  **** // callback. The constants below are the ones still shared by all voices.
 741:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 742:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 743:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 744:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 745:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ŌĆö ~35 ms smooth
 746:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 747:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 748:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 749:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 750:src/main.cpp  **** 
 751:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 752:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 753:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 754:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 755:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 756:src/main.cpp  **** }
