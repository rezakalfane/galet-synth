 437:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 438:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 439:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 440:src/main.cpp  ****     if(raw <= 0)     return 0;
 441:src/main.cpp  ****     if(raw >= range) return 100;
 442:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 443:src/main.cpp  ****     if(raw > range) raw = range;
 444:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 445:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 446:src/main.cpp  ****     // Integer sqrt via Newton
 447:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 448:src/main.cpp  ****     s = (s + scaled/s) / 2;
 449:src/main.cpp  ****     s = (s + scaled/s) / 2;
