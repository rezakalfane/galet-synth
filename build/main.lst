 896:src/voice.h   ****     // SUB OSCILLATOR
 897:src/voice.h   ****     0.5f,
 898:src/voice.h   ****     0.40f,
 899:src/voice.h   ****     WAVE_SQUARE,         // sub   ŌĆö the iconic square sub-osc, one octave down
