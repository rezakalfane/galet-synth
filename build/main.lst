 193:src/main.cpp  ****         uint32_t acc = 0; int n = 0;
 194:src/main.cpp  ****         bool     calibrated = false;
 195:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0в†’1в†’0 cycle
 196:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 197:src/main.cpp  ****         uint16_t scan[N_CH];
 198:src/main.cpp  **** 
 199:src/main.cpp  ****         while(true) {
 200:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 201:src/main.cpp  **** 
 202:src/main.cpp  ****             // Sinusoidal position 0в†’1в†’0 over SWEEP_PERIOD_MS вЂ” eases at the
 203:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 204:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
 205:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
 206:src/main.cpp  **** 
 207:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 208:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 209:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 210:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 211:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 212:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 213:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 214:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 215:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 216:src/main.cpp  ****             g_led3_duty = led3;
 217:src/main.cpp  **** 
 218:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 219:src/main.cpp  ****             if(!calibrated) {
 220:src/main.cpp  ****                 acc += hw.adc.Get(0);
 221:src/main.cpp  ****                 n++;
 222:src/main.cpp  ****                 if(elapsed >= 2000) {
 223:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 224:src/main.cpp  ****                     calibrated = true;
 225:src/main.cpp  ****                 }
ARM GAS  /tmp/claude-502/cc6NAAlX.s 			page 28


 226:src/main.cpp  ****             }
 227:src/main.cpp  **** 
 228:src/main.cpp  ****             // Exit on any touch.
 229:src/main.cpp  ****             read_electrodes(scan);
 230:src/main.cpp  ****             int32_t max_d = 0;
 231:src/main.cpp  ****             for(int i = 0; i < N_CH; i++) {
 232:src/main.cpp  ****                 int32_t d = (int32_t)baseline[i] - (int32_t)scan[i];
 233:src/main.cpp  ****                 if(d > max_d) max_d = d;
 234:src/main.cpp  ****             }
 235:src/main.cpp  ****             if(max_d >= TOUCH_THRESHOLD) break;
 236:src/main.cpp  **** 
 237:src/main.cpp  ****             System::Delay(10);
 238:src/main.cpp  ****         }
 239:src/main.cpp  **** 
