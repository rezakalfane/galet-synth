 168:src/main.cpp  **** // ŌöĆŌöĆ Touch structs ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 169:src/main.cpp  **** struct Finger { bool active; int32_t pos,pressure,peak_ch,peak_delta; };
 170:src/main.cpp  **** struct TrackedFinger { bool alive; int32_t pos,pressure; int peak_ch; int32_t peak_delta; };
 171:src/main.cpp  **** static TrackedFinger tracked[2]={};
