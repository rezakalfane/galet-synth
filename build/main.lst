 622:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 623:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 624:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 625:src/main.cpp  ****     if(raw <= 0)     return 0;
 626:src/main.cpp  ****     if(raw >= range) return 100;
 627:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 628:src/main.cpp  ****     if(raw > range) raw = range;
 629:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 630:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 631:src/main.cpp  ****     // Integer sqrt via Newton
 632:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 633:src/main.cpp  ****     s = (s + scaled/s) / 2;
 634:src/main.cpp  ****     s = (s + scaled/s) / 2;
 635:src/main.cpp  ****     s = (s + scaled/s) / 2;
 636:src/main.cpp  ****     s = (s + scaled/s) / 2;
 637:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 638:src/main.cpp  ****     if(s < 0)   s = 0;
 639:src/main.cpp  ****     if(s > 100) s = 100;
 640:src/main.cpp  ****     return s;
 641:src/main.cpp  **** }
