 169:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 170:src/main.cpp  **** {
 171:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 172:src/main.cpp  ****     for(int i=s;i<=e;i++){
 173:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 174:src/main.cpp  ****         sw+=w;swx+=w*i;
 175:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 176:src/main.cpp  ****     }
 177:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 178:src/main.cpp  ****     if(sw==0)return -1;
 179:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 180:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 181:src/main.cpp  ****     return p;
 182:src/main.cpp  **** }
 183:src/main.cpp  **** 
 184:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 185:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 186:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
ARM GAS  /tmp/claude-502/cc3JAR3K.s 			page 12


 187:src/main.cpp  ****     if(raw <= 0)     return 0;
 188:src/main.cpp  ****     if(raw >= range) return 100;
 189:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 190:src/main.cpp  ****     if(raw > range) raw = range;
 191:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 192:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 193:src/main.cpp  ****     // Integer sqrt via Newton
 194:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 195:src/main.cpp  ****     s = (s + scaled/s) / 2;
 196:src/main.cpp  ****     s = (s + scaled/s) / 2;
 197:src/main.cpp  ****     s = (s + scaled/s) / 2;
 198:src/main.cpp  ****     s = (s + scaled/s) / 2;
 199:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 200:src/main.cpp  ****     if(s < 0)   s = 0;
 201:src/main.cpp  ****     if(s > 100) s = 100;
 202:src/main.cpp  ****     return s;
 203:src/main.cpp  **** }
