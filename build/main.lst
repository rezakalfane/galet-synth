 648:src/main.cpp  **** 
 649:src/main.cpp  ****         // Vibrato: modulate frequency by ¬±1 semitone * depth
 650:src/main.cpp  ****         // powf(2, semitones/12) ‚Äî approx for small values: exp(x*0.0578)
 651:src/main.cpp  ****         float vib_amt = lfo * s_vibdepth * 0.05f; // max ¬±~0.05 semitones*depth
 652:src/main.cpp  ****         float freq_vib = s_freq * (1.0f + vib_amt);
 653:src/main.cpp  **** 
 654:src/main.cpp  ****         // Osc 2 frequency. Lead: finger-2 detune around the base ratio.
 655:src/main.cpp  ****         // Bass (and any fixed-interval voice): hold osc2_ratio (e.g. a 5th).
 656:src/main.cpp  ****         // VOICE is constexpr, so only the taken branch is compiled in.
 657:src/main.cpp  ****         float freq2;
 658:src/main.cpp  ****         if(VOICE.osc2_detune) {
 659:src/main.cpp  ****             float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for ¬±1 oct
 660:src/main.cpp  ****             freq2 = freq_vib * VOICE.osc2_ratio * det_ratio;
 661:src/main.cpp  ****         } else {
 662:src/main.cpp  ****             freq2 = freq_vib * VOICE.osc2_ratio;
 663:src/main.cpp  ****         }
 664:src/main.cpp  **** 
 665:src/main.cpp  ****         // Sub and octave oscillators (ratios are voice-defined).
 666:src/main.cpp  ****         float freq_sub = freq_vib * VOICE.sub_ratio;
ARM GAS  /tmp/claude-502/ccwMOaii.s 			page 25


 667:src/main.cpp  ****         float freq_oct = freq_vib * VOICE.oct_ratio;
 668:src/main.cpp  **** 
 669:src/main.cpp  ****         // Ring mod carrier: slightly above fundamental for metallic beating
 670:src/main.cpp  ****         float freq_rm = freq_vib * 1.0f; // unison ring mod (can offset for effect)
 671:src/main.cpp  **** 
 672:src/main.cpp  ****         // Oscillators (mix levels are voice-defined).
 673:src/main.cpp  ****         float osc1    = osc(s_phase1,   VOICE.osc1_wave) * VOICE.osc1_level;
 674:src/main.cpp  ****         float osc2    = osc(s_phase2,   VOICE.osc2_wave) * VOICE.osc2_level;
 675:src/main.cpp  ****         float sub     = osc(s_phase_sub,VOICE.sub_wave)  * VOICE.sub_level;
 676:src/main.cpp  ****         float osc_oct = osc(s_phase_oct,VOICE.oct_wave)  * VOICE.oct_level;
 677:src/main.cpp  **** 
 678:src/main.cpp  ****         // Mix ‚Äî reduce osc1 slightly to make room for the new octave osc
 679:src/main.cpp  ****         float mix = osc1 + osc2 + sub + osc_oct;
 680:src/main.cpp  **** 
 681:src/main.cpp  ****         // Ring modulation (finger 2 pressure ‚Üí metallic/bell edge)
 682:src/main.cpp  ****         float rm_carrier = tri(s_phase_rm);
 683:src/main.cpp  ****         mix = mix*(1.0f-s_ringmod) + (mix*rm_carrier)*s_ringmod;
 684:src/main.cpp  **** 
 685:src/main.cpp  ****         // Waveshaper drive before filter (adds harmonics, warms tone)
 686:src/main.cpp  ****         mix = fast_tanh(mix * s_drive);
 687:src/main.cpp  **** 
