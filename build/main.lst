 931:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0‚Üí1000‚Üí0 through the same
 932:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 933:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 934:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 935:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 6579              		.loc 6 935 5 view .LVU1904
 936:src/main.cpp  ****         uint32_t start = System::GetNow();
