 520:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 521:src/main.cpp  **** {
 522:src/main.cpp  ****     for(int i=7;i>=0;i--){
 523:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 524:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 525:src/main.cpp  ****     }
 526:src/main.cpp  ****     sda_high();d();scl_high();d();
 527:src/main.cpp  ****     bool ack=!sda.Read();
 528:src/main.cpp  ****     scl_low();d();
ARM GAS  /tmp/claude-502/ccqNkRH0.s 			page 18


 529:src/main.cpp  ****     return ack;
 530:src/main.cpp  **** }
 531:src/main.cpp  **** 
 532:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 533:src/main.cpp  **** {
 534:src/main.cpp  ****     uint8_t b=0;sda_high();
 535:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 536:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 537:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 538:src/main.cpp  ****     return b;
 539:src/main.cpp  **** }
