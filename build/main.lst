 644:src/main.cpp  ****     for(int i=0;i<N_CH;i++) work[i]=delta[i];
 645:src/main.cpp  **** 
 646:src/main.cpp  ****     int peaks[MAX_FINGERS];
 647:src/main.cpp  ****     int found=0;
 648:src/main.cpp  ****     for(int attempt=0; attempt<maxf && found<maxf; attempt++){
 649:src/main.cpp  ****         int pk=0; int32_t mx=0;
 650:src/main.cpp  ****         for(int i=0;i<N_CH;i++) if(work[i]>mx){ mx=work[i]; pk=i; }
 651:src/main.cpp  ****         if(mx<TOUCH_THRESHOLD) break;                 // nothing left above threshold
 652:src/main.cpp  **** 
 653:src/main.cpp  ****         bool sep_ok=true;
