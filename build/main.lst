 708:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 709:src/main.cpp  **** static inline float fast_tanh(float x)
 710:src/main.cpp  **** {
 711:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 712:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
