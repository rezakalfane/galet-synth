 120:src/voice.h   ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ‚Äî root
 121:src/voice.h   ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ‚Äî fixed perfect fifth (the power chord)
 122:src/voice.h   ****     0.5f,        0.30f, WAVE_TRI,   // sub   ‚Äî slightly less so the openness reads
 123:src/voice.h   ****     2.0f,        0.22f, WAVE_TRI,   // oct   ‚Äî top of the power chord
 124:src/voice.h   ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 125:src/voice.h   ****     0.5f, 10.0f, 0.65f,   // brighter base + wider pressure sweep + more resonance
