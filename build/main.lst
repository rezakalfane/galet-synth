 349:src/voice.h   **** // ŌöĆŌöĆ Voice 5: screaming aggressive lead ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 350:src/voice.h   **** //   Detuned sawtooth stack (root + a hair-sharp twin + octave) for a thick,
 351:src/voice.h   **** //   buzzing supersaw bite, pushed up into a cutting register. Heavy drive and a
 352:src/voice.h   **** //   very high filter resonance make the cutoff whistle and scream as pressure
 353:src/voice.h   **** //   sweeps it wide open. Finger-2 pressure piles on ring-mod + wavefold for
 354:src/voice.h   **** //   extra snarl. Loud and nasty ŌĆö the output soft-clip keeps it from blowing up.
 355:src/voice.h   **** static constexpr Voice VOICE_SCREAM = {
 356:src/voice.h   ****     "Scream",
 357:src/voice.h   ****     // FREQUENCY RANGE
 358:src/voice.h   ****     90.0f,
 359:src/voice.h   ****     720.0f,
 360:src/voice.h   ****     2.07944f,            // 90ŌĆō720 Hz, ln(8) ŌĆö high, cutting register
 361:src/voice.h   ****     // OSCILLATOR STACK
 362:src/voice.h   ****     1.0f,
 363:src/voice.h   ****     0.42f,
 364:src/voice.h   ****     WAVE_SAW,            // osc1  ŌĆö saw root
 365:src/voice.h   ****     // SECONDARY OSCILLATOR
 366:src/voice.h   ****     1.008f,
 367:src/voice.h   ****     0.38f,
 368:src/voice.h   ****     WAVE_SAW,            // osc2  ŌĆö slightly sharp twin ŌåÆ thick beating buzz
 369:src/voice.h   ****     // SUB OSCILLATOR
 370:src/voice.h   ****     0.5f,
 371:src/voice.h   ****     0.20f,
 372:src/voice.h   ****     WAVE_SAW,            // sub   ŌĆö a little weight underneath
 373:src/voice.h   ****     // OCTAVE OSCILLATOR
 374:src/voice.h   ****     2.0f,
 375:src/voice.h   ****     0.30f,
 376:src/voice.h   ****     WAVE_SAW,            // oct   ŌĆö octave up for bright, cutting scream
 377:src/voice.h   ****     // FILTER
 378:src/voice.h   ****     false,               // osc2 is a fixed detune, not finger-2 controlled
 379:src/voice.h   ****     3.0f,
 380:src/voice.h   ****     11.0f,
 381:src/voice.h   ****     0.90f,               // bright base + wide sweep + near-self-osc resonance
 382:src/voice.h   ****     // DRIVE
 383:src/voice.h   ****     4.0f,                // heavy drive ŌĆö saturated and aggressive
 384:src/voice.h   ****     // NOISE
