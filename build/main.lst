 209:src/main.cpp  **** int32_t pressure_pct(int32_t pk){
 210:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF - TOUCH_THRESHOLD;
 211:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 212:src/main.cpp  ****     if(raw < 0)      return 0;
 213:src/main.cpp  ****     if(raw >= range) return 100;
 214:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 215:src/main.cpp  ****     if(raw > range) raw = range;
 216:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 217:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 218:src/main.cpp  ****     // Integer sqrt via Newton ŌĆö start from 101 (max output) for guaranteed convergence
 219:src/main.cpp  ****     int32_t s = 101;
 220:src/main.cpp  ****     s = (s + scaled/s) / 2;
 221:src/main.cpp  ****     s = (s + scaled/s) / 2;
 222:src/main.cpp  ****     s = (s + scaled/s) / 2;
 223:src/main.cpp  ****     s = (s + scaled/s) / 2;
 224:src/main.cpp  ****     // Remap [0,100] ŌåÆ [10,100]: threshold delta = 10%, max = 100%
 225:src/main.cpp  ****     s = 10 + s * 90 / 100;
 226:src/main.cpp  ****     if(s < 0)   s = 0;
 227:src/main.cpp  ****     if(s > 100) s = 100;
 228:src/main.cpp  ****     return s;
 229:src/main.cpp  **** }
 230:src/main.cpp  **** 
 231:src/main.cpp  **** int detect_raw(int32_t* delta,Finger out[2])
 232:src/main.cpp  **** {
 233:src/main.cpp  ****     out[0].active=out[1].active=false;
 234:src/main.cpp  ****     int pka=0;int32_t da=0;
 235:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(delta[i]>da){da=delta[i];pka=i;}
 236:src/main.cpp  ****     if(da<TOUCH_THRESHOLD)return 0;
 237:src/main.cpp  ****     int ws=pka-2;if(ws<0)ws=0;int we=pka+2;if(we>=N_CH)we=N_CH-1;
 238:src/main.cpp  ****     int32_t pa;int pca;
 239:src/main.cpp  ****     int32_t posa=centroid_window(delta,ws,we,&pa,&pca);
 240:src/main.cpp  ****     out[0]={true,posa,pressure_pct(pa),pca,pa};
 241:src/main.cpp  **** 
 242:src/main.cpp  ****     int32_t d2[N_CH];
 243:src/main.cpp  ****     int ss=pka-2;if(ss<0)ss=0;int se=pka+2;if(se>=N_CH)se=N_CH-1;
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccyGWFCh.s 			page 13


 244:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
 245:src/main.cpp  ****     int pkb=0;int32_t db=0;
 246:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(d2[i]>db){db=d2[i];pkb=i;}
 247:src/main.cpp  ****     int sep=pkb-pka;if(sep<0)sep=-sep;
 248:src/main.cpp  ****     if(db<TOUCH_THRESHOLD||sep<MIN_FINGER_SEP)return 1;
 249:src/main.cpp  ****     int ws2=pkb-2;if(ws2<0)ws2=0;int we2=pkb+2;if(we2>=N_CH)we2=N_CH-1;
 250:src/main.cpp  ****     int32_t pb;int pcb;
 251:src/main.cpp  ****     int32_t posb=centroid_window(d2,ws2,we2,&pb,&pcb);
 252:src/main.cpp  ****     out[1]={true,posb,pressure_pct(pb),pcb,pb};
 253:src/main.cpp  ****     return 2;
 254:src/main.cpp  **** }
