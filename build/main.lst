 828:src/voice.h   **** // ŌöĆŌöĆ Voice 12: SH-101-style mono synth ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 829:src/voice.h   **** //   A Roland SH-101 homage: one "VCO" putting out saw + square (pulse) together
 830:src/voice.h   **** //   over a square sub-oscillator an octave down ŌĆö the fat single-osc stack the
 831:src/voice.h   **** //   SH-101 is loved for ŌĆö through the resonant 4-pole ladder. The cutoff sits
 832:src/voice.h   **** //   fairly closed and pressure sweeps it wide open with high resonance for the
 833:src/voice.h   **** //   squelchy acid "wow" (the SH-101's filter-env squelch, here played by finger
 834:src/voice.h   **** //   pressure). A whisper of noise, portamento glide between notes. Plays diatonic
 835:src/voice.h   **** //   triads (chords = true) quantized to a MINOR scale so acid chords stay in key
 836:src/voice.h   **** //   while slides bend the whole chord. Bass + leads. (Major twin: VOICE_SH101_MAJ.)
 837:src/voice.h   **** static constexpr Voice VOICE_SH101 = {
 838:src/voice.h   ****     "SH-101 min",
