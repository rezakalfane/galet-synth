1369:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
1370:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1371:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1372:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1373:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1374:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1375:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1376:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1377:src/main.cpp  ****             };
