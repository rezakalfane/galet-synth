 525:src/main.cpp  **** // ‚îÄ‚îÄ Note quantizer ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 526:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 527:src/main.cpp  **** float quantize_midi(float midi)
 528:src/main.cpp  **** {
ARM GAS  /tmp/claude-502/ccx0z8cn.s 			page 18


 529:src/main.cpp  ****     int root = (int)midi;
 530:src/main.cpp  ****     int pc   = root % 12;
 531:src/main.cpp  ****     int oct  = root / 12;
 532:src/main.cpp  ****     // find nearest scale degree
 533:src/main.cpp  ****     int best_deg=0, best_dist=127;
 534:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 535:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 536:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 537:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 538:src/main.cpp  ****     }
 539:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 540:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 541:src/main.cpp  ****     float frac=midi-(float)root;
 542:src/main.cpp  ****     return q+frac;
 543:src/main.cpp  **** }
