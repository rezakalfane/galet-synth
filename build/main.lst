   1:src/dsp.h     **** #pragma once
   2:src/dsp.h     **** // Pure DSP/math primitives ŌĆö no hardware, no global state (except moog()
   3:src/dsp.h     **** // which lives in the engine). Header-only & inline for the audio hot path.
   4:src/dsp.h     **** #include <math.h>
   5:src/dsp.h     **** 
   6:src/dsp.h     **** // Oscillator shape ŌĆö set per oscillator, so one voice can mix (e.g. saw root +
   7:src/dsp.h     **** // square fifth + sine sub). SQUARE and SAW are naive (not band-limited) ŌĆö they
   8:src/dsp.h     **** // alias at high pitch, but on a low bass voice that just reads as rich harmonics
   9:src/dsp.h     **** // for the filter to chew.
  10:src/dsp.h     **** enum Waveform { WAVE_TRI, WAVE_SINE, WAVE_SQUARE, WAVE_SAW };
