 923:src/main.cpp  ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 924:src/main.cpp  ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 925:src/main.cpp  ****               + osc(h.phs,V.sub_wave )*V.sub_level
 926:src/main.cpp  ****               + osc(h.pho,V.oct_wave )*V.oct_level;
