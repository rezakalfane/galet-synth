 217:src/main.cpp  **** 
 218:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 219:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 220:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
