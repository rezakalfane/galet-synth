 134:src/main.cpp  ****     true,          // osc2 follows finger-2 detune
 135:src/main.cpp  ****     0.3f, 12.0f, 0.75f,
 136:src/main.cpp  ****     2.5f,
 137:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 138:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.15f, 0.18f, 4.0f, 400.0f, 40.0f
 139:src/main.cpp  **** };
