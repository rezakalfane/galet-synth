 229:src/main.cpp  ****     "Scream",
 230:src/main.cpp  ****     90.0f, 720.0f, 2.07944f,   // 90ŌĆō720 Hz, ln(8) ŌĆö high, cutting register
 231:src/main.cpp  ****     1.0f,    0.42f, WAVE_SAW,   // osc1  ŌĆö saw root
 232:src/main.cpp  ****     1.008f,  0.38f, WAVE_SAW,   // osc2  ŌĆö slightly sharp twin ŌåÆ thick beating buzz
 233:src/main.cpp  ****     0.5f,    0.20f, WAVE_SAW,   // sub   ŌĆö a little weight underneath
 234:src/main.cpp  ****     2.0f,    0.30f, WAVE_SAW,   // oct   ŌĆö octave up for bright, cutting scream
 235:src/main.cpp  ****     false,                      // osc2 is a fixed detune, not finger-2 controlled
 236:src/main.cpp  ****     3.0f, 11.0f, 0.90f,         // bright base + wide sweep + near-self-osc resonance
 237:src/main.cpp  ****     4.0f,                       // heavy drive ŌĆö saturated and aggressive
 238:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 239:src/main.cpp  ****     0.05f, 1.0f, 2.5f, 0.40f, 0.30f, 2.0f, 200.0f, 35.0f // hiss + inharmonic metallic ring-mod
 240:src/main.cpp  **** };
