 354:src/main.cpp  ****         hw.dac.WriteValue(DacHandle::Channel::TWO, on ? (uint16_t)LED2_MAX : 0);
 355:src/main.cpp  ****         g_led3_duty = on ? LED3_INTENSITY : 0.0f;
