 267:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 268:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 269:src/main.cpp  **** float quantize_midi(float midi)
 270:src/main.cpp  **** {
 271:src/main.cpp  ****     int root = (int)midi;
 272:src/main.cpp  ****     int pc   = root % 12;
 273:src/main.cpp  ****     int oct  = root / 12;
 274:src/main.cpp  ****     // find nearest scale degree
 275:src/main.cpp  ****     int best_deg=0, best_dist=127;
 276:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 277:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 278:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 279:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 280:src/main.cpp  ****     }
 281:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 282:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 283:src/main.cpp  ****     float frac=midi-(float)root;
 284:src/main.cpp  ****     return q+frac;
 285:src/main.cpp  **** }
