 896:src/voice.h   ****     // NOISE
 897:src/voice.h   ****     0.02f,               // noise level ‚Äî a whisper (the SH-101 noise source)
 898:src/voice.h   ****     1.0f,                // keytrack
 899:src/voice.h   ****     1.0f,                // ringmod ratio
 900:src/voice.h   ****     0.10f,               // ringmod max
 901:src/voice.h   ****     0.12f,               // fold max
