 243:src/voice.h   ****     1.6f,    0.15f, WAVE_SINE,   // osc2  ‚Äî upper mode (inharmonic ring)
 244:src/voice.h   ****     0.5f,    0.10f, WAVE_SINE,   // sub   ‚Äî a little thump
 245:src/voice.h   ****     2.0f,    0.0f,  WAVE_SINE,   // oct   ‚Äî off
 246:src/voice.h   ****     false,                       // osc2 is a fixed ratio, not finger-2 detune
 247:src/voice.h   ****     3.0f, 3.0f, 0.30f,           // tom ‚Äî low 1-pole cutoff for a dark, round body
 248:src/voice.h   ****     1.5f,                        // drive ‚Äî snap and saturation on hard hits
 249:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 250:src/voice.h   ****     0.70f, 0.3f, 1.0f, 0.0f, 0.10f, 1.0f, 150.0f, 5.0f,  // noise-dominant, instant hit, short tail
 251:src/voice.h   ****     // pitch_env_oct, pitch_env_ms ‚Äî tom "boww": start 1 oct up, drop in 80 ms
 252:src/voice.h   ****     1.0f, 80.0f,
 253:src/voice.h   ****     0.0f,        // noise_hp
