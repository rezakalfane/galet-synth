 216:src/main.cpp  **** 
 217:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 218:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 219:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
 220:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
 221:src/main.cpp  **** 
 222:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 223:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 224:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 225:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 226:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
