 904:src/voice.h   ****     // FILTER
 905:src/voice.h   ****     false,               // osc2 is a fixed unison, not finger-2 detune
 906:src/voice.h   ****     0.8f,
 907:src/voice.h   ****     9.0f,
 908:src/voice.h   ****     0.80f,               // closed-ish base, huge pressure sweep, squelchy acid res
