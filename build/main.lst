 267:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 268:src/main.cpp  **** static inline float fast_tanh(float x)
 269:src/main.cpp  **** {
 270:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 271:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 272:src/main.cpp  ****     float x2=x*x;
 273:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 274:src/main.cpp  **** }
 275:src/main.cpp  **** 
 276:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 277:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 278:src/main.cpp  **** float quantize_midi(float midi)
 279:src/main.cpp  **** {
 280:src/main.cpp  ****     int root = (int)midi;
 281:src/main.cpp  ****     int pc   = root % 12;
 282:src/main.cpp  ****     int oct  = root / 12;
 283:src/main.cpp  ****     // find nearest scale degree
 284:src/main.cpp  ****     int best_deg=0, best_dist=127;
 285:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 286:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 287:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 288:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 289:src/main.cpp  ****     }
 290:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 291:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 292:src/main.cpp  ****     float frac=midi-(float)root;
 293:src/main.cpp  ****     return q+frac;
 294:src/main.cpp  **** }
