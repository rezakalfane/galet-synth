 615:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 616:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 617:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 618:src/main.cpp  ****     if(raw <= 0)     return 0;
 619:src/main.cpp  ****     if(raw >= range) return 100;
 620:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 621:src/main.cpp  ****     if(raw > range) raw = range;
 622:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 623:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 624:src/main.cpp  ****     // Integer sqrt via Newton
 625:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 626:src/main.cpp  ****     s = (s + scaled/s) / 2;
 627:src/main.cpp  ****     s = (s + scaled/s) / 2;
 628:src/main.cpp  ****     s = (s + scaled/s) / 2;
 629:src/main.cpp  ****     s = (s + scaled/s) / 2;
 630:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 631:src/main.cpp  ****     if(s < 0)   s = 0;
 632:src/main.cpp  ****     if(s > 100) s = 100;
 633:src/main.cpp  ****     return s;
 634:src/main.cpp  **** }
