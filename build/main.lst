 297:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 298:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 299:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 300:src/main.cpp  ****     if(raw <= 0)     return 0;
ARM GAS  /tmp/claude-502/cc5FnLRa.s 			page 14


 301:src/main.cpp  ****     if(raw >= range) return 100;
 302:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 303:src/main.cpp  ****     if(raw > range) raw = range;
 304:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 305:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 306:src/main.cpp  ****     // Integer sqrt via Newton
 307:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 308:src/main.cpp  ****     s = (s + scaled/s) / 2;
 309:src/main.cpp  ****     s = (s + scaled/s) / 2;
 310:src/main.cpp  ****     s = (s + scaled/s) / 2;
 311:src/main.cpp  ****     s = (s + scaled/s) / 2;
 312:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 313:src/main.cpp  ****     if(s < 0)   s = 0;
 314:src/main.cpp  ****     if(s > 100) s = 100;
 315:src/main.cpp  ****     return s;
 316:src/main.cpp  **** }
