 814:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ŌĆö matches sin(2ŽĆ┬Ęph).
 815:src/main.cpp  **** static inline float osc_sine(float ph){
 816:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 817:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -ŽĆ..ŽĆ (angle shifted by ŽĆ)
 818:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 819:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 820:src/main.cpp  ****     return -y;                                 // undo the ŽĆ shift: sin(x+ŽĆ) = -sin(x)
 821:src/main.cpp  **** }
 822:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 823:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 824:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
