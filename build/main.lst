 704:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 705:src/main.cpp  ****         const Voice& V = VOICES[vidx];
 706:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 707:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 708:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
