 197:src/main.cpp  **** 
 198:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 199:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 200:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
