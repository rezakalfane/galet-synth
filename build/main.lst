 285:src/voice.h   **** // ‚îÄ‚îÄ Voice 10: snare (noise-driven) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 286:src/voice.h   **** //   The bright, noisy cousin of the Tom ‚Äî PLAY IT BY TAPPING. Broadband noise
 287:src/voice.h   **** //   (the "wires" rattle) dominates over two tonal modes (body + a 1.8√ó ring); a
 288:src/voice.h   **** //   wide-open filter keeps it crisp and cracking. Instant attack, short tail,
 289:src/voice.h   **** //   and a quick subtle pitch snap (0.7 oct in 30 ms) for the hit. Harder presses
 290:src/voice.h   **** //   open it further. Finger-1 position tunes the drum.
 291:src/voice.h   **** static constexpr Voice VOICE_SNARE = {
 292:src/voice.h   ****     "Snare",
 293:src/voice.h   ****     150.0f, 500.0f, 1.20397f,   // 150‚Äì500 Hz, ln(3.33) ‚Äî snare tuning range
 294:src/voice.h   ****     1.0f,    0.15f, WAVE_SINE,   // osc1  ‚Äî body (lower mode)
 295:src/voice.h   ****     1.8f,    0.12f, WAVE_TRI,    // osc2  ‚Äî upper mode/ring (triangle = more harmonics)
 296:src/voice.h   ****     0.5f,    0.05f, WAVE_SINE,   // sub   ‚Äî slight body weight
 297:src/voice.h   ****     2.0f,    0.0f,  WAVE_SINE,   // oct   ‚Äî off
 298:src/voice.h   ****     false,                       // osc2 is a fixed ratio, not finger-2 detune
 299:src/voice.h   ****     18.0f, 4.0f, 0.30f,          // wide open & bright ‚Äî the noise rattle cracks through
