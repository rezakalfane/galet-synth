1414:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
1415:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1416:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
1417:src/main.cpp  ****             };
1418:src/main.cpp  **** 
1419:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top.
