 596:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 597:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 598:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 599:src/main.cpp  ****     if(raw <= 0)     return 0;
 600:src/main.cpp  ****     if(raw >= range) return 100;
 601:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 602:src/main.cpp  ****     if(raw > range) raw = range;
 603:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 604:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 605:src/main.cpp  ****     // Integer sqrt via Newton
 606:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 607:src/main.cpp  ****     s = (s + scaled/s) / 2;
 608:src/main.cpp  ****     s = (s + scaled/s) / 2;
 609:src/main.cpp  ****     s = (s + scaled/s) / 2;
 610:src/main.cpp  ****     s = (s + scaled/s) / 2;
 611:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 612:src/main.cpp  ****     if(s < 0)   s = 0;
 613:src/main.cpp  ****     if(s > 100) s = 100;
 614:src/main.cpp  ****     return s;
 615:src/main.cpp  **** }
