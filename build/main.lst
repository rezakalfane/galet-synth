 924:src/main.cpp  **** 
 925:src/main.cpp  ****             // Convert to MIDI for quantizer: midi = 69 + 12*log2(freq/440)
 926:src/main.cpp  ****             // log2(x) = ln(x)/ln(2); ln approx via y=(x-1)/(x+1) series
 927:src/main.cpp  ****             float freq_ratio = freq_continuous / 440.0f;
 928:src/main.cpp  ****             float y = (freq_ratio - 1.0f) / (freq_ratio + 1.0f);
 929:src/main.cpp  ****             float y2 = y*y;
 930:src/main.cpp  ****             float ln_ratio = 2.0f*y*(1.0f + y2*(0.3333f + y2*0.2f));
 931:src/main.cpp  ****             float midi_raw = 69.0f + 17.3123f * ln_ratio; // 17.3123 = 12/ln(2)
