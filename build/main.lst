 605:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 606:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 607:src/main.cpp  **** float quantize_midi(float midi)
 608:src/main.cpp  **** {
 609:src/main.cpp  ****     int root = (int)midi;
 610:src/main.cpp  ****     int pc   = root % 12;
 611:src/main.cpp  ****     int oct  = root / 12;
 612:src/main.cpp  ****     // find nearest scale degree
 613:src/main.cpp  ****     int best_deg=0, best_dist=127;
 614:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 615:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 616:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 617:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 618:src/main.cpp  ****     }
 619:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 620:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 621:src/main.cpp  ****     float frac=midi-(float)root;
 622:src/main.cpp  ****     return q+frac;
 623:src/main.cpp  **** }
