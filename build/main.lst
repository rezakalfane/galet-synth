 134:src/main.cpp  **** bool mpr_init()
 135:src/main.cpp  **** {
 136:src/main.cpp  ****     mpr_write(REG_SOFTRESET,0x63);System::Delay(10);
 137:src/main.cpp  ****     mpr_write(REG_ECR,0x00);
 138:src/main.cpp  ****     mpr_write(REG_MHDR,0x01);mpr_write(REG_NHDR,0x01);
 139:src/main.cpp  ****     mpr_write(REG_NCLR,0x10);mpr_write(REG_FDLR,0x20);
 140:src/main.cpp  ****     mpr_write(REG_MHDF,0x01);mpr_write(REG_NHDF,0x01);
 141:src/main.cpp  ****     mpr_write(REG_NCLF,0x10);mpr_write(REG_FDLF,0x20);
 142:src/main.cpp  ****     mpr_write(REG_NHDT,0x00);mpr_write(REG_NCLT,0x00);mpr_write(REG_FDLT,0x00);
 143:src/main.cpp  ****     for(uint8_t ch=0;ch<12;ch++){mpr_write(0x41+ch*2,4);mpr_write(0x42+ch*2,2);}
 144:src/main.cpp  ****     mpr_write(REG_DEBOUNCE,0x11);
 145:src/main.cpp  ****     mpr_write(REG_CONFIG1,0xF0);  // FFI=34 | CDC=48uA
 146:src/main.cpp  ****     mpr_write(REG_CONFIG2,0x4C);  // CDT=4us | SFI=18 | ESI=1ms
 147:src/main.cpp  ****     mpr_write(REG_ECR,0x8C);
 148:src/main.cpp  ****     System::Delay(100);
 149:src/main.cpp  ****     uint8_t ecr=0;mpr_read(REG_ECR,&ecr,1);
 150:src/main.cpp  ****     return(ecr==0x8C);
 151:src/main.cpp  **** }
 152:src/main.cpp  **** 
 153:src/main.cpp  **** void read_electrodes(uint16_t* out)
 154:src/main.cpp  **** {
 155:src/main.cpp  ****     uint8_t buf[24];
 156:src/main.cpp  ****     mpr_read(REG_ELE0_LSB,buf,24);
 157:src/main.cpp  ****     for(int i=0;i<N_CH;i++)
 158:src/main.cpp  ****         out[i]=(uint16_t)(buf[i*2]|((buf[i*2+1]&0x03)<<8));
 159:src/main.cpp  **** }
 160:src/main.cpp  **** 
 161:src/main.cpp  **** void capture_baseline(uint16_t* bl)
 162:src/main.cpp  **** {
 163:src/main.cpp  ****     uint32_t acc[N_CH]={0};uint16_t tmp[N_CH];
 164:src/main.cpp  ****     for(int s=0;s<REBASELINE_SAMPLES;s++){
 165:src/main.cpp  ****         read_electrodes(tmp);
 166:src/main.cpp  ****         for(int i=0;i<N_CH;i++)acc[i]+=tmp[i];
 167:src/main.cpp  ****         System::Delay(5);
 168:src/main.cpp  ****     }
 169:src/main.cpp  ****     for(int i=0;i<N_CH;i++)bl[i]=(uint16_t)(acc[i]/REBASELINE_SAMPLES);
 170:src/main.cpp  **** }
