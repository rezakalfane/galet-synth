 474:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 475:src/main.cpp  **** static inline float fast_tanh(float x)
 476:src/main.cpp  **** {
 477:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 478:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 479:src/main.cpp  ****     float x2=x*x;
 480:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 481:src/main.cpp  **** }
 482:src/main.cpp  **** 
 483:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 484:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 485:src/main.cpp  **** float quantize_midi(float midi)
 486:src/main.cpp  **** {
 487:src/main.cpp  ****     int root = (int)midi;
 488:src/main.cpp  ****     int pc   = root % 12;
 489:src/main.cpp  ****     int oct  = root / 12;
 490:src/main.cpp  ****     // find nearest scale degree
 491:src/main.cpp  ****     int best_deg=0, best_dist=127;
 492:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 493:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 494:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 495:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 496:src/main.cpp  ****     }
 497:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 498:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 499:src/main.cpp  ****     float frac=midi-(float)root;
 500:src/main.cpp  ****     return q+frac;
 501:src/main.cpp  **** }
