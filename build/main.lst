 512:src/voice.h   ****     // SUB OSCILLATOR
 513:src/voice.h   ****     0.5f,
 514:src/voice.h   ****     0.22f,
 515:src/voice.h   ****     WAVE_SAW,            // sub   ŌĆö octave-down body/weight
 516:src/voice.h   ****     // OCTAVE OSCILLATOR
 517:src/voice.h   ****     2.0f,
 518:src/voice.h   ****     0.18f,
 519:src/voice.h   ****     WAVE_SAW,            // oct   ŌĆö octave-up jangle / pick brightness
