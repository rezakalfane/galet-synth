 473:src/voice.h   **** // ‚îÄ‚îÄ Voice 6: electric guitar power chord ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 474:src/voice.h   **** //   A driven sawtooth power chord ‚Äî each note is a root + fixed perfect fifth +
 475:src/voice.h   **** //   octave-up jangle over a saw octave-down body, so it plays as a chord like a
 476:src/voice.h   **** //   rock guitar. Heavy-ish drive adds overdrive crunch; the filter sits a touch
 477:src/voice.h   **** //   above the fundamental and sweeps wide open with pressure (dig in = bright,
 478:src/voice.h   **** //   pick-attack bite), with resonance for a vocal amp "quack". A fast pitch-env
 479:src/voice.h   **** //   "twang" + a little pick-grit noise on the onset, then amp decay-to-silence
 480:src/voice.h   **** //   (decay_ms/sustain below) so each note plucks and rings out over ~1.2 s while
 481:src/voice.h   **** //   held ‚Äî like a struck string, not an organ. Quantized to a major scale so
 482:src/voice.h   **** //   tapped chords land in key. For a BASS guitar instead: drop freq_low/high ~¬Ω,
 483:src/voice.h   **** //   cut drive to ~1.5, use WAVE_TRI, and raise `sustain` if you want it to hold.
 484:src/voice.h   **** static constexpr Voice VOICE_GUITAR = {
 485:src/voice.h   ****     "Guitar",
 486:src/voice.h   ****     // FREQUENCY RANGE
 487:src/voice.h   ****     80.0f,
 488:src/voice.h   ****     320.0f,
 489:src/voice.h   ****     1.38629f,            // 80‚Äì320 Hz, ln(4) ‚Äî E2-ish up two octaves
 490:src/voice.h   ****     // OSCILLATOR STACK
 491:src/voice.h   ****     1.0f,
 492:src/voice.h   ****     0.40f,
 493:src/voice.h   ****     WAVE_SAW,            // osc1  ‚Äî saw root (bright, string-like)
 494:src/voice.h   ****     // SECONDARY OSCILLATOR
 495:src/voice.h   ****     RATIO_FIFTH,
 496:src/voice.h   ****     0.30f,
 497:src/voice.h   ****     WAVE_SAW,            // osc2  ‚Äî fixed perfect fifth (the power chord)
 498:src/voice.h   ****     // SUB OSCILLATOR
 499:src/voice.h   ****     0.5f,
ARM GAS  /tmp/claude-502/ccZeCIQr.s 			page 44


 500:src/voice.h   ****     0.22f,
 501:src/voice.h   ****     WAVE_SAW,            // sub   ‚Äî octave-down body/weight
 502:src/voice.h   ****     // OCTAVE OSCILLATOR
 503:src/voice.h   ****     2.0f,
 504:src/voice.h   ****     0.18f,
 505:src/voice.h   ****     WAVE_SAW,            // oct   ‚Äî octave-up jangle / pick brightness
 506:src/voice.h   ****     // FILTER
 507:src/voice.h   ****     false,               // osc2 is a fixed fifth, not finger-2 detune
 508:src/voice.h   ****     1.5f,
 509:src/voice.h   ****     6.0f,
 510:src/voice.h   ****     0.42f,               // bright-ish base, wide sweep, resonant mid "quack" (amp-like)
 511:src/voice.h   ****     // DRIVE
 512:src/voice.h   ****     3.6f,                // overdrive crunch ‚Äî the electric-guitar grit
 513:src/voice.h   ****     // NOISE
 514:src/voice.h   ****     0.03f,               // noise level ‚Äî a little pick grit (rides the amp decay)
 515:src/voice.h   ****     1.0f,                // keytrack
 516:src/voice.h   ****     1.0f,                // ringmod ratio
 517:src/voice.h   ****     0.12f,               // ringmod max
 518:src/voice.h   ****     0.15f,               // fold max
 519:src/voice.h   ****     3.0f,                // attack ‚Äî fast pluck onset
 520:src/voice.h   ****     280.0f,              // release ‚Äî ring tail after lift
 521:src/voice.h   ****     8.0f,                // glide ‚Äî quick, distinct chord changes
 522:src/voice.h   ****     // PITCH ENVELOPE ‚Äî fast pick-attack "twang": start ~0.12 oct sharp, settle 18 ms
 523:src/voice.h   ****     0.12f, 18.0f,        // pitch_env_oct, pitch_env_ms
 524:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 525:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
 526:src/voice.h   ****     // PITCH QUANTIZE ‚Äî snap to a major scale on touch-down so chords land in key
 527:src/voice.h   ****     true,
 528:src/voice.h   ****     SCALE_MAJOR, (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0])),
 529:src/voice.h   ****     // AMP DECAY ‚Äî the pluck: ring out to silence over ~1.2 s while held
 530:src/voice.h   ****     1200.0f,             // decay_ms
 531:src/voice.h   ****     0.0f                 // sustain (0 = decays to silence)
 532:src/voice.h   **** };
