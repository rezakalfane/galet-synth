 276:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 277:src/main.cpp  **** {
 278:src/main.cpp  ****     for(int i=7;i>=0;i--){
 279:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 280:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 281:src/main.cpp  ****     }
 282:src/main.cpp  ****     sda_high();d();scl_high();d();
 283:src/main.cpp  ****     bool ack=!sda.Read();
 284:src/main.cpp  ****     scl_low();d();
 285:src/main.cpp  ****     return ack;
 286:src/main.cpp  **** }
 287:src/main.cpp  **** 
 288:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 289:src/main.cpp  **** {
 290:src/main.cpp  ****     uint8_t b=0;sda_high();
 291:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 292:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 293:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 294:src/main.cpp  ****     return b;
 295:src/main.cpp  **** }
