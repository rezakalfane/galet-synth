 862:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
 863:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 864:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 865:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 866:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 5808              		.loc 6 866 5 view .LVU1682
 867:src/main.cpp  ****         uint32_t start = System::GetNow();
