 288:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 289:src/main.cpp  **** static inline float fast_tanh(float x)
 290:src/main.cpp  **** {
 291:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 292:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 293:src/main.cpp  ****     float x2=x*x;
 294:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 295:src/main.cpp  **** }
 296:src/main.cpp  **** 
 297:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 298:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 299:src/main.cpp  **** float quantize_midi(float midi)
 300:src/main.cpp  **** {
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccgY3Zif.s 			page 14


 301:src/main.cpp  ****     int root = (int)midi;
 302:src/main.cpp  ****     int pc   = root % 12;
 303:src/main.cpp  ****     int oct  = root / 12;
 304:src/main.cpp  ****     // find nearest scale degree
 305:src/main.cpp  ****     int best_deg=0, best_dist=127;
 306:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 307:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 308:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 309:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 310:src/main.cpp  ****     }
 311:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 312:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 313:src/main.cpp  ****     float frac=midi-(float)root;
 314:src/main.cpp  ****     return q+frac;
 315:src/main.cpp  **** }
