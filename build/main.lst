 386:src/voice.h   ****     1.0f,                // keytrack
 387:src/voice.h   ****     2.5f,                // ringmod ratio ŌĆö inharmonic metallic
 388:src/voice.h   ****     0.40f,               // ringmod max
 389:src/voice.h   ****     0.30f,               // fold max
 390:src/voice.h   ****     2.0f,                // attack
