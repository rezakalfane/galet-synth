 119:src/voice.h   **** // ‚îÄ‚îÄ Diatonic triad ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 120:src/voice.h   **** // For a root pitch class (0‚Äì11 semitones within an octave) that belongs to
 121:src/voice.h   **** // `scale`, return the semitone offsets of the 3rd and 5th scale-degrees above it
 122:src/voice.h   **** // (stacking thirds: degrees i, i+2, i+4). Wrapping past the top of the scale
 123:src/voice.h   **** // adds an octave. Used by chord voices (Voice::chords). With no scale it falls
 124:src/voice.h   **** // back to a fixed major triad (4, 7). Pure (no Hz, no note-number line) so it
 125:src/voice.h   **** // runs in the host tests.
 126:src/voice.h   **** static inline void diatonic_triad(int root_pc, const int8_t *scale, int n,
 127:src/voice.h   ****                                   int &semis_third, int &semis_fifth) {
 128:src/voice.h   ****   if (!scale || n <= 0) {
 129:src/voice.h   ****     semis_third = 4;
 130:src/voice.h   ****     semis_fifth = 7;
 131:src/voice.h   ****     return;
 132:src/voice.h   ****   }
 133:src/voice.h   ****   int pc = ((root_pc % 12) + 12) % 12;
 134:src/voice.h   ****   // Nearest scale degree to the root pitch class.
 135:src/voice.h   ****   int idx = 0, best = 127;
 136:src/voice.h   ****   for (int i = 0; i < n; i++) {
 137:src/voice.h   ****     int d = scale[i] - pc;
 138:src/voice.h   ****     if (d < 0)
 139:src/voice.h   ****       d = -d;
 140:src/voice.h   ****     if (d < best) {
 141:src/voice.h   ****       best = d;
 142:src/voice.h   ****       idx = i;
 143:src/voice.h   ****     }
 144:src/voice.h   ****   }
 145:src/voice.h   ****   auto deg = [&](int k) { return scale[k % n] + 12 * (k / n); };
 146:src/voice.h   ****   int base = deg(idx);
 147:src/voice.h   ****   semis_third = deg(idx + 2) - base;
 148:src/voice.h   ****   semis_fifth = deg(idx + 4) - base;
 149:src/voice.h   **** }
 150:src/voice.h   **** 
 151:src/voice.h   **** // ‚îÄ‚îÄ Quantize scales ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 152:src/voice.h   **** // Semitone offsets within an octave. A voice with quantize = true snaps finger-1
 153:src/voice.h   **** // to the nearest degree of its `scale` (see Voice::scale / quantize_midi).
 154:src/voice.h   **** static constexpr int8_t SCALE_CHROMATIC[] = {0, 1, 2, 3, 4,  5,
 155:src/voice.h   ****                                              6, 7, 8, 9, 10, 11};
 156:src/voice.h   **** static constexpr int8_t SCALE_MAJOR[] = {0, 2, 4, 5, 7, 9, 11};
 157:src/voice.h   **** static constexpr int8_t SCALE_MINOR[] = {0, 2, 3, 5, 7, 8, 10};
 158:src/voice.h   **** 
 159:src/voice.h   **** // Perfect-fifth frequency ratio = 2^(7/12).
 160:src/voice.h   **** static constexpr float RATIO_FIFTH = 1.49831f;
