 529:src/main.cpp  **** 
 530:src/main.cpp  **** // Dispatch on the voice's waveform. VOICE.wave is a compile-time constant, so at
 531:src/main.cpp  **** // -O2 this folds to a single waveform call with no branch.
 532:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 533:src/main.cpp  ****     switch(w){
 534:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 535:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 536:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 537:src/main.cpp  ****         case WAVE_TRI:
 538:src/main.cpp  ****         default:          return tri(ph);
 539:src/main.cpp  ****     }
 540:src/main.cpp  **** }
 541:src/main.cpp  **** 
 542:src/main.cpp  **** // Moog 4-pole ladder
 543:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 544:src/main.cpp  **** {
 545:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 546:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 547:src/main.cpp  ****     float k  = 3.8f*res;
 548:src/main.cpp  ****     float fb = k*s_flt[3];
 549:src/main.cpp  ****     float x  = in - fb;
 550:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 551:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 552:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 553:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 554:src/main.cpp  ****     return s_flt[3];
 555:src/main.cpp  **** }
 556:src/main.cpp  **** 
 557:src/main.cpp  **** // Wavefolder distortion
 558:src/main.cpp  **** // Folds signal back when it exceeds threshold ‚Äî creates rich harmonics.
 559:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 560:src/main.cpp  **** static inline float wavefold(float in, float amount)
 561:src/main.cpp  **** {
 562:src/main.cpp  ****     if(amount < 0.01f) return in;
 563:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 564:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 565:src/main.cpp  ****     // Fold: reflect signal at ¬±1 boundary repeatedly
 566:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 567:src/main.cpp  ****     float x = driven;
 568:src/main.cpp  ****     // 2 passes of folding for richness
 569:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 570:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 571:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 572:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 573:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 574:src/main.cpp  ****     }
 575:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 576:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 577:src/main.cpp  **** }
