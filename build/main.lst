 976:src/main.cpp  ****             // ‚îÄ‚îÄ Direct exponential frequency mapping across the voice range ‚îÄ‚îÄ
 977:src/main.cpp  ****             // freq = freq_low * (freq_high/freq_low)^pos01
 978:src/main.cpp  ****             //      = freq_low * e^(pos01 * log_freq_ratio)
 979:src/main.cpp  ****             float earg = pos01 * VOICE.log_freq_ratio;
 980:src/main.cpp  ****             float ex   = 1.0f + earg*(1.0f + earg*(0.5f + earg*0.1667f));
 981:src/main.cpp  ****             float freq_continuous = clampf(VOICE.freq_low * ex, VOICE.freq_low, VOICE.freq_high);
 982:src/main.cpp  **** 
 983:src/main.cpp  ****             // Convert to MIDI for quantizer: midi = 69 + 12*log2(freq/440)
 984:src/main.cpp  ****             // log2(x) = ln(x)/ln(2); ln approx via y=(x-1)/(x+1) series
 985:src/main.cpp  ****             float freq_ratio = freq_continuous / 440.0f;
 986:src/main.cpp  ****             float y = (freq_ratio - 1.0f) / (freq_ratio + 1.0f);
 987:src/main.cpp  ****             float y2 = y*y;
 988:src/main.cpp  ****             float ln_ratio = 2.0f*y*(1.0f + y2*(0.3333f + y2*0.2f));
