 649:src/main.cpp  **** 
 650:src/main.cpp  ****             // Cutoff: base tracks 2├Ś pitch, pressure opens it up
 651:src/main.cpp  ****             // Light press = 1├Ś pitch (dark, Moog-like tracking)
 652:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
 653:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 654:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
 655:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
 656:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
 657:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
 658:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
 659:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 660:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
 661:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
 662:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
 663:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 664:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
 665:src/main.cpp  ****             };
 666:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
 667:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 668:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
 669:src/main.cpp  ****             };
 670:src/main.cpp  **** 
 671:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top
 672:src/main.cpp  ****             float prs_cut  = smootherstep(prs01);
 673:src/main.cpp  ****             float cutoff_oct = 12.0f * prs_cut;              // 12 octaves of sweep
 674:src/main.cpp  ****             float oct_arg  = cutoff_oct * 0.6931f;
 675:src/main.cpp  ****             float oct_mult = 1.0f + oct_arg*(1.0f + oct_arg*(0.5f + oct_arg*(0.1667f + oct_arg*0.04
 676:src/main.cpp  ****             float cutoff   = clampf(freq * 0.3f * oct_mult, 20.0f, 18000.0f); // screams
 677:src/main.cpp  **** 
 678:src/main.cpp  ****             // Vibrato: smoothstep, only activates above 60% pressure
 679:src/main.cpp  ****             float vib_in = clampf((prs01 - 0.6f) / 0.4f, 0.0f, 1.0f);
 680:src/main.cpp  ****             float vib    = smoothstep(vib_in) * 0.8f;
 681:src/main.cpp  **** 
 682:src/main.cpp  ****             // Drive: smoothstep ŌĆö clean at low, progressively warmer
 683:src/main.cpp  ****             float drive = 1.0f + smoothstep(prs01) * 2.5f;
 684:src/main.cpp  **** 
