  90:src/main.cpp  **** void i2c_start(){sda_high();d();scl_high();d();sda_low();d();scl_low();d();}
  91:src/main.cpp  **** void i2c_stop() {sda_low();d();scl_high();d();sda_high();d();}
  92:src/main.cpp  **** 
  93:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
  94:src/main.cpp  **** {
  95:src/main.cpp  ****     for(int i=7;i>=0;i--){
  96:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
  97:src/main.cpp  ****         d();scl_high();d();scl_low();d();
  98:src/main.cpp  ****     }
  99:src/main.cpp  ****     sda_high();d();scl_high();d();
 100:src/main.cpp  ****     bool ack=!sda.Read();
 101:src/main.cpp  ****     scl_low();d();
 102:src/main.cpp  ****     return ack;
 103:src/main.cpp  **** }
 104:src/main.cpp  **** 
 105:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 106:src/main.cpp  **** {
 107:src/main.cpp  ****     uint8_t b=0;sda_high();
 108:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 109:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 110:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 111:src/main.cpp  ****     return b;
 112:src/main.cpp  **** }
