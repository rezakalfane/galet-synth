 664:src/voice.h   ****     // OCTAVE OSCILLATOR
 665:src/voice.h   ****     2.0f,
 666:src/voice.h   ****     0.0f,
 667:src/voice.h   ****     WAVE_SINE,           // oct   ŌĆö off
 668:src/voice.h   ****     // FILTER
 669:src/voice.h   ****     false,               // osc2 is a fixed ratio, not finger-2 detune
 670:src/voice.h   ****     3.0f,
 671:src/voice.h   ****     2.0f,
 672:src/voice.h   ****     0.20f,               // very closed/dark ŌĆö round; tiny pressure sweep
 673:src/voice.h   ****     // DRIVE
