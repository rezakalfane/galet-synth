  96:src/main.cpp  **** // ŌöĆŌöĆ Bit-bang I2C ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  97:src/main.cpp  **** // SDA: OUTPUT_OD + PULLUP ŌĆö Write(1) releases (high-Z, pulled up), Write(0) drives low.
  98:src/main.cpp  **** //      Read() works in OD mode (STM32 IDR always reflects actual pin state).
  99:src/main.cpp  **** // SCL: OUTPUT push-pull ŌĆö master always drives it, never reads it.
 100:src/main.cpp  **** // Both pins inited once in main(); no mode switching in the hot path.
 101:src/main.cpp  **** inline void sda_high(){sda.Write(true);}
 102:src/main.cpp  **** inline void sda_low() {sda.Write(false);}
 103:src/main.cpp  **** inline void scl_high(){scl.Write(true);}
 104:src/main.cpp  **** inline void scl_low() {scl.Write(false);}
 105:src/main.cpp  **** inline void d(){System::DelayUs(HP);}
 106:src/main.cpp  **** 
 107:src/main.cpp  **** void i2c_start(){sda_high();d();scl_high();d();sda_low();d();scl_low();d();}
 108:src/main.cpp  **** void i2c_stop() {sda_low();d();scl_high();d();sda_high();d();}
 109:src/main.cpp  **** 
 110:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 111:src/main.cpp  **** {
 112:src/main.cpp  ****     for(int i=7;i>=0;i--){
 113:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 114:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 115:src/main.cpp  ****     }
 116:src/main.cpp  ****     sda_high();d();scl_high();d();
 117:src/main.cpp  ****     bool ack=!sda.Read();
 118:src/main.cpp  ****     scl_low();d();
 119:src/main.cpp  ****     return ack;
 120:src/main.cpp  **** }
 121:src/main.cpp  **** 
 122:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 123:src/main.cpp  **** {
 124:src/main.cpp  ****     uint8_t b=0;sda_high();
 125:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 126:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 127:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 128:src/main.cpp  ****     return b;
 129:src/main.cpp  **** }
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccgY3Zif.s 			page 11


 130:src/main.cpp  **** 
 131:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 132:src/main.cpp  **** {
 133:src/main.cpp  ****     i2c_start();
 134:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 135:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 136:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 137:src/main.cpp  ****     i2c_stop();return true;
 138:src/main.cpp  **** }
 139:src/main.cpp  **** 
 140:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 141:src/main.cpp  **** {
 142:src/main.cpp  ****     i2c_start();
 143:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 144:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 145:src/main.cpp  ****     i2c_start();
 146:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 147:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 148:src/main.cpp  ****     i2c_stop();return true;
 149:src/main.cpp  **** }
 150:src/main.cpp  **** 
 151:src/main.cpp  **** bool mpr_init()
 152:src/main.cpp  **** {
 153:src/main.cpp  ****     mpr_write(REG_SOFTRESET,0x63);System::Delay(10);
 154:src/main.cpp  ****     mpr_write(REG_ECR,0x00);
 155:src/main.cpp  ****     mpr_write(REG_MHDR,0x01);mpr_write(REG_NHDR,0x01);
 156:src/main.cpp  ****     mpr_write(REG_NCLR,0x10);mpr_write(REG_FDLR,0x20);
 157:src/main.cpp  ****     mpr_write(REG_MHDF,0x01);mpr_write(REG_NHDF,0x01);
 158:src/main.cpp  ****     mpr_write(REG_NCLF,0x10);mpr_write(REG_FDLF,0x20);
 159:src/main.cpp  ****     mpr_write(REG_NHDT,0x00);mpr_write(REG_NCLT,0x00);mpr_write(REG_FDLT,0x00);
 160:src/main.cpp  ****     for(uint8_t ch=0;ch<12;ch++){mpr_write(0x41+ch*2,4);mpr_write(0x42+ch*2,2);}
 161:src/main.cpp  ****     mpr_write(REG_DEBOUNCE,0x11);
 162:src/main.cpp  ****     mpr_write(REG_CONFIG1,0x50);
 163:src/main.cpp  ****     mpr_write(REG_CONFIG2,0x7C);  // CDT=32us SFI=18 ESI=1ms
 164:src/main.cpp  ****     mpr_write(REG_ECR,0x8C);
 165:src/main.cpp  ****     System::Delay(100);
 166:src/main.cpp  ****     uint8_t ecr=0;mpr_read(REG_ECR,&ecr,1);
 167:src/main.cpp  ****     return(ecr==0x8C);
 168:src/main.cpp  **** }
 169:src/main.cpp  **** 
 170:src/main.cpp  **** void read_electrodes(uint16_t* out)
 171:src/main.cpp  **** {
 172:src/main.cpp  ****     uint8_t buf[24];
 173:src/main.cpp  ****     mpr_read(REG_ELE0_LSB,buf,24);
 174:src/main.cpp  ****     for(int i=0;i<N_CH;i++)
 175:src/main.cpp  ****         out[i]=(uint16_t)(buf[i*2]|((buf[i*2+1]&0x03)<<8));
 176:src/main.cpp  **** }
 177:src/main.cpp  **** 
 178:src/main.cpp  **** void capture_baseline(uint16_t* bl)
 179:src/main.cpp  **** {
 180:src/main.cpp  ****     uint32_t acc[N_CH]={0};uint16_t tmp[N_CH];
 181:src/main.cpp  ****     for(int s=0;s<REBASELINE_SAMPLES;s++){
 182:src/main.cpp  ****         read_electrodes(tmp);
 183:src/main.cpp  ****         for(int i=0;i<N_CH;i++)acc[i]+=tmp[i];
 184:src/main.cpp  ****         System::Delay(5);
 185:src/main.cpp  ****     }
 186:src/main.cpp  ****     for(int i=0;i<N_CH;i++)bl[i]=(uint16_t)(acc[i]/REBASELINE_SAMPLES);
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccgY3Zif.s 			page 12


 187:src/main.cpp  **** }
