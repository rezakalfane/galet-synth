 756:src/voice.h   **** // ŌöĆŌöĆ Voice 11: hi-hat (noise-driven) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 757:src/voice.h   **** //   A crisp "tss" ŌĆö PLAY IT BY TAPPING. Almost pure high-frequency noise through
 758:src/voice.h   **** //   a wide-open filter, with three inharmonic square partials for metallic edge
 759:src/voice.h   **** //   and no low end. Instant attack and a very short ~55 ms tail = a tight closed
 760:src/voice.h   **** //   hat. Finger-1 position tunes the metallic pitch. (Raise release_ms for an
 761:src/voice.h   **** //   open-hat feel.)
 762:src/voice.h   **** static constexpr Voice VOICE_HIHAT = {
 763:src/voice.h   ****     "HiHat",
