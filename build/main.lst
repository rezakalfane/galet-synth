 233:src/voice.h   **** // ‚îÄ‚îÄ Voice 8: tom / percussion (noise-driven) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 234:src/voice.h   **** //   A drum, not a sustained note ‚Äî PLAY IT BY TAPPING the glass. Noise over two
 235:src/voice.h   **** //   low sine modes (body + an inharmonic 1.6√ó ring) and a little sub thump. An
 236:src/voice.h   **** //   instant attack and a short ~150 ms release make each tap a percussive hit.
 237:src/voice.h   **** //   A closed, dark filter keeps it round and muffled (tom, not bright snare);
 238:src/voice.h   **** //   harder presses open it a touch. Finger-1 position tunes the drum.
 239:src/voice.h   **** static constexpr Voice VOICE_TOM = {
 240:src/voice.h   ****     "Tom",
 241:src/voice.h   ****     40.0f, 400.0f, 2.30259f,    // 40‚Äì400 Hz, ln(10) ‚Äî finger-1 tunes from kick/tom up
