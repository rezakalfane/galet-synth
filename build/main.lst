 715:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 716:src/main.cpp  **** static inline float fast_tanh(float x)
 717:src/main.cpp  **** {
 718:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 719:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 720:src/main.cpp  ****     float x2=x*x;
