 394:src/main.cpp  ****     // Trigger drum slot `s` from a tap at (pos, pressure): zone ŌåÆ drum, fine
 395:src/main.cpp  ****     // position ŌåÆ interval pitch, pressure ŌåÆ velocity (loudness/brightness/drive).
 396:src/main.cpp  ****     auto trigger_drum = [&](int s, int32_t pos, int32_t pressure){
 397:src/main.cpp  ****         float p    = clampf((float)pos / 1000.0f, 0.0f, 1.0f);
 398:src/main.cpp  ****         int   zone = (int)(p * 4.0f); if(zone > 3) zone = 3;
 399:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 400:src/main.cpp  ****         const Voice& V = g_bank[vidx];
 401:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 402:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 403:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
 404:src/main.cpp  ****         float freq = V.freq_low * MULTI_INTERVALS[step];
