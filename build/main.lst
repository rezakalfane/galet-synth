 162:src/main.cpp  **** // Up to 4 fingers tracked (for the polyphonic Drums MultiVoice). The mono
 163:src/main.cpp  **** // melodic path still only uses tracked[0] (pitch) and tracked[1] (effects).
 164:src/main.cpp  **** static constexpr int MAX_FINGERS = 4;
 165:src/main.cpp  **** struct Finger { bool active; int32_t pos,pressure,peak_ch,peak_delta; };
 166:src/main.cpp  **** struct TrackedFinger { bool alive; int32_t pos,pressure; int peak_ch; int32_t peak_delta; };
 167:src/main.cpp  **** static TrackedFinger tracked[MAX_FINGERS]={};
