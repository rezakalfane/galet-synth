 410:src/voice.h   **** // ‚îÄ‚îÄ Voice 5: screaming aggressive lead ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 411:src/voice.h   **** //   Detuned sawtooth stack (root + a hair-sharp twin + octave) for a thick,
 412:src/voice.h   **** //   buzzing supersaw bite, pushed up into a cutting register. Heavy drive and a
 413:src/voice.h   **** //   very high filter resonance make the cutoff whistle and scream as pressure
 414:src/voice.h   **** //   sweeps it wide open. Finger-2 pressure piles on ring-mod + wavefold for
 415:src/voice.h   **** //   extra snarl. Loud and nasty ‚Äî the output soft-clip keeps it from blowing up.
 416:src/voice.h   **** static constexpr Voice VOICE_SCREAM = {
 417:src/voice.h   ****     "Scream",
 418:src/voice.h   ****     // FREQUENCY RANGE
 419:src/voice.h   ****     90.0f,
 420:src/voice.h   ****     720.0f,
 421:src/voice.h   ****     2.07944f,            // 90‚Äì720 Hz, ln(8) ‚Äî high, cutting register
