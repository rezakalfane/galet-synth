 164:src/main.cpp  ****     constexpr uint16_t FSR_MIN       = 8000;
 165:src/main.cpp  ****     constexpr float    FSR_DEADZONE  = 0.10f;  // top 10% of travel = full volume (no change)
 166:src/main.cpp  ****     uint16_t           fsr_max       = 55000;
 167:src/main.cpp  ****     // Volume stays 100% until pressure passes the deadzone (raw drops below
