 284:src/main.cpp  **** // ŌöĆŌöĆ Maths helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 285:src/main.cpp  **** static inline float clampf(float v,float lo,float hi){
 286:src/main.cpp  ****     return v<lo?lo:v>hi?hi:v;
 287:src/main.cpp  **** }
