 889:src/voice.h   ****     // FILTER
 890:src/voice.h   ****     false,               // osc2 is a fixed unison, not finger-2 detune
 891:src/voice.h   ****     0.8f,
 892:src/voice.h   ****     9.0f,
 893:src/voice.h   ****     0.80f,               // closed-ish base, huge pressure sweep, squelchy acid res
 894:src/voice.h   ****     // DRIVE
