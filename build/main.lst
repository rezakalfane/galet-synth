 110:src/voice.h   **** // ŌöĆŌöĆ Diatonic triad ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 111:src/voice.h   **** // For a root pitch class (0ŌĆō11 semitones within an octave) that belongs to
 112:src/voice.h   **** // `scale`, return the semitone offsets of the 3rd and 5th scale-degrees above it
 113:src/voice.h   **** // (stacking thirds: degrees i, i+2, i+4). Wrapping past the top of the scale
 114:src/voice.h   **** // adds an octave. Used by chord voices (Voice::chords). With no scale it falls
 115:src/voice.h   **** // back to a fixed major triad (4, 7). Pure (no Hz, no note-number line) so it
 116:src/voice.h   **** // runs in the host tests.
 117:src/voice.h   **** static inline void diatonic_triad(int root_pc, const int8_t *scale, int n,
ARM GAS  /tmp/claude-502/cceToCIK.s 			page 40


 118:src/voice.h   ****                                   int &semis_third, int &semis_fifth) {
 119:src/voice.h   ****   if (!scale || n <= 0) {
 120:src/voice.h   ****     semis_third = 4;
 121:src/voice.h   ****     semis_fifth = 7;
 122:src/voice.h   ****     return;
 123:src/voice.h   ****   }
 124:src/voice.h   ****   int pc = ((root_pc % 12) + 12) % 12;
 125:src/voice.h   ****   // Nearest scale degree to the root pitch class.
 126:src/voice.h   ****   int idx = 0, best = 127;
 127:src/voice.h   ****   for (int i = 0; i < n; i++) {
 128:src/voice.h   ****     int d = scale[i] - pc;
 129:src/voice.h   ****     if (d < 0)
 130:src/voice.h   ****       d = -d;
 131:src/voice.h   ****     if (d < best) {
 132:src/voice.h   ****       best = d;
 133:src/voice.h   ****       idx = i;
 134:src/voice.h   ****     }
 135:src/voice.h   ****   }
 136:src/voice.h   ****   auto deg = [&](int k) { return scale[k % n] + 12 * (k / n); };
 137:src/voice.h   ****   int base = deg(idx);
 138:src/voice.h   ****   semis_third = deg(idx + 2) - base;
 139:src/voice.h   ****   semis_fifth = deg(idx + 4) - base;
 140:src/voice.h   **** }
 141:src/voice.h   **** 
 142:src/voice.h   **** // ŌöĆŌöĆ Quantize scales ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 143:src/voice.h   **** // Semitone offsets within an octave. A voice with quantize = true snaps finger-1
 144:src/voice.h   **** // to the nearest degree of its `scale` (see Voice::scale / quantize_midi).
 145:src/voice.h   **** static constexpr int8_t SCALE_CHROMATIC[] = {0, 1, 2, 3, 4,  5,
 146:src/voice.h   ****                                              6, 7, 8, 9, 10, 11};
 147:src/voice.h   **** static constexpr int8_t SCALE_MAJOR[] = {0, 2, 4, 5, 7, 9, 11};
 148:src/voice.h   **** static constexpr int8_t SCALE_MINOR[] = {0, 2, 3, 5, 7, 8, 10};
 149:src/voice.h   **** 
