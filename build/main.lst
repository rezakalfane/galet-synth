 165:src/voice.h   **** // ŌöĆŌöĆ Voice 5: screaming aggressive lead ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 166:src/voice.h   **** //   Detuned sawtooth stack (root + a hair-sharp twin + octave) for a thick,
 167:src/voice.h   **** //   buzzing supersaw bite, pushed up into a cutting register. Heavy drive and a
 168:src/voice.h   **** //   very high filter resonance make the cutoff whistle and scream as pressure
 169:src/voice.h   **** //   sweeps it wide open. Finger-2 pressure piles on ring-mod + wavefold for
 170:src/voice.h   **** //   extra snarl. Loud and nasty ŌĆö the output soft-clip keeps it from blowing up.
 171:src/voice.h   **** static constexpr Voice VOICE_SCREAM = {
 172:src/voice.h   ****     "Scream",
 173:src/voice.h   ****     90.0f, 720.0f, 2.07944f,   // 90ŌĆō720 Hz, ln(8) ŌĆö high, cutting register
