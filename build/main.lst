 814:src/main.cpp  **** }
 815:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 816:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 817:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
