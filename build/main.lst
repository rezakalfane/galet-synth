 897:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 898:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 899:src/main.cpp  ****         uint16_t scan[N_CH];
 900:src/main.cpp  **** 
 901:src/main.cpp  ****         while(true) {
 902:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 903:src/main.cpp  **** 
 904:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 905:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 906:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
