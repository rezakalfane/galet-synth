 341:src/main.cpp  **** // Triangle wave
 342:src/main.cpp  **** static inline float tri(float ph){
 343:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 344:src/main.cpp  **** }
 345:src/main.cpp  **** 
 346:src/main.cpp  **** // Moog 4-pole ladder
 347:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 348:src/main.cpp  **** {
 349:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 350:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 351:src/main.cpp  ****     float k  = 3.8f*res;
 352:src/main.cpp  ****     float fb = k*s_flt[3];
 353:src/main.cpp  ****     float x  = in - fb;
 354:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 355:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 356:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 357:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//cch1Xbz7.s 			page 15


 358:src/main.cpp  ****     return s_flt[3];
 359:src/main.cpp  **** }
 360:src/main.cpp  **** 
 361:src/main.cpp  **** // Wavefolder distortion
 362:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 363:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 364:src/main.cpp  **** static inline float wavefold(float in, float amount)
 365:src/main.cpp  **** {
 366:src/main.cpp  ****     if(amount < 0.01f) return in;
 367:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 368:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 369:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 370:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 371:src/main.cpp  ****     float x = driven;
 372:src/main.cpp  ****     // 2 passes of folding for richness
 373:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 374:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 375:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 376:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 377:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 378:src/main.cpp  ****     }
 379:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 380:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 381:src/main.cpp  **** }
