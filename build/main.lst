1013:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
1014:src/main.cpp  ****             // ‚îÄ‚îÄ Moog-style exponential cutoff ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
1015:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
1016:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ‚Äî exponential opening
1017:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
1018:src/main.cpp  ****             // This gives the classic Moog "closed ‚Üí wah ‚Üí bright" feel.
1019:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1020:src/main.cpp  ****             // ‚îÄ‚îÄ Smootherstep pressure curves (6x‚Åµ - 15x‚Å¥ + 10x¬≥) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
1021:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1022:src/main.cpp  ****             // Much more playable than power curves ‚Äî feels like a real knob.
1023:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1024:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1025:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1026:src/main.cpp  ****             };
1027:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
1028:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1029:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
1030:src/main.cpp  ****             };
1031:src/main.cpp  **** 
1032:src/main.cpp  ****             // Cutoff: smootherstep ‚Äî very dark at low, dramatic in mid, eases at top.
1033:src/main.cpp  ****             // Base cutoff and sweep depth are voice-defined.
