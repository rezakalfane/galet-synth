1424:src/main.cpp  ****         // Three-LED position indicator. Linear "tents" hand off cleanly:
1425:src/main.cpp  ****         //   LED1 (DAC1, middle)       ŌåÆ 1 - 2*|p - 0.5|
1426:src/main.cpp  ****         //   LED2 (DAC2, pos 0 end)    ŌåÆ max(0, 1 - 2*p)
1427:src/main.cpp  ****         //   LED3 (PWM A0, pos 1 end)  ŌåÆ max(0, 2*p - 1)
1428:src/main.cpp  ****         // Fourth-root curve (gamma=0.25) keeps each LED above its forward-voltage
1429:src/main.cpp  ****         // floor at the handoff points (50% raw ŌåÆ ~84% drive). Pressure adds a
1430:src/main.cpp  ****         // subtle ~75%ŌåÆ100% intensity scale.
1431:src/main.cpp  ****         float led1_target = 0.0f, led2_target = 0.0f, led3_target = 0.0f;
1432:src/main.cpp  ****         if(f1_on) {
