 347:src/main.cpp  ****     // position в†’ interval pitch, pressure в†’ velocity (loudness/brightness/drive).
 348:src/main.cpp  ****     auto trigger_drum = [&](int s, int32_t pos, int32_t pressure){
 1254              		.loc 6 348 5 view .LVU402
 349:src/main.cpp  ****         float p    = clampf((float)pos / 1000.0f, 0.0f, 1.0f);
 350:src/main.cpp  ****         int   zone = (int)(p * 4.0f); if(zone > 3) zone = 3;
 351:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 352:src/main.cpp  ****         const Voice& V = VOICES[vidx];
 353:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 354:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 355:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
 356:src/main.cpp  ****         float freq = V.freq_low * MULTI_INTERVALS[step];
 357:src/main.cpp  ****         float v    = FIX_DRUM ? 1.0f : clampf((float)pressure / 100.0f, 0.0f, 1.0f);
 358:src/main.cpp  ****         float amp  = 0.72f * ((1.0f - V.vel_sens) + V.vel_sens * v);
 359:src/main.cpp  ****         // Cutoff from velocity, same curve as the mono path.
 360:src/main.cpp  ****         float cutoff_oct = V.cutoff_oct_max * smootherstep_f(v);
 361:src/main.cpp  ****         float oa = cutoff_oct * 0.6931f;
 362:src/main.cpp  ****         float om = 1.0f + oa*(1.0f + oa*(0.5f + oa*(0.1667f + oa*0.0417f)));
 363:src/main.cpp  ****         float tf = (V.keytrack >= 0.999f) ? freq
 364:src/main.cpp  ****                    : V.freq_low * powf(freq / V.freq_low, V.keytrack);
 365:src/main.cpp  ****         float cutoff = clampf(tf * V.cutoff_mult * om, 20.0f, 18000.0f);
 366:src/main.cpp  ****         float drive  = 1.0f + smoothstep_f(v) * V.drive_max;
 367:src/main.cpp  ****         drum_trigger(g_hits[s], vidx, freq, amp, cutoff, drive, hw.AudioSampleRate());
 368:src/main.cpp  ****         g_active_voice = vidx;   // header shows the last-hit drum
 369:src/main.cpp  ****     };
