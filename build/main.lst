 293:src/main.cpp  ****     0.5f,    0.10f, WAVE_SINE,   // sub   ŌĆö a little thump
 294:src/main.cpp  ****     2.0f,    0.0f,  WAVE_SINE,   // oct   ŌĆö off
 295:src/main.cpp  ****     false,                       // osc2 is a fixed ratio, not finger-2 detune
 296:src/main.cpp  ****     6.0f, 3.0f, 0.30f,           // dark/round tom, opened slightly for a touch more body
 297:src/main.cpp  ****     1.5f,                        // drive ŌĆö snap and saturation on hard hits
 298:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 299:src/main.cpp  ****     0.70f, 0.3f, 1.0f, 0.0f, 0.10f, 1.0f, 150.0f, 5.0f,  // noise-dominant, instant hit, short tail
