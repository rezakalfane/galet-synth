 782:src/main.cpp  ****                 s_led2 = s_led2 * LED_SMOOTH + led2_target * (1.0f - LED_SMOOTH);
 783:src/main.cpp  ****                 s_led3 = s_led3 * smooth3   + led3_target * (1.0f - smooth3);
 784:src/main.cpp  ****             }
