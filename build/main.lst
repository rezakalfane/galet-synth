 587:src/main.cpp  **** // Wavefolder distortion
 588:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 589:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 590:src/main.cpp  **** static inline float wavefold(float in, float amount)
 591:src/main.cpp  **** {
 592:src/main.cpp  ****     if(amount < 0.01f) return in;
 593:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 594:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 595:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 596:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 597:src/main.cpp  ****     float x = driven;
 598:src/main.cpp  ****     // 2 passes of folding for richness
 599:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 600:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 601:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 602:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 603:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 604:src/main.cpp  ****     }
 605:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 606:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 607:src/main.cpp  **** }
