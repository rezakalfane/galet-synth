 343:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 344:src/main.cpp  **** {
 345:src/main.cpp  ****     bool ra[2]={false,false};
 346:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 347:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 348:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 349:src/main.cpp  ****         for(int r=0;r<n;r++){
 350:src/main.cpp  ****             if(ra[r])continue;
 351:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 352:src/main.cpp  ****             if(c<best){best=c;br=r;}
 353:src/main.cpp  ****         }
 354:src/main.cpp  ****         if(br>=0){
 355:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 356:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 357:src/main.cpp  ****             ra[br]=true;
