 590:src/main.cpp  **** 
 591:src/main.cpp  ****         // Vibrato: modulate frequency by ┬▒1 semitone * depth
 592:src/main.cpp  ****         // powf(2, semitones/12) ŌĆö approx for small values: exp(x*0.0578)
 593:src/main.cpp  ****         float vib_amt = lfo * s_vibdepth * 0.05f; // max ┬▒~0.05 semitones*depth
 594:src/main.cpp  ****         float freq_vib = s_freq * (1.0f + vib_amt);
 595:src/main.cpp  **** 
 596:src/main.cpp  ****         // Osc 2 frequency. Lead: finger-2 detune around the base ratio.
 597:src/main.cpp  ****         // Bass (and any fixed-interval voice): hold osc2_ratio (e.g. a 5th).
 598:src/main.cpp  ****         // VOICE is constexpr, so only the taken branch is compiled in.
 599:src/main.cpp  ****         float freq2;
 600:src/main.cpp  ****         if(VOICE.osc2_detune) {
 601:src/main.cpp  ****             float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for ┬▒1 oct
 602:src/main.cpp  ****             freq2 = freq_vib * VOICE.osc2_ratio * det_ratio;
 603:src/main.cpp  ****         } else {
 604:src/main.cpp  ****             freq2 = freq_vib * VOICE.osc2_ratio;
 605:src/main.cpp  ****         }
 606:src/main.cpp  **** 
 607:src/main.cpp  ****         // Sub and octave oscillators (ratios are voice-defined).
 608:src/main.cpp  ****         float freq_sub = freq_vib * VOICE.sub_ratio;
ARM GAS  /tmp/claude-502/cc5FnLRa.s 			page 24


 609:src/main.cpp  ****         float freq_oct = freq_vib * VOICE.oct_ratio;
 610:src/main.cpp  **** 
 611:src/main.cpp  ****         // Ring mod carrier: slightly above fundamental for metallic beating
 612:src/main.cpp  ****         float freq_rm = freq_vib * 1.0f; // unison ring mod (can offset for effect)
 613:src/main.cpp  **** 
 614:src/main.cpp  ****         // Oscillators (mix levels are voice-defined).
 615:src/main.cpp  ****         float osc1    = osc(s_phase1,   VOICE.osc1_wave) * VOICE.osc1_level;
 616:src/main.cpp  ****         float osc2    = osc(s_phase2,   VOICE.osc2_wave) * VOICE.osc2_level;
 617:src/main.cpp  ****         float sub     = osc(s_phase_sub,VOICE.sub_wave)  * VOICE.sub_level;
 618:src/main.cpp  ****         float osc_oct = osc(s_phase_oct,VOICE.oct_wave)  * VOICE.oct_level;
 619:src/main.cpp  **** 
 620:src/main.cpp  ****         // Mix ŌĆö reduce osc1 slightly to make room for the new octave osc
 621:src/main.cpp  ****         float mix = osc1 + osc2 + sub + osc_oct;
 622:src/main.cpp  **** 
 623:src/main.cpp  ****         // Ring modulation (finger 2 pressure ŌåÆ metallic/bell edge)
 624:src/main.cpp  ****         float rm_carrier = tri(s_phase_rm);
 625:src/main.cpp  ****         mix = mix*(1.0f-s_ringmod) + (mix*rm_carrier)*s_ringmod;
 626:src/main.cpp  **** 
 627:src/main.cpp  ****         // Waveshaper drive before filter (adds harmonics, warms tone)
 628:src/main.cpp  ****         mix = fast_tanh(mix * s_drive);
 629:src/main.cpp  **** 
