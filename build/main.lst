 371:src/main.cpp  **** static void drum_trigger(DrumHit& h, int vidx, float freq, float amp_tgt,
 372:src/main.cpp  ****                          float cutoff, float drive, float sr)
 373:src/main.cpp  **** {
 374:src/main.cpp  ****     const Voice& V = VOICES[vidx];
 375:src/main.cpp  ****     h.active=true; h.gate=true; h.vidx=vidx;
 376:src/main.cpp  ****     h.freq=freq; h.amp_tgt=amp_tgt; h.cutoff=cutoff; h.drive=drive;
 377:src/main.cpp  ****     h.ph1=h.ph2=h.phs=h.pho=0.0f;
 378:src/main.cpp  ****     h.amp=0.0f; h.noise_lp=0.0f;
 379:src/main.cpp  ****     // 1-pole lowpass coefficient from the (latched) cutoff: a = 1 - e^(-2ŽĆ┬Ęfc/sr).
 380:src/main.cpp  ****     h.lp_state = 0.0f;
 381:src/main.cpp  ****     h.lp_coeff = clampf(1.0f - expf(-6.2831853f * cutoff / sr), 0.0f, 1.0f);
 382:src/main.cpp  ****     h.atk_c      = ms_to_coeff(V.attack_ms,    sr);
 383:src/main.cpp  ****     h.rel_c      = ms_to_coeff(V.release_ms,   sr);
 384:src/main.cpp  ****     h.penv_c     = ms_to_coeff(V.pitch_env_ms, sr);
 385:src/main.cpp  ****     h.penv_start = exp2f(V.pitch_env_oct);
 386:src/main.cpp  ****     h.pmult      = h.penv_start;
 387:src/main.cpp  **** }
 388:src/main.cpp  **** 
 389:src/main.cpp  **** static float drum_render(DrumHit& h, float sr)
 390:src/main.cpp  **** {
 391:src/main.cpp  ****     if(!h.active) return 0.0f;
 392:src/main.cpp  ****     const Voice& V = VOICES[h.vidx];
 393:src/main.cpp  ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 394:src/main.cpp  ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
 395:src/main.cpp  ****     float c   = (tgt > h.amp) ? h.atk_c : h.rel_c;
 396:src/main.cpp  ****     h.amp = h.amp*c + tgt*(1.0f-c);
 397:src/main.cpp  ****     if(!h.gate && h.amp < 0.0004f){ h.active=false; return 0.0f; }
 398:src/main.cpp  ****     // Pitch envelope decays to 1.0.
 399:src/main.cpp  ****     h.pmult = 1.0f + (h.pmult - 1.0f) * h.penv_c;
 400:src/main.cpp  ****     float f = h.freq * h.pmult;
 401:src/main.cpp  ****     // Oscillators + noise
 402:src/main.cpp  ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 403:src/main.cpp  ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 404:src/main.cpp  ****               + osc(h.phs,V.sub_wave )*V.sub_level
 405:src/main.cpp  ****               + osc(h.pho,V.oct_wave )*V.oct_level;
 406:src/main.cpp  ****     if(V.noise_level > 0.0f){
 407:src/main.cpp  ****         s_noise_rng ^= s_noise_rng<<13; s_noise_rng ^= s_noise_rng>>17; s_noise_rng ^= s_noise_rng<
 408:src/main.cpp  ****         float white  = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 409:src/main.cpp  ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 410:src/main.cpp  ****         float bright = white - h.noise_lp;
 411:src/main.cpp  ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
 412:src/main.cpp  ****     }
 413:src/main.cpp  ****     mix = fast_tanh(mix * h.drive);
 414:src/main.cpp  ****     // Per-drum 1-pole lowpass (cheap ŌĆö one multiply-add ŌĆö instead of the 4-pole
ARM GAS  /tmp/claude-502/cc3JAR3K.s 			page 16


 415:src/main.cpp  ****     // Moog) at the drum's own cutoff: keeps Kick/Tom dark, Snare/Hat bright.
 416:src/main.cpp  ****     h.lp_state += h.lp_coeff * (mix - h.lp_state);
 417:src/main.cpp  ****     h.ph1 += f*V.osc1_ratio/sr; if(h.ph1>=1.0f)h.ph1-=1.0f;
 418:src/main.cpp  ****     h.ph2 += f*V.osc2_ratio/sr; if(h.ph2>=1.0f)h.ph2-=1.0f;
 419:src/main.cpp  ****     h.phs += f*V.sub_ratio /sr; if(h.phs>=1.0f)h.phs-=1.0f;
 420:src/main.cpp  ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
 421:src/main.cpp  ****     return fast_tanh(h.lp_state*1.3f) * h.amp;
 422:src/main.cpp  **** }
