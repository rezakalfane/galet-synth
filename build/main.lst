1293:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
1294:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1295:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
1296:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
1297:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
1298:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
1299:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1300:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1301:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1302:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1303:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1304:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1305:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1306:src/main.cpp  ****             };
1307:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
1308:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1309:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
1310:src/main.cpp  ****             };
1311:src/main.cpp  **** 
1312:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top.
1313:src/main.cpp  ****             // Base cutoff and sweep depth are voice-defined.
1314:src/main.cpp  ****             float prs_cut  = smootherstep(prs01);
