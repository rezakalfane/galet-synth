 114:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 115:src/main.cpp  **** {
 116:src/main.cpp  ****     i2c_start();
 117:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 118:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 119:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 120:src/main.cpp  ****     i2c_stop();return true;
 121:src/main.cpp  **** }
 122:src/main.cpp  **** 
 123:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 124:src/main.cpp  **** {
 125:src/main.cpp  ****     i2c_start();
 126:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 127:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 128:src/main.cpp  ****     i2c_start();
 129:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccJ1Nbd8.s 			page 11


 130:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 131:src/main.cpp  ****     i2c_stop();return true;
 132:src/main.cpp  **** }
