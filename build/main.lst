 256:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 257:src/main.cpp  **** {
 258:src/main.cpp  ****     bool ra[2]={false,false};
 259:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 260:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 261:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 262:src/main.cpp  ****         for(int r=0;r<n;r++){
 263:src/main.cpp  ****             if(ra[r])continue;
 264:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 265:src/main.cpp  ****             if(c<best){best=c;br=r;}
 266:src/main.cpp  ****         }
 267:src/main.cpp  ****         if(br>=0){
 268:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 269:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 270:src/main.cpp  ****             ra[br]=true;
 271:src/main.cpp  ****         } else tracked[slot].alive=false;
 272:src/main.cpp  ****     }
 273:src/main.cpp  ****     for(int r=0;r<n;r++){
 274:src/main.cpp  ****         if(ra[r])continue;
 275:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 276:src/main.cpp  ****             if(!tracked[slot].alive){
 277:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 278:src/main.cpp  ****                 ra[r]=true;break;
 279:src/main.cpp  ****             }
 280:src/main.cpp  ****         }
 281:src/main.cpp  ****     }
 282:src/main.cpp  **** }
