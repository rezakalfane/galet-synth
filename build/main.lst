 768:src/main.cpp  **** // ŌöĆŌöĆ Oscillator waveforms (phase ph in [0,1) ŌåÆ sample in [-1,1]) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 769:src/main.cpp  **** // Triangle wave
 770:src/main.cpp  **** static inline float tri(float ph){
 771:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 772:src/main.cpp  **** }
 773:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ŌĆö matches sin(2ŽĆ┬Ęph).
 774:src/main.cpp  **** static inline float osc_sine(float ph){
 775:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 776:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -ŽĆ..ŽĆ (angle shifted by ŽĆ)
 777:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 778:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 779:src/main.cpp  ****     return -y;                                 // undo the ŽĆ shift: sin(x+ŽĆ) = -sin(x)
 780:src/main.cpp  **** }
 781:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 782:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 783:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 784:src/main.cpp  **** 
 785:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 786:src/main.cpp  **** // switched live). A small jump table ŌĆö cheap at audio rate on the H750.
 787:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 788:src/main.cpp  ****     switch(w){
 789:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 790:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 791:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 792:src/main.cpp  ****         case WAVE_TRI:
 793:src/main.cpp  ****         default:          return tri(ph);
 794:src/main.cpp  ****     }
 795:src/main.cpp  **** }
 796:src/main.cpp  **** 
 797:src/main.cpp  **** // Moog 4-pole ladder
 798:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 799:src/main.cpp  **** {
 800:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 801:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 802:src/main.cpp  ****     float k  = 3.8f*res;
 803:src/main.cpp  ****     float fb = k*s_flt[3];
 804:src/main.cpp  ****     float x  = in - fb;
 805:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 806:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 807:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 808:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 809:src/main.cpp  ****     return s_flt[3];
 810:src/main.cpp  **** }
 811:src/main.cpp  **** 
 812:src/main.cpp  **** // Wavefolder distortion
 813:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
ARM GAS  /tmp/claude-502/ccgDx762.s 			page 23


 814:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 815:src/main.cpp  **** static inline float wavefold(float in, float amount)
 816:src/main.cpp  **** {
 817:src/main.cpp  ****     if(amount < 0.01f) return in;
 818:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 819:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 820:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 821:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 822:src/main.cpp  ****     float x = driven;
 823:src/main.cpp  ****     // 2 passes of folding for richness
 824:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 825:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 826:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 827:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 828:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 829:src/main.cpp  ****     }
 830:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 831:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 832:src/main.cpp  **** }
