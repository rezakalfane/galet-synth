 634:src/main.cpp  **** // Moog 4-pole ladder
 635:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 636:src/main.cpp  **** {
 637:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 638:src/main.cpp  ****     if(f>0.98f)f=0.98f;
