   1:src/main.cpp  **** /**
   2:src/main.cpp  ****  * mpr121_synth.cpp ‚Äî Glass Touch Moog Synth
   3:src/main.cpp  ****  * Daisy Seed ‚Äî Bit-Bang I2C  SDA=D12  SCL=D11
   4:src/main.cpp  ****  *
   5:src/main.cpp  ****  * FINGER 1:
   6:src/main.cpp  ****  *   Position  ‚Üí Pitch (quantized on touch-down, continuous slide after)
   7:src/main.cpp  ****  *   Pressure  ‚Üí Filter cutoff (light=dark/closed, hard=bright/open)
   8:src/main.cpp  ****  *               + Vibrato depth (press harder for more wobble)
   9:src/main.cpp  ****  *
  10:src/main.cpp  ****  * FINGER 2:
  11:src/main.cpp  ****  *   Position  ‚Üí Oscillator detune (spread between osc1 and osc2)
  12:src/main.cpp  ****  *   Pressure  ‚Üí Wavefold distortion (gentle saturation to complex fold)
  13:src/main.cpp  ****  *               + Ring mod amount (extreme pressure adds metallic edge)
  14:src/main.cpp  ****  *
  15:src/main.cpp  ****  * EXPRESSION:
ARM GAS  /tmp/claude-502/ccwMOaii.s 			page 9


  16:src/main.cpp  ****  *   - Note quantize on initial touch, then free pitch bend on slide
  17:src/main.cpp  ****  *   - Pressure-controlled vibrato (LFO depth from finger 1 pressure)
  18:src/main.cpp  ****  *   - Portamento / glide between quantized notes
  19:src/main.cpp  ****  *   - Sub oscillator one octave below (adds weight)
  20:src/main.cpp  ****  *   - Soft-clip waveshaper before output
  21:src/main.cpp  ****  *   - Amplitude envelope: fast attack, pressure-controlled release
  22:src/main.cpp  ****  */
  23:src/main.cpp  **** 
  24:src/main.cpp  **** #include "daisy_seed.h"
  25:src/main.cpp  **** #include <math.h>
  26:src/main.cpp  **** #include <string.h>
  27:src/main.cpp  **** 
  28:src/main.cpp  **** using namespace daisy;
  29:src/main.cpp  **** using namespace daisy::seed;
  30:src/main.cpp  **** 
  31:src/main.cpp  **** // ‚îÄ‚îÄ Pin / I2C config ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
  32:src/main.cpp  **** static constexpr Pin      SDA_PIN  = D12;
  33:src/main.cpp  **** static constexpr Pin      SCL_PIN  = D11;
  34:src/main.cpp  **** static constexpr uint8_t  MPR_ADDR = 0x5A;
  35:src/main.cpp  **** static constexpr uint32_t HP       = 5;
  36:src/main.cpp  **** static constexpr int      N_CH     = 12;
  37:src/main.cpp  **** 
  38:src/main.cpp  **** // ‚îÄ‚îÄ Touch tuning ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
  39:src/main.cpp  **** static constexpr int32_t  TOUCH_THRESHOLD    = 10;
  40:src/main.cpp  **** static constexpr int32_t  PRESSURE_MAX_REF[12] = {
  41:src/main.cpp  ****     42,35,34,34,34,34,
  42:src/main.cpp  ****     34,34,33,32,29,30
  43:src/main.cpp  **** };
  44:src/main.cpp  **** static constexpr int32_t  MIN_FINGER_SEP     = 4;
  45:src/main.cpp  **** static constexpr uint32_t REBASELINE_IDLE_MS = 2000;
  46:src/main.cpp  **** static constexpr int      REBASELINE_SAMPLES = 32;
  47:src/main.cpp  **** static constexpr int32_t  MAX_POS_JUMP       = 200;
  48:src/main.cpp  **** 
  49:src/main.cpp  **** // LED slew at ~60Hz touch loop. Closer to 1.0 = smoother/slower fade.
  50:src/main.cpp  **** // 0.0 = no smoothing (snap), 0.7 = ~80ms fade, 0.9 = ~250ms fade.
  51:src/main.cpp  **** static constexpr float    LED_SMOOTH         = 0.45f;
  52:src/main.cpp  **** // LED3 (software sigma-delta PWM on A0 / ADC0 / pin 22) max-brightness scale.
  53:src/main.cpp  **** static constexpr float    LED3_INTENSITY     = 0.1f;
  54:src/main.cpp  **** // Smoothing coefficient used for LED3 only when no finger is touching. Smaller
  55:src/main.cpp  **** // than LED_SMOOTH = faster fade-out on lift. 0.0 = instant snap to 0.
  56:src/main.cpp  **** static constexpr float    LED3_RELEASE_SMOOTH = 0.10f;
  57:src/main.cpp  **** 
  58:src/main.cpp  **** // ‚îÄ‚îÄ Voices ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
  59:src/main.cpp  **** // A "Voice" bundles everything that defines a sound: the oscillator stack
  60:src/main.cpp  **** // (which pitches sound and at what level), the filter/drive character, and the
  61:src/main.cpp  **** // pitch range finger-1 sweeps across. Add a preset below, then point ACTIVE
  62:src/main.cpp  **** // VOICE at it ‚Äî selection is a compile-time constant, so there is zero runtime
  63:src/main.cpp  **** // cost (the unused branches fold away).
  64:src/main.cpp  **** 
  65:src/main.cpp  **** // Oscillator shape ‚Äî set per oscillator, so one voice can mix (e.g. saw root +
  66:src/main.cpp  **** // square fifth + sine sub). SQUARE and SAW are naive (not band-limited) ‚Äî they
  67:src/main.cpp  **** // alias at high pitch, but on a low bass voice that just reads as rich harmonics
  68:src/main.cpp  **** // for the filter to chew.
  69:src/main.cpp  **** enum Waveform { WAVE_TRI, WAVE_SINE, WAVE_SQUARE, WAVE_SAW };
  70:src/main.cpp  **** 
  71:src/main.cpp  **** struct Voice {
  72:src/main.cpp  ****     const char* name;
ARM GAS  /tmp/claude-502/ccwMOaii.s 			page 10


  73:src/main.cpp  **** 
  74:src/main.cpp  ****     // Pitch range. Finger-1 position 0‚Äì1000 maps exponentially across this.
  75:src/main.cpp  ****     float freq_low;
  76:src/main.cpp  ****     float freq_high;
  77:src/main.cpp  ****     float log_freq_ratio;   // = ln(freq_high / freq_low), precomputed (logf isn't constexpr)
  78:src/main.cpp  **** 
  79:src/main.cpp  ****     // Oscillator stack. Each oscillator's pitch = fundamental * ratio, and each
  80:src/main.cpp  ****     // has its own waveform. Set a level to 0 to silence an oscillator.
  81:src/main.cpp  ****     float osc1_ratio, osc1_level;  Waveform osc1_wave;   // primary
  82:src/main.cpp  ****     float osc2_ratio, osc2_level;  Waveform osc2_wave;   // second osc (see osc2_detune)
  83:src/main.cpp  ****     float sub_ratio,  sub_level;   Waveform sub_wave;    // weight below
  84:src/main.cpp  ****     float oct_ratio,  oct_level;   Waveform oct_wave;    // shimmer / chord top
  85:src/main.cpp  ****     bool  osc2_detune;              // true  ‚Üí finger-2 detune controls osc2 pitch (lead)
  86:src/main.cpp  ****                                     // false ‚Üí osc2 stays at osc2_ratio (e.g. a fixed 5th)
  87:src/main.cpp  **** 
  88:src/main.cpp  ****     // Filter character. Base cutoff = freq * cutoff_mult; pressure opens it
  89:src/main.cpp  ****     // by up to cutoff_oct_max octaves on top.
  90:src/main.cpp  ****     float cutoff_mult;
  91:src/main.cpp  ****     float cutoff_oct_max;
  92:src/main.cpp  ****     float resonance;
  93:src/main.cpp  **** 
  94:src/main.cpp  ****     // Drive ‚Äî pressure-controlled waveshaper gain added on top of 1.0.
  95:src/main.cpp  ****     float drive_max;
  96:src/main.cpp  **** };
  97:src/main.cpp  **** 
  98:src/main.cpp  **** // Perfect-fifth frequency ratio = 2^(7/12).
  99:src/main.cpp  **** static constexpr float RATIO_FIFTH = 1.49831f;
 100:src/main.cpp  **** 
 101:src/main.cpp  **** // ‚îÄ‚îÄ Voice 0: the original glass-Moog lead ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 102:src/main.cpp  **** //   F1 pos‚Üípitch, F1 prs‚Üícutoff+vibrato; F2 pos‚Üídetune, F2 prs‚Üíwavefold+ringmod.
 103:src/main.cpp  **** static constexpr Voice VOICE_LEAD = {
 104:src/main.cpp  ****     "Lead",
 105:src/main.cpp  ****     50.0f, 300.0f, 1.79176f,   // 50‚Äì300 Hz, ln(6)
 106:src/main.cpp  ****     1.0f, 0.50f, WAVE_TRI,   // osc1  ‚Äî root
 107:src/main.cpp  ****     1.0f, 0.22f, WAVE_TRI,   // osc2  ‚Äî detune-controlled, ratio is just the base
 108:src/main.cpp  ****     0.5f, 0.18f, WAVE_TRI,   // sub   ‚Äî one octave below
 109:src/main.cpp  ****     2.0f, 0.15f, WAVE_TRI,   // oct   ‚Äî one octave above
 110:src/main.cpp  ****     true,          // osc2 follows finger-2 detune
 111:src/main.cpp  ****     0.3f, 12.0f, 0.75f,
 112:src/main.cpp  ****     2.5f
 113:src/main.cpp  **** };
 114:src/main.cpp  **** 
 115:src/main.cpp  **** // ‚îÄ‚îÄ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 116:src/main.cpp  **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
 117:src/main.cpp  **** //   so every note sounds as a power chord. Lower range, gentler filter, less
 118:src/main.cpp  **** //   drive ‚Üí deep and round rather than bright and screaming.
 119:src/main.cpp  **** static constexpr Voice VOICE_BASS = {
 120:src/main.cpp  ****     "Bass",
 121:src/main.cpp  ****     40.0f, 160.0f, 1.38629f,   // 40‚Äì160 Hz, ln(4) ‚Äî sits under the lead
 122:src/main.cpp  ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ‚Äî root
 123:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ‚Äî fixed perfect fifth (the power chord)
 124:src/main.cpp  ****     0.5f,        0.34f, WAVE_TRI,   // sub   ‚Äî extra weight for a round bottom
 125:src/main.cpp  ****     2.0f,        0.20f, WAVE_TRI,   // oct   ‚Äî top of the power chord
 126:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 127:src/main.cpp  ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 128:src/main.cpp  ****     1.0f                  // less drive ‚Äî keep it clean and round
 129:src/main.cpp  **** };
ARM GAS  /tmp/claude-502/ccwMOaii.s 			page 11


 130:src/main.cpp  **** 
 131:src/main.cpp  **** // ‚îÄ‚îÄ Voice 2: open power-chord bass ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 132:src/main.cpp  **** //   Same chord stack as VOICE_BASS, but the filter starts brighter and sweeps
 133:src/main.cpp  **** //   much further with pressure ‚Äî light touch is still warm, hard press opens it
 134:src/main.cpp  **** //   wide. A touch more resonance and drive for presence as it opens.
 135:src/main.cpp  **** static constexpr Voice VOICE_BASS_OPEN = {
 136:src/main.cpp  ****     "OpenBass",
 137:src/main.cpp  ****     40.0f, 180.0f, 1.50408f,   // 40‚Äì180 Hz, ln(4.5) ‚Äî a little more reach up top
 138:src/main.cpp  ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ‚Äî root
 139:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ‚Äî fixed perfect fifth (the power chord)
 140:src/main.cpp  ****     0.5f,        0.30f, WAVE_TRI,   // sub   ‚Äî slightly less so the openness reads
 141:src/main.cpp  ****     2.0f,        0.22f, WAVE_TRI,   // oct   ‚Äî top of the power chord
 142:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 143:src/main.cpp  ****     0.5f, 10.0f, 0.65f,   // brighter base + wider pressure sweep + more resonance
 144:src/main.cpp  ****     1.8f                  // more drive ‚Äî grit comes in as you press
 145:src/main.cpp  **** };
 146:src/main.cpp  **** 
 147:src/main.cpp  **** // ‚îÄ‚îÄ Voice 3: rich power-chord bass with mixed waveforms + huge filter sweep ‚îÄ‚îÄ‚îÄ‚îÄ
 148:src/main.cpp  **** //   Mixed shapes for body: saw root (harmonic-rich), square fifth (hollow), a
 149:src/main.cpp  **** //   clean sine sub (tight low end), saw octave on top. Starts dark, then
 150:src/main.cpp  **** //   pressure opens the cutoff dramatically (13 octaves) with high resonance ‚Äî
 151:src/main.cpp  **** //   a vocal, acid-style "wow" as you press harder.
 152:src/main.cpp  **** static constexpr Voice VOICE_BASS_RICH = {
 153:src/main.cpp  ****     "RichBass",
 154:src/main.cpp  ****     40.0f, 160.0f, 1.38629f,   // 40‚Äì160 Hz, ln(4)
 155:src/main.cpp  ****     1.0f,        0.40f, WAVE_SAW,    // osc1  ‚Äî saw root (rich harmonics)
 156:src/main.cpp  ****     RATIO_FIFTH, 0.26f, WAVE_SQUARE, // osc2  ‚Äî square fifth (hollow contrast)
 157:src/main.cpp  ****     0.5f,        0.32f, WAVE_SINE,   // sub   ‚Äî clean sine for a tight low end
 158:src/main.cpp  ****     2.0f,        0.18f, WAVE_SAW,    // oct   ‚Äî saw top of the power chord
 159:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 160:src/main.cpp  ****     0.2f, 13.0f, 0.82f,   // dark base + enormous pressure sweep + high resonance
 161:src/main.cpp  ****     2.2f                  // generous drive ‚Äî grit blooms with pressure
 162:src/main.cpp  **** };
 163:src/main.cpp  **** 
 164:src/main.cpp  **** // ‚îÄ‚îÄ Voice 4: clean sine organ / flute (a melodic, non-bass departure) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 165:src/main.cpp  **** //   Pure sine oscillators stacked like organ drawbars: octave-down body, root,
 166:src/main.cpp  **** //   octave-up air, plus a second osc tuned a hair sharp (1.005√ó) for a slow,
 167:src/main.cpp  **** //   warm chorus shimmer instead of a chord. Higher register than the basses, a
 168:src/main.cpp  **** //   mostly-open clean filter, and just a touch of drive so pressure adds gentle
 169:src/main.cpp  **** //   harmonic warmth. Sines never alias, so it stays smooth all the way up.
 170:src/main.cpp  **** static constexpr Voice VOICE_ORGAN = {
 171:src/main.cpp  ****     "Organ",
 172:src/main.cpp  ****     65.0f, 520.0f, 2.07944f,   // 65‚Äì520 Hz, ln(8) ‚Äî a melodic keyboard register
 173:src/main.cpp  ****     1.0f,    0.45f, WAVE_SINE,  // osc1  ‚Äî root (8')
 174:src/main.cpp  ****     1.005f,  0.40f, WAVE_SINE,  // osc2  ‚Äî slightly sharp unison ‚Üí slow chorus shimmer
 175:src/main.cpp  ****     0.5f,    0.30f, WAVE_SINE,  // sub   ‚Äî octave-down body (16')
 176:src/main.cpp  ****     2.0f,    0.28f, WAVE_SINE,  // oct   ‚Äî octave-up air (4')
 177:src/main.cpp  ****     false,                      // osc2 is a fixed chorus detune, not finger-2 detune
 178:src/main.cpp  ****     2.0f, 5.0f, 0.20f,          // mostly-open clean filter, gentle pressure lift, low res
 179:src/main.cpp  ****     0.8f                        // light drive ‚Äî pressure adds subtle warmth, stays pure
 180:src/main.cpp  **** };
 181:src/main.cpp  **** 
 182:src/main.cpp  **** // ‚îÄ‚îÄ Voice 5: screaming aggressive lead ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 183:src/main.cpp  **** //   Detuned sawtooth stack (root + a hair-sharp twin + octave) for a thick,
 184:src/main.cpp  **** //   buzzing supersaw bite, pushed up into a cutting register. Heavy drive and a
