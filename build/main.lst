 407:src/main.cpp  ****     int32_t d2[N_CH];
 408:src/main.cpp  ****     int ss=pka-2;if(ss<0)ss=0;int se=pka+2;if(se>=N_CH)se=N_CH-1;
 409:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
