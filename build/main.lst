 550:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 551:src/main.cpp  **** {
 552:src/main.cpp  ****     i2c_start();
 553:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 554:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 555:src/main.cpp  ****     i2c_start();
 556:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 557:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 558:src/main.cpp  ****     i2c_stop();return true;
 559:src/main.cpp  **** }
