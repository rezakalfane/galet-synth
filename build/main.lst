  95:src/voice.h   **** // ‚îÄ‚îÄ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
  96:src/voice.h   **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
  97:src/voice.h   **** //   so every note sounds as a power chord. Lower range, gentler filter, less
  98:src/voice.h   **** //   drive ‚Üí deep and round rather than bright and screaming.
  99:src/voice.h   **** static constexpr Voice VOICE_BASS = {
 100:src/voice.h   ****     "Bass",
 101:src/voice.h   ****     40.0f, 160.0f, 1.38629f,   // 40‚Äì160 Hz, ln(4) ‚Äî sits under the lead
 102:src/voice.h   ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ‚Äî root
 103:src/voice.h   ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ‚Äî fixed perfect fifth (the power chord)
 104:src/voice.h   ****     0.5f,        0.34f, WAVE_TRI,   // sub   ‚Äî extra weight for a round bottom
 105:src/voice.h   ****     2.0f,        0.20f, WAVE_TRI,   // oct   ‚Äî top of the power chord
 106:src/voice.h   ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 107:src/voice.h   ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 108:src/voice.h   ****     1.0f,                 // less drive ‚Äî keep it clean and round
 109:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 110:src/voice.h   ****     0.0f, 1.0f, 1.0f, 0.12f, 0.12f, 6.0f, 300.0f, 25.0f
 111:src/voice.h   **** };
 112:src/voice.h   **** 
 113:src/voice.h   **** // ‚îÄ‚îÄ Voice 2: open power-chord bass ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 114:src/voice.h   **** //   Same chord stack as VOICE_BASS, but the filter starts brighter and sweeps
 115:src/voice.h   **** //   much further with pressure ‚Äî light touch is still warm, hard press opens it
 116:src/voice.h   **** //   wide. A touch more resonance and drive for presence as it opens.
 117:src/voice.h   **** static constexpr Voice VOICE_BASS_OPEN = {
