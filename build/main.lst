 941:src/main.cpp  ****         uint16_t scan[N_CH];
 942:src/main.cpp  **** 
 943:src/main.cpp  ****         while(true) {
 944:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 945:src/main.cpp  **** 
 946:src/main.cpp  ****             // Sinusoidal position 0‚Üí1‚Üí0 over SWEEP_PERIOD_MS ‚Äî eases at the
 947:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 948:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
