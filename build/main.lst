 643:src/main.cpp  **** // Find up to `maxf` fingers: repeatedly take the strongest remaining peak, and
 644:src/main.cpp  **** // if it's far enough from the peaks already found, record its centroid; then
 645:src/main.cpp  **** // zero a ┬▒2 window around it and look again. The first two peaks come out
 646:src/main.cpp  **** // identical to the old 2-finger detector, so the mono path is unchanged.
 647:src/main.cpp  **** int detect_raw(int32_t* delta, Finger* out, int maxf)
 648:src/main.cpp  **** {
 649:src/main.cpp  ****     for(int i=0;i<maxf;i++) out[i].active=false;
 650:src/main.cpp  ****     int32_t work[N_CH];
 651:src/main.cpp  ****     for(int i=0;i<N_CH;i++) work[i]=delta[i];
 652:src/main.cpp  **** 
 653:src/main.cpp  ****     int peaks[MAX_FINGERS];
 654:src/main.cpp  ****     int found=0;
 655:src/main.cpp  ****     for(int attempt=0; attempt<maxf && found<maxf; attempt++){
 656:src/main.cpp  ****         int pk=0; int32_t mx=0;
 657:src/main.cpp  ****         for(int i=0;i<N_CH;i++) if(work[i]>mx){ mx=work[i]; pk=i; }
 658:src/main.cpp  ****         if(mx<TOUCH_THRESHOLD) break;                 // nothing left above threshold
 659:src/main.cpp  **** 
 660:src/main.cpp  ****         bool sep_ok=true;
 661:src/main.cpp  ****         for(int j=0;j<found;j++){ int s=pk-peaks[j]; if(s<0)s=-s; if(s<MIN_FINGER_SEP){ sep_ok=fals
 662:src/main.cpp  ****         if(sep_ok){
 663:src/main.cpp  ****             int ws=pk-2; if(ws<0)ws=0; int we=pk+2; if(we>=N_CH)we=N_CH-1;
 664:src/main.cpp  ****             int32_t pkv; int pkc;
 665:src/main.cpp  ****             int32_t pos=centroid_window(work,ws,we,&pkv,&pkc);
 666:src/main.cpp  ****             out[found]={true,pos,pressure_pct(pkv,pkc),pkc,pkv};
 667:src/main.cpp  ****             peaks[found]=pk;
 668:src/main.cpp  ****             found++;
 669:src/main.cpp  ****         }
 670:src/main.cpp  ****         // Zero this peak's window so the next pass finds a different finger.
 671:src/main.cpp  ****         for(int i=pk-2;i<=pk+2;i++) if(i>=0 && i<N_CH) work[i]=0;
 672:src/main.cpp  ****     }
 673:src/main.cpp  ****     return found;
 674:src/main.cpp  **** }
