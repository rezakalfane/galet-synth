 534:src/voice.h   **** // ‚îÄ‚îÄ Voice 7: warm ensemble pad ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 535:src/voice.h   **** //   A lush, evolving pad. Two saws a hair apart (1.006√ó) give an ensemble/chorus
 536:src/voice.h   **** //   width, a soft triangle sub adds body, an airy sine octave sits on top. A
 537:src/voice.h   **** //   moderate, low-resonance filter keeps it warm rather than bright. The pad
 538:src/voice.h   **** //   character comes from the envelope: a slow ~2.2 s swell in and a long ~2 s
 539:src/voice.h   **** //   tail, so notes bloom and linger. A whisper of noise adds air.
 540:src/voice.h   **** static constexpr Voice VOICE_PAD = {
 541:src/voice.h   ****     "Pad",
 542:src/voice.h   ****     // FREQUENCY RANGE
 543:src/voice.h   ****     70.0f,
 544:src/voice.h   ****     560.0f,
 545:src/voice.h   ****     2.07944f,            // 70‚Äì560 Hz, ln(8) ‚Äî mid melodic register
 546:src/voice.h   ****     // OSCILLATOR STACK
 547:src/voice.h   ****     1.0f,
 548:src/voice.h   ****     0.32f,
 549:src/voice.h   ****     WAVE_SAW,            // osc1  ‚Äî saw root
 550:src/voice.h   ****     // SECONDARY OSCILLATOR
 551:src/voice.h   ****     1.006f,
 552:src/voice.h   ****     0.30f,
 553:src/voice.h   ****     WAVE_SAW,            // osc2  ‚Äî detuned saw ‚Üí lush ensemble width
 554:src/voice.h   ****     // SUB OSCILLATOR
 555:src/voice.h   ****     0.5f,
 556:src/voice.h   ****     0.22f,
ARM GAS  /tmp/claude-502/ccZeCIQr.s 			page 45


 557:src/voice.h   ****     WAVE_TRI,            // sub   ‚Äî soft triangle body
 558:src/voice.h   ****     // OCTAVE OSCILLATOR
 559:src/voice.h   ****     2.0f,
