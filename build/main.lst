 238:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 239:src/main.cpp  **** {
 240:src/main.cpp  ****     bool ra[2]={false,false};
 241:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 242:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 243:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccJ1Nbd8.s 			page 13


 244:src/main.cpp  ****         for(int r=0;r<n;r++){
 245:src/main.cpp  ****             if(ra[r])continue;
 246:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 247:src/main.cpp  ****             if(c<best){best=c;br=r;}
 248:src/main.cpp  ****         }
 249:src/main.cpp  ****         if(br>=0){
 250:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 251:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 252:src/main.cpp  ****             ra[br]=true;
 253:src/main.cpp  ****         } else tracked[slot].alive=false;
 254:src/main.cpp  ****     }
 255:src/main.cpp  ****     for(int r=0;r<n;r++){
 256:src/main.cpp  ****         if(ra[r])continue;
 257:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 258:src/main.cpp  ****             if(!tracked[slot].alive){
 259:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 260:src/main.cpp  ****                 ra[r]=true;break;
 261:src/main.cpp  ****             }
 262:src/main.cpp  ****         }
 263:src/main.cpp  ****     }
 264:src/main.cpp  **** }
