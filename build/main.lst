 790:src/voice.h   **** // ŌöĆŌöĆ Voice 12: SH-101-style mono synth ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 791:src/voice.h   **** //   A Roland SH-101 homage: one "VCO" putting out saw + square (pulse) together
 792:src/voice.h   **** //   over a square sub-oscillator an octave down ŌĆö the fat single-osc stack the
 793:src/voice.h   **** //   SH-101 is loved for ŌĆö through the resonant 4-pole ladder. The cutoff sits
 794:src/voice.h   **** //   fairly closed and pressure sweeps it wide open with high resonance for the
 795:src/voice.h   **** //   squelchy acid "wow" (the SH-101's filter-env squelch, here played by finger
 796:src/voice.h   **** //   pressure). A whisper of noise, portamento glide between notes. Plays diatonic
 797:src/voice.h   **** //   triads (chords = true) quantized to a MINOR scale so acid chords stay in key
 798:src/voice.h   **** //   while slides bend the whole chord. Bass + leads. (Major twin: VOICE_SH101_MAJ.)
 799:src/voice.h   **** static constexpr Voice VOICE_SH101 = {
 800:src/voice.h   ****     "SH-101 min",
 801:src/voice.h   ****     // FREQUENCY RANGE
ARM GAS  /tmp/claude-502/cceToCIK.s 			page 52


 802:src/voice.h   ****     40.0f,
 803:src/voice.h   ****     400.0f,
 804:src/voice.h   ****     2.30259f,            // 40ŌĆō400 Hz, ln(10) ŌĆö bass up to lead
 805:src/voice.h   ****     // OSCILLATOR STACK
 806:src/voice.h   ****     1.0f,
 807:src/voice.h   ****     0.42f,
 808:src/voice.h   ****     WAVE_SAW,            // osc1  ŌĆö the saw VCO
 809:src/voice.h   ****     // SECONDARY OSCILLATOR
 810:src/voice.h   ****     1.0f,
 811:src/voice.h   ****     0.28f,
 812:src/voice.h   ****     WAVE_SQUARE,         // osc2  ŌĆö pulse, in unison (saw + pulse = the SH-101 blend)
 813:src/voice.h   ****     // SUB OSCILLATOR
 814:src/voice.h   ****     0.5f,
 815:src/voice.h   ****     0.40f,
 816:src/voice.h   ****     WAVE_SQUARE,         // sub   ŌĆö the iconic square sub-osc, one octave down
 817:src/voice.h   ****     // OCTAVE OSCILLATOR
 818:src/voice.h   ****     2.0f,
 819:src/voice.h   ****     0.0f,
 820:src/voice.h   ****     WAVE_SQUARE,         // oct   ŌĆö off (the SH-101 has no up-octave)
 821:src/voice.h   ****     // FILTER
 822:src/voice.h   ****     false,               // osc2 is a fixed unison, not finger-2 detune
 823:src/voice.h   ****     0.8f,
 824:src/voice.h   ****     9.0f,
 825:src/voice.h   ****     0.80f,               // closed-ish base, huge pressure sweep, squelchy acid res
 826:src/voice.h   ****     // DRIVE
 827:src/voice.h   ****     1.8f,                // a little drive for warmth/grit
 828:src/voice.h   ****     // NOISE
 829:src/voice.h   ****     0.02f,               // noise level ŌĆö a whisper (the SH-101 noise source)
 830:src/voice.h   ****     1.0f,                // keytrack
 831:src/voice.h   ****     1.0f,                // ringmod ratio
 832:src/voice.h   ****     0.10f,               // ringmod max
 833:src/voice.h   ****     0.12f,               // fold max
 834:src/voice.h   ****     2.0f,                // attack ŌĆö snappy
 835:src/voice.h   ****     220.0f,              // release
 836:src/voice.h   ****     30.0f,               // glide ŌĆö portamento slide between notes
 837:src/voice.h   ****     // PITCH ENVELOPE
 838:src/voice.h   ****     0.0f, 0.0f,          // pitch_env_oct, pitch_env_ms (none)
 839:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 840:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
 841:src/voice.h   ****     // PITCH QUANTIZE ŌĆö minor scale: chords land as diatonic triads (i, ii┬░, IIIŌĆ”)
 842:src/voice.h   ****     // and stay in key; slides still bend between notes
 843:src/voice.h   ****     true,
 844:src/voice.h   ****     SCALE_MINOR, (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0])),
 845:src/voice.h   ****     // AMP DECAY ŌĆö none: sustained mono synth (hold the note; pressure does the wow)
 846:src/voice.h   ****     0.0f,                // decay_ms
 847:src/voice.h   ****     0.0f,                // sustain (ignored when decay_ms == 0)
 848:src/voice.h   ****     // CHORDS ŌĆö play the snapped note as a 3-note diatonic triad (root + 3rd + 5th)
 849:src/voice.h   ****     true
 850:src/voice.h   **** };
 851:src/voice.h   **** 
