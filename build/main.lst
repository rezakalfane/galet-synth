 831:src/main.cpp  **** // Moog 4-pole ladder, operating on a caller-supplied state array (so multiple
 832:src/main.cpp  **** // voices can each have their own filter).
 833:src/main.cpp  **** static inline float moog_st(float in, float cutoff, float res, float sr, float st[4])
 834:src/main.cpp  **** {
 835:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 836:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 837:src/main.cpp  ****     float k  = 3.8f*res;
 838:src/main.cpp  ****     float fb = k*st[3];
 839:src/main.cpp  ****     float x  = in - fb;
 840:src/main.cpp  ****     st[0]+=f*(fast_tanh(x)    -fast_tanh(st[0]));
 841:src/main.cpp  ****     st[1]+=f*(fast_tanh(st[0])-fast_tanh(st[1]));
 842:src/main.cpp  ****     st[2]+=f*(fast_tanh(st[1])-fast_tanh(st[2]));
 843:src/main.cpp  ****     st[3]+=f*(fast_tanh(st[2])-fast_tanh(st[3]));
 844:src/main.cpp  ****     return st[3];
 845:src/main.cpp  **** }
 846:src/main.cpp  **** // Mono ladder using the shared global state (the monophonic melodic engine).
 847:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 848:src/main.cpp  **** {
 849:src/main.cpp  ****     return moog_st(in, cutoff, res, sr, s_flt);
 850:src/main.cpp  **** }
