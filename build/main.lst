 203:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 204:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 205:src/main.cpp  ****         uint16_t scan[N_CH];
 206:src/main.cpp  **** 
 207:src/main.cpp  ****         while(true) {
