 799:src/voice.h   **** // ‚îÄ‚îÄ Voice 12: SH-101-style mono synth ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
ARM GAS  /tmp/claude-502/ccN5Z8iY.s 			page 52


 800:src/voice.h   **** //   A Roland SH-101 homage: one "VCO" putting out saw + square (pulse) together
 801:src/voice.h   **** //   over a square sub-oscillator an octave down ‚Äî the fat single-osc stack the
 802:src/voice.h   **** //   SH-101 is loved for ‚Äî through the resonant 4-pole ladder. The cutoff sits
 803:src/voice.h   **** //   fairly closed and pressure sweeps it wide open with high resonance for the
 804:src/voice.h   **** //   squelchy acid "wow" (the SH-101's filter-env squelch, here played by finger
 805:src/voice.h   **** //   pressure). A whisper of noise, portamento glide between notes. Plays diatonic
 806:src/voice.h   **** //   triads (chords = true) quantized to a MINOR scale so acid chords stay in key
 807:src/voice.h   **** //   while slides bend the whole chord. Bass + leads. (Major twin: VOICE_SH101_MAJ.)
 808:src/voice.h   **** static constexpr Voice VOICE_SH101 = {
 809:src/voice.h   ****     "SH-101 min",
 810:src/voice.h   ****     // FREQUENCY RANGE
 811:src/voice.h   ****     40.0f,
 812:src/voice.h   ****     400.0f,
 813:src/voice.h   ****     2.30259f,            // 40‚Äì400 Hz, ln(10) ‚Äî bass up to lead
 814:src/voice.h   ****     // OSCILLATOR STACK
 815:src/voice.h   ****     1.0f,
 816:src/voice.h   ****     0.42f,
 817:src/voice.h   ****     WAVE_SAW,            // osc1  ‚Äî the saw VCO
 818:src/voice.h   ****     // SECONDARY OSCILLATOR
 819:src/voice.h   ****     1.0f,
 820:src/voice.h   ****     0.28f,
 821:src/voice.h   ****     WAVE_SQUARE,         // osc2  ‚Äî pulse, in unison (saw + pulse = the SH-101 blend)
 822:src/voice.h   ****     // SUB OSCILLATOR
 823:src/voice.h   ****     0.5f,
 824:src/voice.h   ****     0.40f,
 825:src/voice.h   ****     WAVE_SQUARE,         // sub   ‚Äî the iconic square sub-osc, one octave down
 826:src/voice.h   ****     // OCTAVE OSCILLATOR
 827:src/voice.h   ****     2.0f,
 828:src/voice.h   ****     0.0f,
 829:src/voice.h   ****     WAVE_SQUARE,         // oct   ‚Äî off (the SH-101 has no up-octave)
 830:src/voice.h   ****     // FILTER
 831:src/voice.h   ****     false,               // osc2 is a fixed unison, not finger-2 detune
 832:src/voice.h   ****     0.8f,
 833:src/voice.h   ****     9.0f,
 834:src/voice.h   ****     0.80f,               // closed-ish base, huge pressure sweep, squelchy acid res
 835:src/voice.h   ****     // DRIVE
 836:src/voice.h   ****     1.8f,                // a little drive for warmth/grit
 837:src/voice.h   ****     // NOISE
 838:src/voice.h   ****     0.02f,               // noise level ‚Äî a whisper (the SH-101 noise source)
 839:src/voice.h   ****     1.0f,                // keytrack
 840:src/voice.h   ****     1.0f,                // ringmod ratio
 841:src/voice.h   ****     0.10f,               // ringmod max
 842:src/voice.h   ****     0.12f,               // fold max
 843:src/voice.h   ****     2.0f,                // attack ‚Äî snappy
 844:src/voice.h   ****     220.0f,              // release
 845:src/voice.h   ****     30.0f,               // glide ‚Äî portamento slide between notes
 846:src/voice.h   ****     // PITCH ENVELOPE
 847:src/voice.h   ****     0.0f, 0.0f,          // pitch_env_oct, pitch_env_ms (none)
 848:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 849:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
 850:src/voice.h   ****     // PITCH QUANTIZE ‚Äî minor scale: chords land as diatonic triads (i, ii¬∞, III‚Ä¶)
 851:src/voice.h   ****     // and stay in key; slides still bend between notes
 852:src/voice.h   ****     true,
 853:src/voice.h   ****     SCALE_MINOR, (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0])),
 854:src/voice.h   ****     // AMP DECAY ‚Äî none: sustained mono synth (hold the note; pressure does the wow)
 855:src/voice.h   ****     0.0f,                // decay_ms
 856:src/voice.h   ****     0.0f,                // sustain (ignored when decay_ms == 0)
ARM GAS  /tmp/claude-502/ccN5Z8iY.s 			page 53


 857:src/voice.h   ****     // CHORDS ‚Äî 3-note diatonic triad; upper notes near-full level, open voicing
 858:src/voice.h   ****     true,                // chords
 859:src/voice.h   ****     0.9f,                // chord_level (upper two notes vs root)
 860:src/voice.h   ****     1                    // chord_spread (octaves on the 3rd: 1 = root‚Äì5th‚Äì10th)
 861:src/voice.h   **** };
 862:src/voice.h   **** 
