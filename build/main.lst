 191:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 192:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 193:src/main.cpp  ****         uint16_t scan[N_CH];
 194:src/main.cpp  **** 
 195:src/main.cpp  ****         while(true) {
 196:src/main.cpp  ****             // Stay responsive to a host tuner while idling: this loop would
 197:src/main.cpp  ****             // otherwise spin until a glass touch / FSR press, leaving serial
 198:src/main.cpp  ****             // commands (dump/select/save) unparsed in the RX ring. Poll them
 199:src/main.cpp  ****             // here, and leave the chase the instant tune mode is entered.
 200:src/main.cpp  ****             serial_tune_poll();
 201:src/main.cpp  ****             if(g_live_tune) break;
 202:src/main.cpp  **** 
 203:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 204:src/main.cpp  **** 
 205:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 206:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 207:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
 208:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
 209:src/main.cpp  **** 
 210:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 211:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 212:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 213:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 214:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 215:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 216:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 217:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * LED1_MAX));
 218:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * LED2_MAX));
 219:src/main.cpp  ****             g_led3_duty = led3;
 220:src/main.cpp  **** 
 221:src/main.cpp  ****             // FSR: drive calibration, and also break out if it's pressed to the
 222:src/main.cpp  ****             // floor ŌĆö so the voice-select gesture (hold FSR) works straight from
 223:src/main.cpp  ****             // idle, without having to touch the glass first to exit the chase.
 224:src/main.cpp  ****             uint16_t fsr_now = hw.adc.Get(0);
