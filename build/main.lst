 531:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 532:src/main.cpp  ****     i2c_start();
 533:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
