 518:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 519:src/main.cpp  **** {
 520:src/main.cpp  ****     i2c_start();
 521:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 522:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 523:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 524:src/main.cpp  ****     i2c_stop();return true;
 525:src/main.cpp  **** }
