 455:src/main.cpp  **** // ŌöĆŌöĆ Oscillator waveforms (phase ph in [0,1) ŌåÆ sample in [-1,1]) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 456:src/main.cpp  **** // Triangle wave
 457:src/main.cpp  **** static inline float tri(float ph){
 458:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 459:src/main.cpp  **** }
 460:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ŌĆö matches sin(2ŽĆ┬Ęph).
 461:src/main.cpp  **** static inline float osc_sine(float ph){
 462:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 463:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -ŽĆ..ŽĆ (angle shifted by ŽĆ)
 464:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 465:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 466:src/main.cpp  ****     return -y;                                 // undo the ŽĆ shift: sin(x+ŽĆ) = -sin(x)
 467:src/main.cpp  **** }
 468:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 469:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 470:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 471:src/main.cpp  **** 
ARM GAS  /tmp/claude-502/cc5FnLRa.s 			page 17


 472:src/main.cpp  **** // Dispatch on the voice's waveform. VOICE.wave is a compile-time constant, so at
 473:src/main.cpp  **** // -O2 this folds to a single waveform call with no branch.
 474:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 475:src/main.cpp  ****     switch(w){
 476:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 477:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 478:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 479:src/main.cpp  ****         case WAVE_TRI:
 480:src/main.cpp  ****         default:          return tri(ph);
 481:src/main.cpp  ****     }
 482:src/main.cpp  **** }
 483:src/main.cpp  **** 
 484:src/main.cpp  **** // Moog 4-pole ladder
 485:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 486:src/main.cpp  **** {
 487:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 488:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 489:src/main.cpp  ****     float k  = 3.8f*res;
 490:src/main.cpp  ****     float fb = k*s_flt[3];
 491:src/main.cpp  ****     float x  = in - fb;
 492:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 493:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 494:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 495:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 496:src/main.cpp  ****     return s_flt[3];
 497:src/main.cpp  **** }
 498:src/main.cpp  **** 
 499:src/main.cpp  **** // Wavefolder distortion
 500:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 501:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 502:src/main.cpp  **** static inline float wavefold(float in, float amount)
 503:src/main.cpp  **** {
 504:src/main.cpp  ****     if(amount < 0.01f) return in;
 505:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 506:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 507:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 508:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 509:src/main.cpp  ****     float x = driven;
 510:src/main.cpp  ****     // 2 passes of folding for richness
 511:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 512:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 513:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 514:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 515:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 516:src/main.cpp  ****     }
 517:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 518:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 519:src/main.cpp  **** }
