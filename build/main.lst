 910:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 911:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 912:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 913:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 914:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 915:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 916:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 917:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 918:src/main.cpp  ****             g_led3_duty = led3;
 919:src/main.cpp  **** 
 920:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 921:src/main.cpp  ****             if(!calibrated) {
 922:src/main.cpp  ****                 acc += hw.adc.Get(0);
 923:src/main.cpp  ****                 n++;
 924:src/main.cpp  ****                 if(elapsed >= 2000) {
 925:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 926:src/main.cpp  ****                     calibrated = true;
 927:src/main.cpp  ****                 }
 928:src/main.cpp  ****             }
