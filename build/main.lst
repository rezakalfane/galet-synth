 818:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0‚Üí1‚Üí0 cycle
 819:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 820:src/main.cpp  ****         uint16_t scan[N_CH];
 821:src/main.cpp  **** 
 822:src/main.cpp  ****         while(true) {
 823:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 824:src/main.cpp  **** 
 825:src/main.cpp  ****             // Sinusoidal position 0‚Üí1‚Üí0 over SWEEP_PERIOD_MS ‚Äî eases at the
 826:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 827:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
