 490:src/voice.h   ****     // OSCILLATOR STACK
 491:src/voice.h   ****     1.0f,
 492:src/voice.h   ****     0.40f,
 493:src/voice.h   ****     WAVE_SAW,            // osc1  ŌĆö saw root (bright, string-like)
 494:src/voice.h   ****     // SECONDARY OSCILLATOR
 495:src/voice.h   ****     RATIO_FIFTH,
 496:src/voice.h   ****     0.30f,
 497:src/voice.h   ****     WAVE_SAW,            // osc2  ŌĆö fixed perfect fifth (the power chord)
 498:src/voice.h   ****     // SUB OSCILLATOR
 499:src/voice.h   ****     0.5f,
 500:src/voice.h   ****     0.22f,
 501:src/voice.h   ****     WAVE_SAW,            // sub   ŌĆö octave-down body/weight
 502:src/voice.h   ****     // OCTAVE OSCILLATOR
 503:src/voice.h   ****     2.0f,
 504:src/voice.h   ****     0.18f,
 505:src/voice.h   ****     WAVE_SAW,            // oct   ŌĆö octave-up jangle / pick brightness
 506:src/voice.h   ****     // FILTER
 507:src/voice.h   ****     false,               // osc2 is a fixed fifth, not finger-2 detune
 508:src/voice.h   ****     1.5f,
 509:src/voice.h   ****     6.0f,
ARM GAS  /tmp/claude-502/ccMZiWpD.s 			page 47


 510:src/voice.h   ****     0.42f,               // bright-ish base, wide sweep, resonant mid "quack" (amp-like)
 511:src/voice.h   ****     // DRIVE
 512:src/voice.h   ****     3.6f,                // overdrive crunch ŌĆö the electric-guitar grit
 513:src/voice.h   ****     // NOISE
 514:src/voice.h   ****     0.03f,               // noise level ŌĆö a little pick grit (rides the amp decay)
 515:src/voice.h   ****     1.0f,                // keytrack
 516:src/voice.h   ****     1.0f,                // ringmod ratio
 517:src/voice.h   ****     0.12f,               // ringmod max
 518:src/voice.h   ****     0.15f,               // fold max
 519:src/voice.h   ****     3.0f,                // attack ŌĆö fast pluck onset
 520:src/voice.h   ****     280.0f,              // release ŌĆö ring tail after lift
 521:src/voice.h   ****     8.0f,                // glide ŌĆö quick, distinct chord changes
 522:src/voice.h   ****     // PITCH ENVELOPE ŌĆö fast pick-attack "twang": start ~0.12 oct sharp, settle 18 ms
 523:src/voice.h   ****     0.12f, 18.0f,        // pitch_env_oct, pitch_env_ms
 524:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 525:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
 526:src/voice.h   ****     // PITCH QUANTIZE ŌĆö snap to a major scale on touch-down so chords land in key
 527:src/voice.h   ****     true,
 528:src/voice.h   ****     SCALE_MAJOR, (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0])),
 529:src/voice.h   ****     // AMP DECAY ŌĆö the pluck: ring out to silence over ~1.2 s while held
 530:src/voice.h   ****     1200.0f,             // decay_ms
 531:src/voice.h   ****     0.0f                 // sustain (0 = decays to silence)
 532:src/voice.h   **** };
