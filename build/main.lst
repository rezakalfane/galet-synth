 782:src/voice.h   ****     0.06f,
 783:src/voice.h   ****     WAVE_SQUARE,         // oct   ŌĆö high partial (2.0├Ś keeps it under Nyquist)
 784:src/voice.h   ****     // FILTER
 785:src/voice.h   ****     false,               // osc2 is a fixed ratio, not finger-2 detune
 786:src/voice.h   ****     25.0f,
 787:src/voice.h   ****     2.0f,
 788:src/voice.h   ****     0.20f,               // wide open
 789:src/voice.h   ****     // DRIVE
 790:src/voice.h   ****     1.2f,                // light drive
 791:src/voice.h   ****     // NOISE
 792:src/voice.h   ****     0.80f,               // noise level ŌĆö noise-led
 793:src/voice.h   ****     0.2f,                // keytrack
 794:src/voice.h   ****     1.0f,                // ringmod ratio
