 783:src/voice.h   **** // ŌöĆŌöĆ Voice bank ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 784:src/voice.h   **** // All voices, in cycle order. Holding the FSR pressed steps through these live
 785:src/voice.h   **** // (see the voice-switch gesture in the main loop). Edit the order here to taste.
 786:src/voice.h   **** static constexpr Voice VOICES[] = {
 787:src/voice.h   ****     VOICE_LEAD,  VOICE_BASS,   VOICE_BASS_OPEN,   VOICE_BASS_RICH,
 788:src/voice.h   ****     VOICE_ORGAN, VOICE_SCREAM, VOICE_BASS_CLOSED, VOICE_PAD,
 789:src/voice.h   ****     VOICE_TOM,   VOICE_KICK,   VOICE_SNARE,       VOICE_HIHAT,
 790:src/voice.h   ****     VOICE_DRUMS, // MultiVoice ŌĆö must stay last (MULTI_IDX = NUM_VOICES-1)
 791:src/voice.h   **** };
 792:src/voice.h   **** static constexpr int NUM_VOICES = (int)(sizeof(VOICES) / sizeof(VOICES[0]));
 793:src/voice.h   **** 
 794:src/voice.h   **** // ŌöĆŌöĆ MultiVoice "Drums" config ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 795:src/voice.h   **** // MULTI_IDX is the bank slot of VOICE_DRUMS (kept last). When that voice is
