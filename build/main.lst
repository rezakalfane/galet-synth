 385:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 386:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 387:src/main.cpp  **** float quantize_midi(float midi)
 388:src/main.cpp  **** {
 389:src/main.cpp  ****     int root = (int)midi;
 390:src/main.cpp  ****     int pc   = root % 12;
 391:src/main.cpp  ****     int oct  = root / 12;
 392:src/main.cpp  ****     // find nearest scale degree
 393:src/main.cpp  ****     int best_deg=0, best_dist=127;
 394:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 395:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 396:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 397:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 398:src/main.cpp  ****     }
 399:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 400:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 401:src/main.cpp  ****     float frac=midi-(float)root;
 402:src/main.cpp  ****     return q+frac;
 403:src/main.cpp  **** }
