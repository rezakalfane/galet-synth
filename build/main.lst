 829:src/main.cpp  **** 
 830:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 831:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 832:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 833:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 834:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 835:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 836:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 837:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 838:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 839:src/main.cpp  ****             g_led3_duty = led3;
 840:src/main.cpp  **** 
 841:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 842:src/main.cpp  ****             if(!calibrated) {
 843:src/main.cpp  ****                 acc += hw.adc.Get(0);
 844:src/main.cpp  ****                 n++;
 845:src/main.cpp  ****                 if(elapsed >= 2000) {
 846:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 847:src/main.cpp  ****                     calibrated = true;
 848:src/main.cpp  ****                 }
 849:src/main.cpp  ****             }
