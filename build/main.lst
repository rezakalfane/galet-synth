 593:src/main.cpp  **** // Up to 4 fingers tracked (for the polyphonic Drums MultiVoice). The mono
 594:src/main.cpp  **** // melodic path still only uses tracked[0] (pitch) and tracked[1] (effects).
 595:src/main.cpp  **** static constexpr int MAX_FINGERS = 4;
