 454:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 455:src/main.cpp  **** static inline float fast_tanh(float x)
 456:src/main.cpp  **** {
 457:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 458:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 459:src/main.cpp  ****     float x2=x*x;
 460:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 461:src/main.cpp  **** }
 462:src/main.cpp  **** 
 463:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 464:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 465:src/main.cpp  **** float quantize_midi(float midi)
 466:src/main.cpp  **** {
 467:src/main.cpp  ****     int root = (int)midi;
 468:src/main.cpp  ****     int pc   = root % 12;
 469:src/main.cpp  ****     int oct  = root / 12;
 470:src/main.cpp  ****     // find nearest scale degree
 471:src/main.cpp  ****     int best_deg=0, best_dist=127;
ARM GAS  /tmp/claude-502/ccb6uqMv.s 			page 17


 472:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 473:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 474:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 475:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 476:src/main.cpp  ****     }
 477:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 478:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 479:src/main.cpp  ****     float frac=midi-(float)root;
 480:src/main.cpp  ****     return q+frac;
 481:src/main.cpp  **** }
