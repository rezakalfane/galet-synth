 130:src/main.cpp  **** bool mpr_init()
 131:src/main.cpp  **** {
 132:src/main.cpp  ****     mpr_write(REG_SOFTRESET,0x63);System::Delay(10);
 133:src/main.cpp  ****     mpr_write(REG_ECR,0x00);
 134:src/main.cpp  ****     mpr_write(REG_MHDR,0x01);mpr_write(REG_NHDR,0x01);
 135:src/main.cpp  ****     mpr_write(REG_NCLR,0x10);mpr_write(REG_FDLR,0x20);
 136:src/main.cpp  ****     mpr_write(REG_MHDF,0x01);mpr_write(REG_NHDF,0x01);
 137:src/main.cpp  ****     mpr_write(REG_NCLF,0x10);mpr_write(REG_FDLF,0x20);
 138:src/main.cpp  ****     mpr_write(REG_NHDT,0x00);mpr_write(REG_NCLT,0x00);mpr_write(REG_FDLT,0x00);
 139:src/main.cpp  ****     for(uint8_t ch=0;ch<12;ch++){mpr_write(0x41+ch*2,4);mpr_write(0x42+ch*2,2);}
 140:src/main.cpp  ****     mpr_write(REG_DEBOUNCE,0x11);
 141:src/main.cpp  ****     mpr_write(REG_CONFIG1,0x50);
 142:src/main.cpp  ****     mpr_write(REG_CONFIG2,0x7C);  // CDT=32us SFI=18 ESI=1ms
 143:src/main.cpp  ****     mpr_write(REG_ECR,0x8C);
 144:src/main.cpp  ****     System::Delay(100);
 145:src/main.cpp  ****     uint8_t ecr=0;mpr_read(REG_ECR,&ecr,1);
 146:src/main.cpp  ****     return(ecr==0x8C);
 147:src/main.cpp  **** }
