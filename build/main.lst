 209:src/main.cpp  **** int32_t pressure_pct(int32_t pk){
 210:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF - TOUCH_THRESHOLD;
 211:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 212:src/main.cpp  ****     if(raw < 0)      return 0;
 213:src/main.cpp  ****     if(raw >= range) return 100;
 214:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 215:src/main.cpp  ****     if(raw > range) raw = range;
 216:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 217:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 218:src/main.cpp  ****     // Integer sqrt via Newton ŌĆö start from 101 (max output) for guaranteed convergence
 219:src/main.cpp  ****     int32_t s = 101;
 220:src/main.cpp  ****     s = (s + scaled/s) / 2;
 221:src/main.cpp  ****     s = (s + scaled/s) / 2;
 222:src/main.cpp  ****     s = (s + scaled/s) / 2;
 223:src/main.cpp  ****     s = (s + scaled/s) / 2;
 224:src/main.cpp  ****     // Remap [0,100] ŌåÆ [10,100]: threshold delta = 10%, max = 100%
 225:src/main.cpp  ****     s = 10 + s * 90 / 100;
 226:src/main.cpp  ****     if(s < 0)   s = 0;
 227:src/main.cpp  ****     if(s > 100) s = 100;
 228:src/main.cpp  ****     return s;
 229:src/main.cpp  **** }
