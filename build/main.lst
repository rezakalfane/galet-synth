1400:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
1401:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1402:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
1403:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
1404:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
1405:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
1406:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1407:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1408:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1409:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1410:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1411:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1412:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
