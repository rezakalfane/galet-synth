 892:src/main.cpp  **** static void drum_trigger(DrumHit& h, int vidx, float freq, float amp_tgt,
 893:src/main.cpp  ****                          float cutoff, float drive, float sr)
 894:src/main.cpp  **** {
 895:src/main.cpp  ****     const Voice& V = VOICES[vidx];
 896:src/main.cpp  ****     h.active=true; h.gate=true; h.vidx=vidx;
 897:src/main.cpp  ****     h.freq=freq; h.amp_tgt=amp_tgt; h.cutoff=cutoff; h.drive=drive;
 898:src/main.cpp  ****     h.ph1=h.ph2=h.phs=h.pho=0.0f;
 899:src/main.cpp  ****     h.amp=0.0f; h.noise_lp=0.0f;
 900:src/main.cpp  ****     // 1-pole lowpass coefficient from the (latched) cutoff: a = 1 - e^(-2ŽĆ┬Ęfc/sr).
 901:src/main.cpp  ****     h.lp_state = 0.0f;
 902:src/main.cpp  ****     h.lp_coeff = clampf(1.0f - expf(-6.2831853f * cutoff / sr), 0.0f, 1.0f);
 903:src/main.cpp  ****     h.atk_c      = ms_to_coeff(V.attack_ms,    sr);
 904:src/main.cpp  ****     h.rel_c      = ms_to_coeff(V.release_ms,   sr);
 905:src/main.cpp  ****     h.penv_c     = ms_to_coeff(V.pitch_env_ms, sr);
 906:src/main.cpp  ****     h.penv_start = exp2f(V.pitch_env_oct);
 907:src/main.cpp  ****     h.pmult      = h.penv_start;
 908:src/main.cpp  **** }
