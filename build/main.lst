  66:src/voice.h   ****     // retriggers). A full lift always retriggers regardless. Default 0 keeps the
  67:src/voice.h   ****     // melodic voices free of accidental re-articulation; drums set a value.
  68:src/voice.h   ****     float retrig_ms;
  69:src/voice.h   **** };
