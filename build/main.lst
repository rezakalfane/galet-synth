  80:src/main.cpp  **** inline void sda_high(){sda.Init(SDA_PIN,GPIO::Mode::INPUT, GPIO::Pull::PULLUP);}
  81:src/main.cpp  **** inline void sda_low() {sda.Init(SDA_PIN,GPIO::Mode::OUTPUT,GPIO::Pull::NOPULL);sda.Write(false);}
  82:src/main.cpp  **** inline void scl_high(){scl.Init(SCL_PIN,GPIO::Mode::INPUT, GPIO::Pull::PULLUP);}
  83:src/main.cpp  **** inline void scl_low() {scl.Init(SCL_PIN,GPIO::Mode::OUTPUT,GPIO::Pull::NOPULL);scl.Write(false);}
  84:src/main.cpp  **** inline void d(){System::DelayUs(HP);}
  85:src/main.cpp  **** 
  86:src/main.cpp  **** void i2c_start(){sda_high();d();scl_high();d();sda_low();d();scl_low();d();}
  87:src/main.cpp  **** void i2c_stop() {sda_low();d();scl_high();d();sda_high();d();}
  88:src/main.cpp  **** 
  89:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
  90:src/main.cpp  **** {
  91:src/main.cpp  ****     for(int i=7;i>=0;i--){
  92:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
  93:src/main.cpp  ****         d();scl_high();d();scl_low();d();
  94:src/main.cpp  ****     }
  95:src/main.cpp  ****     sda_high();d();scl_high();d();
  96:src/main.cpp  ****     bool ack=!sda.Read();
  97:src/main.cpp  ****     scl_low();d();
  98:src/main.cpp  ****     return ack;
  99:src/main.cpp  **** }
 100:src/main.cpp  **** 
 101:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 102:src/main.cpp  **** {
 103:src/main.cpp  ****     uint8_t b=0;sda_high();
 104:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 105:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 106:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 107:src/main.cpp  ****     return b;
 108:src/main.cpp  **** }
 109:src/main.cpp  **** 
 110:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 111:src/main.cpp  **** {
 112:src/main.cpp  ****     i2c_start();
 113:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 114:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 115:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 116:src/main.cpp  ****     i2c_stop();return true;
 117:src/main.cpp  **** }
 118:src/main.cpp  **** 
 119:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 120:src/main.cpp  **** {
 121:src/main.cpp  ****     i2c_start();
 122:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 123:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 124:src/main.cpp  ****     i2c_start();
 125:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 126:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 127:src/main.cpp  ****     i2c_stop();return true;
 128:src/main.cpp  **** }
