 198:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 199:src/main.cpp  **** {
 200:src/main.cpp  ****     for(int i=7;i>=0;i--){
 201:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 202:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 203:src/main.cpp  ****     }
 204:src/main.cpp  ****     sda_high();d();scl_high();d();
 205:src/main.cpp  ****     bool ack=!sda.Read();
 206:src/main.cpp  ****     scl_low();d();
 207:src/main.cpp  ****     return ack;
 208:src/main.cpp  **** }
 209:src/main.cpp  **** 
 210:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 211:src/main.cpp  **** {
 212:src/main.cpp  ****     uint8_t b=0;sda_high();
 213:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 214:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 215:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 216:src/main.cpp  ****     return b;
 217:src/main.cpp  **** }
