 700:src/main.cpp  **** 
 701:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 702:src/main.cpp  **** // Lower value = faster response.
 703:src/main.cpp  **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
 704:src/main.cpp  **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
 705:src/main.cpp  **** // callback. The constants below are the ones still shared by all voices.
 706:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 707:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 708:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 709:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 710:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ŌĆö ~35 ms smooth
 711:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 712:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 713:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 714:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 715:src/main.cpp  **** 
 716:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 717:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 718:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 719:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 720:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 721:src/main.cpp  **** }
 722:src/main.cpp  **** 
 723:src/main.cpp  **** // ŌöĆŌöĆ Oscillator waveforms (phase ph in [0,1) ŌåÆ sample in [-1,1]) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 724:src/main.cpp  **** // Triangle wave
 725:src/main.cpp  **** static inline float tri(float ph){
 726:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 727:src/main.cpp  **** }
 728:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ŌĆö matches sin(2ŽĆ┬Ęph).
 729:src/main.cpp  **** static inline float osc_sine(float ph){
 730:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 731:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -ŽĆ..ŽĆ (angle shifted by ŽĆ)
 732:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 733:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 734:src/main.cpp  ****     return -y;                                 // undo the ŽĆ shift: sin(x+ŽĆ) = -sin(x)
 735:src/main.cpp  **** }
 736:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 737:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 738:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 739:src/main.cpp  **** 
 740:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 741:src/main.cpp  **** // switched live). A small jump table ŌĆö cheap at audio rate on the H750.
 742:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 743:src/main.cpp  ****     switch(w){
 744:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 745:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 746:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 747:src/main.cpp  ****         case WAVE_TRI:
 748:src/main.cpp  ****         default:          return tri(ph);
 749:src/main.cpp  ****     }
 750:src/main.cpp  **** }
