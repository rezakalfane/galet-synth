1099:src/main.cpp  ****         // hiss. noise_hp blends from full white ("shhh") to high-passed ("tsss",
1100:src/main.cpp  ****         // for hi-hats). The `if` folds away when a voice sets noise_level = 0.
1101:src/main.cpp  ****         float noise = 0.0f;
1102:src/main.cpp  ****         if(VOICE.noise_level > 0.0f){
