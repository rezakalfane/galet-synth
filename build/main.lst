 758:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 759:src/main.cpp  **** 
 760:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 761:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 762:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
