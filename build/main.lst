 449:src/main.cpp  **** // ŌöĆŌöĆ Maths helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 450:src/main.cpp  **** static inline float clampf(float v,float lo,float hi){
