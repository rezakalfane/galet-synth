 366:src/main.cpp  **** // Triangle wave
 367:src/main.cpp  **** static inline float tri(float ph){
 368:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 369:src/main.cpp  **** }
