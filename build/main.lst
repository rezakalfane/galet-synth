  13:src/voice.h   ****     float log_freq_ratio;   // = ln(freq_high / freq_low), precomputed (logf isn't constexpr)
  14:src/voice.h   **** 
  15:src/voice.h   ****     // Oscillator stack. Each oscillator's pitch = fundamental * ratio, and each
  16:src/voice.h   ****     // has its own waveform. Set a level to 0 to silence an oscillator.
  17:src/voice.h   ****     float osc1_ratio, osc1_level;  Waveform osc1_wave;   // primary
  18:src/voice.h   ****     float osc2_ratio, osc2_level;  Waveform osc2_wave;   // second osc (see osc2_detune)
  19:src/voice.h   ****     float sub_ratio,  sub_level;   Waveform sub_wave;    // weight below
  20:src/voice.h   ****     float oct_ratio,  oct_level;   Waveform oct_wave;    // shimmer / chord top
  21:src/voice.h   ****     bool  osc2_detune;              // true  ŌåÆ finger-2 detune controls osc2 pitch (lead)
  22:src/voice.h   ****                                     // false ŌåÆ osc2 stays at osc2_ratio (e.g. a fixed 5th)
  23:src/voice.h   **** 
  24:src/voice.h   ****     // Filter character. Base cutoff = freq * cutoff_mult; pressure opens it
  25:src/voice.h   ****     // by up to cutoff_oct_max octaves on top.
  26:src/voice.h   ****     float cutoff_mult;
  27:src/voice.h   ****     float cutoff_oct_max;
  28:src/voice.h   ****     float resonance;
  29:src/voice.h   **** 
  30:src/voice.h   ****     // Drive ŌĆö pressure-controlled waveshaper gain added on top of 1.0.
  31:src/voice.h   ****     float drive_max;
  32:src/voice.h   **** 
  33:src/voice.h   ****     // ŌöĆŌöĆ Extras (appended so existing field order stays stable) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  34:src/voice.h   ****     float noise_level;     // white noise mixed into the oscillator stack (0 = none)
  35:src/voice.h   ****     float keytrack;        // 0..1 ŌĆö how much the cutoff follows pitch (1 = full)
  36:src/voice.h   ****     float ringmod_ratio;   // ring-mod carrier pitch ratio (1.0 = unison; non-int = bell/metallic)
  37:src/voice.h   ****     float ringmod_max;     // max ring-mod wet from finger-2 pressure
  38:src/voice.h   ****     float fold_max;        // max wavefold amount from finger-2 pressure
  39:src/voice.h   ****     float attack_ms;       // amp envelope attack time
  40:src/voice.h   ****     float release_ms;      // amp envelope + filter-close release time
  41:src/voice.h   ****     float glide_ms;        // portamento (pitch glide) time
  42:src/voice.h   **** 
  43:src/voice.h   ****     // Pitch envelope ŌĆö a fast downward pitch sweep at note onset (kick "boom",
  44:src/voice.h   ****     // zap, tom thump). Left at 0 (the default for voices that omit them) = off.
  45:src/voice.h   ****     float pitch_env_oct;   // octaves the pitch starts ABOVE the note at onset (0 = none)
  46:src/voice.h   ****     float pitch_env_ms;    // time the pitch sweep takes to settle to the note
  47:src/voice.h   **** 
  48:src/voice.h   ****     // Noise tone: 0 = full white noise ("shhh"), 1 = high-passed/bright ("tsss",
  49:src/voice.h   ****     // for hi-hats/cymbals). Default 0 leaves the noise white. See NOISE_HP_COEF.
  50:src/voice.h   ****     float noise_hp;
  51:src/voice.h   **** 
  52:src/voice.h   ****     // FSR-gesture cycling: true = skip this voice in the cycle (still reachable
  53:src/voice.h   ****     // as the boot voice or via the Drums MultiVoice). Default false = in cycle.
  54:src/voice.h   ****     // The raw drums set this so the gesture cycles instruments + Drums only.
  55:src/voice.h   ****     bool no_cycle;
  56:src/voice.h   **** 
  57:src/voice.h   ****     // Velocity sensitivity 0..1: how much the onset hit strength (peak pressure
  58:src/voice.h   ****     // in the first few ms) scales loudness. 0 = fixed loudness (default ŌĆö the
  59:src/voice.h   ****     // sustained instruments); ~0.85 on drums for accents/ghost notes. Loudness
  60:src/voice.h   ****     // floor = (1 - vel_sens), so soft taps stay audible.
  61:src/voice.h   ****     float vel_sens;
  62:src/voice.h   **** 
  63:src/voice.h   ****     // Re-attack speed on hold: minimum ms between bounce-retriggers (the cap on
  64:src/voice.h   ****     // how fast a held finger can repeat by pulsing pressure). SMALLER = faster
  65:src/voice.h   ****     // repeats allowed; LARGER = slower. 0 = off (only a full lift + re-tap
