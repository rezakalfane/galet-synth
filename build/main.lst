 797:src/voice.h   **** // (leftŌåÆright), and the fine position within a zone snaps the pitch to one of
 798:src/voice.h   **** // MULTI_INTERVALS above the drum's base pitch (freq_low).
 799:src/voice.h   **** static constexpr int MULTI_IDX = NUM_VOICES - 1;
