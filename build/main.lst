 795:src/voice.h   ****     0.0f,                // ringmod max
 796:src/voice.h   ****     0.05f,               // fold max
 797:src/voice.h   ****     1.0f,                // attack ŌĆö instant
 798:src/voice.h   ****     160.0f,              // release ŌĆö sizzly tail
 799:src/voice.h   ****     3.0f,                // glide
 800:src/voice.h   ****     // PITCH ENVELOPE
 801:src/voice.h   ****     0.0f,                // pitch env octaves (off)
 802:src/voice.h   ****     0.0f,                // pitch env time
 803:src/voice.h   ****     // NOISE TONE
