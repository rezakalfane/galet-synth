1273:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
1274:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
1275:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
1276:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
1277:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 8450              		.loc 6 1277 5 view .LVU2449
1278:src/main.cpp  ****         uint32_t start = System::GetNow();
