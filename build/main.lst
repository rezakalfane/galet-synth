 322:src/main.cpp  ****     mpr_write(REG_NCLR,0x10);mpr_write(REG_FDLR,0x20);
 323:src/main.cpp  ****     mpr_write(REG_MHDF,0x01);mpr_write(REG_NHDF,0x01);
 324:src/main.cpp  ****     mpr_write(REG_NCLF,0x10);mpr_write(REG_FDLF,0x20);
 325:src/main.cpp  ****     mpr_write(REG_NHDT,0x00);mpr_write(REG_NCLT,0x00);mpr_write(REG_FDLT,0x00);
