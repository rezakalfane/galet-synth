 661:src/voice.h   ****     0.5f,
 662:src/voice.h   ****     0.15f,
 663:src/voice.h   ****     WAVE_SINE,           // sub   ŌĆö sub-octave rumble
 664:src/voice.h   ****     // OCTAVE OSCILLATOR
 665:src/voice.h   ****     2.0f,
 666:src/voice.h   ****     0.0f,
 667:src/voice.h   ****     WAVE_SINE,           // oct   ŌĆö off
 668:src/voice.h   ****     // FILTER
 669:src/voice.h   ****     false,               // osc2 is a fixed ratio, not finger-2 detune
 670:src/voice.h   ****     3.0f,
 671:src/voice.h   ****     2.0f,
 672:src/voice.h   ****     0.20f,               // very closed/dark ŌĆö round; tiny pressure sweep
 673:src/voice.h   ****     // DRIVE
 674:src/voice.h   ****     1.8f,                // drive ŌĆö punch and saturation
 675:src/voice.h   ****     // NOISE
 676:src/voice.h   ****     0.08f,               // noise level ŌĆö soft beater click
 677:src/voice.h   ****     0.5f,                // keytrack
 678:src/voice.h   ****     1.0f,                // ringmod ratio
 679:src/voice.h   ****     0.0f,                // ringmod max
 680:src/voice.h   ****     0.0f,                // fold max
