 684:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 685:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 686:src/main.cpp  **** float quantize_midi(float midi)
 687:src/main.cpp  **** {
 688:src/main.cpp  ****     int root = (int)midi;
 689:src/main.cpp  ****     int pc   = root % 12;
 690:src/main.cpp  ****     int oct  = root / 12;
 691:src/main.cpp  ****     // find nearest scale degree
 692:src/main.cpp  ****     int best_deg=0, best_dist=127;
 693:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 694:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 695:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 696:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 697:src/main.cpp  ****     }
 698:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 699:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
ARM GAS  /tmp/claude-502/ccgDx762.s 			page 21


 700:src/main.cpp  ****     float frac=midi-(float)root;
 701:src/main.cpp  ****     return q+frac;
 702:src/main.cpp  **** }
