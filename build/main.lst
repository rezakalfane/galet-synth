 487:src/voice.h   **** // ŌöĆŌöĆ Voice 6: electric guitar power chord ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 488:src/voice.h   **** //   A driven sawtooth power chord ŌĆö each note is a root + fixed perfect fifth +
 489:src/voice.h   **** //   octave-up jangle over a saw octave-down body, so it plays as a chord like a
 490:src/voice.h   **** //   rock guitar. Heavy-ish drive adds overdrive crunch; the filter sits a touch
 491:src/voice.h   **** //   above the fundamental and sweeps wide open with pressure (dig in = bright,
 492:src/voice.h   **** //   pick-attack bite), with resonance for a vocal amp "quack". A fast pitch-env
 493:src/voice.h   **** //   "twang" + a little pick-grit noise on the onset, then amp decay-to-silence
 494:src/voice.h   **** //   (decay_ms/sustain below) so each note plucks and rings out over ~1.2 s while
 495:src/voice.h   **** //   held ŌĆö like a struck string, not an organ. Quantized to a major scale so
 496:src/voice.h   **** //   tapped chords land in key. For a BASS guitar instead: drop freq_low/high ~┬Į,
 497:src/voice.h   **** //   cut drive to ~1.5, use WAVE_TRI, and raise `sustain` if you want it to hold.
 498:src/voice.h   **** static constexpr Voice VOICE_GUITAR = {
ARM GAS  /tmp/claude-502/ccV8DHZX.s 			page 44


 499:src/voice.h   ****     "Guitar",
 500:src/voice.h   ****     // FREQUENCY RANGE
 501:src/voice.h   ****     80.0f,
 502:src/voice.h   ****     320.0f,
 503:src/voice.h   ****     1.38629f,            // 80ŌĆō320 Hz, ln(4) ŌĆö E2-ish up two octaves
 504:src/voice.h   ****     // OSCILLATOR STACK
 505:src/voice.h   ****     1.0f,
 506:src/voice.h   ****     0.40f,
 507:src/voice.h   ****     WAVE_SAW,            // osc1  ŌĆö saw root (bright, string-like)
 508:src/voice.h   ****     // SECONDARY OSCILLATOR
 509:src/voice.h   ****     RATIO_FIFTH,
 510:src/voice.h   ****     0.30f,
 511:src/voice.h   ****     WAVE_SAW,            // osc2  ŌĆö fixed perfect fifth (the power chord)
 512:src/voice.h   ****     // SUB OSCILLATOR
 513:src/voice.h   ****     0.5f,
 514:src/voice.h   ****     0.22f,
 515:src/voice.h   ****     WAVE_SAW,            // sub   ŌĆö octave-down body/weight
 516:src/voice.h   ****     // OCTAVE OSCILLATOR
 517:src/voice.h   ****     2.0f,
 518:src/voice.h   ****     0.18f,
 519:src/voice.h   ****     WAVE_SAW,            // oct   ŌĆö octave-up jangle / pick brightness
 520:src/voice.h   ****     // FILTER
 521:src/voice.h   ****     false,               // osc2 is a fixed fifth, not finger-2 detune
 522:src/voice.h   ****     1.5f,
 523:src/voice.h   ****     6.0f,
 524:src/voice.h   ****     0.42f,               // bright-ish base, wide sweep, resonant mid "quack" (amp-like)
 525:src/voice.h   ****     // DRIVE
 526:src/voice.h   ****     3.6f,                // overdrive crunch ŌĆö the electric-guitar grit
 527:src/voice.h   ****     // NOISE
 528:src/voice.h   ****     0.03f,               // noise level ŌĆö a little pick grit (rides the amp decay)
 529:src/voice.h   ****     1.0f,                // keytrack
 530:src/voice.h   ****     1.0f,                // ringmod ratio
 531:src/voice.h   ****     0.12f,               // ringmod max
 532:src/voice.h   ****     0.15f,               // fold max
 533:src/voice.h   ****     3.0f,                // attack ŌĆö fast pluck onset
 534:src/voice.h   ****     280.0f,              // release ŌĆö ring tail after lift
 535:src/voice.h   ****     8.0f,                // glide ŌĆö quick, distinct chord changes
 536:src/voice.h   ****     // PITCH ENVELOPE ŌĆö fast pick-attack "twang": start ~0.12 oct sharp, settle 18 ms
 537:src/voice.h   ****     0.12f, 18.0f,        // pitch_env_oct, pitch_env_ms
 538:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 539:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
