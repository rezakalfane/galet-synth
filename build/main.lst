 534:src/voice.h   **** // ŌöĆŌöĆ Voice 7: warm ensemble pad ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 535:src/voice.h   **** //   A lush, evolving pad. Two saws a hair apart (1.006├Ś) give an ensemble/chorus
 536:src/voice.h   **** //   width, a soft triangle sub adds body, an airy sine octave sits on top. A
 537:src/voice.h   **** //   moderate, low-resonance filter keeps it warm rather than bright. The pad
 538:src/voice.h   **** //   character comes from the envelope: a slow ~2.2 s swell in and a long ~2 s
 539:src/voice.h   **** //   tail, so notes bloom and linger. A whisper of noise adds air.
 540:src/voice.h   **** static constexpr Voice VOICE_PAD = {
 541:src/voice.h   ****     "Pad",
 542:src/voice.h   ****     // FREQUENCY RANGE
 543:src/voice.h   ****     70.0f,
