 205:src/main.cpp  **** // Find up to `maxf` fingers: repeatedly take the strongest remaining peak, and
 206:src/main.cpp  **** // if it's far enough from the peaks already found, record its centroid; then
 207:src/main.cpp  **** // zero a ┬▒2 window around it and look again. The first two peaks come out
 208:src/main.cpp  **** // identical to the old 2-finger detector, so the mono path is unchanged.
 209:src/main.cpp  **** int detect_raw(int32_t* delta, Finger* out, int maxf)
 210:src/main.cpp  **** {
 211:src/main.cpp  ****     for(int i=0;i<maxf;i++) out[i].active=false;
 212:src/main.cpp  ****     int32_t work[N_CH];
 213:src/main.cpp  ****     for(int i=0;i<N_CH;i++) work[i]=delta[i];
 214:src/main.cpp  **** 
 215:src/main.cpp  ****     int peaks[MAX_FINGERS];
 216:src/main.cpp  ****     int found=0;
 217:src/main.cpp  ****     for(int attempt=0; attempt<maxf && found<maxf; attempt++){
 218:src/main.cpp  ****         int pk=0; int32_t mx=0;
 219:src/main.cpp  ****         for(int i=0;i<N_CH;i++) if(work[i]>mx){ mx=work[i]; pk=i; }
 220:src/main.cpp  ****         if(mx<TOUCH_THRESHOLD) break;                 // nothing left above threshold
 221:src/main.cpp  **** 
 222:src/main.cpp  ****         bool sep_ok=true;
 223:src/main.cpp  ****         for(int j=0;j<found;j++){ int s=pk-peaks[j]; if(s<0)s=-s; if(s<MIN_FINGER_SEP){ sep_ok=fals
 224:src/main.cpp  ****         if(sep_ok){
 225:src/main.cpp  ****             int ws=pk-2; if(ws<0)ws=0; int we=pk+2; if(we>=N_CH)we=N_CH-1;
