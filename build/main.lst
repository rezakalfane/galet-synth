 162:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ŌĆö fixed perfect fifth (the power chord)
 163:src/main.cpp  ****     0.5f,        0.30f, WAVE_TRI,   // sub   ŌĆö slightly less so the openness reads
 164:src/main.cpp  ****     2.0f,        0.22f, WAVE_TRI,   // oct   ŌĆö top of the power chord
 165:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 166:src/main.cpp  ****     0.5f, 10.0f, 0.65f,   // brighter base + wider pressure sweep + more resonance
 167:src/main.cpp  ****     1.8f,                 // more drive ŌĆö grit comes in as you press
 168:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 169:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.15f, 0.15f, 5.0f, 350.0f, 25.0f
