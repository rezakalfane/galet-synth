 327:src/main.cpp  ****     int      sel_mode      = 0;      // 0 = normal play, 1 = voice-select mode
 328:src/main.cpp  ****     bool     full_state    = false;  // schmitt-latched "FSR pressed to the floor"
 329:src/main.cpp  ****     uint32_t full_since    = 0;      // when full_state went true (enter timer; 0 = not full)
 330:src/main.cpp  ****     bool     prev_held     = false;  // bridged glass-touch state last loop (tap edge detect)
 331:src/main.cpp  ****     uint32_t touch_last_ms = 0;      // last loop the glass read as touched (lift bridge)
 332:src/main.cpp  ****     uint32_t last_tap_ms   = 0;      // last glass-tap advance (debounce)
 333:src/main.cpp  ****     uint32_t drum2_at      = 0;      // scheduled 2nd drum hit (snare) for the kit preview
 334:src/main.cpp  ****     // Non-blocking LED blinker: blink_start(n) queues n flashes, blink_tick()
 335:src/main.cpp  ****     // advances them between loops so glass taps still register (the old blocking
 336:src/main.cpp  ****     // flash stalled the loop up to ~2 s). Voice-select blinks the position on
 337:src/main.cpp  ****     // enter and on save (which voice), and a single blink per tap-advance (the
 338:src/main.cpp  ****     // audio preview IDs it). Startup uses the blocking flasher for the boot voice.
 339:src/main.cpp  ****     int      blink_left    = 0;
 340:src/main.cpp  ****     bool     blink_on      = false;
 341:src/main.cpp  ****     uint32_t blink_t       = 0;
 342:src/main.cpp  ****     auto leds_write = [&](bool on){
 343:src/main.cpp  ****         hw.dac.WriteValue(DacHandle::Channel::ONE, on ? (uint16_t)LED1_MAX : 0);
 344:src/main.cpp  ****         hw.dac.WriteValue(DacHandle::Channel::TWO, on ? (uint16_t)LED2_MAX : 0);
 345:src/main.cpp  ****         g_led3_duty = on ? LED3_INTENSITY : 0.0f;
 346:src/main.cpp  ****     };
 347:src/main.cpp  ****     auto blink_start = [&](int n, uint32_t now){
 348:src/main.cpp  ****         blink_left = n;
 349:src/main.cpp  ****         if(n > 0){ leds_write(true); blink_on = true; blink_t = now + 110; }
 350:src/main.cpp  ****         else     { leds_write(false); blink_on = false; }
 351:src/main.cpp  ****     };
 352:src/main.cpp  ****     auto blink_tick = [&](uint32_t now){
 353:src/main.cpp  ****         if(blink_left == 0 && !blink_on) return;
 354:src/main.cpp  ****         if((int32_t)(now - blink_t) < 0)  return;
 355:src/main.cpp  ****         if(blink_on){ leds_write(false); blink_on = false; blink_left--; blink_t = now + 140; }
 356:src/main.cpp  ****         else if(blink_left > 0){ leds_write(true); blink_on = true; blink_t = now + 110; }
 357:src/main.cpp  ****     };
 358:src/main.cpp  **** 
 359:src/main.cpp  ****     // Blocking flash used only at startup to announce the boot/restored voice.
 360:src/main.cpp  ****     auto flash_voice_leds = [&](int count){
 361:src/main.cpp  ****         for(int f = 0; f < count; f++){
 362:src/main.cpp  ****             leds_write(true);  System::Delay(110);
 363:src/main.cpp  ****             leds_write(false); System::Delay(140);
 364:src/main.cpp  ****         }
 365:src/main.cpp  ****     };
