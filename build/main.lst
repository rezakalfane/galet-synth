 228:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 229:src/main.cpp  **** {
 230:src/main.cpp  ****     i2c_start();
 231:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 232:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 233:src/main.cpp  ****     i2c_start();
 234:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 235:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 236:src/main.cpp  ****     i2c_stop();return true;
 237:src/main.cpp  **** }
