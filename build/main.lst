 303:src/voice.h   **** // ŌöĆŌöĆ Voice 11: hi-hat (noise-driven) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 304:src/voice.h   **** //   A crisp "tss" ŌĆö PLAY IT BY TAPPING. Almost pure high-frequency noise through
 305:src/voice.h   **** //   a wide-open filter, with three inharmonic square partials for metallic edge
 306:src/voice.h   **** //   and no low end. Instant attack and a very short ~55 ms tail = a tight closed
 307:src/voice.h   **** //   hat. Finger-1 position tunes the metallic pitch. (Raise release_ms for an
 308:src/voice.h   **** //   open-hat feel.)
 309:src/voice.h   **** static constexpr Voice VOICE_HIHAT = {
 310:src/voice.h   ****     "HiHat",
 311:src/voice.h   ****     4000.0f, 11000.0f, 1.01160f, // 4000ŌĆō11000 Hz, ln(2.75) ŌĆö metallic edge pitch
 312:src/voice.h   ****     1.0f,    0.10f, WAVE_SQUARE,  // osc1  ŌĆö quiet metallic edge (the tss noise leads)
 313:src/voice.h   ****     1.68f,   0.08f, WAVE_SQUARE,  // osc2  ŌĆö inharmonic metallic partial
 314:src/voice.h   ****     0.5f,    0.0f,  WAVE_SINE,    // sub   ŌĆö off (no low end on a hat)
 315:src/voice.h   ****     2.0f,    0.06f, WAVE_SQUARE,  // oct   ŌĆö high partial (2.0├Ś keeps it under Nyquist)
 316:src/voice.h   ****     false,                        // osc2 is a fixed ratio, not finger-2 detune
 317:src/voice.h   ****     25.0f, 2.0f, 0.20f,           // wide open
 318:src/voice.h   ****     1.2f,                         // light drive
 319:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 320:src/voice.h   ****     0.80f, 0.2f, 1.0f, 0.0f, 0.05f, 1.0f, 160.0f, 3.0f, // noise-led, instant, sizzly tail
 321:src/voice.h   ****     // pitch_env_oct, pitch_env_ms, noise_hp ŌĆö high-passed bright "tsss"
 322:src/voice.h   ****     0.0f, 0.0f, 1.0f,
 323:src/voice.h   ****     true,        // no_cycle ŌĆö reached via the Drums MultiVoice
 324:src/voice.h   ****     0.85f,       // vel_sens ŌĆö dynamic taps
 325:src/voice.h   ****     400.0f        // retrig_ms ŌĆö dedupe strike + cap repeat rate
 326:src/voice.h   **** };
