  90:src/voice.h   **** // ŌöĆŌöĆ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  91:src/voice.h   **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
  92:src/voice.h   **** //   so every note sounds as a power chord. Lower range, gentler filter, less
  93:src/voice.h   **** //   drive ŌåÆ deep and round rather than bright and screaming.
  94:src/voice.h   **** static constexpr Voice VOICE_BASS = {
  95:src/voice.h   ****     "Bass",
  96:src/voice.h   ****     40.0f, 160.0f, 1.38629f,   // 40ŌĆō160 Hz, ln(4) ŌĆö sits under the lead
  97:src/voice.h   ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ŌĆö root
  98:src/voice.h   ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ŌĆö fixed perfect fifth (the power chord)
  99:src/voice.h   ****     0.5f,        0.34f, WAVE_TRI,   // sub   ŌĆö extra weight for a round bottom
 100:src/voice.h   ****     2.0f,        0.20f, WAVE_TRI,   // oct   ŌĆö top of the power chord
 101:src/voice.h   ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 102:src/voice.h   ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 103:src/voice.h   ****     1.0f,                 // less drive ŌĆö keep it clean and round
 104:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 105:src/voice.h   ****     0.0f, 1.0f, 1.0f, 0.12f, 0.12f, 6.0f, 300.0f, 25.0f
 106:src/voice.h   **** };
