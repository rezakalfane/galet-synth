 349:src/voice.h   **** // ‚îÄ‚îÄ Voice 4: clean sine organ / flute (a melodic, non-bass departure) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 350:src/voice.h   **** //   Pure sine oscillators stacked like organ drawbars: octave-down body, root,
 351:src/voice.h   **** //   octave-up air, plus a second osc tuned a hair sharp (1.005√ó) for a slow,
 352:src/voice.h   **** //   warm chorus shimmer instead of a chord. Higher register than the basses, a
 353:src/voice.h   **** //   mostly-open clean filter, and just a touch of drive so pressure adds gentle
 354:src/voice.h   **** //   harmonic warmth. Sines never alias, so it stays smooth all the way up.
 355:src/voice.h   **** static constexpr Voice VOICE_ORGAN = {
 356:src/voice.h   ****     "Organ",
 357:src/voice.h   ****     // FREQUENCY RANGE
 358:src/voice.h   ****     65.0f,
 359:src/voice.h   ****     520.0f,
 360:src/voice.h   ****     2.07944f,            // 65‚Äì520 Hz, ln(8) ‚Äî a melodic keyboard register
 361:src/voice.h   ****     // OSCILLATOR STACK
 362:src/voice.h   ****     1.0f,
 363:src/voice.h   ****     0.45f,
 364:src/voice.h   ****     WAVE_SINE,           // osc1  ‚Äî root (8')
 365:src/voice.h   ****     // SECONDARY OSCILLATOR
 366:src/voice.h   ****     1.005f,
 367:src/voice.h   ****     0.40f,
 368:src/voice.h   ****     WAVE_SINE,           // osc2  ‚Äî slightly sharp unison ‚Üí slow chorus shimmer
 369:src/voice.h   ****     // SUB OSCILLATOR
 370:src/voice.h   ****     0.5f,
 371:src/voice.h   ****     0.30f,
 372:src/voice.h   ****     WAVE_SINE,           // sub   ‚Äî octave-down body (16')
 373:src/voice.h   ****     // OCTAVE OSCILLATOR
 374:src/voice.h   ****     2.0f,
 375:src/voice.h   ****     0.28f,
 376:src/voice.h   ****     WAVE_SINE,           // oct   ‚Äî octave-up air (4')
 377:src/voice.h   ****     // FILTER
 378:src/voice.h   ****     false,               // osc2 is a fixed chorus detune, not finger-2 detune
 379:src/voice.h   ****     2.0f,
 380:src/voice.h   ****     5.0f,
 381:src/voice.h   ****     0.20f,               // mostly-open clean filter, gentle pressure lift, low res
 382:src/voice.h   ****     // DRIVE
 383:src/voice.h   ****     0.8f,                // light drive ‚Äî pressure adds subtle warmth, stays pure
 384:src/voice.h   ****     // NOISE
 385:src/voice.h   ****     0.03f,               // noise level ‚Äî breath chiff
 386:src/voice.h   ****     1.0f,                // keytrack
 387:src/voice.h   ****     1.0f,                // ringmod ratio
 388:src/voice.h   ****     0.05f,               // ringmod max
 389:src/voice.h   ****     0.0f,                // fold max
 390:src/voice.h   ****     8.0f,                // attack
 391:src/voice.h   ****     120.0f,              // release
 392:src/voice.h   ****     8.0f,                // glide ‚Äî fast on/off, no glide
 393:src/voice.h   ****     // PITCH ENVELOPE
 394:src/voice.h   ****     0.0f,                // pitch env octaves (off)
 395:src/voice.h   ****     0.0f,                // pitch env time
 396:src/voice.h   ****     // NOISE TONE
 397:src/voice.h   ****     0.0f,                // noise_hp (white)
 398:src/voice.h   ****     // CYCLING
 399:src/voice.h   ****     false,               // no_cycle (stays in the FSR cycle)
 400:src/voice.h   ****     // VELOCITY
ARM GAS  /tmp/claude-502/ccN5Z8iY.s 			page 45


 401:src/voice.h   ****     0.0f,                // vel_sens (fixed loudness)
 402:src/voice.h   ****     // RETRIGGER
 403:src/voice.h   ****     0.0f,                // retrig_ms (off)
 404:src/voice.h   ****     // PITCH QUANTIZE
 405:src/voice.h   ****     true,                // quantize ‚Äî snap on touch-down (organ/keyboard feel)
 406:src/voice.h   ****     SCALE_MINOR,         // scale
 407:src/voice.h   ****     (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0])) // scale_len ‚Äî minor
 408:src/voice.h   **** };
