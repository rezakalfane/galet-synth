 541:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 542:src/main.cpp  **** // Lower value = faster response.
 543:src/main.cpp  **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
 544:src/main.cpp  **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
 545:src/main.cpp  **** // callback. The constants below are the ones still shared by all voices.
 546:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 547:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 548:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 549:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 550:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ‚Äî ~35 ms smooth
 551:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 552:src/main.cpp  **** // Finger 2 ‚Äî asymmetric attack/release
 553:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 554:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 555:src/main.cpp  **** 
 556:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 557:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 558:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 559:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 560:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 561:src/main.cpp  **** }
 562:src/main.cpp  **** 
 563:src/main.cpp  **** // ‚îÄ‚îÄ Oscillator waveforms (phase ph in [0,1) ‚Üí sample in [-1,1]) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 564:src/main.cpp  **** // Triangle wave
 565:src/main.cpp  **** static inline float tri(float ph){
 566:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 567:src/main.cpp  **** }
 568:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ‚Äî matches sin(2œÄ¬∑ph).
 569:src/main.cpp  **** static inline float osc_sine(float ph){
 570:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 571:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -œÄ..œÄ (angle shifted by œÄ)
 572:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 573:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 574:src/main.cpp  ****     return -y;                                 // undo the œÄ shift: sin(x+œÄ) = -sin(x)
 575:src/main.cpp  **** }
 576:src/main.cpp  **** // Naive square / saw ‚Äî alias at high pitch but sound rich on a bass voice.
 577:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 578:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 579:src/main.cpp  **** 
 580:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 581:src/main.cpp  **** // switched live). A small jump table ‚Äî cheap at audio rate on the H750.
 582:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 583:src/main.cpp  ****     switch(w){
 584:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 585:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
ARM GAS  /tmp/claude-502/ccL8jzgy.s 			page 19


 586:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 587:src/main.cpp  ****         case WAVE_TRI:
 588:src/main.cpp  ****         default:          return tri(ph);
 589:src/main.cpp  ****     }
 590:src/main.cpp  **** }
