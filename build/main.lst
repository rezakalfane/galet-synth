 681:src/voice.h   ****     1.0f,                // attack ŌĆö instant
 682:src/voice.h   ****     160.0f,              // release ŌĆö short
 683:src/voice.h   ****     5.0f,                // glide
 684:src/voice.h   ****     // PITCH ENVELOPE
 685:src/voice.h   ****     2.0f,                // pitch env octaves ŌĆö kick "boom": start 2 oct up
 686:src/voice.h   ****     45.0f,               // pitch env time ŌĆö drop in 45 ms
 687:src/voice.h   ****     // NOISE TONE
 688:src/voice.h   ****     0.0f,                // noise_hp (white)
