1437:src/main.cpp  ****             float l3_raw   = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
1438:src/main.cpp  ****             float l2_raw   = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
1439:src/main.cpp  ****             led1_target    = sqrtf(sqrtf(l2_raw)) * prs_mult;  // middle tent
