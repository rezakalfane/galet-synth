 502:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 503:src/main.cpp  **** {
 504:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 505:src/main.cpp  ****     for(int i=s;i<=e;i++){
 506:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 507:src/main.cpp  ****         sw+=w;swx+=w*i;
 508:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 509:src/main.cpp  ****     }
 510:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 511:src/main.cpp  ****     if(sw==0)return -1;
 512:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 513:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 514:src/main.cpp  ****     return p;
 515:src/main.cpp  **** }
