1260:src/main.cpp  ****             float prs_mult = 0.75f + 0.25f * pr01;
1261:src/main.cpp  ****             float l1_raw   = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
1262:src/main.cpp  ****             float l3_raw   = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
