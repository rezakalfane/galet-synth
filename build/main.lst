 344:src/main.cpp  **** // Triangle wave
 345:src/main.cpp  **** static inline float tri(float ph){
 346:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 347:src/main.cpp  **** }
 348:src/main.cpp  **** 
 349:src/main.cpp  **** // Moog 4-pole ladder
 350:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 351:src/main.cpp  **** {
 352:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 353:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 354:src/main.cpp  ****     float k  = 3.8f*res;
 355:src/main.cpp  ****     float fb = k*s_flt[3];
 356:src/main.cpp  ****     float x  = in - fb;
 357:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccV3nS87.s 			page 15


 358:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 359:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 360:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 361:src/main.cpp  ****     return s_flt[3];
 362:src/main.cpp  **** }
 363:src/main.cpp  **** 
 364:src/main.cpp  **** // Wavefolder distortion
 365:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 366:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 367:src/main.cpp  **** static inline float wavefold(float in, float amount)
 368:src/main.cpp  **** {
 369:src/main.cpp  ****     if(amount < 0.01f) return in;
 370:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 371:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 372:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 373:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 374:src/main.cpp  ****     float x = driven;
 375:src/main.cpp  ****     // 2 passes of folding for richness
 376:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 377:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 378:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 379:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 380:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 381:src/main.cpp  ****     }
 382:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 383:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 384:src/main.cpp  **** }
