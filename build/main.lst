 440:src/main.cpp  ****         // Bleed filter state toward zero when silent
 441:src/main.cpp  ****         // Prevents stale filter energy from clicking on next note onset
 442:src/main.cpp  ****         if(s_amp < 0.001f) {
 443:src/main.cpp  ****             s_flt[0] *= 0.999f;
 444:src/main.cpp  ****             s_flt[1] *= 0.999f;
