 874:src/main.cpp  **** // ŌöĆŌöĆ Polyphonic drum engine (Drums MultiVoice only) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 875:src/main.cpp  **** // A pool of independent drum voices, one per finger. Each is a self-contained
 876:src/main.cpp  **** // slice of the synth (oscillators + noise + ladder filter + amp & pitch
 877:src/main.cpp  **** // envelopes) with its own state, so up to POLY drums sound at once. Params are
 878:src/main.cpp  **** // latched at the tap (drum, pitch, velocity-scaled level, cutoff, drive); the
 879:src/main.cpp  **** // note plays its attack while the finger is down and releases when it lifts.
 880:src/main.cpp  **** static constexpr int POLY = MAX_FINGERS;
 881:src/main.cpp  **** struct DrumHit {
 882:src/main.cpp  ****     bool  active=false, gate=false;
 883:src/main.cpp  ****     int   vidx=9;
 884:src/main.cpp  ****     float freq=80.0f, amp_tgt=0.0f, cutoff=200.0f, drive=1.0f;
 885:src/main.cpp  ****     float ph1=0,ph2=0,phs=0,pho=0;
 886:src/main.cpp  ****     float amp=0.0f, pmult=1.0f, noise_lp=0.0f;
 887:src/main.cpp  ****     float lp_state=0.0f, lp_coeff=1.0f;   // per-drum 1-pole lowpass
 888:src/main.cpp  ****     float atk_c=0, rel_c=0, penv_c=0, penv_start=1.0f;
 889:src/main.cpp  **** };
 890:src/main.cpp  **** static DrumHit g_hits[POLY];
