 881:src/main.cpp  **** // ŌöĆŌöĆ Polyphonic drum engine (Drums MultiVoice only) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 882:src/main.cpp  **** // A pool of independent drum voices, one per finger. Each is a self-contained
 883:src/main.cpp  **** // slice of the synth (oscillators + noise + ladder filter + amp & pitch
 884:src/main.cpp  **** // envelopes) with its own state, so up to POLY drums sound at once. Params are
 885:src/main.cpp  **** // latched at the tap (drum, pitch, velocity-scaled level, cutoff, drive); the
 886:src/main.cpp  **** // note plays its attack while the finger is down and releases when it lifts.
 887:src/main.cpp  **** static constexpr int POLY = MAX_FINGERS;
 888:src/main.cpp  **** struct DrumHit {
 889:src/main.cpp  ****     bool  active=false, gate=false;
 890:src/main.cpp  ****     int   vidx=9;
 891:src/main.cpp  ****     float freq=80.0f, amp_tgt=0.0f, cutoff=200.0f, drive=1.0f;
 892:src/main.cpp  ****     float ph1=0,ph2=0,phs=0,pho=0;
 893:src/main.cpp  ****     float amp=0.0f, pmult=1.0f, noise_lp=0.0f;
 894:src/main.cpp  ****     float lp_state=0.0f, lp_coeff=1.0f;   // per-drum 1-pole lowpass
 895:src/main.cpp  ****     float atk_c=0, rel_c=0, penv_c=0, penv_start=1.0f;
 896:src/main.cpp  **** };
 897:src/main.cpp  **** static DrumHit g_hits[POLY];
 898:src/main.cpp  **** 
 899:src/main.cpp  **** static void drum_trigger(DrumHit& h, int vidx, float freq, float amp_tgt,
 900:src/main.cpp  ****                          float cutoff, float drive, float sr)
 901:src/main.cpp  **** {
 902:src/main.cpp  ****     const Voice& V = VOICES[vidx];
 903:src/main.cpp  ****     h.active=true; h.gate=true; h.vidx=vidx;
 904:src/main.cpp  ****     h.freq=freq; h.amp_tgt=amp_tgt; h.cutoff=cutoff; h.drive=drive;
 905:src/main.cpp  ****     h.ph1=h.ph2=h.phs=h.pho=0.0f;
 906:src/main.cpp  ****     h.amp=0.0f; h.noise_lp=0.0f;
 907:src/main.cpp  ****     // 1-pole lowpass coefficient from the (latched) cutoff: a = 1 - e^(-2ŽĆ┬Ęfc/sr).
 908:src/main.cpp  ****     h.lp_state = 0.0f;
 909:src/main.cpp  ****     h.lp_coeff = clampf(1.0f - expf(-6.2831853f * cutoff / sr), 0.0f, 1.0f);
 910:src/main.cpp  ****     h.atk_c      = ms_to_coeff(V.attack_ms,    sr);
 911:src/main.cpp  ****     h.rel_c      = ms_to_coeff(V.release_ms,   sr);
 912:src/main.cpp  ****     h.penv_c     = ms_to_coeff(V.pitch_env_ms, sr);
 913:src/main.cpp  ****     h.penv_start = exp2f(V.pitch_env_oct);
 914:src/main.cpp  ****     h.pmult      = h.penv_start;
 915:src/main.cpp  **** }
 916:src/main.cpp  **** 
 917:src/main.cpp  **** static float drum_render(DrumHit& h, float sr)
 918:src/main.cpp  **** {
 919:src/main.cpp  ****     if(!h.active) return 0.0f;
 920:src/main.cpp  ****     const Voice& V = VOICES[h.vidx];
 921:src/main.cpp  ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 922:src/main.cpp  ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
 923:src/main.cpp  ****     float c   = (tgt > h.amp) ? h.atk_c : h.rel_c;
 924:src/main.cpp  ****     h.amp = h.amp*c + tgt*(1.0f-c);
 925:src/main.cpp  ****     if(!h.gate && h.amp < 0.0004f){ h.active=false; return 0.0f; }
 926:src/main.cpp  ****     // Pitch envelope decays to 1.0.
 927:src/main.cpp  ****     h.pmult = 1.0f + (h.pmult - 1.0f) * h.penv_c;
