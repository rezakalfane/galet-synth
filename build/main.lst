 757:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 758:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 759:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 760:src/main.cpp  **** 
 761:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 762:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 763:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 764:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 765:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 766:src/main.cpp  **** }
