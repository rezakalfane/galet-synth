 380:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 381:src/main.cpp  **** {
 382:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 383:src/main.cpp  ****     for(int i=s;i<=e;i++){
 384:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 385:src/main.cpp  ****         sw+=w;swx+=w*i;
 386:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 387:src/main.cpp  ****     }
 388:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 389:src/main.cpp  ****     if(sw==0)return -1;
 390:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 391:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 392:src/main.cpp  ****     return p;
 393:src/main.cpp  **** }
 394:src/main.cpp  **** 
 395:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 396:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 397:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 398:src/main.cpp  ****     if(raw <= 0)     return 0;
 399:src/main.cpp  ****     if(raw >= range) return 100;
 400:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 401:src/main.cpp  ****     if(raw > range) raw = range;
 402:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 403:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 404:src/main.cpp  ****     // Integer sqrt via Newton
 405:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 406:src/main.cpp  ****     s = (s + scaled/s) / 2;
 407:src/main.cpp  ****     s = (s + scaled/s) / 2;
 408:src/main.cpp  ****     s = (s + scaled/s) / 2;
 409:src/main.cpp  ****     s = (s + scaled/s) / 2;
 410:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 411:src/main.cpp  ****     if(s < 0)   s = 0;
 412:src/main.cpp  ****     if(s > 100) s = 100;
 413:src/main.cpp  ****     return s;
 414:src/main.cpp  **** }
