 427:src/main.cpp  ****         // Finger 2 params: fast attack, slow release
 428:src/main.cpp  ****         { float sa = tdet     > s_detune   ? SLEW_F2_A : SLEW_F2_R;
 429:src/main.cpp  ****           s_detune   = s_detune   * sa + tdet * (1.0f - sa); }
 430:src/main.cpp  ****         { float sa = tbc      > s_bitcrush ? SLEW_F2_A : SLEW_F2_R;
 431:src/main.cpp  ****           s_bitcrush = s_bitcrush * sa + tbc  * (1.0f - sa); }
