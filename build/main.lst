 908:src/main.cpp  ****             // Cutoff: base tracks 2├Ś pitch, pressure opens it up
 909:src/main.cpp  ****             // Light press = 1├Ś pitch (dark, Moog-like tracking)
 910:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
 911:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 912:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
 913:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
 914:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
 915:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
 916:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
 917:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 918:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
 919:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
 920:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
 921:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
