 806:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(s_led2 * LED2_MAX));
 807:src/main.cpp  ****             g_led3_duty = s_led3;  // audio callback sigma-delta's this onto A0
