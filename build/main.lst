1049:src/main.cpp  **** 
1050:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
1051:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
1052:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
