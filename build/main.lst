 746:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 747:src/main.cpp  **** // Lower value = faster response.
 748:src/main.cpp  **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
 749:src/main.cpp  **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
 750:src/main.cpp  **** // callback. The constants below are the ones still shared by all voices.
 751:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 752:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 753:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 754:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 755:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ŌĆö ~35 ms smooth
 756:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
