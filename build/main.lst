  82:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
  83:src/main.cpp  **** {
  84:src/main.cpp  ****     for(int i=7;i>=0;i--){
  85:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
  86:src/main.cpp  ****         d();scl_high();d();scl_low();d();
  87:src/main.cpp  ****     }
  88:src/main.cpp  ****     sda_high();d();scl_high();d();
  89:src/main.cpp  ****     bool ack=!sda.Read();
  90:src/main.cpp  ****     scl_low();d();
  91:src/main.cpp  ****     return ack;
  92:src/main.cpp  **** }
  93:src/main.cpp  **** 
  94:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
  95:src/main.cpp  **** {
  96:src/main.cpp  ****     uint8_t b=0;sda_high();
  97:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
  98:src/main.cpp  ****     if(ack)sda_low();else sda_high();
  99:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 100:src/main.cpp  ****     return b;
 101:src/main.cpp  **** }
