 571:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 572:src/main.cpp  **** {
 573:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 574:src/main.cpp  ****     for(int i=s;i<=e;i++){
 575:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 576:src/main.cpp  ****         sw+=w;swx+=w*i;
 577:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 578:src/main.cpp  ****     }
 579:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 580:src/main.cpp  ****     if(sw==0)return -1;
 581:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 582:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 583:src/main.cpp  ****     return p;
 584:src/main.cpp  **** }
