 150:src/voice.h   **** // ‚îÄ‚îÄ Voice 4: clean sine organ / flute (a melodic, non-bass departure) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 151:src/voice.h   **** //   Pure sine oscillators stacked like organ drawbars: octave-down body, root,
 152:src/voice.h   **** //   octave-up air, plus a second osc tuned a hair sharp (1.005√ó) for a slow,
 153:src/voice.h   **** //   warm chorus shimmer instead of a chord. Higher register than the basses, a
 154:src/voice.h   **** //   mostly-open clean filter, and just a touch of drive so pressure adds gentle
 155:src/voice.h   **** //   harmonic warmth. Sines never alias, so it stays smooth all the way up.
 156:src/voice.h   **** static constexpr Voice VOICE_ORGAN = {
 157:src/voice.h   ****     "Organ",
 158:src/voice.h   ****     65.0f, 520.0f, 2.07944f,   // 65‚Äì520 Hz, ln(8) ‚Äî a melodic keyboard register
 159:src/voice.h   ****     1.0f,    0.45f, WAVE_SINE,  // osc1  ‚Äî root (8')
 160:src/voice.h   ****     1.005f,  0.40f, WAVE_SINE,  // osc2  ‚Äî slightly sharp unison ‚Üí slow chorus shimmer
 161:src/voice.h   ****     0.5f,    0.30f, WAVE_SINE,  // sub   ‚Äî octave-down body (16')
 162:src/voice.h   ****     2.0f,    0.28f, WAVE_SINE,  // oct   ‚Äî octave-up air (4')
 163:src/voice.h   ****     false,                      // osc2 is a fixed chorus detune, not finger-2 detune
 164:src/voice.h   ****     2.0f, 5.0f, 0.20f,          // mostly-open clean filter, gentle pressure lift, low res
 165:src/voice.h   ****     0.8f,                       // light drive ‚Äî pressure adds subtle warmth, stays pure
 166:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 167:src/voice.h   ****     0.03f, 1.0f, 1.0f, 0.05f, 0.0f, 8.0f, 120.0f, 8.0f,  // breath chiff, fast on/off, no glide
 168:src/voice.h   ****     // pitch_env_oct, pitch_env_ms, noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 169:src/voice.h   ****     0.0f, 0.0f, 0.0f, false, 0.0f, 0.0f,
 170:src/voice.h   ****     true         // quantize ‚Äî snap to chromatic notes on touch-down (organ/keyboard feel)
 171:src/voice.h   **** };
