 813:src/voice.h   **** // Voices with no_cycle = true are skipped by the FSR-hold gesture. These helpers
 814:src/voice.h   **** // give the count of cyclable voices and the 1-based position of an index among
 815:src/voice.h   **** // them (used for the LED flash count and the serial display).
 816:src/voice.h   **** static int cycle_total() {
 817:src/voice.h   ****   int n = 0;
