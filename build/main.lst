 791:src/main.cpp  ****         // Sanity floor ‚Äî without enough headroom over FSR_MIN the volume curve
 792:src/main.cpp  ****         // becomes hyper-sensitive to noise.
 793:src/main.cpp  ****         if(avg < FSR_MIN + 500) avg = FSR_MIN + 500;
 794:src/main.cpp  ****         fsr_max       = avg;
 795:src/main.cpp  ****         fsr_range_inv = 1.0f / (float)(fsr_max - FSR_MIN);
 796:src/main.cpp  ****     };
