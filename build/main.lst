 462:src/main.cpp  **** 
 463:src/main.cpp  ****         // Vibrato: modulate frequency by ┬▒1 semitone * depth
 464:src/main.cpp  ****         // powf(2, semitones/12) ŌĆö approx for small values: exp(x*0.0578)
 465:src/main.cpp  ****         float vib_amt = lfo * s_vibdepth * 0.05f; // max ┬▒~0.05 semitones*depth
 466:src/main.cpp  ****         float freq_vib = s_freq * (1.0f + vib_amt);
 467:src/main.cpp  **** 
 468:src/main.cpp  ****         // Osc 2 frequency: detuned by s_detune semitones
 469:src/main.cpp  ****         // pow2(s_detune/12) approximated
 470:src/main.cpp  ****         float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for ┬▒1 oct
 471:src/main.cpp  ****         float freq2 = freq_vib * det_ratio;
 472:src/main.cpp  **** 
 473:src/main.cpp  ****         // Sub osc: one octave down
 474:src/main.cpp  ****         float freq_sub = freq_vib * 0.5f;
 475:src/main.cpp  ****         // Octave-up osc: one octave above fundamental ŌĆö adds air and sparkle
 476:src/main.cpp  ****         float freq_oct = freq_vib * 2.0f;
 477:src/main.cpp  **** 
 478:src/main.cpp  ****         // Ring mod carrier: slightly above fundamental for metallic beating
 479:src/main.cpp  ****         float freq_rm = freq_vib * 1.0f; // unison ring mod (can offset for effect)
 480:src/main.cpp  **** 
 481:src/main.cpp  ****         // Oscillators
 482:src/main.cpp  ****         float osc1    = tri(s_phase1)   * 0.50f;
 483:src/main.cpp  ****         float osc2    = tri(s_phase2)   * 0.22f; // detuned copy
 484:src/main.cpp  ****         float sub     = tri(s_phase_sub)* 0.18f; // one octave below
 485:src/main.cpp  ****         float osc_oct = tri(s_phase_oct)* 0.15f; // one octave above ŌĆö bright shimmer
 486:src/main.cpp  **** 
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccgY3Zif.s 			page 22


 487:src/main.cpp  ****         // Mix ŌĆö reduce osc1 slightly to make room for the new octave osc
 488:src/main.cpp  ****         float mix = osc1 + osc2 + sub + osc_oct;
 489:src/main.cpp  **** 
 490:src/main.cpp  ****         // Ring modulation (finger 2 pressure ŌåÆ metallic/bell edge)
