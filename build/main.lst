  97:src/voice.h   ****     1.0f,        0.45f, WAVE_TRI,   // osc1  вЂ” root
  98:src/voice.h   ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  вЂ” fixed perfect fifth (the power chord)
  99:src/voice.h   ****     0.5f,        0.34f, WAVE_TRI,   // sub   вЂ” extra weight for a round bottom
 100:src/voice.h   ****     2.0f,        0.20f, WAVE_TRI,   // oct   вЂ” top of the power chord
 101:src/voice.h   ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 102:src/voice.h   ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 103:src/voice.h   ****     1.0f,                 // less drive вЂ” keep it clean and round
 104:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 105:src/voice.h   ****     0.0f, 1.0f, 1.0f, 0.12f, 0.12f, 6.0f, 300.0f, 25.0f
 106:src/voice.h   **** };
