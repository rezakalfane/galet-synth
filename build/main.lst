 753:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 754:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 755:src/main.cpp  ****         uint16_t scan[N_CH];
 756:src/main.cpp  **** 
