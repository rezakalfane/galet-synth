1096:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
1097:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
1098:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
1099:src/main.cpp  ****             g_led3_duty = led3;
