 838:src/main.cpp  **** // Moog 4-pole ladder, operating on a caller-supplied state array (so multiple
 839:src/main.cpp  **** // voices can each have their own filter).
 840:src/main.cpp  **** static inline float moog_st(float in, float cutoff, float res, float sr, float st[4])
 841:src/main.cpp  **** {
 842:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 843:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 844:src/main.cpp  ****     float k  = 3.8f*res;
 845:src/main.cpp  ****     float fb = k*st[3];
 846:src/main.cpp  ****     float x  = in - fb;
 847:src/main.cpp  ****     st[0]+=f*(fast_tanh(x)    -fast_tanh(st[0]));
 848:src/main.cpp  ****     st[1]+=f*(fast_tanh(st[0])-fast_tanh(st[1]));
 849:src/main.cpp  ****     st[2]+=f*(fast_tanh(st[1])-fast_tanh(st[2]));
 850:src/main.cpp  ****     st[3]+=f*(fast_tanh(st[2])-fast_tanh(st[3]));
 851:src/main.cpp  ****     return st[3];
 852:src/main.cpp  **** }
 853:src/main.cpp  **** // Mono ladder using the shared global state (the monophonic melodic engine).
 854:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 855:src/main.cpp  **** {
 856:src/main.cpp  ****     return moog_st(in, cutoff, res, sr, s_flt);
 857:src/main.cpp  **** }
