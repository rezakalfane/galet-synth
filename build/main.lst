1385:src/main.cpp  ****                 float qe = (f1_midi_base - 69.0f) * 0.05776f;
1386:src/main.cpp  ****                 freq = clampf(440.0f*(1.0f+qe*(1.0f+qe*(0.5f+qe*0.1667f))), VOICE.freq_low, VOICE.f
