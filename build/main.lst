 326:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 327:src/main.cpp  **** // Lower value = faster response
 328:src/main.cpp  **** static constexpr float SLEW_FREQ   = 0.9985f; // pitch glide
 329:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9800f; // filter cutoff ŌĆö fast response
 330:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 331:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 332:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 333:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 334:src/main.cpp  **** 
 335:src/main.cpp  **** // Separate attack and release for amplitude envelope
 336:src/main.cpp  **** // Attack: very fast (~0.5ms) ŌĆö snappy pluck feel
 337:src/main.cpp  **** // Release: moderate (~80ms) ŌĆö clean tail when finger lifts
 338:src/main.cpp  **** static constexpr float SLEW_AMP_A  = 0.9700f; // attack  (~3ms ŌĆö snappy but click-free)
 339:src/main.cpp  **** static constexpr float SLEW_AMP_R  = 0.999971f; // release (~5 seconds)
