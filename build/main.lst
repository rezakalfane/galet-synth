 354:src/main.cpp  **** // A pool of independent drum voices, one per finger. Each is a self-contained
 355:src/main.cpp  **** // slice of the synth (oscillators + noise + ladder filter + amp & pitch
 356:src/main.cpp  **** // envelopes) with its own state, so up to POLY drums sound at once. Params are
 357:src/main.cpp  **** // latched at the tap (drum, pitch, velocity-scaled level, cutoff, drive); the
ARM GAS  /tmp/claude-502/cc3JAR3K.s 			page 15


 358:src/main.cpp  **** // note plays its attack while the finger is down and releases when it lifts.
 359:src/main.cpp  **** static constexpr int POLY = MAX_FINGERS;
 360:src/main.cpp  **** struct DrumHit {
 361:src/main.cpp  ****     bool  active=false, gate=false;
 362:src/main.cpp  ****     int   vidx=9;
 363:src/main.cpp  ****     float freq=80.0f, amp_tgt=0.0f, cutoff=200.0f, drive=1.0f;
 364:src/main.cpp  ****     float ph1=0,ph2=0,phs=0,pho=0;
 365:src/main.cpp  ****     float amp=0.0f, pmult=1.0f, noise_lp=0.0f;
 366:src/main.cpp  ****     float lp_state=0.0f, lp_coeff=1.0f;   // per-drum 1-pole lowpass
 367:src/main.cpp  ****     float atk_c=0, rel_c=0, penv_c=0, penv_start=1.0f;
 368:src/main.cpp  **** };
 369:src/main.cpp  **** static DrumHit g_hits[POLY];
