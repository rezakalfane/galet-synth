 100:src/voice.h   ****   // root is the quantized finger-1 note; the engine adds the scale's 3rd and 5th
 101:src/voice.h   ****   // above it (stacking scale-thirds ŌĆö see diatonic_triad below), so the chord
 102:src/voice.h   ****   // stays in key. Requires a musical `scale` (major/minor) ŌĆö over a chromatic
 103:src/voice.h   ****   // scale stacking thirds degenerates to a whole-tone cluster, not a triad.
 104:src/voice.h   ****   // Appended after the older fields so every non-chord preset zero-inits to false
 105:src/voice.h   ****   // (single-note, unchanged). The upper two notes use osc1+osc2 only (sub and
 106:src/voice.h   ****   // noise stay on the root) ŌĆö see engine.cpp. The two SH-101 twins set this.
 107:src/voice.h   ****   bool chords;
 108:src/voice.h   ****   // chord_level: level of the two added chord notes vs the root's osc levels.
 109:src/voice.h   ****   // <1 keeps the root dominant and leaves the drive/filter headroom; 1.0 = equal
 110:src/voice.h   ****   // weight (fatter, more saturated). Only meaningful when chords is true; a chord
 111:src/voice.h   ****   // voice must set it (>0) or the upper notes are silent.
 112:src/voice.h   ****   float chord_level;
 113:src/voice.h   ****   // chord_spread: octaves to lift the 3rd, for the voicing width. 0 = close
 114:src/voice.h   ****   // (rootŌĆō3rdŌĆō5th cluster); 1 = open (rootŌĆō5thŌĆō10th ŌĆö clearer over the sub-osc);
 115:src/voice.h   ****   // 2+ wider still. Only meaningful when chords is true.
 116:src/voice.h   ****   int chord_spread;
 117:src/voice.h   **** 
 118:src/voice.h   ****   // reverb_send: how much of this voice's signal feeds the shared reverb (0 =
 119:src/voice.h   ****   // dry, no reverb; ~0.3 a hint of space; ~0.7 a wet wash). The reverb itself
 120:src/voice.h   ****   // (tail length / damping / return level) is global ŌĆö see g_reverb_* in the
 121:src/voice.h   ****   // engine ŌĆö so this is just the per-voice aux send.
 122:src/voice.h   ****   float reverb_send;
 123:src/voice.h   ****   // delay_send: per-voice aux send into the shared echo/delay (0 = dry). The
 124:src/voice.h   ****   // delay's time / feedback / level are global (g_delay_* in the engine). Same
 125:src/voice.h   ****   // idea as reverb_send. Appended last; every voice but the Organ zero-inits to 0.
 126:src/voice.h   ****   float delay_send;
 127:src/voice.h   **** 
 128:src/voice.h   ****   // ŌöĆŌöĆ LFO (per-voice modulation) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 129:src/voice.h   ****   // One triangle LFO per voice, routed to any of three destinations by its own
 130:src/voice.h   ****   // depth (0 = that destination off) ŌĆö so a voice can do vibrato, auto-wah,
 131:src/voice.h   ****   // tremolo, or any combination. All default 0, and lfo_rate 0 falls back to the
 132:src/voice.h   ****   // classic 6 Hz, so existing presets are unchanged: they keep only the finger-
 133:src/voice.h   ****   // pressure vibrato on pitch. Appended last to keep positional initializers stable.
 134:src/voice.h   ****   float lfo_rate;    // LFO speed in Hz (0 ŌåÆ 6 Hz). Shared by all destinations below.
 135:src/voice.h   ****   float lfo_pitch;   // pitch-mod depth 0..1 ŌåÆ always-on VIBRATO (sums with the
 136:src/voice.h   ****                      // finger-pressure vibrato). ~0.2 = a gentle wobble.
 137:src/voice.h   ****   float lfo_filter;  // cutoff-mod depth 0..1 ŌåÆ AUTO-WAH (the Moog cutoff sweeps up
 138:src/voice.h   ****                      // to ┬▒~90% around its current value at full depth).
 139:src/voice.h   ****   float lfo_amp;     // amp-mod depth 0..1 ŌåÆ TREMOLO (1 = level dips to silence on
 140:src/voice.h   ****                      // each trough; ~0.3 = a subtle throb).
 141:src/voice.h   **** };
