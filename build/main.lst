 492:src/main.cpp  **** static float s_flt[4]    = {0,0,0,0};
 493:src/main.cpp  **** 
 494:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 495:src/main.cpp  **** // Lower value = faster response
 496:src/main.cpp  **** static constexpr float SLEW_FREQ   = 0.9985f; // pitch glide
 497:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 498:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 499:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 500:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 501:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ‚Äî ~35 ms smooth
 502:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 503:src/main.cpp  **** // Finger 2 ‚Äî asymmetric attack/release
 504:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 505:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 506:src/main.cpp  **** 
 507:src/main.cpp  **** // Separate attack and release for amplitude envelope
 508:src/main.cpp  **** // Attack: very fast (~0.5ms) ‚Äî snappy pluck feel
 509:src/main.cpp  **** // Release: moderate (~80ms) ‚Äî clean tail when finger lifts
 510:src/main.cpp  **** static constexpr float SLEW_AMP_A  = 0.9700f; // attack  (~3ms ‚Äî snappy but click-free)
 511:src/main.cpp  **** static constexpr float SLEW_AMP_R  = 0.999971f; // release (~5 seconds)
 512:src/main.cpp  **** 
 513:src/main.cpp  **** // ‚îÄ‚îÄ Oscillator waveforms (phase ph in [0,1) ‚Üí sample in [-1,1]) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 514:src/main.cpp  **** // Triangle wave
 515:src/main.cpp  **** static inline float tri(float ph){
 516:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 517:src/main.cpp  **** }
 518:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ‚Äî matches sin(2œÄ¬∑ph).
 519:src/main.cpp  **** static inline float osc_sine(float ph){
 520:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 521:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -œÄ..œÄ (angle shifted by œÄ)
 522:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 523:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 524:src/main.cpp  ****     return -y;                                 // undo the œÄ shift: sin(x+œÄ) = -sin(x)
 525:src/main.cpp  **** }
 526:src/main.cpp  **** // Naive square / saw ‚Äî alias at high pitch but sound rich on a bass voice.
 527:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 528:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
