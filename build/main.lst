 497:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 498:src/main.cpp  **** {
 499:src/main.cpp  ****     for(int i=7;i>=0;i--){
 500:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 501:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 502:src/main.cpp  ****     }
 503:src/main.cpp  ****     sda_high();d();scl_high();d();
 504:src/main.cpp  ****     bool ack=!sda.Read();
 505:src/main.cpp  ****     scl_low();d();
 506:src/main.cpp  ****     return ack;
 507:src/main.cpp  **** }
 508:src/main.cpp  **** 
 509:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 510:src/main.cpp  **** {
 511:src/main.cpp  ****     uint8_t b=0;sda_high();
 512:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 513:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 514:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 515:src/main.cpp  ****     return b;
 516:src/main.cpp  **** }
