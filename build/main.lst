 600:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 601:src/main.cpp  **** {
 602:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 603:src/main.cpp  ****     for(int i=s;i<=e;i++){
 604:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 605:src/main.cpp  ****         sw+=w;swx+=w*i;
 606:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 607:src/main.cpp  ****     }
 608:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 609:src/main.cpp  ****     if(sw==0)return -1;
 610:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 611:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 612:src/main.cpp  ****     return p;
 613:src/main.cpp  **** }
