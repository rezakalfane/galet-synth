 947:src/main.cpp  ****     h.phs += f*V.sub_ratio /sr; if(h.phs>=1.0f)h.phs-=1.0f;
 948:src/main.cpp  ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
 949:src/main.cpp  ****     return fast_tanh(h.lp_state*1.3f) * h.amp;
 950:src/main.cpp  **** }
