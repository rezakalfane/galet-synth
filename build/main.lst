 446:src/main.cpp  **** // ŌöĆŌöĆ Voice cycling ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 447:src/main.cpp  **** // Voices with no_cycle = true are skipped by the FSR-hold gesture. These helpers
 448:src/main.cpp  **** // give the count of cyclable voices and the 1-based position of an index among
 449:src/main.cpp  **** // them (used for the LED flash count and the serial display).
 450:src/main.cpp  **** static int cycle_total(){
 451:src/main.cpp  ****     int n = 0;
 452:src/main.cpp  ****     for(int i = 0; i < NUM_VOICES; i++) if(!VOICES[i].no_cycle) n++;
 453:src/main.cpp  ****     return n;
 454:src/main.cpp  **** }
 455:src/main.cpp  **** static int cycle_pos(int idx){
 456:src/main.cpp  ****     int p = 0;
 457:src/main.cpp  ****     for(int i = 0; i <= idx && i < NUM_VOICES; i++) if(!VOICES[i].no_cycle) p++;
 458:src/main.cpp  ****     return p;
 459:src/main.cpp  **** }
 460:src/main.cpp  **** // Next cyclable voice index after `idx` (wraps). Falls back to idx if none.
 461:src/main.cpp  **** static int cycle_next(int idx){
 462:src/main.cpp  ****     for(int step = 1; step <= NUM_VOICES; step++){
 463:src/main.cpp  ****         int n = (idx + step) % NUM_VOICES;
 464:src/main.cpp  ****         if(!VOICES[n].no_cycle) return n;
 465:src/main.cpp  ****     }
 466:src/main.cpp  ****     return idx;
 467:src/main.cpp  **** }
