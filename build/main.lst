 555:src/main.cpp  ****             // Cutoff: base tracks 2Г— pitch, pressure opens it up
 556:src/main.cpp  ****             // Light press = 1Г— pitch (dark, Moog-like tracking)
 557:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
 558:src/main.cpp  ****             // в”Ђв”Ђ Moog-style exponential cutoff в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”
 559:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
 560:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) вЂ” exponential opening
 561:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
 562:src/main.cpp  ****             // This gives the classic Moog "closed в†’ wah в†’ bright" feel.
 563:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
