 311:src/voice.h   **** // ‚îÄ‚îÄ Voice 11: hi-hat (noise-driven) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 312:src/voice.h   **** //   A crisp "tss" ‚Äî PLAY IT BY TAPPING. Almost pure high-frequency noise through
 313:src/voice.h   **** //   a wide-open filter, with three inharmonic square partials for metallic edge
 314:src/voice.h   **** //   and no low end. Instant attack and a very short ~55 ms tail = a tight closed
 315:src/voice.h   **** //   hat. Finger-1 position tunes the metallic pitch. (Raise release_ms for an
 316:src/voice.h   **** //   open-hat feel.)
 317:src/voice.h   **** static constexpr Voice VOICE_HIHAT = {
 318:src/voice.h   ****     "HiHat",
 319:src/voice.h   ****     4000.0f, 11000.0f, 1.01160f, // 4000‚Äì11000 Hz, ln(2.75) ‚Äî metallic edge pitch
 320:src/voice.h   ****     1.0f,    0.10f, WAVE_SQUARE,  // osc1  ‚Äî quiet metallic edge (the tss noise leads)
 321:src/voice.h   ****     1.68f,   0.08f, WAVE_SQUARE,  // osc2  ‚Äî inharmonic metallic partial
 322:src/voice.h   ****     0.5f,    0.0f,  WAVE_SINE,    // sub   ‚Äî off (no low end on a hat)
 323:src/voice.h   ****     2.0f,    0.06f, WAVE_SQUARE,  // oct   ‚Äî high partial (2.0√ó keeps it under Nyquist)
 324:src/voice.h   ****     false,                        // osc2 is a fixed ratio, not finger-2 detune
 325:src/voice.h   ****     25.0f, 2.0f, 0.20f,           // wide open
 326:src/voice.h   ****     1.2f,                         // light drive
 327:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 328:src/voice.h   ****     0.80f, 0.2f, 1.0f, 0.0f, 0.05f, 1.0f, 160.0f, 3.0f, // noise-led, instant, sizzly tail
 329:src/voice.h   ****     // pitch_env_oct, pitch_env_ms, noise_hp ‚Äî high-passed bright "tsss"
 330:src/voice.h   ****     0.0f, 0.0f, 1.0f,
 331:src/voice.h   ****     true,        // no_cycle ‚Äî reached via the Drums MultiVoice
 332:src/voice.h   ****     0.85f,       // vel_sens ‚Äî dynamic taps
 333:src/voice.h   ****     400.0f        // retrig_ms ‚Äî dedupe strike + cap repeat rate
 334:src/voice.h   **** };
 335:src/voice.h   **** 
 336:src/voice.h   **** // ‚îÄ‚îÄ Voice 12: MultiVoice "Drums" ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 337:src/voice.h   **** //   A meta-voice: when selected, the slider splits into 4 equal zones, each
