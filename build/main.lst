 551:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 552:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 553:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 554:src/main.cpp  ****     if(raw <= 0)     return 0;
 555:src/main.cpp  ****     if(raw >= range) return 100;
 556:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 557:src/main.cpp  ****     if(raw > range) raw = range;
 558:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 559:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 560:src/main.cpp  ****     // Integer sqrt via Newton
 561:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 562:src/main.cpp  ****     s = (s + scaled/s) / 2;
 563:src/main.cpp  ****     s = (s + scaled/s) / 2;
 564:src/main.cpp  ****     s = (s + scaled/s) / 2;
 565:src/main.cpp  ****     s = (s + scaled/s) / 2;
 566:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 567:src/main.cpp  ****     if(s < 0)   s = 0;
 568:src/main.cpp  ****     if(s > 100) s = 100;
 569:src/main.cpp  ****     return s;
 570:src/main.cpp  **** }
