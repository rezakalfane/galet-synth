1003:src/voice.h   ****     VOICE_SH101_MAJ, // same synth, major-scale chords ŌĆö cycle here to flip the flavor
1004:src/voice.h   ****     VOICE_DRUMS,     // MultiVoice ŌĆö must stay last (MULTI_IDX = NUM_VOICES-1)
1005:src/voice.h   **** };
