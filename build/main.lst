 306:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 307:src/main.cpp  **** {
 308:src/main.cpp  ****     i2c_start();
 309:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 310:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 311:src/main.cpp  ****     i2c_start();
 312:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 313:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 314:src/main.cpp  ****     i2c_stop();return true;
 315:src/main.cpp  **** }
