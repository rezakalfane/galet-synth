 646:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 647:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 648:src/main.cpp  ****         for(int r=0;r<n;r++){
 649:src/main.cpp  ****             if(ra[r])continue;
 650:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 651:src/main.cpp  ****             if(c<best){best=c;br=r;}
