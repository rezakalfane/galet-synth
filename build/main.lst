 220:src/voice.h   **** // ‚îÄ‚îÄ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 221:src/voice.h   **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
 222:src/voice.h   **** //   so every note sounds as a power chord. Lower range, gentler filter, less
 223:src/voice.h   **** //   drive ‚Üí deep and round rather than bright and screaming.
 224:src/voice.h   **** static constexpr Voice VOICE_BASS = {
 225:src/voice.h   ****     "Bass",
 226:src/voice.h   ****     // FREQUENCY RANGE
 227:src/voice.h   ****     40.0f,
 228:src/voice.h   ****     160.0f,
 229:src/voice.h   ****     1.38629f,            // 40‚Äì160 Hz, ln(4) ‚Äî sits under the lead
