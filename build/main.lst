 617:src/main.cpp  ****         if(f1_on)
 618:src/main.cpp  ****         {
 619:src/main.cpp  ****             float pos01 = clampf((float)tracked[0].pos / 1000.0f, 0.0f, 1.0f);
 620:src/main.cpp  ****             float prs01 = clampf((float)tracked[0].pressure / 100.0f, 0.0f, 1.0f); // hard clamp
 621:src/main.cpp  **** 
 622:src/main.cpp  ****             // ŌöĆŌöĆ Direct exponential frequency mapping: 50Hz to 300Hz ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 623:src/main.cpp  ****             // freq = 50 * (300/50)^pos01 = 50 * 6^pos01
 624:src/main.cpp  ****             // Using e^x approx: 6^x = e^(x*ln6), ln6=1.7918
 625:src/main.cpp  ****             float earg = pos01 * 1.7918f;
 626:src/main.cpp  ****             float ex   = 1.0f + earg*(1.0f + earg*(0.5f + earg*0.1667f));
 627:src/main.cpp  ****             float freq_continuous = clampf(50.0f * ex, 50.0f, 300.0f);
 628:src/main.cpp  **** 
 629:src/main.cpp  ****             // Convert to MIDI for quantizer: midi = 69 + 12*log2(freq/440)
 630:src/main.cpp  ****             // log2(x) = ln(x)/ln(2); ln approx via y=(x-1)/(x+1) series
 631:src/main.cpp  ****             float freq_ratio = freq_continuous / 440.0f;
 632:src/main.cpp  ****             float y = (freq_ratio - 1.0f) / (freq_ratio + 1.0f);
 633:src/main.cpp  ****             float y2 = y*y;
 634:src/main.cpp  ****             float ln_ratio = 2.0f*y*(1.0f + y2*(0.3333f + y2*0.2f));
 635:src/main.cpp  ****             float midi_raw = 69.0f + 17.3123f * ln_ratio; // 17.3123 = 12/ln(2)
 636:src/main.cpp  **** 
 637:src/main.cpp  ****             float freq; // final frequency to use
 638:src/main.cpp  **** 
 639:src/main.cpp  ****             if(QUANTIZE_ENABLED && f1_fresh)
 640:src/main.cpp  ****             {
 641:src/main.cpp  ****                 // Touch-down: snap to nearest chromatic note
 642:src/main.cpp  ****                 f1_midi_base = quantize_midi(midi_raw);
 643:src/main.cpp  ****                 // Convert quantized MIDI back to Hz
 644:src/main.cpp  ****                 float qe = (f1_midi_base - 69.0f) * 0.05776f;
 645:src/main.cpp  ****                 freq = clampf(440.0f*(1.0f+qe*(1.0f+qe*(0.5f+qe*0.1667f))), 50.0f, 300.0f);
 646:src/main.cpp  ****                 f1_sliding = false;
 647:src/main.cpp  ****             }
 648:src/main.cpp  ****             else
 649:src/main.cpp  ****             {
 650:src/main.cpp  ****                 // Sliding or quantize disabled: follow continuous frequency directly
 651:src/main.cpp  ****                 f1_midi_base = f1_midi_base*0.88f + midi_raw*0.12f;
 652:src/main.cpp  ****                 freq = freq_continuous;
 653:src/main.cpp  ****                 f1_sliding = true;
 654:src/main.cpp  ****             }
 655:src/main.cpp  ****             freq = clampf(freq, 50.0f, 300.0f);
 656:src/main.cpp  **** 
 657:src/main.cpp  ****             // Cutoff: base tracks 2├Ś pitch, pressure opens it up
 658:src/main.cpp  ****             // Light press = 1├Ś pitch (dark, Moog-like tracking)
 659:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccV3nS87.s 			page 141


 660:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 661:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
 662:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
 663:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
 664:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
 665:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
 666:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 667:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
 668:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
 669:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
 670:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 671:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
 672:src/main.cpp  ****             };
 673:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
 674:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 675:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
 676:src/main.cpp  ****             };
 677:src/main.cpp  **** 
 678:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top
 679:src/main.cpp  ****             float prs_cut  = smootherstep(prs01);
 680:src/main.cpp  ****             float cutoff_oct = 12.0f * prs_cut;              // 12 octaves of sweep
 681:src/main.cpp  ****             float oct_arg  = cutoff_oct * 0.6931f;
 682:src/main.cpp  ****             float oct_mult = 1.0f + oct_arg*(1.0f + oct_arg*(0.5f + oct_arg*(0.1667f + oct_arg*0.04
 683:src/main.cpp  ****             float cutoff   = clampf(freq * 0.3f * oct_mult, 20.0f, 18000.0f); // screams
 684:src/main.cpp  **** 
 685:src/main.cpp  ****             // Vibrato: smoothstep, only activates above 60% pressure
 686:src/main.cpp  ****             float vib_in = clampf((prs01 - 0.6f) / 0.4f, 0.0f, 1.0f);
 687:src/main.cpp  ****             float vib    = smoothstep(vib_in) * 0.8f;
 688:src/main.cpp  **** 
 689:src/main.cpp  ****             // Drive: smoothstep ŌĆö clean at low, progressively warmer
 690:src/main.cpp  ****             float drive = 1.0f + smoothstep(prs01) * 2.5f;
 691:src/main.cpp  **** 
 692:src/main.cpp  ****             g_target_freq    = freq;
 693:src/main.cpp  ****             g_target_cutoff  = cutoff;
 694:src/main.cpp  ****             g_vibrato_depth  = vib;
 695:src/main.cpp  ****             g_target_drive   = drive;
 696:src/main.cpp  ****             g_finger_on      = true;
 697:src/main.cpp  ****             g_amp_target     = 0.72f;
