 255:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 256:src/main.cpp  **** {
 257:src/main.cpp  ****     bool ra[2]={false,false};
 258:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 259:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 260:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 261:src/main.cpp  ****         for(int r=0;r<n;r++){
 262:src/main.cpp  ****             if(ra[r])continue;
 263:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 264:src/main.cpp  ****             if(c<best){best=c;br=r;}
 265:src/main.cpp  ****         }
 266:src/main.cpp  ****         if(br>=0){
 267:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 268:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 269:src/main.cpp  ****             ra[br]=true;
 270:src/main.cpp  ****         } else tracked[slot].alive=false;
 271:src/main.cpp  ****     }
 272:src/main.cpp  ****     for(int r=0;r<n;r++){
 273:src/main.cpp  ****         if(ra[r])continue;
 274:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 275:src/main.cpp  ****             if(!tracked[slot].alive){
 276:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 277:src/main.cpp  ****                 ra[r]=true;break;
 278:src/main.cpp  ****             }
 279:src/main.cpp  ****         }
 280:src/main.cpp  ****     }
 281:src/main.cpp  **** }
