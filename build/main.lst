 184:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 185:src/main.cpp  ****     0.2f, 13.0f, 0.82f,   // dark base + enormous pressure sweep + high resonance
 186:src/main.cpp  ****     2.2f,                 // generous drive ŌĆö grit blooms with pressure
ARM GAS  /tmp/claude-502/ccry90Vn.s 			page 12


 187:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 188:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.20f, 0.20f, 3.0f, 250.0f, 18.0f   // snappy + fast acid glide
