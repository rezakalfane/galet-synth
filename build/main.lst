 187:src/main.cpp  ****     0.5f,        0.32f, WAVE_SINE,   // sub   ŌĆö clean sine for a tight low end
 188:src/main.cpp  ****     2.0f,        0.18f, WAVE_SAW,    // oct   ŌĆö saw top of the power chord
