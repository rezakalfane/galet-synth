 207:src/main.cpp  ****     "ClosedBass",
 208:src/main.cpp  ****     35.0f, 140.0f, 1.38629f,   // 35‚Äì140 Hz, ln(4) ‚Äî deep
 209:src/main.cpp  ****     1.0f,        0.42f, WAVE_TRI,    // osc1  ‚Äî mellow triangle root
 210:src/main.cpp  ****     RATIO_FIFTH, 0.18f, WAVE_TRI,    // osc2  ‚Äî fifth, dialed back
 211:src/main.cpp  ****     0.5f,        0.44f, WAVE_SINE,   // sub   ‚Äî clean sine carries the weight
 212:src/main.cpp  ****     2.0f,        0.10f, WAVE_TRI,    // oct   ‚Äî barely there, keep it dark
 213:src/main.cpp  ****     false,                      // osc2 is a fixed fifth, not finger-2 detune
 214:src/main.cpp  ****     1.0f, 2.0f, 0.30f,          // cutoff sits near the fundamental, tiny sweep, low res
 215:src/main.cpp  ****     0.5f                        // minimal drive ‚Äî stays clean and round
 216:src/main.cpp  **** };
