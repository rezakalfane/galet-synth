  63:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
  64:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
  65:src/main.cpp  **** float quantize_midi(float midi)
  66:src/main.cpp  **** {
  67:src/main.cpp  ****     int root = (int)midi;
  68:src/main.cpp  ****     int pc   = root % 12;
  69:src/main.cpp  ****     int oct  = root / 12;
  70:src/main.cpp  ****     // find nearest scale degree
  71:src/main.cpp  ****     int best_deg=0, best_dist=127;
  72:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
ARM GAS  /tmp/claude-502/ccxENaH3.s 			page 10


  73:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
  74:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
  75:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
  76:src/main.cpp  ****     }
  77:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
  78:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
  79:src/main.cpp  ****     float frac=midi-(float)root;
  80:src/main.cpp  ****     return q+frac;
  81:src/main.cpp  **** }
