 430:src/main.cpp  **** // Fast tanh approximation (Pad√©)
 431:src/main.cpp  **** static inline float fast_tanh(float x)
 432:src/main.cpp  **** {
 433:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 434:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 435:src/main.cpp  ****     float x2=x*x;
 436:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 437:src/main.cpp  **** }
 438:src/main.cpp  **** 
 439:src/main.cpp  **** // ‚îÄ‚îÄ Note quantizer ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 440:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 441:src/main.cpp  **** float quantize_midi(float midi)
 442:src/main.cpp  **** {
 443:src/main.cpp  ****     int root = (int)midi;
 444:src/main.cpp  ****     int pc   = root % 12;
 445:src/main.cpp  ****     int oct  = root / 12;
 446:src/main.cpp  ****     // find nearest scale degree
 447:src/main.cpp  ****     int best_deg=0, best_dist=127;
 448:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 449:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 450:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 451:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 452:src/main.cpp  ****     }
 453:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 454:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 455:src/main.cpp  ****     float frac=midi-(float)root;
 456:src/main.cpp  ****     return q+frac;
 457:src/main.cpp  **** }
