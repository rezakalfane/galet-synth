 626:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 627:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 628:src/main.cpp  ****         uint16_t scan[N_CH];
 629:src/main.cpp  **** 
 630:src/main.cpp  ****         while(true) {
 631:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 632:src/main.cpp  **** 
 633:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 634:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 635:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
 636:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
 637:src/main.cpp  **** 
 638:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 639:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 640:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 641:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 642:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 643:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 644:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 645:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 646:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 647:src/main.cpp  ****             g_led3_duty = led3;
 648:src/main.cpp  **** 
 649:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 650:src/main.cpp  ****             if(!calibrated) {
 651:src/main.cpp  ****                 acc += hw.adc.Get(0);
 652:src/main.cpp  ****                 n++;
 653:src/main.cpp  ****                 if(elapsed >= 2000) {
 654:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 655:src/main.cpp  ****                     calibrated = true;
 656:src/main.cpp  ****                 }
 657:src/main.cpp  ****             }
 658:src/main.cpp  **** 
 659:src/main.cpp  ****             // Exit on any touch.
 660:src/main.cpp  ****             read_electrodes(scan);
 661:src/main.cpp  ****             int32_t max_d = 0;
 662:src/main.cpp  ****             for(int i = 0; i < N_CH; i++) {
