1154:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1155:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1156:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1157:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1158:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
