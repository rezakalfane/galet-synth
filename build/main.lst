1218:src/main.cpp  ****             float prs_mult = 0.75f + 0.25f * pr01;
1219:src/main.cpp  ****             float l1_raw   = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
1220:src/main.cpp  ****             float l3_raw   = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
1221:src/main.cpp  ****             float l2_raw   = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
1222:src/main.cpp  ****             led1_target    = sqrtf(sqrtf(l2_raw)) * prs_mult;  // middle tent
1223:src/main.cpp  ****             led2_target    = sqrtf(sqrtf(l1_raw)) * prs_mult;  // pos 0 ramp
1224:src/main.cpp  ****             led3_target    = sqrtf(sqrtf(l3_raw)) * prs_mult * LED3_INTENSITY;
1225:src/main.cpp  ****         }
