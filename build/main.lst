 155:src/main.cpp  **** void capture_baseline(uint16_t* bl)
 156:src/main.cpp  **** {
 157:src/main.cpp  ****     uint32_t acc[N_CH]={0};uint16_t tmp[N_CH];
 158:src/main.cpp  ****     for(int s=0;s<REBASELINE_SAMPLES;s++){
 159:src/main.cpp  ****         read_electrodes(tmp);
 160:src/main.cpp  ****         for(int i=0;i<N_CH;i++)acc[i]+=tmp[i];
 161:src/main.cpp  ****         System::Delay(5);
 162:src/main.cpp  ****     }
 163:src/main.cpp  ****     for(int i=0;i<N_CH;i++)bl[i]=(uint16_t)(acc[i]/REBASELINE_SAMPLES);
 164:src/main.cpp  **** }
