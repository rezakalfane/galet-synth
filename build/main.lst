 385:src/main.cpp  **** 
 386:src/main.cpp  ****     // Trigger drum slot `s` from a tap at (pos, pressure): zone ŌåÆ drum, fine
 387:src/main.cpp  ****     // position ŌåÆ interval pitch, pressure ŌåÆ velocity (loudness/brightness/drive).
 388:src/main.cpp  ****     auto trigger_drum = [&](int s, int32_t pos, int32_t pressure){
 389:src/main.cpp  ****         float p    = clampf((float)pos / 1000.0f, 0.0f, 1.0f);
 390:src/main.cpp  ****         int   zone = (int)(p * 4.0f); if(zone > 3) zone = 3;
 391:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 392:src/main.cpp  ****         const Voice& V = VOICES[vidx];
 393:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 394:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 395:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
 396:src/main.cpp  ****         float freq = V.freq_low * MULTI_INTERVALS[step];
 397:src/main.cpp  ****         float v    = FIX_DRUM ? 1.0f : clampf((float)pressure / 100.0f, 0.0f, 1.0f);
 398:src/main.cpp  ****         float amp  = 0.72f * ((1.0f - V.vel_sens) + V.vel_sens * v);
 399:src/main.cpp  ****         // Cutoff from velocity, same curve as the mono path.
 400:src/main.cpp  ****         float cutoff_oct = V.cutoff_oct_max * smootherstep_f(v);
 401:src/main.cpp  ****         float oa = cutoff_oct * 0.6931f;
 402:src/main.cpp  ****         float om = 1.0f + oa*(1.0f + oa*(0.5f + oa*(0.1667f + oa*0.0417f)));
 403:src/main.cpp  ****         float tf = (V.keytrack >= 0.999f) ? freq
 404:src/main.cpp  ****                    : V.freq_low * powf(freq / V.freq_low, V.keytrack);
 405:src/main.cpp  ****         float cutoff = clampf(tf * V.cutoff_mult * om, 20.0f, 18000.0f);
 406:src/main.cpp  ****         float drive  = 1.0f + smoothstep_f(v) * V.drive_max;
 407:src/main.cpp  ****         drum_trigger(g_hits[s], vidx, freq, amp, cutoff, drive, hw.AudioSampleRate());
 408:src/main.cpp  ****         g_active_voice = vidx;   // header shows the last-hit drum
 409:src/main.cpp  ****     };
 410:src/main.cpp  **** 
 411:src/main.cpp  ****     // Fire one drum (bank index `bankidx`) on hit-pool slot `slot` at full
 412:src/main.cpp  ****     // velocity, at its natural low pitch. Used by the kit preview below.
ARM GAS  /tmp/claude-502/ccMZiWpD.s 			page 68


 413:src/main.cpp  ****     auto preview_drum = [&](int slot, int bankidx){
 414:src/main.cpp  ****         const Voice& V = VOICES[bankidx];
 415:src/main.cpp  ****         float freq   = V.freq_low;
 416:src/main.cpp  ****         // Bright enough that the noisy drums (snare/hat) crack through; the
 417:src/main.cpp  ****         // tonal drums stay dark via their own low cutoff_mult.
 418:src/main.cpp  ****         float cutoff = clampf(freq * V.cutoff_mult * 3.0f, 60.0f, 16000.0f);
 419:src/main.cpp  ****         float drive  = 1.0f + 0.6f * V.drive_max;
 420:src/main.cpp  ****         drum_trigger(g_hits[slot], bankidx, freq, 0.85f, cutoff, drive, hw.AudioSampleRate());
 421:src/main.cpp  ****         // ONE-SHOT: jump to full amp and immediately ungate so the hit decays on
 422:src/main.cpp  ****         // its own. A preview has no finger-lift to clear the gate, so leaving it
 423:src/main.cpp  ****         // gated would sustain the drum's noise forever (the "100% noise when Drums
 424:src/main.cpp  ****         // selected" bug). attack_ms (~1 ms) makes skipping the ramp inaudible.
 425:src/main.cpp  ****         g_hits[slot].amp  = g_hits[slot].amp_tgt;
 426:src/main.cpp  ****         g_hits[slot].gate = false;
 427:src/main.cpp  ****     };
