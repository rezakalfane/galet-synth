 227:src/main.cpp  ****                 if(elapsed >= 2000) {
 228:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 229:src/main.cpp  ****                     calibrated = true;
 230:src/main.cpp  ****                 }
 231:src/main.cpp  ****             }
