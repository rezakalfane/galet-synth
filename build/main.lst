 463:src/main.cpp  **** 
 464:src/main.cpp  ****         // Vibrato: modulate frequency by ┬▒1 semitone * depth
 465:src/main.cpp  ****         // powf(2, semitones/12) ŌĆö approx for small values: exp(x*0.0578)
 466:src/main.cpp  ****         float vib_amt = lfo * s_vibdepth * 0.05f; // max ┬▒~0.05 semitones*depth
 467:src/main.cpp  ****         float freq_vib = s_freq * (1.0f + vib_amt);
 468:src/main.cpp  **** 
 469:src/main.cpp  ****         // Osc 2 frequency: detuned by s_detune semitones
 470:src/main.cpp  ****         // pow2(s_detune/12) approximated
 471:src/main.cpp  ****         float det_ratio = 1.0f + s_detune * 0.05776f; // linear approx, good for ┬▒1 oct
 472:src/main.cpp  ****         float freq2 = freq_vib * det_ratio;
 473:src/main.cpp  **** 
 474:src/main.cpp  ****         // Sub osc: one octave down
 475:src/main.cpp  ****         float freq_sub = freq_vib * 0.5f;
 476:src/main.cpp  ****         // Octave-up osc: one octave above fundamental ŌĆö adds air and sparkle
 477:src/main.cpp  ****         float freq_oct = freq_vib * 2.0f;
 478:src/main.cpp  **** 
 479:src/main.cpp  ****         // Ring mod carrier: slightly above fundamental for metallic beating
 480:src/main.cpp  ****         float freq_rm = freq_vib * 1.0f; // unison ring mod (can offset for effect)
 481:src/main.cpp  **** 
 482:src/main.cpp  ****         // Oscillators
 483:src/main.cpp  ****         float osc1    = tri(s_phase1)   * 0.50f;
 484:src/main.cpp  ****         float osc2    = tri(s_phase2)   * 0.22f; // detuned copy
 485:src/main.cpp  ****         float sub     = tri(s_phase_sub)* 0.18f; // one octave below
 486:src/main.cpp  ****         float osc_oct = tri(s_phase_oct)* 0.15f; // one octave above ŌĆö bright shimmer
