 141:src/main.cpp  **** // ŌöĆŌöĆ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 142:src/main.cpp  **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
 143:src/main.cpp  **** //   so every note sounds as a power chord. Lower range, gentler filter, less
 144:src/main.cpp  **** //   drive ŌåÆ deep and round rather than bright and screaming.
 145:src/main.cpp  **** static constexpr Voice VOICE_BASS = {
 146:src/main.cpp  ****     "Bass",
 147:src/main.cpp  ****     40.0f, 160.0f, 1.38629f,   // 40ŌĆō160 Hz, ln(4) ŌĆö sits under the lead
 148:src/main.cpp  ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ŌĆö root
 149:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ŌĆö fixed perfect fifth (the power chord)
 150:src/main.cpp  ****     0.5f,        0.34f, WAVE_TRI,   // sub   ŌĆö extra weight for a round bottom
 151:src/main.cpp  ****     2.0f,        0.20f, WAVE_TRI,   // oct   ŌĆö top of the power chord
 152:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 153:src/main.cpp  ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 154:src/main.cpp  ****     1.0f,                 // less drive ŌĆö keep it clean and round
 155:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 156:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.12f, 0.12f, 6.0f, 300.0f, 25.0f
 157:src/main.cpp  **** };
 158:src/main.cpp  **** 
 159:src/main.cpp  **** // ŌöĆŌöĆ Voice 2: open power-chord bass ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 160:src/main.cpp  **** //   Same chord stack as VOICE_BASS, but the filter starts brighter and sweeps
 161:src/main.cpp  **** //   much further with pressure ŌĆö light touch is still warm, hard press opens it
 162:src/main.cpp  **** //   wide. A touch more resonance and drive for presence as it opens.
 163:src/main.cpp  **** static constexpr Voice VOICE_BASS_OPEN = {
 164:src/main.cpp  ****     "OpenBass",
