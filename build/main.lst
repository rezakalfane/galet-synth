 177:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 178:src/main.cpp  **** {
 179:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 180:src/main.cpp  ****     for(int i=s;i<=e;i++){
 181:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 182:src/main.cpp  ****         sw+=w;swx+=w*i;
 183:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 184:src/main.cpp  ****     }
 185:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 186:src/main.cpp  ****     if(sw==0)return -1;
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccJ1Nbd8.s 			page 12


 187:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 188:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 189:src/main.cpp  ****     return p;
 190:src/main.cpp  **** }
 191:src/main.cpp  **** 
 192:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 193:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 194:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 195:src/main.cpp  ****     if(raw <= 0)     return 0;
 196:src/main.cpp  ****     if(raw >= range) return 100;
 197:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 198:src/main.cpp  ****     if(raw > range) raw = range;
 199:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 200:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 201:src/main.cpp  ****     // Integer sqrt via Newton
 202:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 203:src/main.cpp  ****     s = (s + scaled/s) / 2;
 204:src/main.cpp  ****     s = (s + scaled/s) / 2;
 205:src/main.cpp  ****     s = (s + scaled/s) / 2;
 206:src/main.cpp  ****     s = (s + scaled/s) / 2;
 207:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 208:src/main.cpp  ****     if(s < 0)   s = 0;
 209:src/main.cpp  ****     if(s > 100) s = 100;
 210:src/main.cpp  ****     return s;
 211:src/main.cpp  **** }
