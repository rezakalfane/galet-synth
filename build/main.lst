1187:src/main.cpp  ****             // Cutoff: base tracks 2√ó pitch, pressure opens it up
1188:src/main.cpp  ****             // Light press = 1√ó pitch (dark, Moog-like tracking)
1189:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
1190:src/main.cpp  ****             // ‚îÄ‚îÄ Moog-style exponential cutoff ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
1191:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
1192:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ‚Äî exponential opening
1193:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
1194:src/main.cpp  ****             // This gives the classic Moog "closed ‚Üí wah ‚Üí bright" feel.
1195:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1196:src/main.cpp  ****             // ‚îÄ‚îÄ Smootherstep pressure curves (6x‚Åµ - 15x‚Å¥ + 10x¬≥) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
1197:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1198:src/main.cpp  ****             // Much more playable than power curves ‚Äî feels like a real knob.
1199:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1200:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1201:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1202:src/main.cpp  ****             };
1203:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
1204:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1205:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
1206:src/main.cpp  ****             };
1207:src/main.cpp  **** 
1208:src/main.cpp  ****             // Cutoff: smootherstep ‚Äî very dark at low, dramatic in mid, eases at top.
1209:src/main.cpp  ****             // Base cutoff and sweep depth are voice-defined.
1210:src/main.cpp  ****             float prs_cut  = smootherstep(prs01);
1211:src/main.cpp  ****             float cutoff_oct = VOICE.cutoff_oct_max * prs_cut;
1212:src/main.cpp  ****             float oct_arg  = cutoff_oct * 0.6931f;
1213:src/main.cpp  ****             float oct_mult = 1.0f + oct_arg*(1.0f + oct_arg*(0.5f + oct_arg*(0.1667f + oct_arg*0.04
1214:src/main.cpp  ****             // Keytracking: how much the cutoff base follows pitch. keytrack=1 is
1215:src/main.cpp  ****             // full tracking (cutoff ‚àù freq); <1 holds the cutoff lower as pitch
1216:src/main.cpp  ****             // rises, for a more consistent tone across the range. (constexpr ‚Üí
1217:src/main.cpp  ****             // the common keytrack=1 case folds to no powf.)
1218:src/main.cpp  ****             float track_freq = (VOICE.keytrack >= 0.999f)
1219:src/main.cpp  ****                 ? freq
