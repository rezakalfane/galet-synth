 312:src/voice.h   **** // ŌöĆŌöĆ Voice 3: rich power-chord bass with mixed waveforms + huge filter sweep ŌöĆŌöĆŌöĆŌöĆ
 313:src/voice.h   **** //   Mixed shapes for body: saw root (harmonic-rich), square fifth (hollow), a
 314:src/voice.h   **** //   clean sine sub (tight low end), saw octave on top. Starts dark, then
 315:src/voice.h   **** //   pressure opens the cutoff dramatically (13 octaves) with high resonance ŌĆö
 316:src/voice.h   **** //   a vocal, acid-style "wow" as you press harder.
 317:src/voice.h   **** static constexpr Voice VOICE_BASS_RICH = {
 318:src/voice.h   ****     "RichBass",
 319:src/voice.h   ****     // FREQUENCY RANGE
 320:src/voice.h   ****     40.0f,
 321:src/voice.h   ****     160.0f,
