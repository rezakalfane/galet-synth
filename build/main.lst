 108:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 109:src/main.cpp  **** {
 110:src/main.cpp  ****     i2c_start();
 111:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 112:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 113:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 114:src/main.cpp  ****     i2c_stop();return true;
 115:src/main.cpp  **** }
 116:src/main.cpp  **** 
 117:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 118:src/main.cpp  **** {
 119:src/main.cpp  ****     i2c_start();
 120:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 121:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 122:src/main.cpp  ****     i2c_start();
 123:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 124:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 125:src/main.cpp  ****     i2c_stop();return true;
 126:src/main.cpp  **** }
