 929:src/main.cpp  ****         float white  = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 930:src/main.cpp  ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 931:src/main.cpp  ****         float bright = white - h.noise_lp;
 932:src/main.cpp  ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
