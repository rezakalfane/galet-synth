 596:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 597:src/main.cpp  **** static inline float fast_tanh(float x)
 598:src/main.cpp  **** {
 599:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 600:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 601:src/main.cpp  ****     float x2=x*x;
 602:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 603:src/main.cpp  **** }
