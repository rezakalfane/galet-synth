 676:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 677:src/main.cpp  **** {
 678:src/main.cpp  ****     bool ra[MAX_FINGERS]={};
 679:src/main.cpp  ****     for(int slot=0;slot<MAX_FINGERS;slot++){
 680:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 681:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 682:src/main.cpp  ****         for(int r=0;r<n;r++){
 683:src/main.cpp  ****             if(ra[r])continue;
 684:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
