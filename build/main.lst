 937:src/main.cpp  ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 938:src/main.cpp  ****         float bright = white - h.noise_lp;
 939:src/main.cpp  ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
 940:src/main.cpp  ****     }
 941:src/main.cpp  ****     mix = fast_tanh(mix * h.drive);
 942:src/main.cpp  ****     // Per-drum 1-pole lowpass (cheap ŌĆö one multiply-add ŌĆö instead of the 4-pole
 943:src/main.cpp  ****     // Moog) at the drum's own cutoff: keeps Kick/Tom dark, Snare/Hat bright.
 944:src/main.cpp  ****     h.lp_state += h.lp_coeff * (mix - h.lp_state);
