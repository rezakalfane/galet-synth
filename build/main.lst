 605:src/main.cpp  **** // ‚îÄ‚îÄ Oscillator waveforms (phase ph in [0,1) ‚Üí sample in [-1,1]) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 606:src/main.cpp  **** // Triangle wave
 607:src/main.cpp  **** static inline float tri(float ph){
 608:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 609:src/main.cpp  **** }
 610:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ‚Äî matches sin(2œÄ¬∑ph).
 611:src/main.cpp  **** static inline float osc_sine(float ph){
 612:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 613:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -œÄ..œÄ (angle shifted by œÄ)
 614:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 615:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 616:src/main.cpp  ****     return -y;                                 // undo the œÄ shift: sin(x+œÄ) = -sin(x)
 617:src/main.cpp  **** }
 618:src/main.cpp  **** // Naive square / saw ‚Äî alias at high pitch but sound rich on a bass voice.
 619:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 620:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 621:src/main.cpp  **** 
 622:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 623:src/main.cpp  **** // switched live). A small jump table ‚Äî cheap at audio rate on the H750.
 624:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 625:src/main.cpp  ****     switch(w){
 626:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 627:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 628:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 629:src/main.cpp  ****         case WAVE_TRI:
 630:src/main.cpp  ****         default:          return tri(ph);
 631:src/main.cpp  ****     }
 632:src/main.cpp  **** }
