 867:src/main.cpp  ****         // ŌöĆŌöĆ LED targets + slew ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 868:src/main.cpp  ****         // Three-LED position indicator. Linear "tents" hand off cleanly:
 869:src/main.cpp  ****         //   LED1 (DAC1, middle)       ŌåÆ 1 - 2*|p - 0.5|
 870:src/main.cpp  ****         //   LED2 (DAC2, pos 0 end)    ŌåÆ max(0, 1 - 2*p)
 871:src/main.cpp  ****         //   LED3 (PWM A0, pos 1 end)  ŌåÆ max(0, 2*p - 1)
 872:src/main.cpp  ****         // Fourth-root curve (gamma=0.25) keeps each LED above its forward-voltage
 873:src/main.cpp  ****         // floor at the handoff points (50% raw ŌåÆ ~84% drive). Pressure adds a
 874:src/main.cpp  ****         // subtle ~75%ŌåÆ100% intensity scale.
 875:src/main.cpp  ****         float led1_target = 0.0f, led2_target = 0.0f, led3_target = 0.0f;
 876:src/main.cpp  ****         if(f1_on) {
 877:src/main.cpp  ****             float p01      = clampf((float)tracked[0].pos / 1000.0f, 0.0f, 1.0f);
 878:src/main.cpp  ****             float pr01     = clampf((float)tracked[0].pressure / 100.0f, 0.0f, 1.0f);
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccJ1Nbd8.s 			page 158


 879:src/main.cpp  ****             float prs_mult = 0.75f + 0.25f * pr01;
 880:src/main.cpp  ****             float l1_raw   = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 881:src/main.cpp  ****             float l3_raw   = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 882:src/main.cpp  ****             float l2_raw   = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 883:src/main.cpp  ****             led1_target    = sqrtf(sqrtf(l2_raw)) * prs_mult;  // middle tent
 884:src/main.cpp  ****             led2_target    = sqrtf(sqrtf(l1_raw)) * prs_mult;  // pos 0 ramp
