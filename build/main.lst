 351:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 352:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 353:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 354:src/main.cpp  ****     if(raw <= 0)     return 0;
 355:src/main.cpp  ****     if(raw >= range) return 100;
 356:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 357:src/main.cpp  ****     if(raw > range) raw = range;
ARM GAS  /tmp/claude-502/ccwMOaii.s 			page 15


 358:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 359:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 360:src/main.cpp  ****     // Integer sqrt via Newton
 361:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 362:src/main.cpp  ****     s = (s + scaled/s) / 2;
 363:src/main.cpp  ****     s = (s + scaled/s) / 2;
 364:src/main.cpp  ****     s = (s + scaled/s) / 2;
 365:src/main.cpp  ****     s = (s + scaled/s) / 2;
 366:src/main.cpp  ****     // Hard clamp output ‚Äî Newton can land at 101 due to rounding
 367:src/main.cpp  ****     if(s < 0)   s = 0;
 368:src/main.cpp  ****     if(s > 100) s = 100;
 369:src/main.cpp  ****     return s;
 370:src/main.cpp  **** }
