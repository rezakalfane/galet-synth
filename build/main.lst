1281:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
1282:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
1283:src/main.cpp  ****         uint16_t scan[N_CH];
1284:src/main.cpp  **** 
1285:src/main.cpp  ****         while(true) {
1286:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
1287:src/main.cpp  **** 
1288:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
1289:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
1290:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
1291:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
1292:src/main.cpp  **** 
1293:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
1294:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
1295:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
1296:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
1297:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
1298:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
1299:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
1300:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
1301:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
1302:src/main.cpp  ****             g_led3_duty = led3;
1303:src/main.cpp  **** 
1304:src/main.cpp  ****             // FSR calibration window: first 2 s only.
1305:src/main.cpp  ****             if(!calibrated) {
1306:src/main.cpp  ****                 acc += hw.adc.Get(0);
1307:src/main.cpp  ****                 n++;
1308:src/main.cpp  ****                 if(elapsed >= 2000) {
1309:src/main.cpp  ****                     commit_fsr_avg(acc, n);
1310:src/main.cpp  ****                     calibrated = true;
1311:src/main.cpp  ****                 }
1312:src/main.cpp  ****             }
1313:src/main.cpp  **** 
