 928:src/main.cpp  ****     float f = h.freq * h.pmult;
 929:src/main.cpp  ****     // Oscillators + noise
 930:src/main.cpp  ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 931:src/main.cpp  ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 932:src/main.cpp  ****               + osc(h.phs,V.sub_wave )*V.sub_level
 933:src/main.cpp  ****               + osc(h.pho,V.oct_wave )*V.oct_level;
