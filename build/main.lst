 592:src/main.cpp  **** // Moog 4-pole ladder
 593:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 594:src/main.cpp  **** {
 595:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 596:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 597:src/main.cpp  ****     float k  = 3.8f*res;
 598:src/main.cpp  ****     float fb = k*s_flt[3];
 599:src/main.cpp  ****     float x  = in - fb;
 600:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 601:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 602:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 603:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 604:src/main.cpp  ****     return s_flt[3];
 605:src/main.cpp  **** }
