1061:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
1062:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
1063:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
1064:src/main.cpp  ****             g_led3_duty = led3;
1065:src/main.cpp  **** 
1066:src/main.cpp  ****             // FSR calibration window: first 2 s only.
