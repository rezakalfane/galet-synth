 219:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 220:src/main.cpp  **** {
 221:src/main.cpp  ****     i2c_start();
 222:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 223:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 224:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 225:src/main.cpp  ****     i2c_stop();return true;
 226:src/main.cpp  **** }
