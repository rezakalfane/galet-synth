 787:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 788:src/main.cpp  **** // Lower value = faster response.
 789:src/main.cpp  **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
 790:src/main.cpp  **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
 791:src/main.cpp  **** // callback. The constants below are the ones still shared by all voices.
 792:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 793:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 794:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
 795:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 796:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ŌĆö ~35 ms smooth
 797:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 798:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 799:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 800:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 801:src/main.cpp  **** 
 802:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 803:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 804:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 805:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 806:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 807:src/main.cpp  **** }
