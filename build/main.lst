 640:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 641:src/main.cpp  **** float quantize_midi(float midi)
 642:src/main.cpp  **** {
ARM GAS  /tmp/claude-502/ccry90Vn.s 			page 20


 643:src/main.cpp  ****     int root = (int)midi;
 644:src/main.cpp  ****     int pc   = root % 12;
 645:src/main.cpp  ****     int oct  = root / 12;
 646:src/main.cpp  ****     // find nearest scale degree
 647:src/main.cpp  ****     int best_deg=0, best_dist=127;
 648:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 649:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 650:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 651:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 652:src/main.cpp  ****     }
 653:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 654:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 655:src/main.cpp  ****     float frac=midi-(float)root;
 656:src/main.cpp  ****     return q+frac;
 657:src/main.cpp  **** }
