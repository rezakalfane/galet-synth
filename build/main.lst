 103:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 104:src/main.cpp  **** {
 105:src/main.cpp  ****     i2c_start();
 106:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 107:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 108:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 109:src/main.cpp  ****     i2c_stop();return true;
 110:src/main.cpp  **** }
 111:src/main.cpp  **** 
 112:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 113:src/main.cpp  **** {
 114:src/main.cpp  ****     i2c_start();
 115:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 116:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 117:src/main.cpp  ****     i2c_start();
 118:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 119:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 120:src/main.cpp  ****     i2c_stop();return true;
 121:src/main.cpp  **** }
