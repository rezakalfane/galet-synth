 384:src/main.cpp  ****     int ss=pka-2;if(ss<0)ss=0;int se=pka+2;if(se>=N_CH)se=N_CH-1;
 385:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
 386:src/main.cpp  ****     int pkb=0;int32_t db=0;
