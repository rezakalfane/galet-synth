 674:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 675:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 676:src/main.cpp  **** float quantize_midi(float midi)
 677:src/main.cpp  **** {
 678:src/main.cpp  ****     int root = (int)midi;
 679:src/main.cpp  ****     int pc   = root % 12;
 680:src/main.cpp  ****     int oct  = root / 12;
 681:src/main.cpp  ****     // find nearest scale degree
