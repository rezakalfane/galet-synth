 909:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 910:src/main.cpp  ****         const Voice& V = VOICES[vidx];
 911:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 912:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 913:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
