 649:src/main.cpp  **** // Wavefolder distortion
 650:src/main.cpp  **** // Folds signal back when it exceeds threshold ‚Äî creates rich harmonics.
 651:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 652:src/main.cpp  **** static inline float wavefold(float in, float amount)
 653:src/main.cpp  **** {
 654:src/main.cpp  ****     if(amount < 0.01f) return in;
 655:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 656:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 657:src/main.cpp  ****     // Fold: reflect signal at ¬±1 boundary repeatedly
 658:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 659:src/main.cpp  ****     float x = driven;
 660:src/main.cpp  ****     // 2 passes of folding for richness
 661:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 662:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 663:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 664:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 665:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 666:src/main.cpp  ****     }
 667:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 668:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 669:src/main.cpp  **** }
