 458:src/voice.h   **** // ‚îÄ‚îÄ Voice 6: electric guitar power chord ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚
 459:src/voice.h   **** //   A driven sawtooth power chord ‚Äî each note is a root + fixed perfect fifth +
 460:src/voice.h   **** //   octave-up jangle over a saw octave-down body, so it plays as a chord like a
 461:src/voice.h   **** //   rock guitar. Heavy-ish drive adds overdrive crunch; the filter sits a touch
 462:src/voice.h   **** //   above the fundamental and sweeps wide open with pressure (dig in = bright,
 463:src/voice.h   **** //   pick-attack bite), with resonance for a vocal amp "quack". A fast pitch-env
 464:src/voice.h   **** //   "twang" + a little pick-grit noise on the onset, then amp decay-to-silence
 465:src/voice.h   **** //   (decay_ms/sustain below) so each note plucks and rings out over ~1.2 s while
 466:src/voice.h   **** //   held ‚Äî like a struck string, not an organ. Quantized to a major scale so
 467:src/voice.h   **** //   tapped chords land in key. For a BASS guitar instead: drop freq_low/high ~¬Ω,
 468:src/voice.h   **** //   cut drive to ~1.5, use WAVE_TRI, and raise `sustain` if you want it to hold.
 469:src/voice.h   **** static constexpr Voice VOICE_GUITAR = {
 470:src/voice.h   ****     "Guitar",
 471:src/voice.h   ****     // FREQUENCY RANGE
 472:src/voice.h   ****     80.0f,
 473:src/voice.h   ****     320.0f,
 474:src/voice.h   ****     1.38629f,            // 80‚Äì320 Hz, ln(4) ‚Äî E2-ish up two octaves
 475:src/voice.h   ****     // OSCILLATOR STACK
 476:src/voice.h   ****     1.0f,
 477:src/voice.h   ****     0.40f,
 478:src/voice.h   ****     WAVE_SAW,            // osc1  ‚Äî saw root (bright, string-like)
 479:src/voice.h   ****     // SECONDARY OSCILLATOR
 480:src/voice.h   ****     RATIO_FIFTH,
 481:src/voice.h   ****     0.30f,
 482:src/voice.h   ****     WAVE_SAW,            // osc2  ‚Äî fixed perfect fifth (the power chord)
 483:src/voice.h   ****     // SUB OSCILLATOR
 484:src/voice.h   ****     0.5f,
 485:src/voice.h   ****     0.22f,
 486:src/voice.h   ****     WAVE_SAW,            // sub   ‚Äî octave-down body/weight
 487:src/voice.h   ****     // OCTAVE OSCILLATOR
 488:src/voice.h   ****     2.0f,
 489:src/voice.h   ****     0.18f,
 490:src/voice.h   ****     WAVE_SAW,            // oct   ‚Äî octave-up jangle / pick brightness
 491:src/voice.h   ****     // FILTER
 492:src/voice.h   ****     false,               // osc2 is a fixed fifth, not finger-2 detune
 493:src/voice.h   ****     1.5f,
 494:src/voice.h   ****     6.0f,
 495:src/voice.h   ****     0.42f,               // bright-ish base, wide sweep, resonant mid "quack" (amp-like)
 496:src/voice.h   ****     // DRIVE
 497:src/voice.h   ****     3.6f,                // overdrive crunch ‚Äî the electric-guitar grit
 498:src/voice.h   ****     // NOISE
 499:src/voice.h   ****     0.03f,               // noise level ‚Äî a little pick grit (rides the amp decay)
 500:src/voice.h   ****     1.0f,                // keytrack
 501:src/voice.h   ****     1.0f,                // ringmod ratio
 502:src/voice.h   ****     0.12f,               // ringmod max
 503:src/voice.h   ****     0.15f,               // fold max
 504:src/voice.h   ****     3.0f,                // attack ‚Äî fast pluck onset
 505:src/voice.h   ****     280.0f,              // release ‚Äî ring tail after lift
 506:src/voice.h   ****     8.0f,                // glide ‚Äî quick, distinct chord changes
 507:src/voice.h   ****     // PITCH ENVELOPE ‚Äî fast pick-attack "twang": start ~0.12 oct sharp, settle 18 ms
 508:src/voice.h   ****     0.12f, 18.0f,        // pitch_env_oct, pitch_env_ms
 509:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 510:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
 511:src/voice.h   ****     // PITCH QUANTIZE ‚Äî snap to a major scale on touch-down so chords land in key
 512:src/voice.h   ****     true,
 513:src/voice.h   ****     SCALE_MAJOR, (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0])),
 514:src/voice.h   ****     // AMP DECAY ‚Äî the pluck: ring out to silence over ~1.2 s while held
ARM GAS  /tmp/claude-502/ccN5Z8iY.s 			page 47


 515:src/voice.h   ****     1200.0f,             // decay_ms
 516:src/voice.h   ****     0.0f                 // sustain (0 = decays to silence)
 517:src/voice.h   **** };
 518:src/voice.h   **** 
 519:src/voice.h   **** // ‚îÄ‚îÄ Voice 7: warm ensemble pad ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
 520:src/voice.h   **** //   A lush, evolving pad. Two saws a hair apart (1.006√ó) give an ensemble/chorus
 521:src/voice.h   **** //   width, a soft triangle sub adds body, an airy sine octave sits on top. A
 522:src/voice.h   **** //   moderate, low-resonance filter keeps it warm rather than bright. The pad
 523:src/voice.h   **** //   character comes from the envelope: a slow ~2.2 s swell in and a long ~2 s
 524:src/voice.h   **** //   tail, so notes bloom and linger. A whisper of noise adds air.
 525:src/voice.h   **** static constexpr Voice VOICE_PAD = {
 526:src/voice.h   ****     "Pad",
 527:src/voice.h   ****     // FREQUENCY RANGE
 528:src/voice.h   ****     70.0f,
 529:src/voice.h   ****     560.0f,
