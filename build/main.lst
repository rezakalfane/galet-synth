 202:src/main.cpp  **** // ŌöĆŌöĆ Voice 4: clean sine organ / flute (a melodic, non-bass departure) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 203:src/main.cpp  **** //   Pure sine oscillators stacked like organ drawbars: octave-down body, root,
 204:src/main.cpp  **** //   octave-up air, plus a second osc tuned a hair sharp (1.005├Ś) for a slow,
 205:src/main.cpp  **** //   warm chorus shimmer instead of a chord. Higher register than the basses, a
 206:src/main.cpp  **** //   mostly-open clean filter, and just a touch of drive so pressure adds gentle
 207:src/main.cpp  **** //   harmonic warmth. Sines never alias, so it stays smooth all the way up.
 208:src/main.cpp  **** static constexpr Voice VOICE_ORGAN = {
 209:src/main.cpp  ****     "Organ",
 210:src/main.cpp  ****     65.0f, 520.0f, 2.07944f,   // 65ŌĆō520 Hz, ln(8) ŌĆö a melodic keyboard register
 211:src/main.cpp  ****     1.0f,    0.45f, WAVE_SINE,  // osc1  ŌĆö root (8')
 212:src/main.cpp  ****     1.005f,  0.40f, WAVE_SINE,  // osc2  ŌĆö slightly sharp unison ŌåÆ slow chorus shimmer
 213:src/main.cpp  ****     0.5f,    0.30f, WAVE_SINE,  // sub   ŌĆö octave-down body (16')
 214:src/main.cpp  ****     2.0f,    0.28f, WAVE_SINE,  // oct   ŌĆö octave-up air (4')
 215:src/main.cpp  ****     false,                      // osc2 is a fixed chorus detune, not finger-2 detune
 216:src/main.cpp  ****     2.0f, 5.0f, 0.20f,          // mostly-open clean filter, gentle pressure lift, low res
 217:src/main.cpp  ****     0.8f,                       // light drive ŌĆö pressure adds subtle warmth, stays pure
 218:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 219:src/main.cpp  ****     0.03f, 1.0f, 1.0f, 0.05f, 0.0f, 8.0f, 120.0f, 8.0f   // breath chiff, fast on/off, no glide
 220:src/main.cpp  **** };
