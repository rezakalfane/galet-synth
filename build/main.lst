 209:src/main.cpp  **** int detect_raw(int32_t* delta,Finger out[2])
 210:src/main.cpp  **** {
 211:src/main.cpp  ****     out[0].active=out[1].active=false;
 212:src/main.cpp  ****     int pka=0;int32_t da=0;
 213:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(delta[i]>da){da=delta[i];pka=i;}
 214:src/main.cpp  ****     if(da<TOUCH_THRESHOLD)return 0;
 215:src/main.cpp  ****     int ws=pka-2;if(ws<0)ws=0;int we=pka+2;if(we>=N_CH)we=N_CH-1;
 216:src/main.cpp  ****     int32_t pa;int pca;
 217:src/main.cpp  ****     int32_t posa=centroid_window(delta,ws,we,&pa,&pca);
 218:src/main.cpp  ****     out[0]={true,posa,pressure_pct(pa,pca),pca,pa};
 219:src/main.cpp  **** 
 220:src/main.cpp  ****     int32_t d2[N_CH];
 221:src/main.cpp  ****     int ss=pka-2;if(ss<0)ss=0;int se=pka+2;if(se>=N_CH)se=N_CH-1;
 222:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
 223:src/main.cpp  ****     int pkb=0;int32_t db=0;
 224:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(d2[i]>db){db=d2[i];pkb=i;}
 225:src/main.cpp  ****     int sep=pkb-pka;if(sep<0)sep=-sep;
 226:src/main.cpp  ****     if(db<TOUCH_THRESHOLD||sep<MIN_FINGER_SEP)return 1;
 227:src/main.cpp  ****     int ws2=pkb-2;if(ws2<0)ws2=0;int we2=pkb+2;if(we2>=N_CH)we2=N_CH-1;
 228:src/main.cpp  ****     int32_t pb;int pcb;
 229:src/main.cpp  ****     int32_t posb=centroid_window(d2,ws2,we2,&pb,&pcb);
 230:src/main.cpp  ****     out[1]={true,posb,pressure_pct(pb,pcb),pcb,pb};
 231:src/main.cpp  ****     return 2;
 232:src/main.cpp  **** }
 233:src/main.cpp  **** 
 234:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 235:src/main.cpp  **** {
 236:src/main.cpp  ****     bool ra[2]={false,false};
 237:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 238:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 239:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 240:src/main.cpp  ****         for(int r=0;r<n;r++){
 241:src/main.cpp  ****             if(ra[r])continue;
 242:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 243:src/main.cpp  ****             if(c<best){best=c;br=r;}
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccV3nS87.s 			page 13


 244:src/main.cpp  ****         }
 245:src/main.cpp  ****         if(br>=0){
 246:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 247:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 248:src/main.cpp  ****             ra[br]=true;
 249:src/main.cpp  ****         } else tracked[slot].alive=false;
 250:src/main.cpp  ****     }
 251:src/main.cpp  ****     for(int r=0;r<n;r++){
 252:src/main.cpp  ****         if(ra[r])continue;
 253:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 254:src/main.cpp  ****             if(!tracked[slot].alive){
 255:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 256:src/main.cpp  ****                 ra[r]=true;break;
 257:src/main.cpp  ****             }
 258:src/main.cpp  ****         }
 259:src/main.cpp  ****     }
 260:src/main.cpp  **** }
