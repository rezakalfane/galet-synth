 420:src/main.cpp  **** // ŌöĆŌöĆ Voice cycling ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 421:src/main.cpp  **** // Voices with no_cycle = true are skipped by the FSR-hold gesture. These helpers
 422:src/main.cpp  **** // give the count of cyclable voices and the 1-based position of an index among
 423:src/main.cpp  **** // them (used for the LED flash count and the serial display).
 424:src/main.cpp  **** static int cycle_total(){
 425:src/main.cpp  ****     int n = 0;
 426:src/main.cpp  ****     for(int i = 0; i < NUM_VOICES; i++) if(!VOICES[i].no_cycle) n++;
 427:src/main.cpp  ****     return n;
 428:src/main.cpp  **** }
 429:src/main.cpp  **** static int cycle_pos(int idx){
 430:src/main.cpp  ****     int p = 0;
 431:src/main.cpp  ****     for(int i = 0; i <= idx && i < NUM_VOICES; i++) if(!VOICES[i].no_cycle) p++;
 432:src/main.cpp  ****     return p;
 433:src/main.cpp  **** }
 434:src/main.cpp  **** // Next cyclable voice index after `idx` (wraps). Falls back to idx if none.
 435:src/main.cpp  **** static int cycle_next(int idx){
 436:src/main.cpp  ****     for(int step = 1; step <= NUM_VOICES; step++){
 437:src/main.cpp  ****         int n = (idx + step) % NUM_VOICES;
 438:src/main.cpp  ****         if(!VOICES[n].no_cycle) return n;
 439:src/main.cpp  ****     }
 440:src/main.cpp  ****     return idx;
 441:src/main.cpp  **** }
