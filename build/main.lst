 598:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 599:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 600:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 601:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 602:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 603:src/main.cpp  **** }
