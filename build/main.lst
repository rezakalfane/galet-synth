 251:src/voice.h   **** // ŌöĆŌöĆ Voice 9: kick drum (noise-driven) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 252:src/voice.h   **** //   A deep, punchy thud ŌĆö PLAY IT BY TAPPING. A low sine body with a sub-octave
 253:src/voice.h   **** //   for weight and a quiet octave "click" for beater attack; a whisper of noise
 254:src/voice.h   **** //   adds beater texture. Very closed dark filter + a little drive keep it round
 255:src/voice.h   **** //   and punchy. Instant attack, short tail. Finger-1 position tunes the kick.
 256:src/voice.h   **** //   A pitch envelope (start 2 oct up, drop in 45 ms) gives the classic "boom".
 257:src/voice.h   **** static constexpr Voice VOICE_KICK = {
 258:src/voice.h   ****     "Kick",
 259:src/voice.h   ****     30.0f, 80.0f, 0.98083f,     // 30ŌĆō80 Hz, ln(2.67) ŌĆö deep, position tunes the kick
 260:src/voice.h   ****     1.0f,    0.55f, WAVE_SINE,   // osc1  ŌĆö deep sine body
 261:src/voice.h   ****     2.0f,    0.10f, WAVE_SINE,   // osc2  ŌĆö octave "click" for attack punch
 262:src/voice.h   ****     0.5f,    0.15f, WAVE_SINE,   // sub   ŌĆö sub-octave rumble
 263:src/voice.h   ****     2.0f,    0.0f,  WAVE_SINE,   // oct   ŌĆö off
 264:src/voice.h   ****     false,                       // osc2 is a fixed ratio, not finger-2 detune
 265:src/voice.h   ****     3.0f, 2.0f, 0.20f,           // very closed/dark ŌĆö round; tiny pressure sweep
 266:src/voice.h   ****     1.8f,                        // drive ŌĆö punch and saturation
 267:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 268:src/voice.h   ****     0.08f, 0.5f, 1.0f, 0.0f, 0.0f, 1.0f, 160.0f, 5.0f,  // soft beater click, instant, short
 269:src/voice.h   ****     // pitch_env_oct, pitch_env_ms ŌĆö the kick "boom": start 2 oct up, drop in 45 ms
 270:src/voice.h   ****     2.0f, 45.0f,
 271:src/voice.h   ****     0.0f,        // noise_hp
 272:src/voice.h   ****     true,        // no_cycle ŌĆö reached via the Drums MultiVoice
 273:src/voice.h   ****     0.85f,       // vel_sens ŌĆö dynamic taps
 274:src/voice.h   ****     400.0f        // retrig_ms ŌĆö dedupe strike + cap repeat rate
 275:src/voice.h   **** };
 276:src/voice.h   **** 
 277:src/voice.h   **** // ŌöĆŌöĆ Voice 10: snare (noise-driven) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 278:src/voice.h   **** //   The bright, noisy cousin of the Tom ŌĆö PLAY IT BY TAPPING. Broadband noise
 279:src/voice.h   **** //   (the "wires" rattle) dominates over two tonal modes (body + a 1.8├Ś ring); a
 280:src/voice.h   **** //   wide-open filter keeps it crisp and cracking. Instant attack, short tail,
 281:src/voice.h   **** //   and a quick subtle pitch snap (0.7 oct in 30 ms) for the hit. Harder presses
 282:src/voice.h   **** //   open it further. Finger-1 position tunes the drum.
 283:src/voice.h   **** static constexpr Voice VOICE_SNARE = {
 284:src/voice.h   ****     "Snare",
 285:src/voice.h   ****     150.0f, 500.0f, 1.20397f,   // 150ŌĆō500 Hz, ln(3.33) ŌĆö snare tuning range
 286:src/voice.h   ****     1.0f,    0.15f, WAVE_SINE,   // osc1  ŌĆö body (lower mode)
 287:src/voice.h   ****     1.8f,    0.12f, WAVE_TRI,    // osc2  ŌĆö upper mode/ring (triangle = more harmonics)
 288:src/voice.h   ****     0.5f,    0.05f, WAVE_SINE,   // sub   ŌĆö slight body weight
 289:src/voice.h   ****     2.0f,    0.0f,  WAVE_SINE,   // oct   ŌĆö off
 290:src/voice.h   ****     false,                       // osc2 is a fixed ratio, not finger-2 detune
 291:src/voice.h   ****     18.0f, 4.0f, 0.30f,          // wide open & bright ŌĆö the noise rattle cracks through
 292:src/voice.h   ****     1.5f,                        // drive ŌĆö snap
 293:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
ARM GAS  /tmp/claude-502/cc3JAR3K.s 			page 224


 294:src/voice.h   ****     0.72f, 0.3f, 1.0f, 0.0f, 0.10f, 1.0f, 140.0f, 5.0f,  // noise-dominant rattle (trimmed ~15%)
 295:src/voice.h   ****     // pitch_env_oct, pitch_env_ms ŌĆö quick subtle snap
 296:src/voice.h   ****     0.7f, 30.0f,
 297:src/voice.h   ****     0.0f,        // noise_hp
 298:src/voice.h   ****     true,        // no_cycle ŌĆö reached via the Drums MultiVoice
 299:src/voice.h   ****     0.85f,       // vel_sens ŌĆö dynamic taps
 300:src/voice.h   ****     400.0f       // retrig_ms ŌĆö dedupe strike + cap repeat rate
