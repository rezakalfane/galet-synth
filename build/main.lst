 340:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 341:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 342:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 343:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
