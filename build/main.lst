 202:src/main.cpp  **** // ‚îÄ‚îÄ Voice 5: screaming aggressive lead ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 203:src/main.cpp  **** //   Detuned sawtooth stack (root + a hair-sharp twin + octave) for a thick,
 204:src/main.cpp  **** //   buzzing supersaw bite, pushed up into a cutting register. Heavy drive and a
 205:src/main.cpp  **** //   very high filter resonance make the cutoff whistle and scream as pressure
 206:src/main.cpp  **** //   sweeps it wide open. Finger-2 pressure piles on ring-mod + wavefold for
 207:src/main.cpp  **** //   extra snarl. Loud and nasty ‚Äî the output soft-clip keeps it from blowing up.
 208:src/main.cpp  **** static constexpr Voice VOICE_SCREAM = {
 209:src/main.cpp  ****     "Scream",
 210:src/main.cpp  ****     90.0f, 720.0f, 2.07944f,   // 90‚Äì720 Hz, ln(8) ‚Äî high, cutting register
 211:src/main.cpp  ****     1.0f,    0.42f, WAVE_SAW,   // osc1  ‚Äî saw root
 212:src/main.cpp  ****     1.008f,  0.38f, WAVE_SAW,   // osc2  ‚Äî slightly sharp twin ‚Üí thick beating buzz
 213:src/main.cpp  ****     0.5f,    0.20f, WAVE_SAW,   // sub   ‚Äî a little weight underneath
 214:src/main.cpp  ****     2.0f,    0.30f, WAVE_SAW,   // oct   ‚Äî octave up for bright, cutting scream
 215:src/main.cpp  ****     false,                      // osc2 is a fixed detune, not finger-2 controlled
 216:src/main.cpp  ****     3.0f, 11.0f, 0.90f,         // bright base + wide sweep + near-self-osc resonance
 217:src/main.cpp  ****     4.0f,                       // heavy drive ‚Äî saturated and aggressive
 218:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 219:src/main.cpp  ****     0.05f, 1.0f, 2.5f, 0.40f, 0.30f, 2.0f, 200.0f, 35.0f // hiss + inharmonic metallic ring-mod
 220:src/main.cpp  **** };
