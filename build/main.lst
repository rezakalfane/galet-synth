 421:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 422:src/main.cpp  **** {
 423:src/main.cpp  ****     bool ra[2]={false,false};
 424:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 425:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 426:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 427:src/main.cpp  ****         for(int r=0;r<n;r++){
 428:src/main.cpp  ****             if(ra[r])continue;
 429:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 430:src/main.cpp  ****             if(c<best){best=c;br=r;}
 431:src/main.cpp  ****         }
 432:src/main.cpp  ****         if(br>=0){
 433:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 434:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 435:src/main.cpp  ****             ra[br]=true;
 436:src/main.cpp  ****         } else tracked[slot].alive=false;
 437:src/main.cpp  ****     }
 438:src/main.cpp  ****     for(int r=0;r<n;r++){
 439:src/main.cpp  ****         if(ra[r])continue;
 440:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 441:src/main.cpp  ****             if(!tracked[slot].alive){
 442:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 443:src/main.cpp  ****                 ra[r]=true;break;
 444:src/main.cpp  ****             }
 445:src/main.cpp  ****         }
 446:src/main.cpp  ****     }
