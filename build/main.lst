 419:src/main.cpp  ****     // Fire one drum (bank index `bankidx`) on hit-pool slot `slot` at full
 420:src/main.cpp  ****     // velocity, at its natural low pitch. Used by the kit preview below.
 421:src/main.cpp  ****     auto preview_drum = [&](int slot, int bankidx){
 422:src/main.cpp  ****         const Voice& V = g_bank[bankidx];
 423:src/main.cpp  ****         float freq   = V.freq_low;
 424:src/main.cpp  ****         // Bright enough that the noisy drums (snare/hat) crack through; the
 425:src/main.cpp  ****         // tonal drums stay dark via their own low cutoff_mult.
 426:src/main.cpp  ****         float cutoff = clampf(freq * V.cutoff_mult * 3.0f, 60.0f, 16000.0f);
 427:src/main.cpp  ****         float drive  = 1.0f + 0.6f * V.drive_max;
 428:src/main.cpp  ****         drum_trigger(g_hits[slot], bankidx, freq, 0.85f, cutoff, drive, hw.AudioSampleRate());
 429:src/main.cpp  ****         // ONE-SHOT: jump to full amp and immediately ungate so the hit decays on
 430:src/main.cpp  ****         // its own. A preview has no finger-lift to clear the gate, so leaving it
 431:src/main.cpp  ****         // gated would sustain the drum's noise forever (the "100% noise when Drums
 432:src/main.cpp  ****         // selected" bug). attack_ms (~1 ms) makes skipping the ramp inaudible.
 433:src/main.cpp  ****         g_hits[slot].amp  = g_hits[slot].amp_tgt;
 434:src/main.cpp  ****         g_hits[slot].gate = false;
 435:src/main.cpp  ****     };
