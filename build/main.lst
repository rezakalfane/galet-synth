 745:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
 746:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 747:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 748:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 749:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 8451              		.loc 6 749 5 view .LVU2449
 750:src/main.cpp  ****         uint32_t start = System::GetNow();
