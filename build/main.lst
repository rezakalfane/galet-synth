 235:src/main.cpp  ****     false,                      // osc2 is a fixed fifth, not finger-2 detune
 236:src/main.cpp  ****     1.0f, 2.0f, 0.30f,          // cutoff sits near the fundamental, tiny sweep, low res
 237:src/main.cpp  ****     0.5f,                       // minimal drive ‚Äî stays clean and round
 238:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 239:src/main.cpp  ****     0.0f, 0.6f, 1.0f, 0.0f, 0.0f, 10.0f, 500.0f, 30.0f   // soft, long tail, less keytrack, clean
