 221:src/main.cpp  ****     2.0f,    0.28f, WAVE_SINE,  // oct   ŌĆö octave-up air (4')
 222:src/main.cpp  ****     false,                      // osc2 is a fixed chorus detune, not finger-2 detune
 223:src/main.cpp  ****     2.0f, 5.0f, 0.20f,          // mostly-open clean filter, gentle pressure lift, low res
 224:src/main.cpp  ****     0.8f,                       // light drive ŌĆö pressure adds subtle warmth, stays pure
 225:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
