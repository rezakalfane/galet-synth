 328:src/main.cpp  ****     mpr_write(REG_CONFIG1,0xF0);  // FFI=34 | CDC=48uA
 329:src/main.cpp  ****     mpr_write(REG_CONFIG2,0x4C);  // CDT=4us | SFI=18 | ESI=1ms
