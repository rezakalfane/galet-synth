 360:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 361:src/main.cpp  **** {
 362:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 363:src/main.cpp  ****     for(int i=s;i<=e;i++){
 364:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 365:src/main.cpp  ****         sw+=w;swx+=w*i;
 366:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 367:src/main.cpp  ****     }
 368:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 369:src/main.cpp  ****     if(sw==0)return -1;
 370:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 371:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 372:src/main.cpp  ****     return p;
 373:src/main.cpp  **** }
