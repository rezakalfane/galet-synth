 620:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 621:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 622:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 5535              		.loc 6 622 5 view .LVU1611
 623:src/main.cpp  ****         uint32_t start = System::GetNow();
