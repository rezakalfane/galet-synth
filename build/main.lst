 667:src/voice.h   **** // ŌöĆŌöĆ Voice 11: hi-hat (noise-driven) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 668:src/voice.h   **** //   A crisp "tss" ŌĆö PLAY IT BY TAPPING. Almost pure high-frequency noise through
 669:src/voice.h   **** //   a wide-open filter, with three inharmonic square partials for metallic edge
 670:src/voice.h   **** //   and no low end. Instant attack and a very short ~55 ms tail = a tight closed
 671:src/voice.h   **** //   hat. Finger-1 position tunes the metallic pitch. (Raise release_ms for an
 672:src/voice.h   **** //   open-hat feel.)
 673:src/voice.h   **** static constexpr Voice VOICE_HIHAT = {
 674:src/voice.h   ****     "HiHat",
 675:src/voice.h   ****     // FREQUENCY RANGE
 676:src/voice.h   ****     4000.0f,
 677:src/voice.h   ****     11000.0f,
 678:src/voice.h   ****     1.01160f,            // 4000ŌĆō11000 Hz, ln(2.75) ŌĆö metallic edge pitch
 679:src/voice.h   ****     // OSCILLATOR STACK
 680:src/voice.h   ****     1.0f,
 681:src/voice.h   ****     0.10f,
 682:src/voice.h   ****     WAVE_SQUARE,         // osc1  ŌĆö quiet metallic edge (the tss noise leads)
 683:src/voice.h   ****     // SECONDARY OSCILLATOR
 684:src/voice.h   ****     1.68f,
 685:src/voice.h   ****     0.08f,
ARM GAS  /tmp/claude-502/cc2bPfvH.s 			page 50


 686:src/voice.h   ****     WAVE_SQUARE,         // osc2  ŌĆö inharmonic metallic partial
 687:src/voice.h   ****     // SUB OSCILLATOR
 688:src/voice.h   ****     0.5f,
 689:src/voice.h   ****     0.0f,
 690:src/voice.h   ****     WAVE_SINE,           // sub   ŌĆö off (no low end on a hat)
 691:src/voice.h   ****     // OCTAVE OSCILLATOR
 692:src/voice.h   ****     2.0f,
 693:src/voice.h   ****     0.06f,
 694:src/voice.h   ****     WAVE_SQUARE,         // oct   ŌĆö high partial (2.0├Ś keeps it under Nyquist)
 695:src/voice.h   ****     // FILTER
 696:src/voice.h   ****     false,               // osc2 is a fixed ratio, not finger-2 detune
 697:src/voice.h   ****     25.0f,
 698:src/voice.h   ****     2.0f,
 699:src/voice.h   ****     0.20f,               // wide open
 700:src/voice.h   ****     // DRIVE
 701:src/voice.h   ****     1.2f,                // light drive
 702:src/voice.h   ****     // NOISE
 703:src/voice.h   ****     0.80f,               // noise level ŌĆö noise-led
 704:src/voice.h   ****     0.2f,                // keytrack
 705:src/voice.h   ****     1.0f,                // ringmod ratio
 706:src/voice.h   ****     0.0f,                // ringmod max
 707:src/voice.h   ****     0.05f,               // fold max
 708:src/voice.h   ****     1.0f,                // attack ŌĆö instant
 709:src/voice.h   ****     160.0f,              // release ŌĆö sizzly tail
 710:src/voice.h   ****     3.0f,                // glide
 711:src/voice.h   ****     // PITCH ENVELOPE
 712:src/voice.h   ****     0.0f,                // pitch env octaves (off)
 713:src/voice.h   ****     0.0f,                // pitch env time
 714:src/voice.h   ****     // NOISE TONE
 715:src/voice.h   ****     1.0f,                // noise_hp ŌĆö high-passed bright "tsss"
 716:src/voice.h   ****     // CYCLING
 717:src/voice.h   ****     true,                // no_cycle ŌĆö reached via the Drums MultiVoice
 718:src/voice.h   ****     // VELOCITY
 719:src/voice.h   ****     0.85f,               // vel_sens ŌĆö dynamic taps
 720:src/voice.h   ****     // RETRIGGER
 721:src/voice.h   ****     400.0f               // retrig_ms ŌĆö dedupe strike + cap repeat rate
 722:src/voice.h   ****     // PITCH QUANTIZE
 723:src/voice.h   **** };
