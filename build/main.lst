 386:src/main.cpp  ****     auto trigger_drum = [&](int s, int32_t pos, int32_t pressure){
 387:src/main.cpp  ****         float p    = clampf((float)pos / 1000.0f, 0.0f, 1.0f);
 388:src/main.cpp  ****         int   zone = (int)(p * 4.0f); if(zone > 3) zone = 3;
 389:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 390:src/main.cpp  ****         const Voice& V = VOICES[vidx];
 391:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 392:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 393:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
 394:src/main.cpp  ****         float freq = V.freq_low * MULTI_INTERVALS[step];
 395:src/main.cpp  ****         float v    = FIX_DRUM ? 1.0f : clampf((float)pressure / 100.0f, 0.0f, 1.0f);
 396:src/main.cpp  ****         float amp  = 0.72f * ((1.0f - V.vel_sens) + V.vel_sens * v);
 397:src/main.cpp  ****         // Cutoff from velocity, same curve as the mono path.
 398:src/main.cpp  ****         float cutoff_oct = V.cutoff_oct_max * smootherstep_f(v);
 399:src/main.cpp  ****         float oa = cutoff_oct * 0.6931f;
