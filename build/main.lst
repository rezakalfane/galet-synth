 487:src/voice.h   **** // ŌöĆŌöĆ Voice 6: electric guitar power chord ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 488:src/voice.h   **** //   A driven sawtooth power chord ŌĆö each note is a root + fixed perfect fifth +
 489:src/voice.h   **** //   octave-up jangle over a saw octave-down body, so it plays as a chord like a
 490:src/voice.h   **** //   rock guitar. Heavy-ish drive adds overdrive crunch; the filter sits a touch
 491:src/voice.h   **** //   above the fundamental and sweeps wide open with pressure (dig in = bright,
 492:src/voice.h   **** //   pick-attack bite), with resonance for a vocal amp "quack". A fast pitch-env
 493:src/voice.h   **** //   "twang" + a little pick-grit noise on the onset, then amp decay-to-silence
 494:src/voice.h   **** //   (decay_ms/sustain below) so each note plucks and rings out over ~1.2 s while
 495:src/voice.h   **** //   held ŌĆö like a struck string, not an organ. Quantized to a major scale so
 496:src/voice.h   **** //   tapped chords land in key. For a BASS guitar instead: drop freq_low/high ~┬Į,
 497:src/voice.h   **** //   cut drive to ~1.5, use WAVE_TRI, and raise `sustain` if you want it to hold.
 498:src/voice.h   **** static constexpr Voice VOICE_GUITAR = {
 499:src/voice.h   ****     "Guitar",
 500:src/voice.h   ****     // FREQUENCY RANGE
 501:src/voice.h   ****     80.0f,
 502:src/voice.h   ****     320.0f,
 503:src/voice.h   ****     1.38629f,            // 80ŌĆō320 Hz, ln(4) ŌĆö E2-ish up two octaves
 504:src/voice.h   ****     // OSCILLATOR STACK
