 213:src/main.cpp  **** int detect_raw(int32_t* delta,Finger out[2])
 214:src/main.cpp  **** {
 215:src/main.cpp  ****     out[0].active=out[1].active=false;
 216:src/main.cpp  ****     int pka=0;int32_t da=0;
 217:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(delta[i]>da){da=delta[i];pka=i;}
 218:src/main.cpp  ****     if(da<TOUCH_THRESHOLD)return 0;
 219:src/main.cpp  ****     int ws=pka-2;if(ws<0)ws=0;int we=pka+2;if(we>=N_CH)we=N_CH-1;
 220:src/main.cpp  ****     int32_t pa;int pca;
 221:src/main.cpp  ****     int32_t posa=centroid_window(delta,ws,we,&pa,&pca);
 222:src/main.cpp  ****     out[0]={true,posa,pressure_pct(pa,pca),pca,pa};
 223:src/main.cpp  **** 
 224:src/main.cpp  ****     int32_t d2[N_CH];
 225:src/main.cpp  ****     int ss=pka-2;if(ss<0)ss=0;int se=pka+2;if(se>=N_CH)se=N_CH-1;
 226:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
 227:src/main.cpp  ****     int pkb=0;int32_t db=0;
 228:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(d2[i]>db){db=d2[i];pkb=i;}
 229:src/main.cpp  ****     int sep=pkb-pka;if(sep<0)sep=-sep;
 230:src/main.cpp  ****     if(db<TOUCH_THRESHOLD||sep<MIN_FINGER_SEP)return 1;
 231:src/main.cpp  ****     int ws2=pkb-2;if(ws2<0)ws2=0;int we2=pkb+2;if(we2>=N_CH)we2=N_CH-1;
 232:src/main.cpp  ****     int32_t pb;int pcb;
 233:src/main.cpp  ****     int32_t posb=centroid_window(d2,ws2,we2,&pb,&pcb);
 234:src/main.cpp  ****     out[1]={true,posb,pressure_pct(pb,pcb),pcb,pb};
 235:src/main.cpp  ****     return 2;
 236:src/main.cpp  **** }
