 565:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 566:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 567:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 568:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 569:src/main.cpp  ****             g_led3_duty = led3;
 570:src/main.cpp  **** 
 571:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 572:src/main.cpp  ****             if(!calibrated) {
 573:src/main.cpp  ****                 acc += hw.adc.Get(0);
 574:src/main.cpp  ****                 n++;
 575:src/main.cpp  ****                 if(elapsed >= 2000) {
 576:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 577:src/main.cpp  ****                     calibrated = true;
 578:src/main.cpp  ****                 }
 579:src/main.cpp  ****             }
