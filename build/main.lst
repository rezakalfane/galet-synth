 689:src/main.cpp  **** // ŌöĆŌöĆ Oscillator waveforms (phase ph in [0,1) ŌåÆ sample in [-1,1]) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 690:src/main.cpp  **** // Triangle wave
 691:src/main.cpp  **** static inline float tri(float ph){
 692:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 693:src/main.cpp  **** }
 694:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ŌĆö matches sin(2ŽĆ┬Ęph).
 695:src/main.cpp  **** static inline float osc_sine(float ph){
 696:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 697:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -ŽĆ..ŽĆ (angle shifted by ŽĆ)
 698:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 699:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
ARM GAS  /tmp/claude-502/ccETDxsq.s 			page 21


 700:src/main.cpp  ****     return -y;                                 // undo the ŽĆ shift: sin(x+ŽĆ) = -sin(x)
 701:src/main.cpp  **** }
 702:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 703:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 704:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 705:src/main.cpp  **** 
 706:src/main.cpp  **** // Dispatch on a per-oscillator waveform (runtime, since the active voice can be
 707:src/main.cpp  **** // switched live). A small jump table ŌĆö cheap at audio rate on the H750.
 708:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 709:src/main.cpp  ****     switch(w){
 710:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 711:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 712:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 713:src/main.cpp  ****         case WAVE_TRI:
 714:src/main.cpp  ****         default:          return tri(ph);
 715:src/main.cpp  ****     }
 716:src/main.cpp  **** }
 717:src/main.cpp  **** 
 718:src/main.cpp  **** // Moog 4-pole ladder
 719:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 720:src/main.cpp  **** {
 721:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 722:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 723:src/main.cpp  ****     float k  = 3.8f*res;
 724:src/main.cpp  ****     float fb = k*s_flt[3];
 725:src/main.cpp  ****     float x  = in - fb;
 726:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 727:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 728:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 729:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 730:src/main.cpp  ****     return s_flt[3];
 731:src/main.cpp  **** }
 732:src/main.cpp  **** 
 733:src/main.cpp  **** // Wavefolder distortion
 734:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 735:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 736:src/main.cpp  **** static inline float wavefold(float in, float amount)
 737:src/main.cpp  **** {
 738:src/main.cpp  ****     if(amount < 0.01f) return in;
 739:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 740:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 741:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 742:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 743:src/main.cpp  ****     float x = driven;
 744:src/main.cpp  ****     // 2 passes of folding for richness
 745:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 746:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 747:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 748:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 749:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 750:src/main.cpp  ****     }
 751:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 752:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 753:src/main.cpp  **** }
