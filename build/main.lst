1035:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
1036:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
1037:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
1038:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
1039:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
