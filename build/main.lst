 889:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
 890:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 891:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 892:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 893:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 6569              		.loc 6 893 5 view .LVU1904
 894:src/main.cpp  ****         uint32_t start = System::GetNow();
