 541:src/main.cpp  ****     mpr_write(REG_ECR,0x00);
 542:src/main.cpp  ****     mpr_write(REG_MHDR,0x01);mpr_write(REG_NHDR,0x01);
 543:src/main.cpp  ****     mpr_write(REG_NCLR,0x10);mpr_write(REG_FDLR,0x20);
 544:src/main.cpp  ****     mpr_write(REG_MHDF,0x01);mpr_write(REG_NHDF,0x01);
 545:src/main.cpp  ****     mpr_write(REG_NCLF,0x10);mpr_write(REG_FDLF,0x20);
 546:src/main.cpp  ****     mpr_write(REG_NHDT,0x00);mpr_write(REG_NCLT,0x00);mpr_write(REG_FDLT,0x00);
 547:src/main.cpp  ****     for(uint8_t ch=0;ch<12;ch++){mpr_write(0x41+ch*2,4);mpr_write(0x42+ch*2,2);}
 548:src/main.cpp  ****     mpr_write(REG_DEBOUNCE,0x11);
 549:src/main.cpp  ****     mpr_write(REG_CONFIG1,0xF0);  // FFI=34 | CDC=48uA
 550:src/main.cpp  ****     mpr_write(REG_CONFIG2,0x4C);  // CDT=4us | SFI=18 | ESI=1ms
 551:src/main.cpp  ****     mpr_write(REG_ECR,0x8C);
 552:src/main.cpp  ****     System::Delay(100);
 553:src/main.cpp  ****     uint8_t ecr=0;mpr_read(REG_ECR,&ecr,1);
 554:src/main.cpp  ****     return(ecr==0x8C);
 555:src/main.cpp  **** }
