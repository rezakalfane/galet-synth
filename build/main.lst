1489:src/main.cpp  ****         // ŌöĆŌöĆ LED targets + slew ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1490:src/main.cpp  ****         // Three-LED position indicator. Linear "tents" hand off cleanly:
1491:src/main.cpp  ****         //   LED1 (DAC1, middle)       ŌåÆ 1 - 2*|p - 0.5|
1492:src/main.cpp  ****         //   LED2 (DAC2, pos 0 end)    ŌåÆ max(0, 1 - 2*p)
1493:src/main.cpp  ****         //   LED3 (PWM A0, pos 1 end)  ŌåÆ max(0, 2*p - 1)
1494:src/main.cpp  ****         // Fourth-root curve (gamma=0.25) keeps each LED above its forward-voltage
1495:src/main.cpp  ****         // floor at the handoff points (50% raw ŌåÆ ~84% drive). Pressure adds a
1496:src/main.cpp  ****         // subtle ~75%ŌåÆ100% intensity scale.
1497:src/main.cpp  ****         float led1_target = 0.0f, led2_target = 0.0f, led3_target = 0.0f;
1498:src/main.cpp  ****         if(f1_on) {
1499:src/main.cpp  ****             float p01      = clampf((float)tracked[0].pos / 1000.0f, 0.0f, 1.0f);
1500:src/main.cpp  ****             float pr01     = clampf((float)tracked[0].pressure / 100.0f, 0.0f, 1.0f);
1501:src/main.cpp  ****             float prs_mult = 0.75f + 0.25f * pr01;
1502:src/main.cpp  ****             float l1_raw   = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
1503:src/main.cpp  ****             float l3_raw   = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
1504:src/main.cpp  ****             float l2_raw   = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
1505:src/main.cpp  ****             led1_target    = sqrtf(sqrtf(l2_raw)) * prs_mult;  // middle tent
1506:src/main.cpp  ****             led2_target    = sqrtf(sqrtf(l1_raw)) * prs_mult;  // pos 0 ramp
1507:src/main.cpp  ****             led3_target    = sqrtf(sqrtf(l3_raw)) * prs_mult * LED3_INTENSITY;
1508:src/main.cpp  ****         }
1509:src/main.cpp  ****         // Snap on touch onset so the LEDs respond instantly to the initial touch;
1510:src/main.cpp  ****         // smooth during sustained touch and on lift-off.
1511:src/main.cpp  ****         if(f1_on && !f1_was_on) {
