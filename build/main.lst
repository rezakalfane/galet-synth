 441:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 442:src/main.cpp  **** {
 443:src/main.cpp  ****     bool ra[2]={false,false};
 444:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 445:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 446:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 447:src/main.cpp  ****         for(int r=0;r<n;r++){
 448:src/main.cpp  ****             if(ra[r])continue;
 449:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 450:src/main.cpp  ****             if(c<best){best=c;br=r;}
 451:src/main.cpp  ****         }
 452:src/main.cpp  ****         if(br>=0){
 453:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 454:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 455:src/main.cpp  ****             ra[br]=true;
 456:src/main.cpp  ****         } else tracked[slot].alive=false;
 457:src/main.cpp  ****     }
 458:src/main.cpp  ****     for(int r=0;r<n;r++){
 459:src/main.cpp  ****         if(ra[r])continue;
 460:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 461:src/main.cpp  ****             if(!tracked[slot].alive){
 462:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 463:src/main.cpp  ****                 ra[r]=true;break;
 464:src/main.cpp  ****             }
 465:src/main.cpp  ****         }
