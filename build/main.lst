 149:src/main.cpp  **** // ŌöĆŌöĆ Polyphonic drum engine (Drums MultiVoice only) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 150:src/main.cpp  **** // A pool of independent drum voices, one per finger. Each is a self-contained
 151:src/main.cpp  **** // slice of the synth (oscillators + noise + ladder filter + amp & pitch
 152:src/main.cpp  **** // envelopes) with its own state, so up to POLY drums sound at once. Params are
 153:src/main.cpp  **** // latched at the tap (drum, pitch, velocity-scaled level, cutoff, drive); the
 154:src/main.cpp  **** // note plays its attack while the finger is down and releases when it lifts.
 155:src/main.cpp  **** static constexpr int POLY = MAX_FINGERS;
 156:src/main.cpp  **** struct DrumHit {
 157:src/main.cpp  ****     bool  active=false, gate=false;
 158:src/main.cpp  ****     int   vidx=9;
 159:src/main.cpp  ****     float freq=80.0f, amp_tgt=0.0f, cutoff=200.0f, drive=1.0f;
 160:src/main.cpp  ****     float ph1=0,ph2=0,phs=0,pho=0;
 161:src/main.cpp  ****     float amp=0.0f, pmult=1.0f, noise_lp=0.0f;
 162:src/main.cpp  ****     float lp_state=0.0f, lp_coeff=1.0f;   // per-drum 1-pole lowpass
 163:src/main.cpp  ****     float atk_c=0, rel_c=0, penv_c=0, penv_start=1.0f;
 164:src/main.cpp  **** };
 165:src/main.cpp  **** static DrumHit g_hits[POLY];
 166:src/main.cpp  **** 
 167:src/main.cpp  **** static void drum_trigger(DrumHit& h, int vidx, float freq, float amp_tgt,
 168:src/main.cpp  ****                          float cutoff, float drive, float sr)
 169:src/main.cpp  **** {
 170:src/main.cpp  ****     const Voice& V = VOICES[vidx];
 171:src/main.cpp  ****     h.active=true; h.gate=true; h.vidx=vidx;
 172:src/main.cpp  ****     h.freq=freq; h.amp_tgt=amp_tgt; h.cutoff=cutoff; h.drive=drive;
 173:src/main.cpp  ****     h.ph1=h.ph2=h.phs=h.pho=0.0f;
 174:src/main.cpp  ****     h.amp=0.0f; h.noise_lp=0.0f;
 175:src/main.cpp  ****     // 1-pole lowpass coefficient from the (latched) cutoff: a = 1 - e^(-2ŽĆ┬Ęfc/sr).
 176:src/main.cpp  ****     h.lp_state = 0.0f;
 177:src/main.cpp  ****     h.lp_coeff = clampf(1.0f - expf(-6.2831853f * cutoff / sr), 0.0f, 1.0f);
 178:src/main.cpp  ****     h.atk_c      = ms_to_coeff(V.attack_ms,    sr);
 179:src/main.cpp  ****     h.rel_c      = ms_to_coeff(V.release_ms,   sr);
 180:src/main.cpp  ****     h.penv_c     = ms_to_coeff(V.pitch_env_ms, sr);
 181:src/main.cpp  ****     h.penv_start = exp2f(V.pitch_env_oct);
 182:src/main.cpp  ****     h.pmult      = h.penv_start;
 183:src/main.cpp  **** }
 184:src/main.cpp  **** 
 185:src/main.cpp  **** static float drum_render(DrumHit& h, float sr)
 186:src/main.cpp  **** {
ARM GAS  /tmp/claude-502/ccxENaH3.s 			page 12


 187:src/main.cpp  ****     if(!h.active) return 0.0f;
 188:src/main.cpp  ****     const Voice& V = VOICES[h.vidx];
 189:src/main.cpp  ****     // Amp envelope: attack while gated, release on lift; free the slot when done.
 190:src/main.cpp  ****     float tgt = h.gate ? h.amp_tgt : 0.0f;
 191:src/main.cpp  ****     float c   = (tgt > h.amp) ? h.atk_c : h.rel_c;
 192:src/main.cpp  ****     h.amp = h.amp*c + tgt*(1.0f-c);
 193:src/main.cpp  ****     if(!h.gate && h.amp < 0.0004f){ h.active=false; return 0.0f; }
 194:src/main.cpp  ****     // Pitch envelope decays to 1.0.
 195:src/main.cpp  ****     h.pmult = 1.0f + (h.pmult - 1.0f) * h.penv_c;
 196:src/main.cpp  ****     float f = h.freq * h.pmult;
 197:src/main.cpp  ****     // Oscillators + noise
 198:src/main.cpp  ****     float mix = osc(h.ph1,V.osc1_wave)*V.osc1_level
 199:src/main.cpp  ****               + osc(h.ph2,V.osc2_wave)*V.osc2_level
 200:src/main.cpp  ****               + osc(h.phs,V.sub_wave )*V.sub_level
 201:src/main.cpp  ****               + osc(h.pho,V.oct_wave )*V.oct_level;
 202:src/main.cpp  ****     if(V.noise_level > 0.0f){
 203:src/main.cpp  ****         s_noise_rng ^= s_noise_rng<<13; s_noise_rng ^= s_noise_rng>>17; s_noise_rng ^= s_noise_rng<
 204:src/main.cpp  ****         float white  = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
 205:src/main.cpp  ****         h.noise_lp  += NOISE_HP_COEF * (white - h.noise_lp);
 206:src/main.cpp  ****         float bright = white - h.noise_lp;
 207:src/main.cpp  ****         mix += (white + (bright*2.0f - white)*V.noise_hp) * V.noise_level;
 208:src/main.cpp  ****     }
 209:src/main.cpp  ****     mix = fast_tanh(mix * h.drive);
 210:src/main.cpp  ****     // Per-drum 1-pole lowpass (cheap ŌĆö one multiply-add ŌĆö instead of the 4-pole
 211:src/main.cpp  ****     // Moog) at the drum's own cutoff: keeps Kick/Tom dark, Snare/Hat bright.
 212:src/main.cpp  ****     h.lp_state += h.lp_coeff * (mix - h.lp_state);
 213:src/main.cpp  ****     h.ph1 += f*V.osc1_ratio/sr; if(h.ph1>=1.0f)h.ph1-=1.0f;
 214:src/main.cpp  ****     h.ph2 += f*V.osc2_ratio/sr; if(h.ph2>=1.0f)h.ph2-=1.0f;
 215:src/main.cpp  ****     h.phs += f*V.sub_ratio /sr; if(h.phs>=1.0f)h.phs-=1.0f;
 216:src/main.cpp  ****     h.pho += f*V.oct_ratio /sr; if(h.pho>=1.0f)h.pho-=1.0f;
 217:src/main.cpp  ****     return fast_tanh(h.lp_state*1.3f) * h.amp;
 218:src/main.cpp  **** }
