  34:src/main.cpp  ****     int32_t voice_idx;
  35:src/main.cpp  ****     bool operator!=(const PersistSettings& o) const { return o.voice_idx != voice_idx; }
  36:src/main.cpp  **** };
  37:src/main.cpp  **** 
  38:src/main.cpp  **** // ŌöĆŌöĆ Pin / I2C config ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
  39:src/main.cpp  **** static constexpr Pin      SDA_PIN  = D12;
  40:src/main.cpp  **** static constexpr Pin      SCL_PIN  = D11;
  41:src/main.cpp  **** static constexpr uint8_t  MPR_ADDR = 0x5A;
  42:src/main.cpp  **** static constexpr uint32_t HP       = 5;
  43:src/main.cpp  **** static constexpr int      N_CH     = 12;
  44:src/main.cpp  **** 
  45:src/main.cpp  **** // ŌöĆŌöĆ Touch tuning ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  46:src/main.cpp  **** static constexpr int32_t  TOUCH_THRESHOLD    = 10;
  47:src/main.cpp  **** static constexpr int32_t  PRESSURE_MAX_REF[12] = {
  48:src/main.cpp  ****     42,35,34,34,34,34,
  49:src/main.cpp  ****     34,34,33,32,29,30
  50:src/main.cpp  **** };
  51:src/main.cpp  **** static constexpr int32_t  MIN_FINGER_SEP     = 4;
  52:src/main.cpp  **** static constexpr uint32_t REBASELINE_IDLE_MS = 2000;
  53:src/main.cpp  **** static constexpr int      REBASELINE_SAMPLES = 32;
  54:src/main.cpp  **** static constexpr int32_t  MAX_POS_JUMP       = 200;
  55:src/main.cpp  **** 
  56:src/main.cpp  **** // LED slew at ~60Hz touch loop. Closer to 1.0 = smoother/slower fade.
  57:src/main.cpp  **** // 0.0 = no smoothing (snap), 0.7 = ~80ms fade, 0.9 = ~250ms fade.
  58:src/main.cpp  **** static constexpr float    LED_SMOOTH         = 0.45f;
  59:src/main.cpp  **** // LED3 (software sigma-delta PWM on A0 / ADC0 / pin 22) max-brightness scale.
  60:src/main.cpp  **** static constexpr float    LED3_INTENSITY     = 0.1f;
  61:src/main.cpp  **** // Smoothing coefficient used for LED3 only when no finger is touching. Smaller
  62:src/main.cpp  **** // than LED_SMOOTH = faster fade-out on lift. 0.0 = instant snap to 0.
  63:src/main.cpp  **** static constexpr float    LED3_RELEASE_SMOOTH = 0.10f;
  64:src/main.cpp  **** 
  65:src/main.cpp  **** // ŌöĆŌöĆ Voices ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
  66:src/main.cpp  **** // A "Voice" bundles everything that defines a sound: the oscillator stack
  67:src/main.cpp  **** // (which pitches sound and at what level), the filter/drive character, and the
  68:src/main.cpp  **** // pitch range finger-1 sweeps across. Presets live in the VOICES[] bank below;
  69:src/main.cpp  **** // the active one is `g_voice_idx`, which the FSR-hold gesture cycles live. The
  70:src/main.cpp  **** // audio callback snapshots it once per block.
  71:src/main.cpp  **** 
  72:src/main.cpp  **** // Oscillator shape ŌĆö set per oscillator, so one voice can mix (e.g. saw root +
ARM GAS  /tmp/claude-502/ccqNkRH0.s 			page 10


  73:src/main.cpp  **** // square fifth + sine sub). SQUARE and SAW are naive (not band-limited) ŌĆö they
  74:src/main.cpp  **** // alias at high pitch, but on a low bass voice that just reads as rich harmonics
  75:src/main.cpp  **** // for the filter to chew.
  76:src/main.cpp  **** enum Waveform { WAVE_TRI, WAVE_SINE, WAVE_SQUARE, WAVE_SAW };
  77:src/main.cpp  **** 
  78:src/main.cpp  **** struct Voice {
  79:src/main.cpp  ****     const char* name;
  80:src/main.cpp  **** 
  81:src/main.cpp  ****     // Pitch range. Finger-1 position 0ŌĆō1000 maps exponentially across this.
  82:src/main.cpp  ****     float freq_low;
  83:src/main.cpp  ****     float freq_high;
  84:src/main.cpp  ****     float log_freq_ratio;   // = ln(freq_high / freq_low), precomputed (logf isn't constexpr)
  85:src/main.cpp  **** 
  86:src/main.cpp  ****     // Oscillator stack. Each oscillator's pitch = fundamental * ratio, and each
  87:src/main.cpp  ****     // has its own waveform. Set a level to 0 to silence an oscillator.
  88:src/main.cpp  ****     float osc1_ratio, osc1_level;  Waveform osc1_wave;   // primary
  89:src/main.cpp  ****     float osc2_ratio, osc2_level;  Waveform osc2_wave;   // second osc (see osc2_detune)
  90:src/main.cpp  ****     float sub_ratio,  sub_level;   Waveform sub_wave;    // weight below
  91:src/main.cpp  ****     float oct_ratio,  oct_level;   Waveform oct_wave;    // shimmer / chord top
  92:src/main.cpp  ****     bool  osc2_detune;              // true  ŌåÆ finger-2 detune controls osc2 pitch (lead)
  93:src/main.cpp  ****                                     // false ŌåÆ osc2 stays at osc2_ratio (e.g. a fixed 5th)
  94:src/main.cpp  **** 
  95:src/main.cpp  ****     // Filter character. Base cutoff = freq * cutoff_mult; pressure opens it
  96:src/main.cpp  ****     // by up to cutoff_oct_max octaves on top.
  97:src/main.cpp  ****     float cutoff_mult;
  98:src/main.cpp  ****     float cutoff_oct_max;
  99:src/main.cpp  ****     float resonance;
 100:src/main.cpp  **** 
 101:src/main.cpp  ****     // Drive ŌĆö pressure-controlled waveshaper gain added on top of 1.0.
 102:src/main.cpp  ****     float drive_max;
 103:src/main.cpp  **** 
 104:src/main.cpp  ****     // ŌöĆŌöĆ Extras (appended so existing field order stays stable) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 105:src/main.cpp  ****     float noise_level;     // white noise mixed into the oscillator stack (0 = none)
 106:src/main.cpp  ****     float keytrack;        // 0..1 ŌĆö how much the cutoff follows pitch (1 = full)
 107:src/main.cpp  ****     float ringmod_ratio;   // ring-mod carrier pitch ratio (1.0 = unison; non-int = bell/metallic)
 108:src/main.cpp  ****     float ringmod_max;     // max ring-mod wet from finger-2 pressure
 109:src/main.cpp  ****     float fold_max;        // max wavefold amount from finger-2 pressure
 110:src/main.cpp  ****     float attack_ms;       // amp envelope attack time
 111:src/main.cpp  ****     float release_ms;      // amp envelope + filter-close release time
 112:src/main.cpp  ****     float glide_ms;        // portamento (pitch glide) time
 113:src/main.cpp  **** 
 114:src/main.cpp  ****     // Pitch envelope ŌĆö a fast downward pitch sweep at note onset (kick "boom",
 115:src/main.cpp  ****     // zap, tom thump). Left at 0 (the default for voices that omit them) = off.
 116:src/main.cpp  ****     float pitch_env_oct;   // octaves the pitch starts ABOVE the note at onset (0 = none)
 117:src/main.cpp  ****     float pitch_env_ms;    // time the pitch sweep takes to settle to the note
 118:src/main.cpp  **** 
 119:src/main.cpp  ****     // Noise tone: 0 = full white noise ("shhh"), 1 = high-passed/bright ("tsss",
 120:src/main.cpp  ****     // for hi-hats/cymbals). Default 0 leaves the noise white. See NOISE_HP_COEF.
 121:src/main.cpp  ****     float noise_hp;
 122:src/main.cpp  **** 
 123:src/main.cpp  ****     // FSR-gesture cycling: true = skip this voice in the cycle (still reachable
 124:src/main.cpp  ****     // as the boot voice or via the Drums MultiVoice). Default false = in cycle.
 125:src/main.cpp  ****     // The raw drums set this so the gesture cycles instruments + Drums only.
 126:src/main.cpp  ****     bool no_cycle;
 127:src/main.cpp  **** 
 128:src/main.cpp  ****     // Velocity sensitivity 0..1: how much the onset hit strength (peak pressure
 129:src/main.cpp  ****     // in the first few ms) scales loudness. 0 = fixed loudness (default ŌĆö the
ARM GAS  /tmp/claude-502/ccqNkRH0.s 			page 11


 130:src/main.cpp  ****     // sustained instruments); ~0.85 on drums for accents/ghost notes. Loudness
 131:src/main.cpp  ****     // floor = (1 - vel_sens), so soft taps stay audible.
 132:src/main.cpp  ****     float vel_sens;
 133:src/main.cpp  **** 
 134:src/main.cpp  ****     // Re-attack speed on hold: minimum ms between bounce-retriggers (the cap on
 135:src/main.cpp  ****     // how fast a held finger can repeat by pulsing pressure). SMALLER = faster
 136:src/main.cpp  ****     // repeats allowed; LARGER = slower. 0 = off (only a full lift + re-tap
 137:src/main.cpp  ****     // retriggers). A full lift always retriggers regardless. Default 0 keeps the
 138:src/main.cpp  ****     // melodic voices free of accidental re-articulation; drums set a value.
 139:src/main.cpp  ****     float retrig_ms;
 140:src/main.cpp  **** };
 141:src/main.cpp  **** 
 142:src/main.cpp  **** // Perfect-fifth frequency ratio = 2^(7/12).
 143:src/main.cpp  **** static constexpr float RATIO_FIFTH = 1.49831f;
 144:src/main.cpp  **** 
 145:src/main.cpp  **** // ŌöĆŌöĆ Voice 0: the original glass-Moog lead ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 146:src/main.cpp  **** //   F1 posŌåÆpitch, F1 prsŌåÆcutoff+vibrato; F2 posŌåÆdetune, F2 prsŌåÆwavefold+ringmod.
 147:src/main.cpp  **** static constexpr Voice VOICE_LEAD = {
 148:src/main.cpp  ****     "Lead",
 149:src/main.cpp  ****     50.0f, 300.0f, 1.79176f,   // 50ŌĆō300 Hz, ln(6)
 150:src/main.cpp  ****     1.0f, 0.50f, WAVE_TRI,   // osc1  ŌĆö root
 151:src/main.cpp  ****     1.0f, 0.22f, WAVE_TRI,   // osc2  ŌĆö detune-controlled, ratio is just the base
 152:src/main.cpp  ****     0.5f, 0.18f, WAVE_TRI,   // sub   ŌĆö one octave below
 153:src/main.cpp  ****     2.0f, 0.15f, WAVE_TRI,   // oct   ŌĆö one octave above
 154:src/main.cpp  ****     true,          // osc2 follows finger-2 detune
 155:src/main.cpp  ****     0.3f, 12.0f, 0.75f,
 156:src/main.cpp  ****     2.5f,
 157:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 158:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.15f, 0.18f, 4.0f, 400.0f, 40.0f
 159:src/main.cpp  **** };
 160:src/main.cpp  **** 
 161:src/main.cpp  **** // ŌöĆŌöĆ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 162:src/main.cpp  **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
 163:src/main.cpp  **** //   so every note sounds as a power chord. Lower range, gentler filter, less
 164:src/main.cpp  **** //   drive ŌåÆ deep and round rather than bright and screaming.
 165:src/main.cpp  **** static constexpr Voice VOICE_BASS = {
 166:src/main.cpp  ****     "Bass",
 167:src/main.cpp  ****     40.0f, 160.0f, 1.38629f,   // 40ŌĆō160 Hz, ln(4) ŌĆö sits under the lead
 168:src/main.cpp  ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ŌĆö root
 169:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ŌĆö fixed perfect fifth (the power chord)
 170:src/main.cpp  ****     0.5f,        0.34f, WAVE_TRI,   // sub   ŌĆö extra weight for a round bottom
 171:src/main.cpp  ****     2.0f,        0.20f, WAVE_TRI,   // oct   ŌĆö top of the power chord
 172:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 173:src/main.cpp  ****     0.25f, 7.0f, 0.50f,   // darker: lower base cutoff, gentler sweep, less resonance
 174:src/main.cpp  ****     1.0f,                 // less drive ŌĆö keep it clean and round
 175:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 176:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.12f, 0.12f, 6.0f, 300.0f, 25.0f
 177:src/main.cpp  **** };
 178:src/main.cpp  **** 
 179:src/main.cpp  **** // ŌöĆŌöĆ Voice 2: open power-chord bass ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 180:src/main.cpp  **** //   Same chord stack as VOICE_BASS, but the filter starts brighter and sweeps
 181:src/main.cpp  **** //   much further with pressure ŌĆö light touch is still warm, hard press opens it
 182:src/main.cpp  **** //   wide. A touch more resonance and drive for presence as it opens.
 183:src/main.cpp  **** static constexpr Voice VOICE_BASS_OPEN = {
 184:src/main.cpp  ****     "OpenBass",
 185:src/main.cpp  ****     40.0f, 180.0f, 1.50408f,   // 40ŌĆō180 Hz, ln(4.5) ŌĆö a little more reach up top
 186:src/main.cpp  ****     1.0f,        0.45f, WAVE_TRI,   // osc1  ŌĆö root
ARM GAS  /tmp/claude-502/ccqNkRH0.s 			page 12


 187:src/main.cpp  ****     RATIO_FIFTH, 0.30f, WAVE_TRI,   // osc2  ŌĆö fixed perfect fifth (the power chord)
 188:src/main.cpp  ****     0.5f,        0.30f, WAVE_TRI,   // sub   ŌĆö slightly less so the openness reads
 189:src/main.cpp  ****     2.0f,        0.22f, WAVE_TRI,   // oct   ŌĆö top of the power chord
 190:src/main.cpp  ****     false,                // osc2 is a fixed fifth, not finger-2 detune
 191:src/main.cpp  ****     0.5f, 10.0f, 0.65f,   // brighter base + wider pressure sweep + more resonance
 192:src/main.cpp  ****     1.8f,                 // more drive ŌĆö grit comes in as you press
 193:src/main.cpp  ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 194:src/main.cpp  ****     0.0f, 1.0f, 1.0f, 0.15f, 0.15f, 5.0f, 350.0f, 25.0f
 195:src/main.cpp  **** };
 196:src/main.cpp  **** 
 197:src/main.cpp  **** // ŌöĆŌöĆ Voice 3: rich power-chord bass with mixed waveforms + huge filter sweep ŌöĆŌöĆŌöĆŌöĆ
 198:src/main.cpp  **** //   Mixed shapes for body: saw root (harmonic-rich), square fifth (hollow), a
 199:src/main.cpp  **** //   clean sine sub (tight low end), saw octave on top. Starts dark, then
 200:src/main.cpp  **** //   pressure opens the cutoff dramatically (13 octaves) with high resonance ŌĆö
 201:src/main.cpp  **** //   a vocal, acid-style "wow" as you press harder.
 202:src/main.cpp  **** static constexpr Voice VOICE_BASS_RICH = {
 203:src/main.cpp  ****     "RichBass",
 204:src/main.cpp  ****     40.0f, 160.0f, 1.38629f,   // 40ŌĆō160 Hz, ln(4)
 205:src/main.cpp  ****     1.0f,        0.40f, WAVE_SAW,    // osc1  ŌĆö saw root (rich harmonics)
