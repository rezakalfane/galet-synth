 433:src/main.cpp  ****           s_ringmod  = s_ringmod  * sa + trm  * (1.0f - sa); }
 434:src/main.cpp  ****         // Asymmetric envelope: fast attack, slower release
 435:src/main.cpp  ****         float slew_amp = (tamp > s_amp) ? SLEW_AMP_A : SLEW_AMP_R;
 436:src/main.cpp  ****         s_amp = s_amp * slew_amp + tamp * (1.0f - slew_amp);
