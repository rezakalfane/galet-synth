 191:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 192:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 193:src/main.cpp  ****         uint16_t scan[N_CH];
 194:src/main.cpp  **** 
 195:src/main.cpp  ****         while(true) {
 196:src/main.cpp  ****             // Stay responsive to a host tuner while idling: this loop would
 197:src/main.cpp  ****             // otherwise spin until a glass touch / FSR press, leaving serial
