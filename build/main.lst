 767:src/main.cpp  **** // Wavefolder distortion
 768:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 769:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 770:src/main.cpp  **** static inline float wavefold(float in, float amount)
 771:src/main.cpp  **** {
 772:src/main.cpp  ****     if(amount < 0.01f) return in;
 773:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 774:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 775:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 776:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 777:src/main.cpp  ****     float x = driven;
 778:src/main.cpp  ****     // 2 passes of folding for richness
 779:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 780:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 781:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 782:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 783:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 784:src/main.cpp  ****     }
 785:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 786:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 787:src/main.cpp  **** }
