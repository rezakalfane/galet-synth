 232:src/main.cpp  **** void update_tracked(Finger* raw,int n)
 233:src/main.cpp  **** {
 234:src/main.cpp  ****     bool ra[2]={false,false};
 235:src/main.cpp  ****     for(int slot=0;slot<2;slot++){
 236:src/main.cpp  ****         if(!tracked[slot].alive)continue;
 237:src/main.cpp  ****         int32_t best=MAX_POS_JUMP+1;int br=-1;
 238:src/main.cpp  ****         for(int r=0;r<n;r++){
 239:src/main.cpp  ****             if(ra[r])continue;
 240:src/main.cpp  ****             int32_t c=raw[r].pos-tracked[slot].pos;if(c<0)c=-c;
 241:src/main.cpp  ****             if(c<best){best=c;br=r;}
 242:src/main.cpp  ****         }
 243:src/main.cpp  ****         if(br>=0){
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//cch1Xbz7.s 			page 13


 244:src/main.cpp  ****             tracked[slot].pos=raw[br].pos;tracked[slot].pressure=raw[br].pressure;
 245:src/main.cpp  ****             tracked[slot].peak_ch=raw[br].peak_ch;tracked[slot].peak_delta=raw[br].peak_delta;
 246:src/main.cpp  ****             ra[br]=true;
 247:src/main.cpp  ****         } else tracked[slot].alive=false;
 248:src/main.cpp  ****     }
 249:src/main.cpp  ****     for(int r=0;r<n;r++){
 250:src/main.cpp  ****         if(ra[r])continue;
 251:src/main.cpp  ****         for(int slot=0;slot<2;slot++){
 252:src/main.cpp  ****             if(!tracked[slot].alive){
 253:src/main.cpp  ****                 tracked[slot]={true,raw[r].pos,raw[r].pressure,raw[r].peak_ch,raw[r].peak_delta};
 254:src/main.cpp  ****                 ra[r]=true;break;
 255:src/main.cpp  ****             }
 256:src/main.cpp  ****         }
 257:src/main.cpp  ****     }
 258:src/main.cpp  **** }
