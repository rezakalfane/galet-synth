 517:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 518:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 519:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 520:src/main.cpp  ****     if(raw <= 0)     return 0;
 521:src/main.cpp  ****     if(raw >= range) return 100;
 522:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 523:src/main.cpp  ****     if(raw > range) raw = range;
 524:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 525:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 526:src/main.cpp  ****     // Integer sqrt via Newton
 527:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 528:src/main.cpp  ****     s = (s + scaled/s) / 2;
ARM GAS  /tmp/claude-502/ccETDxsq.s 			page 18


 529:src/main.cpp  ****     s = (s + scaled/s) / 2;
 530:src/main.cpp  ****     s = (s + scaled/s) / 2;
 531:src/main.cpp  ****     s = (s + scaled/s) / 2;
 532:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 533:src/main.cpp  ****     if(s < 0)   s = 0;
 534:src/main.cpp  ****     if(s > 100) s = 100;
 535:src/main.cpp  ****     return s;
 536:src/main.cpp  **** }
