 338:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 339:src/main.cpp  **** {
 340:src/main.cpp  ****     for(int i=7;i>=0;i--){
 341:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 342:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 343:src/main.cpp  ****     }
 344:src/main.cpp  ****     sda_high();d();scl_high();d();
 345:src/main.cpp  ****     bool ack=!sda.Read();
 346:src/main.cpp  ****     scl_low();d();
 347:src/main.cpp  ****     return ack;
 348:src/main.cpp  **** }
 349:src/main.cpp  **** 
 350:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 351:src/main.cpp  **** {
 352:src/main.cpp  ****     uint8_t b=0;sda_high();
 353:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 354:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 355:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 356:src/main.cpp  ****     return b;
 357:src/main.cpp  **** }
