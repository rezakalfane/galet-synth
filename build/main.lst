 881:src/voice.h   ****     // SUB OSCILLATOR
 882:src/voice.h   ****     0.5f,
 883:src/voice.h   ****     0.40f,
 884:src/voice.h   ****     WAVE_SQUARE,         // sub   ‚Äî the iconic square sub-osc, one octave down
