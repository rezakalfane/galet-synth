 364:src/main.cpp  ****     uint32_t last_retrig[MAX_FINGERS]   = {};   // last held re-attack time (refractory)
 365:src/main.cpp  ****     // Genuine taps (a real lift + re-tap) retrigger with NO limit. A tracker
 366:src/main.cpp  ****     // dropout shorter than TAP_GAP_MS is treated as a flicker ŌĆö the note keeps
 367:src/main.cpp  ****     // holding, no spurious retrigger. While HELD, a sharp pressure rise
 368:src/main.cpp  ****     // re-attacks but is rate-limited by the voice's retrig_ms.
 369:src/main.cpp  ****     static constexpr uint32_t TAP_GAP_MS  = 40;    // min off-time to count as a real lift
 370:src/main.cpp  ****     static constexpr float    PRS_SMOOTH  = 0.5f;  // light smoothing (preserve the attack edge)
 371:src/main.cpp  ****     static constexpr float    RISE_THRESH = 18.0f; // % pressure rise/frame = a held re-attack
 372:src/main.cpp  **** 
 373:src/main.cpp  ****     // Trigger drum slot `s` from a tap at (pos, pressure): zone ŌåÆ drum, fine
 374:src/main.cpp  ****     // position ŌåÆ interval pitch, pressure ŌåÆ velocity (loudness/brightness/drive).
 375:src/main.cpp  ****     auto trigger_drum = [&](int s, int32_t pos, int32_t pressure){
 376:src/main.cpp  ****         float p    = clampf((float)pos / 1000.0f, 0.0f, 1.0f);
 377:src/main.cpp  ****         int   zone = (int)(p * 4.0f); if(zone > 3) zone = 3;
 378:src/main.cpp  ****         int   vidx = MULTI_ZONES[zone];
 379:src/main.cpp  ****         const Voice& V = g_bank[vidx];
 380:src/main.cpp  ****         float subp = p * 4.0f - (float)zone;
 381:src/main.cpp  ****         int   step = (int)(subp * (float)MULTI_NINTERVALS);
 382:src/main.cpp  ****         if(step >= MULTI_NINTERVALS) step = MULTI_NINTERVALS - 1;
 383:src/main.cpp  ****         float freq = V.freq_low * MULTI_INTERVALS[step];
 384:src/main.cpp  ****         float v    = FIX_DRUM ? 1.0f : clampf((float)pressure / 100.0f, 0.0f, 1.0f);
 385:src/main.cpp  ****         float amp  = 0.72f * ((1.0f - V.vel_sens) + V.vel_sens * v);
 386:src/main.cpp  ****         // Cutoff from velocity, same curve as the mono path.
 387:src/main.cpp  ****         float cutoff_oct = V.cutoff_oct_max * smootherstep_f(v);
 388:src/main.cpp  ****         float oa = cutoff_oct * 0.6931f;
 389:src/main.cpp  ****         float om = 1.0f + oa*(1.0f + oa*(0.5f + oa*(0.1667f + oa*0.0417f)));
 390:src/main.cpp  ****         float tf = (V.keytrack >= 0.999f) ? freq
 391:src/main.cpp  ****                    : V.freq_low * powf(freq / V.freq_low, V.keytrack);
 392:src/main.cpp  ****         float cutoff = clampf(tf * V.cutoff_mult * om, 20.0f, 18000.0f);
 393:src/main.cpp  ****         float drive  = 1.0f + smoothstep_f(v) * V.drive_max;
 394:src/main.cpp  ****         drum_trigger(g_hits[s], vidx, freq, amp, cutoff, drive, hw.AudioSampleRate());
 395:src/main.cpp  ****         g_active_voice = vidx;   // header shows the last-hit drum
 396:src/main.cpp  ****     };
 397:src/main.cpp  **** 
 398:src/main.cpp  ****     // Fire one drum (bank index `bankidx`) on hit-pool slot `slot` at full
 399:src/main.cpp  ****     // velocity, at its natural low pitch. Used by the kit preview below.
 400:src/main.cpp  ****     auto preview_drum = [&](int slot, int bankidx){
 401:src/main.cpp  ****         const Voice& V = g_bank[bankidx];
 402:src/main.cpp  ****         float freq   = V.freq_low;
 403:src/main.cpp  ****         // Bright enough that the noisy drums (snare/hat) crack through; the
 404:src/main.cpp  ****         // tonal drums stay dark via their own low cutoff_mult.
 405:src/main.cpp  ****         float cutoff = clampf(freq * V.cutoff_mult * 3.0f, 60.0f, 16000.0f);
 406:src/main.cpp  ****         float drive  = 1.0f + 0.6f * V.drive_max;
 407:src/main.cpp  ****         drum_trigger(g_hits[slot], bankidx, freq, 0.85f, cutoff, drive, hw.AudioSampleRate());
 408:src/main.cpp  ****         // ONE-SHOT: jump to full amp and immediately ungate so the hit decays on
 409:src/main.cpp  ****         // its own. A preview has no finger-lift to clear the gate, so leaving it
 410:src/main.cpp  ****         // gated would sustain the drum's noise forever (the "100% noise when Drums
 411:src/main.cpp  ****         // selected" bug). attack_ms (~1 ms) makes skipping the ramp inaudible.
 412:src/main.cpp  ****         g_hits[slot].amp  = g_hits[slot].amp_tgt;
 413:src/main.cpp  ****         g_hits[slot].gate = false;
 414:src/main.cpp  ****     };
