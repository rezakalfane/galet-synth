 192:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
 193:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 194:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 195:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 196:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 742              		.loc 6 196 5 view .LVU203
 197:src/main.cpp  ****         uint32_t start = System::GetNow();
 198:src/main.cpp  ****         uint32_t acc = 0; int n = 0;
 199:src/main.cpp  ****         bool     calibrated = false;
 200:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 201:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 202:src/main.cpp  ****         uint16_t scan[N_CH];
 203:src/main.cpp  **** 
 204:src/main.cpp  ****         while(true) {
 205:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 206:src/main.cpp  **** 
 207:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 208:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 209:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
 210:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
 211:src/main.cpp  **** 
 212:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 213:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 214:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 215:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 216:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 217:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 218:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 219:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 220:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 221:src/main.cpp  ****             g_led3_duty = led3;
