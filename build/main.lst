1357:src/main.cpp  ****             // ŌöĆŌöĆ Direct exponential frequency mapping across the voice range ŌöĆŌöĆ
1358:src/main.cpp  ****             // freq = freq_low * (freq_high/freq_low)^pos01
1359:src/main.cpp  ****             //      = freq_low * e^(pos01 * log_freq_ratio)
1360:src/main.cpp  ****             float earg = pos01 * VOICE.log_freq_ratio;
1361:src/main.cpp  ****             float ex   = 1.0f + earg*(1.0f + earg*(0.5f + earg*0.1667f));
1362:src/main.cpp  ****             float freq_continuous = clampf(VOICE.freq_low * ex, VOICE.freq_low, VOICE.freq_high);
1363:src/main.cpp  **** 
1364:src/main.cpp  ****             // Convert to MIDI for quantizer: midi = 69 + 12*log2(freq/440)
1365:src/main.cpp  ****             // log2(x) = ln(x)/ln(2); ln approx via y=(x-1)/(x+1) series
1366:src/main.cpp  ****             float freq_ratio = freq_continuous / 440.0f;
1367:src/main.cpp  ****             float y = (freq_ratio - 1.0f) / (freq_ratio + 1.0f);
1368:src/main.cpp  ****             float y2 = y*y;
1369:src/main.cpp  ****             float ln_ratio = 2.0f*y*(1.0f + y2*(0.3333f + y2*0.2f));
1370:src/main.cpp  ****             float midi_raw = 69.0f + 17.3123f * ln_ratio; // 17.3123 = 12/ln(2)
1371:src/main.cpp  **** 
1372:src/main.cpp  ****             float freq; // final frequency to use
1373:src/main.cpp  **** 
