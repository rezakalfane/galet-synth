 630:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 631:src/main.cpp  **** static inline float fast_tanh(float x)
 632:src/main.cpp  **** {
 633:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 634:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 635:src/main.cpp  ****     float x2=x*x;
 636:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 637:src/main.cpp  **** }
