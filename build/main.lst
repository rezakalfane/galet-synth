 657:src/main.cpp  ****             int32_t pkv; int pkc;
 658:src/main.cpp  ****             int32_t pos=centroid_window(work,ws,we,&pkv,&pkc);
 659:src/main.cpp  ****             out[found]={true,pos,pressure_pct(pkv,pkc),pkc,pkv};
 660:src/main.cpp  ****             peaks[found]=pk;
 661:src/main.cpp  ****             found++;
 662:src/main.cpp  ****         }
 663:src/main.cpp  ****         // Zero this peak's window so the next pass finds a different finger.
 664:src/main.cpp  ****         for(int i=pk-2;i<=pk+2;i++) if(i>=0 && i<N_CH) work[i]=0;
 665:src/main.cpp  ****     }
