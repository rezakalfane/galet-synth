 508:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 509:src/main.cpp  **** {
 510:src/main.cpp  ****     i2c_start();
 511:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 512:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 513:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 514:src/main.cpp  ****     i2c_stop();return true;
 515:src/main.cpp  **** }
