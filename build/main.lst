 859:src/main.cpp  **** // Wavefolder distortion
 860:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 861:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 862:src/main.cpp  **** static inline float wavefold(float in, float amount)
 863:src/main.cpp  **** {
 864:src/main.cpp  ****     if(amount < 0.01f) return in;
 865:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 866:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 867:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 868:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 869:src/main.cpp  ****     float x = driven;
 870:src/main.cpp  ****     // 2 passes of folding for richness
ARM GAS  /tmp/claude-502/ccqNkRH0.s 			page 24


 871:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 872:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 873:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 874:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 875:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 876:src/main.cpp  ****     }
 877:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 878:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 879:src/main.cpp  **** }
