 521:src/main.cpp  **** // Slew rates (per sample at 48 kHz)
 522:src/main.cpp  **** // Lower value = faster response.
 523:src/main.cpp  **** // NOTE: pitch glide and the amp attack/release are now per-voice (see Voice
 524:src/main.cpp  **** // glide_ms / attack_ms / release_ms), converted to coefficients in the audio
 525:src/main.cpp  **** // callback. The constants below are the ones still shared by all voices.
 526:src/main.cpp  **** // Cutoff opening slew. The target is recomputed only at the touch-loop rate
 527:src/main.cpp  **** // (~12-16 Hz) and pressure is quantized to integer %, so a too-fast slew lets
 528:src/main.cpp  **** // each coarse step through as zipper/stair-stepping. ~35 ms interpolates across
ARM GAS  /tmp/claude-502/ccb6uqMv.s 			page 18


 529:src/main.cpp  **** // those steps for a smooth filter sweep while still feeling responsive.
 530:src/main.cpp  **** static constexpr float SLEW_CUT    = 0.9994f; // filter cutoff ŌĆö ~35 ms smooth
 531:src/main.cpp  **** static constexpr float SLEW_MISC   = 0.9900f; // drive/vib
 532:src/main.cpp  **** // Finger 2 ŌĆö asymmetric attack/release
 533:src/main.cpp  **** static constexpr float SLEW_F2_A   = 0.9800f; // attack  (~10ms)
 534:src/main.cpp  **** static constexpr float SLEW_F2_R   = 0.9990f; // release (~200ms smooth fade)
 535:src/main.cpp  **** 
 536:src/main.cpp  **** // Convert a one-pole time constant in milliseconds to a per-sample slew
 537:src/main.cpp  **** // coefficient: y += (1-coeff)*(target-y) reaches ~63% after `ms`.
 538:src/main.cpp  **** static inline float ms_to_coeff(float ms, float sr){
 539:src/main.cpp  ****     if(ms <= 0.0f) return 0.0f;            // instant
 540:src/main.cpp  ****     return expf(-1.0f / (ms * 0.001f * sr));
 541:src/main.cpp  **** }
 542:src/main.cpp  **** 
 543:src/main.cpp  **** // ŌöĆŌöĆ Oscillator waveforms (phase ph in [0,1) ŌåÆ sample in [-1,1]) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 544:src/main.cpp  **** // Triangle wave
 545:src/main.cpp  **** static inline float tri(float ph){
 546:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 547:src/main.cpp  **** }
 548:src/main.cpp  **** // Sine via parabolic approximation (no libm call) ŌĆö matches sin(2ŽĆ┬Ęph).
 549:src/main.cpp  **** static inline float osc_sine(float ph){
 550:src/main.cpp  ****     constexpr float PI = 3.14159265f;
 551:src/main.cpp  ****     float x = ph*2.0f*PI - PI;                 // -ŽĆ..ŽĆ (angle shifted by ŽĆ)
 552:src/main.cpp  ****     float y = 1.27323954f*x - 0.405284735f*x*(x<0?-x:x);
 553:src/main.cpp  ****     y = 0.225f*(y*(y<0?-y:y) - y) + y;         // one refinement pass
 554:src/main.cpp  ****     return -y;                                 // undo the ŽĆ shift: sin(x+ŽĆ) = -sin(x)
 555:src/main.cpp  **** }
 556:src/main.cpp  **** // Naive square / saw ŌĆö alias at high pitch but sound rich on a bass voice.
 557:src/main.cpp  **** static inline float osc_square(float ph){ return ph<0.5f ? 1.0f : -1.0f; }
 558:src/main.cpp  **** static inline float osc_saw(float ph){ return 2.0f*ph - 1.0f; }
 559:src/main.cpp  **** 
 560:src/main.cpp  **** // Dispatch on the voice's waveform. VOICE.wave is a compile-time constant, so at
 561:src/main.cpp  **** // -O2 this folds to a single waveform call with no branch.
 562:src/main.cpp  **** static inline float osc(float ph, Waveform w){
 563:src/main.cpp  ****     switch(w){
 564:src/main.cpp  ****         case WAVE_SINE:   return osc_sine(ph);
 565:src/main.cpp  ****         case WAVE_SQUARE: return osc_square(ph);
 566:src/main.cpp  ****         case WAVE_SAW:    return osc_saw(ph);
 567:src/main.cpp  ****         case WAVE_TRI:
 568:src/main.cpp  ****         default:          return tri(ph);
 569:src/main.cpp  ****     }
 570:src/main.cpp  **** }
 571:src/main.cpp  **** 
 572:src/main.cpp  **** // Moog 4-pole ladder
 573:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 574:src/main.cpp  **** {
 575:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 576:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 577:src/main.cpp  ****     float k  = 3.8f*res;
 578:src/main.cpp  ****     float fb = k*s_flt[3];
 579:src/main.cpp  ****     float x  = in - fb;
 580:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 581:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 582:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 583:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 584:src/main.cpp  ****     return s_flt[3];
 585:src/main.cpp  **** }
ARM GAS  /tmp/claude-502/ccb6uqMv.s 			page 19


