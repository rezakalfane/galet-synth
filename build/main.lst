 379:src/main.cpp  ****     // dropout shorter than TAP_GAP_MS is treated as a flicker ŌĆö the note keeps
 380:src/main.cpp  ****     // holding, no spurious retrigger. While HELD, a sharp pressure rise
 381:src/main.cpp  ****     // re-attacks but is rate-limited by the voice's retrig_ms.
 382:src/main.cpp  ****     static constexpr uint32_t TAP_GAP_MS  = 40;    // min off-time to count as a real lift
 383:src/main.cpp  ****     static constexpr float    PRS_SMOOTH  = 0.5f;  // light smoothing (preserve the attack edge)
