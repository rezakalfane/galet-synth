 252:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 253:src/main.cpp  **** {
 254:src/main.cpp  ****     for(int i=7;i>=0;i--){
 255:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 256:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 257:src/main.cpp  ****     }
 258:src/main.cpp  ****     sda_high();d();scl_high();d();
 259:src/main.cpp  ****     bool ack=!sda.Read();
 260:src/main.cpp  ****     scl_low();d();
 261:src/main.cpp  ****     return ack;
 262:src/main.cpp  **** }
 263:src/main.cpp  **** 
 264:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 265:src/main.cpp  **** {
 266:src/main.cpp  ****     uint8_t b=0;sda_high();
 267:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 268:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 269:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 270:src/main.cpp  ****     return b;
 271:src/main.cpp  **** }
