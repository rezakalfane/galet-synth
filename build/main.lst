 377:src/main.cpp  ****     if(da<TOUCH_THRESHOLD)return 0;
 378:src/main.cpp  ****     int ws=pka-2;if(ws<0)ws=0;int we=pka+2;if(we>=N_CH)we=N_CH-1;
