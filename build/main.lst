 586:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 587:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 588:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 589:src/main.cpp  ****     if(raw <= 0)     return 0;
 590:src/main.cpp  ****     if(raw >= range) return 100;
 591:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 592:src/main.cpp  ****     if(raw > range) raw = range;
 593:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 594:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 595:src/main.cpp  ****     // Integer sqrt via Newton
 596:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 597:src/main.cpp  ****     s = (s + scaled/s) / 2;
 598:src/main.cpp  ****     s = (s + scaled/s) / 2;
 599:src/main.cpp  ****     s = (s + scaled/s) / 2;
 600:src/main.cpp  ****     s = (s + scaled/s) / 2;
 601:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 602:src/main.cpp  ****     if(s < 0)   s = 0;
 603:src/main.cpp  ****     if(s > 100) s = 100;
 604:src/main.cpp  ****     return s;
 605:src/main.cpp  **** }
