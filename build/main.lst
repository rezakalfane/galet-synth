 531:src/voice.h   ****     // OSCILLATOR STACK
 532:src/voice.h   ****     1.0f,
 533:src/voice.h   ****     0.32f,
 534:src/voice.h   ****     WAVE_SAW,            // osc1  ‚Äî saw root
 535:src/voice.h   ****     // SECONDARY OSCILLATOR
 536:src/voice.h   ****     1.006f,
 537:src/voice.h   ****     0.30f,
 538:src/voice.h   ****     WAVE_SAW,            // osc2  ‚Äî detuned saw ‚Üí lush ensemble width
 539:src/voice.h   ****     // SUB OSCILLATOR
 540:src/voice.h   ****     0.5f,
 541:src/voice.h   ****     0.22f,
 542:src/voice.h   ****     WAVE_TRI,            // sub   ‚Äî soft triangle body
 543:src/voice.h   ****     // OCTAVE OSCILLATOR
 544:src/voice.h   ****     2.0f,
 545:src/voice.h   ****     0.18f,
 546:src/voice.h   ****     WAVE_SINE,           // oct   ‚Äî airy sine top
 547:src/voice.h   ****     // FILTER
 548:src/voice.h   ****     false,               // osc2 is a fixed chorus detune, not finger-2
 549:src/voice.h   ****     1.2f,
 550:src/voice.h   ****     3.0f,
 551:src/voice.h   ****     0.20f,               // warm & closed: low base cutoff, gentle sweep, low res
 552:src/voice.h   ****     // DRIVE
 553:src/voice.h   ****     0.6f,                // gentle drive ‚Äî stays smooth
 554:src/voice.h   ****     // NOISE
 555:src/voice.h   ****     0.015f,              // noise level ‚Äî air
 556:src/voice.h   ****     1.0f,                // keytrack
 557:src/voice.h   ****     1.0f,                // ringmod ratio
 558:src/voice.h   ****     0.0f,                // ringmod max
 559:src/voice.h   ****     0.08f,               // fold max
 560:src/voice.h   ****     2200.0f,             // attack ‚Äî slow swell
 561:src/voice.h   ****     2000.0f,             // release ‚Äî long tail
 562:src/voice.h   ****     80.0f                // glide
 563:src/voice.h   ****     // PITCH ENVELOPE
 564:src/voice.h   ****     // PITCH QUANTIZE
 565:src/voice.h   **** };
 566:src/voice.h   **** 
 567:src/voice.h   **** // ‚îÄ‚îÄ Voice 8: tom / percussion (noise-driven) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
 568:src/voice.h   **** //   A drum, not a sustained note ‚Äî PLAY IT BY TAPPING the glass. Noise over two
