 541:src/voice.h   ****     true,
 542:src/voice.h   ****     SCALE_MAJOR, (int)(sizeof(SCALE_MAJOR) / sizeof(SCALE_MAJOR[0])),
 543:src/voice.h   ****     // AMP DECAY ŌĆö the pluck: ring out to silence over ~1.2 s while held
