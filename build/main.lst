 630:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
 631:src/main.cpp  ****     int pkb=0;int32_t db=0;
 632:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(d2[i]>db){db=d2[i];pkb=i;}
 633:src/main.cpp  ****     int sep=pkb-pka;if(sep<0)sep=-sep;
