ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccJ1Nbd8.s 			page 156


 779:src/main.cpp  ****             // ŌöĆŌöĆ Direct exponential frequency mapping: 50Hz to 300Hz ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 780:src/main.cpp  ****             // freq = 50 * (300/50)^pos01 = 50 * 6^pos01
 781:src/main.cpp  ****             // Using e^x approx: 6^x = e^(x*ln6), ln6=1.7918
 782:src/main.cpp  ****             float earg = pos01 * 1.7918f;
 783:src/main.cpp  ****             float ex   = 1.0f + earg*(1.0f + earg*(0.5f + earg*0.1667f));
 784:src/main.cpp  ****             float freq_continuous = clampf(50.0f * ex, 50.0f, 300.0f);
 785:src/main.cpp  **** 
 786:src/main.cpp  ****             // Convert to MIDI for quantizer: midi = 69 + 12*log2(freq/440)
 787:src/main.cpp  ****             // log2(x) = ln(x)/ln(2); ln approx via y=(x-1)/(x+1) series
 788:src/main.cpp  ****             float freq_ratio = freq_continuous / 440.0f;
 789:src/main.cpp  ****             float y = (freq_ratio - 1.0f) / (freq_ratio + 1.0f);
 790:src/main.cpp  ****             float y2 = y*y;
 791:src/main.cpp  ****             float ln_ratio = 2.0f*y*(1.0f + y2*(0.3333f + y2*0.2f));
 792:src/main.cpp  ****             float midi_raw = 69.0f + 17.3123f * ln_ratio; // 17.3123 = 12/ln(2)
 793:src/main.cpp  **** 
 794:src/main.cpp  ****             float freq; // final frequency to use
 795:src/main.cpp  **** 
 796:src/main.cpp  ****             if(QUANTIZE_ENABLED && f1_fresh)
 797:src/main.cpp  ****             {
 798:src/main.cpp  ****                 // Touch-down: snap to nearest chromatic note
 799:src/main.cpp  ****                 f1_midi_base = quantize_midi(midi_raw);
 800:src/main.cpp  ****                 // Convert quantized MIDI back to Hz
 801:src/main.cpp  ****                 float qe = (f1_midi_base - 69.0f) * 0.05776f;
 802:src/main.cpp  ****                 freq = clampf(440.0f*(1.0f+qe*(1.0f+qe*(0.5f+qe*0.1667f))), 50.0f, 300.0f);
 803:src/main.cpp  ****                 f1_sliding = false;
 804:src/main.cpp  ****             }
 805:src/main.cpp  ****             else
 806:src/main.cpp  ****             {
 807:src/main.cpp  ****                 // Sliding or quantize disabled: follow continuous frequency directly
 808:src/main.cpp  ****                 f1_midi_base = f1_midi_base*0.88f + midi_raw*0.12f;
 809:src/main.cpp  ****                 freq = freq_continuous;
 810:src/main.cpp  ****                 f1_sliding = true;
 811:src/main.cpp  ****             }
 812:src/main.cpp  ****             freq = clampf(freq, 50.0f, 300.0f);
 813:src/main.cpp  **** 
 814:src/main.cpp  ****             // Cutoff: base tracks 2├Ś pitch, pressure opens it up
 815:src/main.cpp  ****             // Light press = 1├Ś pitch (dark, Moog-like tracking)
 816:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
 817:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 818:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
 819:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
 820:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
 821:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
 822:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
 823:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 824:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
 825:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
 826:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
 827:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 828:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
 829:src/main.cpp  ****             };
 830:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
 831:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
 832:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
 833:src/main.cpp  ****             };
 834:src/main.cpp  **** 
 835:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccJ1Nbd8.s 			page 157


 836:src/main.cpp  ****             float prs_cut  = smootherstep(prs01);
 837:src/main.cpp  ****             float cutoff_oct = 12.0f * prs_cut;              // 12 octaves of sweep
 838:src/main.cpp  ****             float oct_arg  = cutoff_oct * 0.6931f;
 839:src/main.cpp  ****             float oct_mult = 1.0f + oct_arg*(1.0f + oct_arg*(0.5f + oct_arg*(0.1667f + oct_arg*0.04
 840:src/main.cpp  ****             float cutoff   = clampf(freq * 0.3f * oct_mult, 20.0f, 18000.0f); // screams
