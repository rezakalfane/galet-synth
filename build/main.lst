 752:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0ŌåÆ1000ŌåÆ0 through the same
 753:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 754:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 755:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 756:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 5647              		.loc 6 756 5 view .LVU1644
 757:src/main.cpp  ****         uint32_t start = System::GetNow();
 758:src/main.cpp  ****         uint32_t acc = 0; int n = 0;
 759:src/main.cpp  ****         bool     calibrated = false;
 760:src/main.cpp  ****         constexpr uint32_t SWEEP_PERIOD_MS = 12000;  // one 0ŌåÆ1ŌåÆ0 cycle
 761:src/main.cpp  ****         constexpr float    TAU             = 6.2831853f;
 762:src/main.cpp  ****         uint16_t scan[N_CH];
 763:src/main.cpp  **** 
 764:src/main.cpp  ****         while(true) {
 765:src/main.cpp  ****             uint32_t elapsed = System::GetNow() - start;
 766:src/main.cpp  **** 
 767:src/main.cpp  ****             // Sinusoidal position 0ŌåÆ1ŌåÆ0 over SWEEP_PERIOD_MS ŌĆö eases at the
 768:src/main.cpp  ****             // endpoints so the reversal is gentle instead of a triangle kink.
 769:src/main.cpp  ****             float phase = (float)(elapsed % SWEEP_PERIOD_MS) / (float)SWEEP_PERIOD_MS;
 770:src/main.cpp  ****             float p01   = 0.5f * (1.0f - cosf(phase * TAU));
 771:src/main.cpp  **** 
 772:src/main.cpp  ****             // Same tent + gamma-0.25 math as the pitch LED mapping.
 773:src/main.cpp  ****             float l1_raw = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 774:src/main.cpp  ****             float l3_raw = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 775:src/main.cpp  ****             float l2_raw = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 776:src/main.cpp  ****             float led1   = sqrtf(sqrtf(l2_raw));              // middle (DAC1)
 777:src/main.cpp  ****             float led2   = sqrtf(sqrtf(l1_raw));              // pos 0  (DAC2)
 778:src/main.cpp  ****             float led3   = sqrtf(sqrtf(l3_raw)) * LED3_INTENSITY; // pos 1 (PWM A0)
 779:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::ONE, (uint16_t)(led1 * 4095.0f));
 780:src/main.cpp  ****             hw.dac.WriteValue(DacHandle::Channel::TWO, (uint16_t)(led2 * 4095.0f));
 781:src/main.cpp  ****             g_led3_duty = led3;
 782:src/main.cpp  **** 
 783:src/main.cpp  ****             // FSR calibration window: first 2 s only.
 784:src/main.cpp  ****             if(!calibrated) {
 785:src/main.cpp  ****                 acc += hw.adc.Get(0);
 786:src/main.cpp  ****                 n++;
 787:src/main.cpp  ****                 if(elapsed >= 2000) {
 788:src/main.cpp  ****                     commit_fsr_avg(acc, n);
 789:src/main.cpp  ****                     calibrated = true;
 790:src/main.cpp  ****                 }
 791:src/main.cpp  ****             }
 792:src/main.cpp  **** 
 793:src/main.cpp  ****             // Exit on any touch.
 794:src/main.cpp  ****             read_electrodes(scan);
 795:src/main.cpp  ****             int32_t max_d = 0;
 796:src/main.cpp  ****             for(int i = 0; i < N_CH; i++) {
 797:src/main.cpp  ****                 int32_t d = (int32_t)baseline[i] - (int32_t)scan[i];
 798:src/main.cpp  ****                 if(d > max_d) max_d = d;
 799:src/main.cpp  ****             }
