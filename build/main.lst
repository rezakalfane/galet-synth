 797:src/main.cpp  ****                 s_led2 = led2_target;
 798:src/main.cpp  ****                 s_led3 = led3_target;
 799:src/main.cpp  ****             } else {
 800:src/main.cpp  ****                 float smooth3 = f1_on ? LED_SMOOTH : LED3_RELEASE_SMOOTH;
 801:src/main.cpp  ****                 s_led1 = s_led1 * LED_SMOOTH + led1_target * (1.0f - LED_SMOOTH);
 802:src/main.cpp  ****                 s_led2 = s_led2 * LED_SMOOTH + led2_target * (1.0f - LED_SMOOTH);
 803:src/main.cpp  ****                 s_led3 = s_led3 * smooth3   + led3_target * (1.0f - smooth3);
 804:src/main.cpp  ****             }
