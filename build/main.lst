 810:src/main.cpp  ****     // Idle behaviour: sweep a virtual position 0‚Üí1000‚Üí0 through the same
 811:src/main.cpp  ****     // LED-tent math as the pitch mapping (LED2=pos 0, LED1=middle, LED3=pos 1),
 812:src/main.cpp  ****     // recalibrate fsr_max during the first 2 s, then keep sweeping until any
 813:src/main.cpp  ****     // electrode crosses TOUCH_THRESHOLD.
 814:src/main.cpp  ****     auto idle_chase_and_calibrate = [&]() {
 5665              		.loc 6 814 5 view .LVU1637
 815:src/main.cpp  ****         uint32_t start = System::GetNow();
 816:src/main.cpp  ****         uint32_t acc = 0; int n = 0;
