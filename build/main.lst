 724:src/main.cpp  **** // ŌöĆŌöĆ Note quantizer ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 725:src/main.cpp  **** // Returns the nearest MIDI note in SCALE[] for a raw float MIDI pitch.
 726:src/main.cpp  **** float quantize_midi(float midi)
 727:src/main.cpp  **** {
 728:src/main.cpp  ****     int root = (int)midi;
 729:src/main.cpp  ****     int pc   = root % 12;
 730:src/main.cpp  ****     int oct  = root / 12;
 731:src/main.cpp  ****     // find nearest scale degree
 732:src/main.cpp  ****     int best_deg=0, best_dist=127;
 733:src/main.cpp  ****     for(int i=0;i<SCALE_LEN;i++){
 734:src/main.cpp  ****         int d=SCALE[i]-pc; if(d<0)d=-d;
 735:src/main.cpp  ****         int d2=12-d; if(d2<d)d=d2;
 736:src/main.cpp  ****         if(d<best_dist){best_dist=d;best_deg=SCALE[i];}
 737:src/main.cpp  ****     }
 738:src/main.cpp  ****     float q=(float)(oct*12+best_deg);
 739:src/main.cpp  ****     // fractional semitone from the quantized note (for slide expression)
 740:src/main.cpp  ****     float frac=midi-(float)root;
 741:src/main.cpp  ****     return q+frac;
 742:src/main.cpp  **** }
