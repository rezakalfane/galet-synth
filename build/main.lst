 368:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 369:src/main.cpp  **** {
 370:src/main.cpp  ****     i2c_start();
 371:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 372:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 373:src/main.cpp  ****     i2c_start();
 374:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 375:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
