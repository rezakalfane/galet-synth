 918:src/main.cpp  ****             // ŌöĆŌöĆ Direct exponential frequency mapping across the voice range ŌöĆŌöĆ
 919:src/main.cpp  ****             // freq = freq_low * (freq_high/freq_low)^pos01
 920:src/main.cpp  ****             //      = freq_low * e^(pos01 * log_freq_ratio)
 921:src/main.cpp  ****             float earg = pos01 * VOICE.log_freq_ratio;
 922:src/main.cpp  ****             float ex   = 1.0f + earg*(1.0f + earg*(0.5f + earg*0.1667f));
