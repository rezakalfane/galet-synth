 145:src/voice.h   **** // ŌöĆŌöĆ Voice 4: clean sine organ / flute (a melodic, non-bass departure) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 146:src/voice.h   **** //   Pure sine oscillators stacked like organ drawbars: octave-down body, root,
 147:src/voice.h   **** //   octave-up air, plus a second osc tuned a hair sharp (1.005├Ś) for a slow,
 148:src/voice.h   **** //   warm chorus shimmer instead of a chord. Higher register than the basses, a
 149:src/voice.h   **** //   mostly-open clean filter, and just a touch of drive so pressure adds gentle
 150:src/voice.h   **** //   harmonic warmth. Sines never alias, so it stays smooth all the way up.
 151:src/voice.h   **** static constexpr Voice VOICE_ORGAN = {
 152:src/voice.h   ****     "Organ",
 153:src/voice.h   ****     65.0f, 520.0f, 2.07944f,   // 65ŌĆō520 Hz, ln(8) ŌĆö a melodic keyboard register
 154:src/voice.h   ****     1.0f,    0.45f, WAVE_SINE,  // osc1  ŌĆö root (8')
 155:src/voice.h   ****     1.005f,  0.40f, WAVE_SINE,  // osc2  ŌĆö slightly sharp unison ŌåÆ slow chorus shimmer
 156:src/voice.h   ****     0.5f,    0.30f, WAVE_SINE,  // sub   ŌĆö octave-down body (16')
 157:src/voice.h   ****     2.0f,    0.28f, WAVE_SINE,  // oct   ŌĆö octave-up air (4')
 158:src/voice.h   ****     false,                      // osc2 is a fixed chorus detune, not finger-2 detune
 159:src/voice.h   ****     2.0f, 5.0f, 0.20f,          // mostly-open clean filter, gentle pressure lift, low res
