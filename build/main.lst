 143:src/voice.h   **** // ŌöĆŌöĆ Diatonic triad ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 144:src/voice.h   **** // For a root pitch class (0ŌĆō11 semitones within an octave) that belongs to
 145:src/voice.h   **** // `scale`, return the semitone offsets of the 3rd and 5th scale-degrees above it
 146:src/voice.h   **** // (stacking thirds: degrees i, i+2, i+4). Wrapping past the top of the scale
 147:src/voice.h   **** // adds an octave. Used by chord voices (Voice::chords). With no scale it falls
 148:src/voice.h   **** // back to a fixed major triad (4, 7). Pure (no Hz, no note-number line) so it
 149:src/voice.h   **** // runs in the host tests.
 150:src/voice.h   **** static inline void diatonic_triad(int root_pc, const int8_t *scale, int n,
 151:src/voice.h   ****                                   int &semis_third, int &semis_fifth) {
 152:src/voice.h   ****   if (!scale || n <= 0) {
 153:src/voice.h   ****     semis_third = 4;
 154:src/voice.h   ****     semis_fifth = 7;
 155:src/voice.h   ****     return;
 156:src/voice.h   ****   }
