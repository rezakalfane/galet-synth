1105:src/main.cpp  ****             s_noise_rng ^= s_noise_rng << 5;
1106:src/main.cpp  ****             float white = (float)(int32_t)s_noise_rng * (1.0f/2147483648.0f);
1107:src/main.cpp  ****             // One-pole high-pass = white minus its low-frequency content.
1108:src/main.cpp  ****             s_noise_lp += NOISE_HP_COEF * (white - s_noise_lp);
1109:src/main.cpp  ****             float bright = white - s_noise_lp;
1110:src/main.cpp  ****             // Blend white ŌåÆ high-passed by noise_hp (├Ś2 to make up lost level).
1111:src/main.cpp  ****             float n = white + (bright * 2.0f - white) * VOICE.noise_hp;
1112:src/main.cpp  ****             noise = n * VOICE.noise_level;
