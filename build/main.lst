 283:src/main.cpp  **** // ŌöĆŌöĆ Maths helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 284:src/main.cpp  **** static inline float clampf(float v,float lo,float hi){
 285:src/main.cpp  ****     return v<lo?lo:v>hi?hi:v;
 286:src/main.cpp  **** }
