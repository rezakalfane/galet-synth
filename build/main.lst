 727:src/voice.h   ****     false,               // osc2 is a fixed ratio, not finger-2 detune
 728:src/voice.h   ****     18.0f,
 729:src/voice.h   ****     4.0f,
 730:src/voice.h   ****     0.30f,               // wide open & bright ŌĆö the noise rattle cracks through
