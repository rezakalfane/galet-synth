 143:src/voice.h   **** // ŌöĆŌöĆ Diatonic triad ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
 144:src/voice.h   **** // For a root pitch class (0ŌĆō11 semitones within an octave) that belongs to
 145:src/voice.h   **** // `scale`, return the semitone offsets of the 3rd and 5th scale-degrees above it
 146:src/voice.h   **** // (stacking thirds: degrees i, i+2, i+4). Wrapping past the top of the scale
 147:src/voice.h   **** // adds an octave. Used by chord voices (Voice::chords). With no scale it falls
 148:src/voice.h   **** // back to a fixed major triad (4, 7). Pure (no Hz, no note-number line) so it
 149:src/voice.h   **** // runs in the host tests.
 150:src/voice.h   **** static inline void diatonic_triad(int root_pc, const int8_t *scale, int n,
 151:src/voice.h   ****                                   int &semis_third, int &semis_fifth) {
 152:src/voice.h   ****   if (!scale || n <= 0) {
 153:src/voice.h   ****     semis_third = 4;
 154:src/voice.h   ****     semis_fifth = 7;
 155:src/voice.h   ****     return;
 156:src/voice.h   ****   }
ARM GAS  /tmp/claude-502/ccJ8DnOJ.s 			page 36


 157:src/voice.h   ****   int pc = ((root_pc % 12) + 12) % 12;
 158:src/voice.h   ****   // Nearest scale degree to the root pitch class.
 159:src/voice.h   ****   int idx = 0, best = 127;
 160:src/voice.h   ****   for (int i = 0; i < n; i++) {
 161:src/voice.h   ****     int d = scale[i] - pc;
 162:src/voice.h   ****     if (d < 0)
 163:src/voice.h   ****       d = -d;
 164:src/voice.h   ****     if (d < best) {
 165:src/voice.h   ****       best = d;
 166:src/voice.h   ****       idx = i;
 167:src/voice.h   ****     }
 168:src/voice.h   ****   }
 169:src/voice.h   ****   auto deg = [&](int k) { return scale[k % n] + 12 * (k / n); };
 170:src/voice.h   ****   int base = deg(idx);
 171:src/voice.h   ****   semis_third = deg(idx + 2) - base;
 172:src/voice.h   ****   semis_fifth = deg(idx + 4) - base;
 173:src/voice.h   **** }
 174:src/voice.h   **** 
 175:src/voice.h   **** // ŌöĆŌöĆ Quantize scales ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 176:src/voice.h   **** // Semitone offsets within an octave. A voice with quantize = true snaps finger-1
 177:src/voice.h   **** // to the nearest degree of its `scale` (see Voice::scale / quantize_midi).
 178:src/voice.h   **** static constexpr int8_t SCALE_CHROMATIC[] = {0, 1, 2, 3, 4,  5,
 179:src/voice.h   ****                                              6, 7, 8, 9, 10, 11};
 180:src/voice.h   **** static constexpr int8_t SCALE_MAJOR[] = {0, 2, 4, 5, 7, 9, 11};
 181:src/voice.h   **** static constexpr int8_t SCALE_MINOR[] = {0, 2, 3, 5, 7, 8, 10};
 182:src/voice.h   **** 
