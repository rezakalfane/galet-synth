 785:src/main.cpp  ****                 float prs_mult = 0.75f + 0.25f * pr01;
 786:src/main.cpp  ****                 float l1_raw   = 1.0f - 2.0f * p01;                 if(l1_raw < 0) l1_raw = 0;
 787:src/main.cpp  ****                 float l3_raw   = 2.0f * p01 - 1.0f;                 if(l3_raw < 0) l3_raw = 0;
 788:src/main.cpp  ****                 float l2_raw   = 1.0f - 2.0f * fabsf(p01 - 0.5f);   if(l2_raw < 0) l2_raw = 0;
 789:src/main.cpp  ****                 led1_target    = sqrtf(sqrtf(l2_raw)) * prs_mult;  // middle tent
 790:src/main.cpp  ****                 led2_target    = sqrtf(sqrtf(l1_raw)) * prs_mult;  // pos 0 ramp
 791:src/main.cpp  ****                 led3_target    = sqrtf(sqrtf(l3_raw)) * prs_mult * LED3_INTENSITY;
 792:src/main.cpp  ****             }
 793:src/main.cpp  ****             // Snap on touch onset so the LEDs respond instantly to the initial touch;
 794:src/main.cpp  ****             // smooth during sustained touch and on lift-off.
