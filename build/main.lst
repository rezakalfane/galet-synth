1352:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
1353:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1354:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
1355:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
1356:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
1357:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
1358:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1359:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1360:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1361:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1362:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1363:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1364:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1365:src/main.cpp  ****             };
1366:src/main.cpp  ****             auto smootherstep = [](float x) -> float {
1367:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1368:src/main.cpp  ****                 return x*x*x*(x*(x*6.0f - 15.0f) + 10.0f);
1369:src/main.cpp  ****             };
1370:src/main.cpp  **** 
1371:src/main.cpp  ****             // Cutoff: smootherstep ŌĆö very dark at low, dramatic in mid, eases at top.
