  82:src/dsp.h     **** // Wavefolder distortion
  83:src/dsp.h     **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
  84:src/dsp.h     **** // amount 0 = clean, 1 = heavy folding (4 folds)
