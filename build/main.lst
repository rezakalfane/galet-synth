 665:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 666:src/main.cpp  **** static inline float fast_tanh(float x)
 667:src/main.cpp  **** {
 668:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 669:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 670:src/main.cpp  ****     float x2=x*x;
 671:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 672:src/main.cpp  **** }
