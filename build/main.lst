 127:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 128:src/voice.h   ****     0.0f, 1.0f, 1.0f, 0.15f, 0.15f, 5.0f, 350.0f, 25.0f
 129:src/voice.h   **** };
