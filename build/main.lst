 675:src/main.cpp  **** // Fast tanh approximation (Pad├®)
 676:src/main.cpp  **** static inline float fast_tanh(float x)
 677:src/main.cpp  **** {
 678:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 679:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 680:src/main.cpp  ****     float x2=x*x;
 681:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
