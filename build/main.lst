 513:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 514:src/main.cpp  **** {
 515:src/main.cpp  ****     for(int i=7;i>=0;i--){
 516:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 517:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 518:src/main.cpp  ****     }
 519:src/main.cpp  ****     sda_high();d();scl_high();d();
 520:src/main.cpp  ****     bool ack=!sda.Read();
 521:src/main.cpp  ****     scl_low();d();
 522:src/main.cpp  ****     return ack;
 523:src/main.cpp  **** }
 524:src/main.cpp  **** 
 525:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 526:src/main.cpp  **** {
 527:src/main.cpp  ****     uint8_t b=0;sda_high();
 528:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
ARM GAS  /tmp/claude-502/cc8Z2ub8.s 			page 18


 529:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 530:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 531:src/main.cpp  ****     return b;
 532:src/main.cpp  **** }
