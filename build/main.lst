 187:src/main.cpp  **** 
 188:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 189:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - PRESSURE_DEAD_ZONE[ch];
 190:src/main.cpp  ****     int32_t raw   = pk - PRESSURE_DEAD_ZONE[ch];
 191:src/main.cpp  ****     if(raw <= 0)     return 0;
 192:src/main.cpp  ****     if(raw >= range) return 100;
 193:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 194:src/main.cpp  ****     if(raw > range) raw = range;
 195:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 196:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 197:src/main.cpp  ****     // Integer sqrt via Newton ŌĆö start from 101 (max output) for guaranteed convergence
 198:src/main.cpp  ****     int32_t s = 101;
 199:src/main.cpp  ****     s = (s + scaled/s) / 2;
 200:src/main.cpp  ****     s = (s + scaled/s) / 2;
 201:src/main.cpp  ****     s = (s + scaled/s) / 2;
 202:src/main.cpp  ****     s = (s + scaled/s) / 2;
 203:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 204:src/main.cpp  ****     if(s < 0)   s = 0;
 205:src/main.cpp  ****     if(s > 100) s = 100;
 206:src/main.cpp  ****     return s;
 207:src/main.cpp  **** }
