 516:src/main.cpp  **** // Fast tanh approximation (Pad√©)
 517:src/main.cpp  **** static inline float fast_tanh(float x)
 518:src/main.cpp  **** {
 519:src/main.cpp  ****     if(x> 3.0f)return  1.0f;
 520:src/main.cpp  ****     if(x<-3.0f)return -1.0f;
 521:src/main.cpp  ****     float x2=x*x;
 522:src/main.cpp  ****     return x*(27.0f+x2)/(27.0f+9.0f*x2);
 523:src/main.cpp  **** }
