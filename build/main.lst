 610:src/main.cpp  ****         if(f1_on)
 611:src/main.cpp  ****         {
 612:src/main.cpp  ****             float pos01 = clampf((float)tracked[0].pos / 1000.0f, 0.0f, 1.0f);
 613:src/main.cpp  ****             float prs01 = clampf((float)tracked[0].pressure / 100.0f, 0.0f, 1.0f); // hard clamp
 614:src/main.cpp  **** 
 615:src/main.cpp  ****             // ŌöĆŌöĆ Direct exponential frequency mapping: 50Hz to 300Hz ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 616:src/main.cpp  ****             // freq = 50 * (300/50)^pos01 = 50 * 6^pos01
 617:src/main.cpp  ****             // Using e^x approx: 6^x = e^(x*ln6), ln6=1.7918
 618:src/main.cpp  ****             float earg = pos01 * 1.7918f;
 619:src/main.cpp  ****             float ex   = 1.0f + earg*(1.0f + earg*(0.5f + earg*0.1667f));
 620:src/main.cpp  ****             float freq_continuous = clampf(50.0f * ex, 50.0f, 300.0f);
 621:src/main.cpp  **** 
 622:src/main.cpp  ****             // Convert to MIDI for quantizer: midi = 69 + 12*log2(freq/440)
 623:src/main.cpp  ****             // log2(x) = ln(x)/ln(2); ln approx via y=(x-1)/(x+1) series
 624:src/main.cpp  ****             float freq_ratio = freq_continuous / 440.0f;
 625:src/main.cpp  ****             float y = (freq_ratio - 1.0f) / (freq_ratio + 1.0f);
 626:src/main.cpp  ****             float y2 = y*y;
 627:src/main.cpp  ****             float ln_ratio = 2.0f*y*(1.0f + y2*(0.3333f + y2*0.2f));
 628:src/main.cpp  ****             float midi_raw = 69.0f + 17.3123f * ln_ratio; // 17.3123 = 12/ln(2)
 629:src/main.cpp  **** 
 630:src/main.cpp  ****             float freq; // final frequency to use
