 455:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 456:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 457:src/main.cpp  ****     }
 458:src/main.cpp  ****     sda_high();d();scl_high();d();
 459:src/main.cpp  ****     bool ack=!sda.Read();
 460:src/main.cpp  ****     scl_low();d();
 461:src/main.cpp  ****     return ack;
 462:src/main.cpp  **** }
 463:src/main.cpp  **** 
 464:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 465:src/main.cpp  **** {
 466:src/main.cpp  ****     uint8_t b=0;sda_high();
 467:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
