 534:src/main.cpp  **** bool mpr_write(uint8_t reg,uint8_t val)
 535:src/main.cpp  **** {
 536:src/main.cpp  ****     i2c_start();
 537:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 538:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 539:src/main.cpp  ****     if(!i2c_write_byte(val))            {i2c_stop();return false;}
 540:src/main.cpp  ****     i2c_stop();return true;
 541:src/main.cpp  **** }
