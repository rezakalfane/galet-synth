 752:src/main.cpp  **** // Moog 4-pole ladder
 753:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 754:src/main.cpp  **** {
 755:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 756:src/main.cpp  ****     if(f>0.98f)f=0.98f;
ARM GAS  /tmp/claude-502/ccGIYDbf.s 			page 22


 757:src/main.cpp  ****     float k  = 3.8f*res;
 758:src/main.cpp  ****     float fb = k*s_flt[3];
 759:src/main.cpp  ****     float x  = in - fb;
 760:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 761:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 762:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 763:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 764:src/main.cpp  ****     return s_flt[3];
 765:src/main.cpp  **** }
