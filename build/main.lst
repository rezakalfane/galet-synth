 405:src/main.cpp  ****         float v    = FIX_DRUM ? 1.0f : clampf((float)pressure / 100.0f, 0.0f, 1.0f);
 406:src/main.cpp  ****         float amp  = 0.72f * ((1.0f - V.vel_sens) + V.vel_sens * v);
 407:src/main.cpp  ****         // Cutoff from velocity, same curve as the mono path.
 408:src/main.cpp  ****         float cutoff_oct = V.cutoff_oct_max * smootherstep_f(v);
 409:src/main.cpp  ****         float oa = cutoff_oct * 0.6931f;
 410:src/main.cpp  ****         float om = 1.0f + oa*(1.0f + oa*(0.5f + oa*(0.1667f + oa*0.0417f)));
 411:src/main.cpp  ****         float tf = (V.keytrack >= 0.999f) ? freq
 412:src/main.cpp  ****                    : V.freq_low * powf(freq / V.freq_low, V.keytrack);
 413:src/main.cpp  ****         float cutoff = clampf(tf * V.cutoff_mult * om, 20.0f, 18000.0f);
