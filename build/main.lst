 375:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
 376:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - TOUCH_THRESHOLD;
 377:src/main.cpp  ****     int32_t raw   = pk - TOUCH_THRESHOLD;
 378:src/main.cpp  ****     if(raw <= 0)     return 0;
 379:src/main.cpp  ****     if(raw >= range) return 100;
 380:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 381:src/main.cpp  ****     if(raw > range) raw = range;
 382:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 383:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 384:src/main.cpp  ****     // Integer sqrt via Newton
 385:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 386:src/main.cpp  ****     s = (s + scaled/s) / 2;
 387:src/main.cpp  ****     s = (s + scaled/s) / 2;
 388:src/main.cpp  ****     s = (s + scaled/s) / 2;
 389:src/main.cpp  ****     s = (s + scaled/s) / 2;
 390:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 391:src/main.cpp  ****     if(s < 0)   s = 0;
 392:src/main.cpp  ****     if(s > 100) s = 100;
 393:src/main.cpp  ****     return s;
 394:src/main.cpp  **** }
