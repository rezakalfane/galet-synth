 192:src/main.cpp  ****     1.005f,  0.40f, WAVE_SINE,  // osc2  ŌĆö slightly sharp unison ŌåÆ slow chorus shimmer
 193:src/main.cpp  ****     0.5f,    0.30f, WAVE_SINE,  // sub   ŌĆö octave-down body (16')
 194:src/main.cpp  ****     2.0f,    0.28f, WAVE_SINE,  // oct   ŌĆö octave-up air (4')
