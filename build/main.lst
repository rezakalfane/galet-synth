 225:src/voice.h   **** // ŌöĆŌöĆ Voice 8: tom / percussion (noise-driven) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 226:src/voice.h   **** //   A drum, not a sustained note ŌĆö PLAY IT BY TAPPING the glass. Noise over two
 227:src/voice.h   **** //   low sine modes (body + an inharmonic 1.6├Ś ring) and a little sub thump. An
 228:src/voice.h   **** //   instant attack and a short ~150 ms release make each tap a percussive hit.
 229:src/voice.h   **** //   A closed, dark filter keeps it round and muffled (tom, not bright snare);
 230:src/voice.h   **** //   harder presses open it a touch. Finger-1 position tunes the drum.
 231:src/voice.h   **** static constexpr Voice VOICE_TOM = {
 232:src/voice.h   ****     "Tom",
 233:src/voice.h   ****     40.0f, 400.0f, 2.30259f,    // 40ŌĆō400 Hz, ln(10) ŌĆö finger-1 tunes from kick/tom up
 234:src/voice.h   ****     1.0f,    0.22f, WAVE_SINE,   // osc1  ŌĆö body (lower mode)
 235:src/voice.h   ****     1.6f,    0.15f, WAVE_SINE,   // osc2  ŌĆö upper mode (inharmonic ring)
 236:src/voice.h   ****     0.5f,    0.10f, WAVE_SINE,   // sub   ŌĆö a little thump
 237:src/voice.h   ****     2.0f,    0.0f,  WAVE_SINE,   // oct   ŌĆö off
 238:src/voice.h   ****     false,                       // osc2 is a fixed ratio, not finger-2 detune
 239:src/voice.h   ****     3.0f, 3.0f, 0.30f,           // tom ŌĆö low 1-pole cutoff for a dark, round body
 240:src/voice.h   ****     1.5f,                        // drive ŌĆö snap and saturation on hard hits
 241:src/voice.h   ****     // noise, keytrack, rm_ratio, rm_max, fold_max, attack, release, glide (ms)
 242:src/voice.h   ****     0.70f, 0.3f, 1.0f, 0.0f, 0.10f, 1.0f, 150.0f, 5.0f,  // noise-dominant, instant hit, short tail
 243:src/voice.h   ****     // pitch_env_oct, pitch_env_ms ŌĆö tom "boww": start 1 oct up, drop in 80 ms
 244:src/voice.h   ****     1.0f, 80.0f,
 245:src/voice.h   ****     0.0f,        // noise_hp
 246:src/voice.h   ****     true,        // no_cycle ŌĆö reached via the Drums MultiVoice, not the gesture
 247:src/voice.h   ****     0.85f,       // vel_sens ŌĆö dynamic taps
 248:src/voice.h   ****     400.0f       // retrig_ms ŌĆö dedupe strike + cap repeat rate
 249:src/voice.h   **** };
