1028:src/main.cpp  ****             // ŌöĆŌöĆ Direct exponential frequency mapping across the voice range ŌöĆŌöĆ
1029:src/main.cpp  ****             // freq = freq_low * (freq_high/freq_low)^pos01
1030:src/main.cpp  ****             //      = freq_low * e^(pos01 * log_freq_ratio)
