 451:src/voice.h   ****     2.0f,                // attack
 452:src/voice.h   ****     200.0f,              // release
 453:src/voice.h   ****     35.0f                // glide
 454:src/voice.h   ****     // PITCH ENVELOPE
 455:src/voice.h   ****     // PITCH QUANTIZE
 456:src/voice.h   **** };
 457:src/voice.h   **** 
