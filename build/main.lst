 536:src/main.cpp  **** int32_t centroid_window(int32_t* d,int s,int e,int32_t* pk_out,int* pkch_out)
 537:src/main.cpp  **** {
 538:src/main.cpp  ****     int32_t sw=0,swx=0,pk=0;int pkc=s;
 539:src/main.cpp  ****     for(int i=s;i<=e;i++){
 540:src/main.cpp  ****         int32_t w=d[i]>0?d[i]:0;
 541:src/main.cpp  ****         sw+=w;swx+=w*i;
 542:src/main.cpp  ****         if(w>pk){pk=w;pkc=i;}
 543:src/main.cpp  ****     }
 544:src/main.cpp  ****     if(pk_out)*pk_out=pk;if(pkch_out)*pkch_out=pkc;
 545:src/main.cpp  ****     if(sw==0)return -1;
 546:src/main.cpp  ****     int32_t p=(swx*1000)/(sw*(N_CH-1));
 547:src/main.cpp  ****     if(p<0)p=0;if(p>1000)p=1000;
 548:src/main.cpp  ****     return p;
 549:src/main.cpp  **** }
