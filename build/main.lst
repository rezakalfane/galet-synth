1641:src/main.cpp  ****             // Cutoff: base tracks 2├Ś pitch, pressure opens it up
1642:src/main.cpp  ****             // Light press = 1├Ś pitch (dark, Moog-like tracking)
1643:src/main.cpp  ****             // Hard press = up to 12000 Hz (wide open)
1644:src/main.cpp  ****             // ŌöĆŌöĆ Moog-style exponential cutoff ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1645:src/main.cpp  ****             // At zero pressure: cutoff = 0.5x pitch (below fundamental, very dark)
1646:src/main.cpp  ****             // At full pressure: cutoff = 0.5x * 2^(6*prs) ŌĆö exponential opening
1647:src/main.cpp  ****             // 6 octaves of sweep = factor of 64x, so fully open = 32x pitch
1648:src/main.cpp  ****             // This gives the classic Moog "closed ŌåÆ wah ŌåÆ bright" feel.
1649:src/main.cpp  ****             // Power-3 on pressure so the bottom half stays dark and controlled.
1650:src/main.cpp  ****             // ŌöĆŌöĆ Smootherstep pressure curves (6xŌüĄ - 15xŌü┤ + 10x┬│) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌö
1651:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1652:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1653:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1654:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1655:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1656:src/main.cpp  ****             };
