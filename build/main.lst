 827:src/voice.h   **** 
 828:src/voice.h   **** // ŌöĆŌöĆ Voice 12: SH-101-style mono synth ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 829:src/voice.h   **** //   A Roland SH-101 homage: one "VCO" putting out saw + square (pulse) together
 830:src/voice.h   **** //   over a square sub-oscillator an octave down ŌĆö the fat single-osc stack the
 831:src/voice.h   **** //   SH-101 is loved for ŌĆö through the resonant 4-pole ladder. The cutoff sits
 832:src/voice.h   **** //   fairly closed and pressure sweeps it wide open with high resonance for the
 833:src/voice.h   **** //   squelchy acid "wow" (the SH-101's filter-env squelch, here played by finger
 834:src/voice.h   **** //   pressure). A whisper of noise, portamento glide between notes. Plays diatonic
 835:src/voice.h   **** //   triads (chords = true) quantized to a MINOR scale so acid chords stay in key
 836:src/voice.h   **** //   while slides bend the whole chord. Bass + leads. (Major twin: VOICE_SH101_MAJ.)
 837:src/voice.h   **** static constexpr Voice VOICE_SH101 = {
 838:src/voice.h   ****     "SH-101 min",
 839:src/voice.h   ****     // FREQUENCY RANGE
 840:src/voice.h   ****     40.0f,
 841:src/voice.h   ****     400.0f,
 842:src/voice.h   ****     2.30259f,            // 40ŌĆō400 Hz, ln(10) ŌĆö bass up to lead
 843:src/voice.h   ****     // OSCILLATOR STACK
 844:src/voice.h   ****     1.0f,
 845:src/voice.h   ****     0.42f,
 846:src/voice.h   ****     WAVE_SAW,            // osc1  ŌĆö the saw VCO
 847:src/voice.h   ****     // SECONDARY OSCILLATOR
 848:src/voice.h   ****     1.0f,
 849:src/voice.h   ****     0.28f,
 850:src/voice.h   ****     WAVE_SQUARE,         // osc2  ŌĆö pulse, in unison (saw + pulse = the SH-101 blend)
 851:src/voice.h   ****     // SUB OSCILLATOR
 852:src/voice.h   ****     0.5f,
 853:src/voice.h   ****     0.40f,
 854:src/voice.h   ****     WAVE_SQUARE,         // sub   ŌĆö the iconic square sub-osc, one octave down
 855:src/voice.h   ****     // OCTAVE OSCILLATOR
 856:src/voice.h   ****     2.0f,
 857:src/voice.h   ****     0.0f,
 858:src/voice.h   ****     WAVE_SQUARE,         // oct   ŌĆö off (the SH-101 has no up-octave)
 859:src/voice.h   ****     // FILTER
 860:src/voice.h   ****     false,               // osc2 is a fixed unison, not finger-2 detune
 861:src/voice.h   ****     0.8f,
 862:src/voice.h   ****     9.0f,
 863:src/voice.h   ****     0.80f,               // closed-ish base, huge pressure sweep, squelchy acid res
 864:src/voice.h   ****     // DRIVE
 865:src/voice.h   ****     1.8f,                // a little drive for warmth/grit
 866:src/voice.h   ****     // NOISE
 867:src/voice.h   ****     0.02f,               // noise level ŌĆö a whisper (the SH-101 noise source)
 868:src/voice.h   ****     1.0f,                // keytrack
 869:src/voice.h   ****     1.0f,                // ringmod ratio
 870:src/voice.h   ****     0.10f,               // ringmod max
ARM GAS  /tmp/claude-502/ccttP4DK.s 			page 51


 871:src/voice.h   ****     0.12f,               // fold max
 872:src/voice.h   ****     2.0f,                // attack ŌĆö snappy
 873:src/voice.h   ****     220.0f,              // release
 874:src/voice.h   ****     30.0f,               // glide ŌĆö portamento slide between notes
 875:src/voice.h   ****     // PITCH ENVELOPE
 876:src/voice.h   ****     0.0f, 0.0f,          // pitch_env_oct, pitch_env_ms (none)
 877:src/voice.h   ****     // noise_hp, no_cycle, vel_sens, retrig_ms (defaults)
 878:src/voice.h   ****     0.0f, false, 0.0f, 0.0f,
 879:src/voice.h   ****     // PITCH QUANTIZE ŌĆö minor scale: chords land as diatonic triads (i, ii┬░, IIIŌĆ”)
 880:src/voice.h   ****     // and stay in key; slides still bend between notes
 881:src/voice.h   ****     true,
 882:src/voice.h   ****     SCALE_MINOR, (int)(sizeof(SCALE_MINOR) / sizeof(SCALE_MINOR[0])),
 883:src/voice.h   ****     // AMP DECAY ŌĆö none: sustained mono synth (hold the note; pressure does the wow)
 884:src/voice.h   ****     0.0f,                // decay_ms
 885:src/voice.h   ****     0.0f,                // sustain (ignored when decay_ms == 0)
 886:src/voice.h   ****     // CHORDS ŌĆö 3-note diatonic triad; upper notes near-full level, open voicing
 887:src/voice.h   ****     true,                // chords
 888:src/voice.h   ****     0.9f,                // chord_level (upper two notes vs root)
 889:src/voice.h   ****     1                    // chord_spread (octaves on the 3rd: 1 = rootŌĆō5thŌĆō10th)
 890:src/voice.h   **** };
 891:src/voice.h   **** 
