 342:src/main.cpp  ****     mpr_write(REG_NCLR,0x10);mpr_write(REG_FDLR,0x20);
 343:src/main.cpp  ****     mpr_write(REG_MHDF,0x01);mpr_write(REG_NHDF,0x01);
 344:src/main.cpp  ****     mpr_write(REG_NCLF,0x10);mpr_write(REG_FDLF,0x20);
 345:src/main.cpp  ****     mpr_write(REG_NHDT,0x00);mpr_write(REG_NCLT,0x00);mpr_write(REG_FDLT,0x00);
 346:src/main.cpp  ****     for(uint8_t ch=0;ch<12;ch++){mpr_write(0x41+ch*2,4);mpr_write(0x42+ch*2,2);}
 347:src/main.cpp  ****     mpr_write(REG_DEBOUNCE,0x11);
 348:src/main.cpp  ****     mpr_write(REG_CONFIG1,0xF0);  // FFI=34 | CDC=48uA
 349:src/main.cpp  ****     mpr_write(REG_CONFIG2,0x4C);  // CDT=4us | SFI=18 | ESI=1ms
 350:src/main.cpp  ****     mpr_write(REG_ECR,0x8C);
 351:src/main.cpp  ****     System::Delay(100);
