 186:src/main.cpp  **** int32_t pressure_pct(int32_t pk, int ch){
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//cch1Xbz7.s 			page 12


 187:src/main.cpp  ****     int32_t range = PRESSURE_MAX_REF[ch] - PRESSURE_DEAD_ZONE[ch];
 188:src/main.cpp  ****     int32_t raw   = pk - PRESSURE_DEAD_ZONE[ch];
 189:src/main.cpp  ****     if(raw <= 0)     return 0;
 190:src/main.cpp  ****     if(raw >= range) return 100;
 191:src/main.cpp  ****     // Clamp raw strictly before sqrt to prevent Newton overshoot
 192:src/main.cpp  ****     if(raw > range) raw = range;
 193:src/main.cpp  ****     int32_t scaled = raw * 10000 / range; // 0..10000
 194:src/main.cpp  ****     if(scaled > 10000) scaled = 10000;
 195:src/main.cpp  ****     // Integer sqrt via Newton
 196:src/main.cpp  ****     int32_t s = scaled / 2 + 1;
 197:src/main.cpp  ****     s = (s + scaled/s) / 2;
 198:src/main.cpp  ****     s = (s + scaled/s) / 2;
 199:src/main.cpp  ****     s = (s + scaled/s) / 2;
 200:src/main.cpp  ****     s = (s + scaled/s) / 2;
 201:src/main.cpp  ****     // Hard clamp output ŌĆö Newton can land at 101 due to rounding
 202:src/main.cpp  ****     if(s < 0)   s = 0;
 203:src/main.cpp  ****     if(s > 100) s = 100;
 204:src/main.cpp  ****     return s;
 205:src/main.cpp  **** }
 206:src/main.cpp  **** 
 207:src/main.cpp  **** int detect_raw(int32_t* delta,Finger out[2])
 208:src/main.cpp  **** {
 209:src/main.cpp  ****     out[0].active=out[1].active=false;
 210:src/main.cpp  ****     int pka=0;int32_t da=0;
 211:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(delta[i]>da){da=delta[i];pka=i;}
 212:src/main.cpp  ****     if(da<TOUCH_THRESHOLD)return 0;
 213:src/main.cpp  ****     int ws=pka-2;if(ws<0)ws=0;int we=pka+2;if(we>=N_CH)we=N_CH-1;
 214:src/main.cpp  ****     int32_t pa;int pca;
 215:src/main.cpp  ****     int32_t posa=centroid_window(delta,ws,we,&pa,&pca);
 216:src/main.cpp  ****     out[0]={true,posa,pressure_pct(pa,pca),pca,pa};
 217:src/main.cpp  **** 
 218:src/main.cpp  ****     int32_t d2[N_CH];
 219:src/main.cpp  ****     int ss=pka-2;if(ss<0)ss=0;int se=pka+2;if(se>=N_CH)se=N_CH-1;
 220:src/main.cpp  ****     for(int i=0;i<N_CH;i++)d2[i]=(i>=ss&&i<=se)?0:delta[i];
 221:src/main.cpp  ****     int pkb=0;int32_t db=0;
 222:src/main.cpp  ****     for(int i=0;i<N_CH;i++)if(d2[i]>db){db=d2[i];pkb=i;}
 223:src/main.cpp  ****     int sep=pkb-pka;if(sep<0)sep=-sep;
 224:src/main.cpp  ****     if(db<TOUCH_THRESHOLD||sep<MIN_FINGER_SEP)return 1;
 225:src/main.cpp  ****     int ws2=pkb-2;if(ws2<0)ws2=0;int we2=pkb+2;if(we2>=N_CH)we2=N_CH-1;
 226:src/main.cpp  ****     int32_t pb;int pcb;
 227:src/main.cpp  ****     int32_t posb=centroid_window(d2,ws2,we2,&pb,&pcb);
 228:src/main.cpp  ****     out[1]={true,posb,pressure_pct(pb,pcb),pcb,pb};
 229:src/main.cpp  ****     return 2;
 230:src/main.cpp  **** }
