 149:src/main.cpp  **** void read_electrodes(uint16_t* out)
 150:src/main.cpp  **** {
 151:src/main.cpp  ****     uint8_t buf[24];
 152:src/main.cpp  ****     mpr_read(REG_ELE0_LSB,buf,24);
 153:src/main.cpp  ****     for(int i=0;i<N_CH;i++)
 154:src/main.cpp  ****         out[i]=(uint16_t)(buf[i*2]|((buf[i*2+1]&0x03)<<8));
 155:src/main.cpp  **** }
 156:src/main.cpp  **** 
 157:src/main.cpp  **** void capture_baseline(uint16_t* bl)
 158:src/main.cpp  **** {
 159:src/main.cpp  ****     uint32_t acc[N_CH]={0};uint16_t tmp[N_CH];
 160:src/main.cpp  ****     for(int s=0;s<REBASELINE_SAMPLES;s++){
 161:src/main.cpp  ****         read_electrodes(tmp);
 162:src/main.cpp  ****         for(int i=0;i<N_CH;i++)acc[i]+=tmp[i];
 163:src/main.cpp  ****         System::Delay(5);
 164:src/main.cpp  ****     }
 165:src/main.cpp  ****     for(int i=0;i<N_CH;i++)bl[i]=(uint16_t)(acc[i]/REBASELINE_SAMPLES);
 166:src/main.cpp  **** }
