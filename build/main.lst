1428:src/main.cpp  ****             // Starts slow, steep in the middle, eases gently at the top.
1429:src/main.cpp  ****             // Much more playable than power curves ŌĆö feels like a real knob.
1430:src/main.cpp  ****             auto smoothstep = [](float x) -> float {
1431:src/main.cpp  ****                 x = x<0?0:x>1?1:x;
1432:src/main.cpp  ****                 return x*x*(3.0f - 2.0f*x);
1433:src/main.cpp  ****             };
