 125:src/main.cpp  **** };
 126:src/main.cpp  **** 
 127:src/main.cpp  **** // ŌöĆŌöĆ Voice 1: round & dark power-chord bass (root + 5th + octave + sub) ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌ
 128:src/main.cpp  **** //   Same touch mappings, but osc2 is a fixed perfect fifth instead of a detune,
 129:src/main.cpp  **** //   so every note sounds as a power chord. Lower range, gentler filter, less
ARM GAS  /tmp/claude-502/ccZj3JyB.s 			page 11


 130:src/main.cpp  **** //   drive ŌåÆ deep and round rather than bright and screaming.
 131:src/main.cpp  **** static constexpr Voice VOICE_BASS = {
