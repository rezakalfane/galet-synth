 365:src/main.cpp  **** // Triangle wave
 366:src/main.cpp  **** static inline float tri(float ph){
 367:src/main.cpp  ****     return ph<0.5f?(4.0f*ph-1.0f):(3.0f-4.0f*ph);
 368:src/main.cpp  **** }
 369:src/main.cpp  **** 
 370:src/main.cpp  **** // Moog 4-pole ladder
 371:src/main.cpp  **** static inline float moog(float in, float cutoff, float res, float sr)
 372:src/main.cpp  **** {
 373:src/main.cpp  ****     float f = 2.0f*cutoff/sr;
 374:src/main.cpp  ****     if(f>0.98f)f=0.98f;
 375:src/main.cpp  ****     float k  = 3.8f*res;
 376:src/main.cpp  ****     float fb = k*s_flt[3];
 377:src/main.cpp  ****     float x  = in - fb;
 378:src/main.cpp  ****     s_flt[0]+=f*(fast_tanh(x)      -fast_tanh(s_flt[0]));
 379:src/main.cpp  ****     s_flt[1]+=f*(fast_tanh(s_flt[0])-fast_tanh(s_flt[1]));
 380:src/main.cpp  ****     s_flt[2]+=f*(fast_tanh(s_flt[1])-fast_tanh(s_flt[2]));
 381:src/main.cpp  ****     s_flt[3]+=f*(fast_tanh(s_flt[2])-fast_tanh(s_flt[3]));
 382:src/main.cpp  ****     return s_flt[3];
 383:src/main.cpp  **** }
 384:src/main.cpp  **** 
 385:src/main.cpp  **** // Wavefolder distortion
 386:src/main.cpp  **** // Folds signal back when it exceeds threshold ŌĆö creates rich harmonics.
 387:src/main.cpp  **** // amount 0 = clean, 1 = heavy folding (4 folds)
 388:src/main.cpp  **** static inline float wavefold(float in, float amount)
 389:src/main.cpp  **** {
 390:src/main.cpp  ****     if(amount < 0.01f) return in;
 391:src/main.cpp  ****     // Drive the signal harder as amount increases (1x to 5x)
 392:src/main.cpp  ****     float driven = in * (1.0f + amount * 4.0f);
 393:src/main.cpp  ****     // Fold: reflect signal at ┬▒1 boundary repeatedly
 394:src/main.cpp  ****     // fold(x) = 1 - |((x+1) mod 2) - 1|  (triangle fold)
 395:src/main.cpp  ****     float x = driven;
 396:src/main.cpp  ****     // 2 passes of folding for richness
 397:src/main.cpp  ****     for(int fold = 0; fold < 2; fold++) {
 398:src/main.cpp  ****         x = x * 0.5f + 0.5f;           // shift to 0..1
 399:src/main.cpp  ****         x = x - floorf(x);              // wrap to 0..1
 400:src/main.cpp  ****         x = 1.0f - fabsf(2.0f*x - 1.0f); // triangle fold
 401:src/main.cpp  ****         x = x * 2.0f - 1.0f;           // back to -1..1
 402:src/main.cpp  ****     }
 403:src/main.cpp  ****     // Blend dry/wet so at low amounts it stays subtle
 404:src/main.cpp  ****     return in*(1.0f-amount) + x*amount;
 405:src/main.cpp  **** }
