 487:src/main.cpp  **** bool i2c_write_byte(uint8_t byte)
 488:src/main.cpp  **** {
 489:src/main.cpp  ****     for(int i=7;i>=0;i--){
 490:src/main.cpp  ****         if(byte&(1<<i))sda_high();else sda_low();
 491:src/main.cpp  ****         d();scl_high();d();scl_low();d();
 492:src/main.cpp  ****     }
 493:src/main.cpp  ****     sda_high();d();scl_high();d();
 494:src/main.cpp  ****     bool ack=!sda.Read();
 495:src/main.cpp  ****     scl_low();d();
 496:src/main.cpp  ****     return ack;
 497:src/main.cpp  **** }
 498:src/main.cpp  **** 
 499:src/main.cpp  **** uint8_t i2c_read_byte(bool ack)
 500:src/main.cpp  **** {
 501:src/main.cpp  ****     uint8_t b=0;sda_high();
 502:src/main.cpp  ****     for(int i=7;i>=0;i--){d();scl_high();d();if(sda.Read())b|=(1<<i);scl_low();}
 503:src/main.cpp  ****     if(ack)sda_low();else sda_high();
 504:src/main.cpp  ****     d();scl_high();d();scl_low();d();sda_high();
 505:src/main.cpp  ****     return b;
 506:src/main.cpp  **** }
