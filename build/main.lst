 517:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 518:src/main.cpp  **** {
 519:src/main.cpp  ****     i2c_start();
 520:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 521:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 522:src/main.cpp  ****     i2c_start();
 523:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 524:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 525:src/main.cpp  ****     i2c_stop();return true;
 526:src/main.cpp  **** }
