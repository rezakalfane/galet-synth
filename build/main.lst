 318:src/voice.h   ****     "RichBass",
 319:src/voice.h   ****     // FREQUENCY RANGE
 320:src/voice.h   ****     40.0f,
 321:src/voice.h   ****     160.0f,
 322:src/voice.h   ****     1.38629f,            // 40ŌĆō160 Hz, ln(4)
