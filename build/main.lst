 262:src/main.cpp  **** // ŌöĆŌöĆ Maths helpers ŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆŌöĆ
 263:src/main.cpp  **** static inline float clampf(float v,float lo,float hi){
 264:src/main.cpp  ****     return v<lo?lo:v>hi?hi:v;
 265:src/main.cpp  **** }
