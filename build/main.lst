 543:src/main.cpp  **** bool mpr_read(uint8_t reg,uint8_t* buf,uint8_t len)
 544:src/main.cpp  **** {
 545:src/main.cpp  ****     i2c_start();
 546:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|0)){i2c_stop();return false;}
 547:src/main.cpp  ****     if(!i2c_write_byte(reg))            {i2c_stop();return false;}
 548:src/main.cpp  ****     i2c_start();
 549:src/main.cpp  ****     if(!i2c_write_byte((MPR_ADDR<<1)|1)){i2c_stop();return false;}
 550:src/main.cpp  ****     for(uint8_t i=0;i<len;i++) buf[i]=i2c_read_byte(i<len-1);
 551:src/main.cpp  ****     i2c_stop();return true;
 552:src/main.cpp  **** }
