 492:lib/tinyusb/src/class/audio/audio_device.h **** // This function is used to provide data rate feedback from an asynchronous sink. Feedback value wi
 493:lib/tinyusb/src/class/audio/audio_device.h **** //
 494:lib/tinyusb/src/class/audio/audio_device.h **** // The feedback format is specified to be 16.16 for HS and 10.14 for FS devices (see Universal Seri
 495:lib/tinyusb/src/class/audio/audio_device.h **** // the choice of format is left to the caller and feedback argument is sent as-is. If CFG_TUD_AUDIO
 496:lib/tinyusb/src/class/audio/audio_device.h **** // return true, then tinyusb expects 16.16 format and handles the conversion to 10.14 on FS.
 497:lib/tinyusb/src/class/audio/audio_device.h **** //
 498:lib/tinyusb/src/class/audio/audio_device.h **** // Note that due to a bug in its USB Audio 2.0 driver, Windows currently requires 16.16 format for 
 499:lib/tinyusb/src/class/audio/audio_device.h **** // driver can work with either format.
