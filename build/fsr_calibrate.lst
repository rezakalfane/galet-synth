  83:tools/fsr_calibrate.cpp **** static constexpr uint32_t CAL_DURATION_MS  = 15000;
  84:tools/fsr_calibrate.cpp **** static constexpr uint32_t SAMPLE_PERIOD_MS = 20;     // 50 Hz
  85:tools/fsr_calibrate.cpp **** static constexpr int      BAR_W            = 30;
  86:tools/fsr_calibrate.cpp **** // Touch detected when the live reading deviates from idle by more than this.
  87:tools/fsr_calibrate.cpp **** static constexpr int32_t  TOUCH_DELTA      = 2000;   // ADC counts (out of 65535)
  88:tools/fsr_calibrate.cpp **** 
  89:tools/fsr_calibrate.cpp **** static void make_bar(char* out, uint32_t val, uint32_t max_val)
  90:tools/fsr_calibrate.cpp **** {
  91:tools/fsr_calibrate.cpp ****     int n = (max_val > 0) ? (int)((val * BAR_W) / max_val) : 0;
  92:tools/fsr_calibrate.cpp ****     if(n < 0) n = 0; else if(n > BAR_W) n = BAR_W;
  93:tools/fsr_calibrate.cpp ****     out[0] = '[';
