   1:src/usb_descriptors.c **** // USB descriptors for GaletSynth ‚Äî Phase 1: a single CDC ACM interface (the
   2:src/usb_descriptors.c **** // VoiceLab serial link). Phase 2 makes this a composite CDC + UAC device.
   3:src/usb_descriptors.c **** #include "tusb.h"
   4:src/usb_descriptors.c **** #include <string.h>
   5:src/usb_descriptors.c **** 
   6:src/usb_descriptors.c **** #define USB_VID 0x0483          // STMicroelectronics (matches the old CDC enumeration)
   7:src/usb_descriptors.c **** #define USB_PID 0x5740          // ST virtual COM port ‚Üí macOS/Linux/iOS class driver
   8:src/usb_descriptors.c **** #define USB_BCD 0x0200
   9:src/usb_descriptors.c **** 
  10:src/usb_descriptors.c **** // ‚îÄ‚îÄ Device descriptor ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î
  11:src/usb_descriptors.c **** // IAD/misc class so a composite device (Phase 2) enumerates cleanly; fine for a
  12:src/usb_descriptors.c **** // lone CDC too.
  13:src/usb_descriptors.c **** static tusb_desc_device_t const desc_device = {
  14:src/usb_descriptors.c ****     .bLength            = sizeof(tusb_desc_device_t),
  15:src/usb_descriptors.c ****     .bDescriptorType    = TUSB_DESC_DEVICE,
  16:src/usb_descriptors.c ****     .bcdUSB             = USB_BCD,
  17:src/usb_descriptors.c ****     .bDeviceClass       = TUSB_CLASS_MISC,
  18:src/usb_descriptors.c ****     .bDeviceSubClass    = MISC_SUBCLASS_COMMON,
  19:src/usb_descriptors.c ****     .bDeviceProtocol    = MISC_PROTOCOL_IAD,
  20:src/usb_descriptors.c ****     .bMaxPacketSize0    = CFG_TUD_ENDPOINT0_SIZE,
  21:src/usb_descriptors.c ****     .idVendor           = USB_VID,
  22:src/usb_descriptors.c ****     .idProduct          = USB_PID,
  23:src/usb_descriptors.c ****     .bcdDevice          = 0x0100,
  24:src/usb_descriptors.c ****     .iManufacturer      = 0x01,
  25:src/usb_descriptors.c ****     .iProduct           = 0x02,
  26:src/usb_descriptors.c ****     .iSerialNumber      = 0x03,
  27:src/usb_descriptors.c ****     .bNumConfigurations = 0x01,
  28:src/usb_descriptors.c **** };
