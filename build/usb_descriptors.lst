   1:src/usb_descriptors.c **** // USB descriptors for GaletSynth â€” Phase 2: a composite device with a CDC ACM
   2:src/usb_descriptors.c **** // interface (the VoiceLab serial link) + a UAC2 stereo capture interface (the
   3:src/usb_descriptors.c **** // soundcard input). Interfaces: CDC = 0,1 ; Audio Control = 2 ; Audio Streaming = 3.
   4:src/usb_descriptors.c **** #include "tusb.h"
