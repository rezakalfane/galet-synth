   6:src/usb_descriptors.c **** 
   7:src/usb_descriptors.c **** #define USB_VID 0x0483          // STMicroelectronics
   8:src/usb_descriptors.c **** #define USB_PID 0x5741          // bumped from the CDC-only 0x5740 (new descriptor set)
   9:src/usb_descriptors.c **** #define USB_BCD 0x0200
  10:src/usb_descriptors.c **** 
  11:src/usb_descriptors.c **** // â”€â”€ Device descriptor (IAD/misc so the composite enumerates cleanly) â”€â”€â”€â”€â”€â”€â”€â”€
