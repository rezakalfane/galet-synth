 127:tools/mpr121_calibrate.cpp **** // â”€â”€ Capture software baseline (32 samples) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”
 128:tools/mpr121_calibrate.cpp **** void capture_baseline(uint16_t* bl,uint32_t esi_ms)
 129:tools/mpr121_calibrate.cpp **** {
 130:tools/mpr121_calibrate.cpp ****     uint32_t acc[N_CH]={0};uint16_t tmp[N_CH];
 131:tools/mpr121_calibrate.cpp ****     for(int s=0;s<32;s++){
 132:tools/mpr121_calibrate.cpp ****         read_electrodes(tmp);
 133:tools/mpr121_calibrate.cpp ****         for(int i=0;i<N_CH;i++)acc[i]+=tmp[i];
 134:tools/mpr121_calibrate.cpp ****         System::Delay(esi_ms+1);
 135:tools/mpr121_calibrate.cpp ****     }
 136:tools/mpr121_calibrate.cpp ****     for(int i=0;i<N_CH;i++)bl[i]=(uint16_t)(acc[i]/32);
 137:tools/mpr121_calibrate.cpp **** }
 138:tools/mpr121_calibrate.cpp **** 
 139:tools/mpr121_calibrate.cpp **** // â”€â”€ Measure global peak delta over n samples â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
 140:tools/mpr121_calibrate.cpp **** int32_t measure_peak_global(uint16_t* bl,int n,uint32_t esi_ms)
 141:tools/mpr121_calibrate.cpp **** {
 142:tools/mpr121_calibrate.cpp ****     uint16_t v[N_CH];int32_t pk=0;
 143:tools/mpr121_calibrate.cpp ****     for(int s=0;s<n;s++){
 144:tools/mpr121_calibrate.cpp ****         read_electrodes(v);
 145:tools/mpr121_calibrate.cpp ****         for(int i=0;i<N_CH;i++){
 146:tools/mpr121_calibrate.cpp ****             int32_t d=(int32_t)bl[i]-(int32_t)v[i];
 147:tools/mpr121_calibrate.cpp ****             if(d>pk)pk=d;
 148:tools/mpr121_calibrate.cpp ****         }
 149:tools/mpr121_calibrate.cpp ****         System::Delay(esi_ms+1);
 150:tools/mpr121_calibrate.cpp ****     }
 151:tools/mpr121_calibrate.cpp ****     return pk;
 152:tools/mpr121_calibrate.cpp **** }
 153:tools/mpr121_calibrate.cpp **** 
 154:tools/mpr121_calibrate.cpp **** // â”€â”€ AFE result storage â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â
 155:tools/mpr121_calibrate.cpp **** struct AfeResult { uint8_t cdc,cdt,ffi,esi; int32_t snr_x10,peak_on; };
 156:tools/mpr121_calibrate.cpp **** static constexpr int MAX_AFE = 24;
 157:tools/mpr121_calibrate.cpp **** static AfeResult afe_results[MAX_AFE];
 158:tools/mpr121_calibrate.cpp **** static int       n_afe = 0;
 159:tools/mpr121_calibrate.cpp **** 
