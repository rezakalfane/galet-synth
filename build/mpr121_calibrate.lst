 170:tools/mpr121_calibrate.cpp **** // â”€â”€ Block until any electrode exceeds CAL_TOUCH_THRESHOLD, or timeout â”€â”€â”€â”€â”€â”€â”€â”
 171:tools/mpr121_calibrate.cpp **** // Returns true if touch detected, false if timed out.
 172:tools/mpr121_calibrate.cpp **** bool wait_for_touch(uint16_t* bl)
 173:tools/mpr121_calibrate.cpp **** {
 174:tools/mpr121_calibrate.cpp ****     hw.PrintLine("  Waiting for touch (timeout %ds)...", (int)(TOUCH_TIMEOUT_MS / 1000));
 175:tools/mpr121_calibrate.cpp ****     uint16_t v[N_CH];
 176:tools/mpr121_calibrate.cpp ****     uint32_t t_start = System::GetNow();
 177:tools/mpr121_calibrate.cpp ****     while(System::GetNow() - t_start < TOUCH_TIMEOUT_MS)
 178:tools/mpr121_calibrate.cpp ****     {
 179:tools/mpr121_calibrate.cpp ****         read_electrodes(v);
 180:tools/mpr121_calibrate.cpp ****         for(int i = 0; i < N_CH; i++)
 181:tools/mpr121_calibrate.cpp ****             if((int32_t)bl[i] - (int32_t)v[i] >= CAL_TOUCH_THRESHOLD)
 182:tools/mpr121_calibrate.cpp ****             {
 183:tools/mpr121_calibrate.cpp ****                 hw.PrintLine("  Touch detected â€” go!");
 184:tools/mpr121_calibrate.cpp ****                 return true;
 185:tools/mpr121_calibrate.cpp ****             }
 186:tools/mpr121_calibrate.cpp ****         System::Delay(10);
 187:tools/mpr121_calibrate.cpp ****     }
 188:tools/mpr121_calibrate.cpp ****     hw.PrintLine("  TIMEOUT â€” no touch detected, skipping.");
 189:tools/mpr121_calibrate.cpp ****     return false;
 190:tools/mpr121_calibrate.cpp **** }
 191:tools/mpr121_calibrate.cpp **** 
 192:tools/mpr121_calibrate.cpp **** // â”€â”€ Run one AFE config, measure noise + touch SNR â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â
 193:tools/mpr121_calibrate.cpp **** void sweep_one(int idx,int total,uint8_t cdc,uint8_t cdt,uint8_t ffi,uint8_t esi)
 194:tools/mpr121_calibrate.cpp **** {
 195:tools/mpr121_calibrate.cpp ****     uint32_t esi_ms=(uint32_t)(1u<<esi);
 196:tools/mpr121_calibrate.cpp ****     hw.PrintLine("--- %d/%d  CDC=%2duA CDT=%s FFI=%siters ESI=%dms ---",
 197:tools/mpr121_calibrate.cpp ****                  idx,total,(int)cdc,cdt_us(cdt),ffi_str(ffi),(int)esi_ms);
 198:tools/mpr121_calibrate.cpp **** 
 199:tools/mpr121_calibrate.cpp ****     if(!mpr_init_afe(cdc,cdt,ffi,esi)){hw.PrintLine("  INIT FAILED â€” skip");return;}
 200:tools/mpr121_calibrate.cpp **** 
 201:tools/mpr121_calibrate.cpp ****     // Baseline
 202:tools/mpr121_calibrate.cpp ****     hw.PrintLine("  Keep fingers OFF... (2s)");
 203:tools/mpr121_calibrate.cpp ****     System::Delay(2000);
 204:tools/mpr121_calibrate.cpp ****     uint16_t bl[N_CH];
 205:tools/mpr121_calibrate.cpp ****     capture_baseline(bl,esi_ms);
 206:tools/mpr121_calibrate.cpp ****     int32_t noise=measure_peak_global(bl,20,esi_ms);
 207:tools/mpr121_calibrate.cpp ****     if(noise<1)noise=1;
 208:tools/mpr121_calibrate.cpp ****     hw.PrintLine("  Noise: %d counts",(int)noise);
 209:tools/mpr121_calibrate.cpp **** 
 210:tools/mpr121_calibrate.cpp ****     // Touch â€” wait for actual contact before measuring
 211:tools/mpr121_calibrate.cpp ****     hw.PrintLine("  >>> Press glass FIRMLY when ready <<<");
 212:tools/mpr121_calibrate.cpp ****     if(!wait_for_touch(bl)){hw.PrintLine("  Config skipped.");return;}
 213:tools/mpr121_calibrate.cpp ****     int32_t sig=measure_peak_global(bl,60,esi_ms);
 214:tools/mpr121_calibrate.cpp ****     int32_t snr=(sig*10)/noise;
 215:tools/mpr121_calibrate.cpp ****     hw.PrintLine("  Touch: %d  SNR: %d.%d  %s",
 216:tools/mpr121_calibrate.cpp ****                  (int)sig,(int)(snr/10),(int)(snr%10),
 217:tools/mpr121_calibrate.cpp ****                  snr>50?"GOOD":snr>20?"ok":"poor");
 218:tools/mpr121_calibrate.cpp **** 
 219:tools/mpr121_calibrate.cpp ****     if(n_afe<MAX_AFE)
ARM GAS  /var/folders/1t/pyvz513s4fs9l00kxmc709xh0000gp/T//ccl3Mx28.s 			page 44


 220:tools/mpr121_calibrate.cpp ****         afe_results[n_afe++]={cdc,cdt,ffi,esi,snr,sig};
 221:tools/mpr121_calibrate.cpp **** 
 222:tools/mpr121_calibrate.cpp ****     if(idx<total){hw.PrintLine("  Lift finger. Next in 2s...");System::Delay(2000);}
 223:tools/mpr121_calibrate.cpp ****     hw.PrintLine("");
 224:tools/mpr121_calibrate.cpp **** }
 225:tools/mpr121_calibrate.cpp **** 
 226:tools/mpr121_calibrate.cpp **** // â”€â”€ Find index of best SNR result in afe_results[] â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
 227:tools/mpr121_calibrate.cpp **** int find_best()
 228:tools/mpr121_calibrate.cpp **** {
